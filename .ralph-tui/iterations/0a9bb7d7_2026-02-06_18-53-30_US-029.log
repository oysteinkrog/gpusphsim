{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013sQwrt1MAEYnUGca5u6s7K","type":"tool_result","content":"     1→\"\"\"World state management for Falling Sand 3D.\n     2→\n     3→Manages CuPy arrays for all per-particle SoA data. Supports configurable\n     4→max_particles at startup, spawning particles in sphere/cube shapes, and\n     5→tracking num_active via counter.\n     6→\n     7→All arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\n     8→DEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→from typing import Tuple\n    14→\n    15→import cupy as cp\n    16→import numpy as np\n    17→\n    18→from materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n    19→\n    20→# packed_info bitfield macros (mirrors common.cuh)\n    21→_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n    22→\n    23→# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\n    24→DEFAULT_SPACING = 0.02\n    25→\n    26→# Default temperatures for hot materials (Kelvin)\n    27→_DEFAULT_TEMPS = {\n    28→    7: 1500.0,   # LAVA\n    29→    14: 1200.0,  # FIRE\n    30→    12: 373.0,   # STEAM\n    31→    13: 500.0,   # SMOKE\n    32→}\n    33→\n    34→# Ambient temperature\n    35→T_AMBIENT = 293.0\n    36→\n    37→\n    38→class World:\n    39→    \"\"\"Manages all per-particle SoA arrays on GPU.\n    40→\n    41→    Parameters\n    42→    ----------\n    43→    max_particles : int\n    44→        Maximum number of particles to allocate for (default 500000).\n    45→    \"\"\"\n    46→\n    47→    def __init__(self, max_particles: int = 500_000) -> None:\n    48→        self.max_particles: int = max_particles\n    49→        self._high_water: int = 0  # one past last allocated slot\n    50→        self._allocate()\n    51→\n    52→    def _allocate(self) -> None:\n    53→        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n    54→        n = self.max_particles\n    55→        # float4 arrays (stored as (n, 4) float32)\n    56→        self.position = cp.zeros((n, 4), dtype=cp.float32)\n    57→        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n    58→        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n    59→        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    60→        self.color = cp.zeros((n, 4), dtype=cp.float32)\n    61→        # float arrays\n    62→        self.density = cp.zeros(n, dtype=cp.float32)\n    63→        self.mass = cp.zeros(n, dtype=cp.float32)\n    64→        self.temperature = cp.zeros(n, dtype=cp.float32)\n    65→        self.health = cp.zeros(n, dtype=cp.float32)\n    66→        self.lifetime = cp.zeros(n, dtype=cp.float32)\n    67→        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n    68→        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n    69→        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    70→        # uint32 arrays\n    71→        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n    72→        # uint8 arrays\n    73→        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    74→\n    75→        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n    76→        # These are the double-buffer targets: after sort+reorder, physics\n    77→        # kernels (Step1/Step2) read from these.  Integrate writes back to\n    78→        # the unsorted arrays above via sort_indexes.\n    79→        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n    80→        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n    81→        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n    82→        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    83→        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n    84→        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n    85→        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n    86→        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n    87→        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n    88→        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n    89→        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n    90→        self.sorted_dTdt = cp.zeros(n, dtype=cp.float32)\n    91→        self.sorted_exposure_heat = cp.zeros(n, dtype=cp.float32)\n    92→        self.sorted_exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    93→        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n    94→        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    95→        # Sort index arrays (hash + original index, plus sorted versions)\n    96→        self.hashes = cp.zeros(n, dtype=cp.uint32)\n    97→        self.indices = cp.zeros(n, dtype=cp.uint32)\n    98→        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n    99→        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n   100→\n   101→    def resize(self, new_max: int) -> None:\n   102→        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n   103→        self.max_particles = new_max\n   104→        self._high_water = 0\n   105→        self._allocate()\n   106→\n   107→    @property\n   108→    def num_active(self) -> int:\n   109→        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n   110→        if self._high_water == 0:\n   111→            return 0\n   112→        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n   113→\n   114→    def spawn_sphere(\n   115→        self,\n   116→        center: Tuple[float, float, float],\n   117→        radius: float,\n   118→        material_id: int,\n   119→        count: int,\n   120→    ) -> int:\n   121→        \"\"\"Spawn particles with random positions inside a sphere.\n   122→\n   123→        Returns the number of particles actually spawned (may be less than\n   124→        count if max_particles is reached).\n   125→        \"\"\"\n   126→        if material_id not in MATERIALS:\n   127→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   128→\n   129→        available = self.max_particles - self._high_water\n   130→        actual = min(count, available)\n   131→        if actual <= 0:\n   132→            return 0\n   133→\n   134→        mat = MATERIALS[material_id]\n   135→        start = self._high_water\n   136→\n   137→        # Generate random positions in unit sphere using rejection sampling on GPU\n   138→        # Over-generate by ~2x to account for rejection, then take first `actual`\n   139→        needed = actual\n   140→        positions_list = []\n   141→        remaining = needed\n   142→        while remaining > 0:\n   143→            batch = int(remaining * 2.0) + 128\n   144→            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n   145→            r_sq = cp.sum(pts * pts, axis=1)\n   146→            inside = pts[r_sq <= 1.0]\n   147→            take = min(len(inside), remaining)\n   148→            if take > 0:\n   149→                positions_list.append(inside[:take])\n   150→                remaining -= take\n   151→\n   152→        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n   153→        # Scale to desired radius and translate to center\n   154→        cx, cy, cz = center\n   155→        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n   156→        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n   157→        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n   158→\n   159→        sl = slice(start, start + actual)\n   160→        self.position[sl, 0] = sphere_pts[:, 0]\n   161→        self.position[sl, 1] = sphere_pts[:, 1]\n   162→        self.position[sl, 2] = sphere_pts[:, 2]\n   163→        self.position[sl, 3] = 0.0\n   164→\n   165→        self.velocity[sl] = 0.0\n   166→        self.veleval[sl] = 0.0\n   167→        self.sph_force[sl] = 0.0\n   168→\n   169→        # mass = rho0 * spacing^3\n   170→        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n   171→        self.mass[sl] = particle_mass\n   172→\n   173→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   174→        self.packed_info[sl] = cp.uint32(packed)\n   175→\n   176→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   177→        self.temperature[sl] = temp\n   178→        self.health[sl] = 1.0\n   179→        self.lifetime[sl] = 0.0\n   180→        self.shear_rate[sl] = 0.0\n   181→        self.exposure_heat[sl] = 0.0\n   182→        self.exposure_corrode[sl] = 0.0\n   183→\n   184→        self.color[sl, 0] = mat.color_r\n   185→        self.color[sl, 1] = mat.color_g\n   186→        self.color[sl, 2] = mat.color_b\n   187→        self.color[sl, 3] = 1.0\n   188→\n   189→        self.density[sl] = mat.rest_density\n   190→        self.sleep_counter[sl] = 0\n   191→\n   192→        self._high_water += actual\n   193→        return actual\n   194→\n   195→    def spawn_cube(\n   196→        self,\n   197→        min_corner: Tuple[float, float, float],\n   198→        max_corner: Tuple[float, float, float],\n   199→        material_id: int,\n   200→        spacing: float = DEFAULT_SPACING,\n   201→    ) -> int:\n   202→        \"\"\"Spawn particles on a regular grid within a cube.\n   203→\n   204→        Returns the number of particles actually spawned.\n   205→        \"\"\"\n   206→        if material_id not in MATERIALS:\n   207→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   208→\n   209→        # Build grid positions on CPU (small overhead, predictable count)\n   210→        x0, y0, z0 = min_corner\n   211→        x1, y1, z1 = max_corner\n   212→        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n   213→        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n   214→        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n   215→\n   216→        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n   217→            return 0\n   218→\n   219→        total = len(xs) * len(ys) * len(zs)\n   220→        available = self.max_particles - self._high_water\n   221→        actual = min(total, available)\n   222→        if actual <= 0:\n   223→            return 0\n   224→\n   225→        # Generate meshgrid positions\n   226→        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n   227→        positions = np.column_stack([\n   228→            gx.ravel()[:actual],\n   229→            gy.ravel()[:actual],\n   230→            gz.ravel()[:actual],\n   231→        ]).astype(np.float32)\n   232→\n   233→        actual = len(positions)\n   234→        if actual == 0:\n   235→            return 0\n   236→\n   237→        mat = MATERIALS[material_id]\n   238→        start = self._high_water\n   239→        sl = slice(start, start + actual)\n   240→\n   241→        d_positions = cp.asarray(positions)\n   242→        self.position[sl, 0] = d_positions[:, 0]\n   243→        self.position[sl, 1] = d_positions[:, 1]\n   244→        self.position[sl, 2] = d_positions[:, 2]\n   245→        self.position[sl, 3] = 0.0\n   246→\n   247→        self.velocity[sl] = 0.0\n   248→        self.veleval[sl] = 0.0\n   249→        self.sph_force[sl] = 0.0\n   250→\n   251→        particle_mass = mat.rest_density * (spacing ** 3)\n   252→        self.mass[sl] = particle_mass\n   253→\n   254→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   255→        self.packed_info[sl] = cp.uint32(packed)\n   256→\n   257→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   258→        self.temperature[sl] = temp\n   259→        self.health[sl] = 1.0\n   260→        self.lifetime[sl] = 0.0\n   261→        self.shear_rate[sl] = 0.0\n   262→        self.exposure_heat[sl] = 0.0\n   263→        self.exposure_corrode[sl] = 0.0\n   264→\n   265→        self.color[sl, 0] = mat.color_r\n   266→        self.color[sl, 1] = mat.color_g\n   267→        self.color[sl, 2] = mat.color_b\n   268→        self.color[sl, 3] = 1.0\n   269→\n   270→        self.density[sl] = mat.rest_density\n   271→        self.sleep_counter[sl] = 0\n   272→\n   273→        self._high_water += actual\n   274→        return actual\n   275→\n   276→    def kill_in_sphere(\n   277→        self,\n   278→        center: Tuple[float, float, float],\n   279→        radius: float,\n   280→    ) -> int:\n   281→        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n   282→\n   283→        Returns the number of particles killed.\n   284→        \"\"\"\n   285→        if self._high_water == 0:\n   286→            return 0\n   287→\n   288→        n = self._high_water\n   289→        cx, cy, cz = center\n   290→        dx = self.position[:n, 0] - cx\n   291→        dy = self.position[:n, 1] - cy\n   292→        dz = self.position[:n, 2] - cz\n   293→        dist_sq = dx * dx + dy * dy + dz * dz\n   294→\n   295→        mask = dist_sq <= (radius * radius)\n   296→        # Only kill non-DEAD particles\n   297→        mask = mask & (self.packed_info[:n] != 0)\n   298→        killed = int(cp.sum(mask))\n   299→\n   300→        if killed > 0:\n   301→            self.packed_info[:n][mask] = cp.uint32(0)\n   302→\n   303→        return killed\n   304→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"d557a6a8-dde9-41cf-ab3a-fa6ac2ce30b6","uuid":"de1b82a6-0841-4ae0-985c-bebc7881b5d2","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/world.py","content":"\"\"\"World state management for Falling Sand 3D.\n\nManages CuPy arrays for all per-particle SoA data. Supports configurable\nmax_particles at startup, spawning particles in sphere/cube shapes, and\ntracking num_active via counter.\n\nAll arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\nDEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Tuple\n\nimport cupy as cp\nimport numpy as np\n\nfrom materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n\n# packed_info bitfield macros (mirrors common.cuh)\n_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n\n# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\nDEFAULT_SPACING = 0.02\n\n# Default temperatures for hot materials (Kelvin)\n_DEFAULT_TEMPS = {\n    7: 1500.0,   # LAVA\n    14: 1200.0,  # FIRE\n    12: 373.0,   # STEAM\n    13: 500.0,   # SMOKE\n}\n\n# Ambient temperature\nT_AMBIENT = 293.0\n\n\nclass World:\n    \"\"\"Manages all per-particle SoA arrays on GPU.\n\n    Parameters\n    ----------\n    max_particles : int\n        Maximum number of particles to allocate for (default 500000).\n    \"\"\"\n\n    def __init__(self, max_particles: int = 500_000) -> None:\n        self.max_particles: int = max_particles\n        self._high_water: int = 0  # one past last allocated slot\n        self._allocate()\n\n    def _allocate(self) -> None:\n        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n        n = self.max_particles\n        # float4 arrays (stored as (n, 4) float32)\n        self.position = cp.zeros((n, 4), dtype=cp.float32)\n        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n        self.color = cp.zeros((n, 4), dtype=cp.float32)\n        # float arrays\n        self.density = cp.zeros(n, dtype=cp.float32)\n        self.mass = cp.zeros(n, dtype=cp.float32)\n        self.temperature = cp.zeros(n, dtype=cp.float32)\n        self.health = cp.zeros(n, dtype=cp.float32)\n        self.lifetime = cp.zeros(n, dtype=cp.float32)\n        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n        # uint32 arrays\n        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n        # uint8 arrays\n        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n\n        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n        # These are the double-buffer targets: after sort+reorder, physics\n        # kernels (Step1/Step2) read from these.  Integrate writes back to\n        # the unsorted arrays above via sort_indexes.\n        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n        self.sorted_dTdt = cp.zeros(n, dtype=cp.float32)\n        self.sorted_exposure_heat = cp.zeros(n, dtype=cp.float32)\n        self.sorted_exposure_corrode = cp.zeros(n, dtype=cp.float32)\n        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n        # Sort index arrays (hash + original index, plus sorted versions)\n        self.hashes = cp.zeros(n, dtype=cp.uint32)\n        self.indices = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n\n    def resize(self, new_max: int) -> None:\n        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n        self.max_particles = new_max\n        self._high_water = 0\n        self._allocate()\n\n    @property\n    def num_active(self) -> int:\n        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n        if self._high_water == 0:\n            return 0\n        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n\n    def spawn_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n        material_id: int,\n        count: int,\n    ) -> int:\n        \"\"\"Spawn particles with random positions inside a sphere.\n\n        Returns the number of particles actually spawned (may be less than\n        count if max_particles is reached).\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        available = self.max_particles - self._high_water\n        actual = min(count, available)\n        if actual <= 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n\n        # Generate random positions in unit sphere using rejection sampling on GPU\n        # Over-generate by ~2x to account for rejection, then take first `actual`\n        needed = actual\n        positions_list = []\n        remaining = needed\n        while remaining > 0:\n            batch = int(remaining * 2.0) + 128\n            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n            r_sq = cp.sum(pts * pts, axis=1)\n            inside = pts[r_sq <= 1.0]\n            take = min(len(inside), remaining)\n            if take > 0:\n                positions_list.append(inside[:take])\n                remaining -= take\n\n        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n        # Scale to desired radius and translate to center\n        cx, cy, cz = center\n        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n\n        sl = slice(start, start + actual)\n        self.position[sl, 0] = sphere_pts[:, 0]\n        self.position[sl, 1] = sphere_pts[:, 1]\n        self.position[sl, 2] = sphere_pts[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        # mass = rho0 * spacing^3\n        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def spawn_cube(\n        self,\n        min_corner: Tuple[float, float, float],\n        max_corner: Tuple[float, float, float],\n        material_id: int,\n        spacing: float = DEFAULT_SPACING,\n    ) -> int:\n        \"\"\"Spawn particles on a regular grid within a cube.\n\n        Returns the number of particles actually spawned.\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        # Build grid positions on CPU (small overhead, predictable count)\n        x0, y0, z0 = min_corner\n        x1, y1, z1 = max_corner\n        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n\n        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n            return 0\n\n        total = len(xs) * len(ys) * len(zs)\n        available = self.max_particles - self._high_water\n        actual = min(total, available)\n        if actual <= 0:\n            return 0\n\n        # Generate meshgrid positions\n        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n        positions = np.column_stack([\n            gx.ravel()[:actual],\n            gy.ravel()[:actual],\n            gz.ravel()[:actual],\n        ]).astype(np.float32)\n\n        actual = len(positions)\n        if actual == 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n        sl = slice(start, start + actual)\n\n        d_positions = cp.asarray(positions)\n        self.position[sl, 0] = d_positions[:, 0]\n        self.position[sl, 1] = d_positions[:, 1]\n        self.position[sl, 2] = d_positions[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        particle_mass = mat.rest_density * (spacing ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def kill_in_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n    ) -> int:\n        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n\n        Returns the number of particles killed.\n        \"\"\"\n        if self._high_water == 0:\n            return 0\n\n        n = self._high_water\n        cx, cy, cz = center\n        dx = self.position[:n, 0] - cx\n        dy = self.position[:n, 1] - cy\n        dz = self.position[:n, 2] - cz\n        dist_sq = dx * dx + dy * dy + dz * dz\n\n        mask = dist_sq <= (radius * radius)\n        # Only kill non-DEAD particles\n        mask = mask & (self.packed_info[:n] != 0)\n        killed = int(cp.sum(mask))\n\n        if killed > 0:\n            self.packed_info[:n][mask] = cp.uint32(0)\n\n        return killed\n","numLines":304,"startLine":1,"totalLines":304}}}

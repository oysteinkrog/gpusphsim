{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018XBKc67EZa6VS63tsV8yUU","type":"tool_result","content":"     1→/*\n     2→ * reactions.cu -- K_Reactions kernel: per-particle state machine for\n     3→ * phase transitions, combustion, corrosion, and gas lifetime.\n     4→ *\n     5→ * No neighbor loop -- each thread processes one particle independently.\n     6→ * Reads exposure accumulators from Step1, checks temperature and exposure\n     7→ * thresholds, and modifies material type, behavior class, temperature,\n     8→ * health, lifetime, and velocity as needed.\n     9→ *\n    10→ * Runs on SORTED arrays, between Step1 (which computes exposure) and\n    11→ * Step2 (which computes forces). Modifications to sorted_packed_info\n    12→ * flow through Step2 and Integrate naturally.\n    13→ *\n    14→ * Constant memory used:\n    15→ *   c_sim       -- SimParams (dt)\n    16→ *   c_materials -- MaterialProps[32] (for looking up current material props)\n    17→ */\n    18→\n    19→#include \"common.cuh\"\n    20→\n    21→/* ======================================================================\n    22→ * Material IDs (must match materials.py)\n    23→ * ====================================================================== */\n    24→\n    25→#define MAT_DEAD       0\n    26→#define MAT_STONE      1\n    27→#define MAT_WATER      5\n    28→#define MAT_OIL        6\n    29→#define MAT_LAVA       7\n    30→#define MAT_WOOD       9\n    31→#define MAT_ICE       11\n    32→#define MAT_STEAM     12\n    33→#define MAT_FIRE      14\n    34→#define MAT_GUNPOWDER 15\n    35→\n    36→/* ======================================================================\n    37→ * Reaction thresholds\n    38→ * ====================================================================== */\n    39→\n    40→#define ICE_MELT_TEMP         273.0f   // ICE -> WATER above this\n    41→#define LAVA_SOLIDIFY_TEMP    900.0f   // LAVA -> STONE below this\n    42→#define WATER_BOIL_TEMP       373.0f   // WATER -> SPAWN_GAS flag above this\n    43→#define STEAM_CONDENSE_TEMP   373.0f   // STEAM -> WATER below this\n    44→\n    45→#define WOOD_IGNITE_EXPOSURE  0.5f     // WOOD -> FIRE above this exposure_heat\n    46→#define OIL_IGNITE_EXPOSURE   0.3f     // OIL  -> FIRE above this exposure_heat\n    47→#define GUNPOWDER_EXPOSURE    0.1f     // GUNPOWDER -> FIRE above this exposure_heat\n    48→\n    49→#define FIRE_TEMPERATURE     1200.0f   // temperature set on combustion\n    50→#define WOOD_FIRE_LIFETIME      1.0f   // seconds\n    51→#define OIL_FIRE_LIFETIME       1.5f   // seconds\n    52→#define GUNPOWDER_FIRE_LIFETIME 0.3f   // seconds\n    53→\n    54→#define EXPLOSION_SPEED        5.0f    // velocity magnitude for gunpowder burst\n    55→\n    56→/* ======================================================================\n    57→ * Wang hash RNG for explosion direction\n    58→ * ====================================================================== */\n    59→\n    60→__device__ inline uint wang_hash(uint seed) {\n    61→    seed = (seed ^ 61u) ^ (seed >> 16u);\n    62→    seed *= 9u;\n    63→    seed = seed ^ (seed >> 4u);\n    64→    seed *= 0x27d4eb2du;\n    65→    seed = seed ^ (seed >> 15u);\n    66→    return seed;\n    67→}\n    68→\n    69→__device__ inline float hash_to_float(uint h) {\n    70→    // Map hash to [-1, 1]\n    71→    return (float)(h & 0xFFFFu) / 32767.5f - 1.0f;\n    72→}\n    73→\n    74→/* ======================================================================\n    75→ * K_Reactions kernel\n    76→ * ====================================================================== */\n    77→\n    78→extern \"C\" __global__\n    79→void K_Reactions(\n    80→    uint            numParticles,\n    81→    uint            frame,           // for RNG seed\n    82→    // --- Sorted arrays (read+write in-place) ---\n    83→    uint*           __restrict__ packed_info,       // material_id + behavior + flags\n    84→    float*          __restrict__ temperature,       // particle temperature\n    85→    float*          __restrict__ health,            // particle health [0,1]\n    86→    float*          __restrict__ lifetime,          // remaining lifetime (seconds)\n    87→    float4*         __restrict__ velocity,          // particle velocity (for explosion)\n    88→    // --- Sorted inputs (read-only, from Step1) ---\n    89→    const float*    __restrict__ exposure_heat,     // heat exposure accumulator\n    90→    const float*    __restrict__ exposure_corrode,  // corrosion exposure accumulator\n    91→    // --- Freelist output (for spawn system) ---\n    92→    uint*           __restrict__ dead_indices,      // array of dead particle indices\n    93→    uint*           __restrict__ dead_count          // atomic counter\n    94→) {\n    95→    uint i = blockIdx.x * blockDim.x + threadIdx.x;\n    96→    if (i >= numParticles) return;\n    97→\n    98→    uint pi = packed_info[i];\n    99→    uint mat_id = GET_MATERIAL_ID(pi);\n   100→\n   101→    // Skip DEAD particles\n   102→    if (mat_id == MAT_DEAD) return;\n   103→\n   104→    float temp = temperature[i];\n   105→    float hlth = health[i];\n   106→    float lt = lifetime[i];\n   107→    float exp_heat = exposure_heat[i];\n   108→    float exp_corrode = exposure_corrode[i];\n   109→    float dt = c_sim.dt;\n   110→\n   111→    // ---- Phase transitions based on temperature ----\n   112→\n   113→    // ICE (mat=11, temp > 273K) -> WATER (in-place, small density ratio)\n   114→    if (mat_id == MAT_ICE && temp > ICE_MELT_TEMP) {\n   115→        pi = MAKE_PACKED(MAT_WATER, FLUID);\n   116→        packed_info[i] = pi;\n   117→        temperature[i] = temp;\n   118→        return;  // done with this particle\n   119→    }\n   120→\n   121→    // LAVA (mat=7, temp < 900K) -> STONE (in-place)\n   122→    if (mat_id == MAT_LAVA && temp < LAVA_SOLIDIFY_TEMP) {\n   123→        pi = MAKE_PACKED(MAT_STONE, STATIC);\n   124→        packed_info[i] = pi;\n   125→        temperature[i] = temp;\n   126→        return;\n   127→    }\n   128→\n   129→    // WATER (mat=5, temp > 373K) -> set SPAWN_GAS flag (large density ratio, US-023)\n   130→    if (mat_id == MAT_WATER && temp > WATER_BOIL_TEMP) {\n   131→        pi = SET_SPAWN_FLAG(pi);\n   132→        packed_info[i] = pi;\n   133→        return;\n   134→    }\n   135→\n   136→    // STEAM (mat=12, temp < 373K) -> WATER (in-place)\n   137→    if (mat_id == MAT_STEAM && temp < STEAM_CONDENSE_TEMP) {\n   138→        pi = MAKE_PACKED(MAT_WATER, FLUID);\n   139→        packed_info[i] = pi;\n   140→        temperature[i] = temp;\n   141→        return;\n   142→    }\n   143→\n   144→    // ---- Combustion transitions based on exposure_heat ----\n   145→\n   146→    // WOOD (mat=9, exposure_heat > 0.5) -> FIRE\n   147→    if (mat_id == MAT_WOOD && exp_heat > WOOD_IGNITE_EXPOSURE) {\n   148→        pi = MAKE_PACKED(MAT_FIRE, GAS);\n   149→        packed_info[i] = pi;\n   150→        temperature[i] = FIRE_TEMPERATURE;\n   151→        lifetime[i] = WOOD_FIRE_LIFETIME;\n   152→        return;\n   153→    }\n   154→\n   155→    // OIL (mat=6, exposure_heat > 0.3) -> FIRE\n   156→    if (mat_id == MAT_OIL && exp_heat > OIL_IGNITE_EXPOSURE) {\n   157→        pi = MAKE_PACKED(MAT_FIRE, GAS);\n   158→        packed_info[i] = pi;\n   159→        temperature[i] = FIRE_TEMPERATURE;\n   160→        lifetime[i] = OIL_FIRE_LIFETIME;\n   161→        return;\n   162→    }\n   163→\n   164→    // GUNPOWDER (mat=15, exposure_heat > 0.1) -> FIRE + explosion\n   165→    if (mat_id == MAT_GUNPOWDER && exp_heat > GUNPOWDER_EXPOSURE) {\n   166→        pi = MAKE_PACKED(MAT_FIRE, GAS);\n   167→        packed_info[i] = pi;\n   168→        temperature[i] = FIRE_TEMPERATURE;\n   169→        lifetime[i] = GUNPOWDER_FIRE_LIFETIME;\n   170→\n   171→        // Random outward burst using wang_hash RNG\n   172→        uint h1 = wang_hash(i + frame * 0x9E3779B9u);\n   173→        uint h2 = wang_hash(h1);\n   174→        uint h3 = wang_hash(h2);\n   175→        float dx = hash_to_float(h1);\n   176→        float dy = hash_to_float(h2);\n   177→        float dz = hash_to_float(h3);\n   178→        // Normalize and scale\n   179→        float len = sqrtf(dx * dx + dy * dy + dz * dz);\n   180→        if (len > 1e-6f) {\n   181→            float inv_len = EXPLOSION_SPEED / len;\n   182→            float4 v = velocity[i];\n   183→            v.x += dx * inv_len;\n   184→            v.y += dy * inv_len;\n   185→            v.z += dz * inv_len;\n   186→            velocity[i] = v;\n   187→        }\n   188→        return;\n   189→    }\n   190→\n   191→    // ---- Corrosion: health -= exposure_corrode * dt ----\n   192→    if (exp_corrode > 0.0f) {\n   193→        hlth -= exp_corrode * dt;\n   194→        if (hlth <= 0.0f) {\n   195→            // Particle dies from corrosion -- add to freelist\n   196→            packed_info[i] = MAKE_PACKED(MAT_DEAD, STATIC);\n   197→            health[i] = 0.0f;\n   198→            if (dead_indices != 0 && dead_count != 0) {\n   199→                uint idx = atomicAdd(dead_count, 1u);\n   200→                dead_indices[idx] = i;\n   201→            }\n   202→            return;\n   203→        }\n   204→        health[i] = hlth;\n   205→    }\n   206→\n   207→    // ---- GAS lifetime decay ----\n   208→    int behavior = GET_BEHAVIOR(pi);\n   209→    if (behavior == GAS && lt > 0.0f) {\n   210→        lt -= dt;\n   211→        if (lt <= 0.0f) {\n   212→            // Gas particle expired -- add to freelist\n   213→            packed_info[i] = MAKE_PACKED(MAT_DEAD, STATIC);\n   214→            lifetime[i] = 0.0f;\n   215→            health[i] = 0.0f;\n   216→            if (dead_indices != 0 && dead_count != 0) {\n   217→                uint idx = atomicAdd(dead_count, 1u);\n   218→                dead_indices[idx] = i;\n   219→            }\n   220→            return;\n   221→        }\n   222→        lifetime[i] = lt;\n   223→    }\n   224→}\n   225→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_016myLLq9AYQ6ECjeFvfw5cw","session_id":"d557a6a8-dde9-41cf-ab3a-fa6ac2ce30b6","uuid":"bfa95c27-ea52-4e1d-a3c2-fa1f938c81df"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UEXJcCsBwgP2NSezSULnGG","type":"tool_result","content":"     1→/*\n     2→ * spawn.cu -- K_SpawnGas kernel: spawn/kill system for large phase transitions.\n     3→ *\n     4→ * When a water particle has HAS_SPAWN_FLAG set (by Reactions kernel when\n     5→ * temp > 373K), this kernel kills the water particle and spawns N steam\n     6→ * particles in its place using a GPU freelist of dead particle indices.\n     7→ *\n     8→ * Freelist design:\n     9→ *   dead_indices[max_particles]  -- uint32 array of dead particle indices\n    10→ *   dead_count                   -- uint32 atomic counter (number of entries)\n    11→ *\n    12→ * The Reactions kernel populates the freelist when particles die (corrosion\n    13→ * death, gas lifetime expiry). This kernel consumes from it via atomicSub.\n    14→ *\n    15→ * Runs on SORTED arrays after Reactions, before Step2. The spawned particles\n    16→ * are written to sorted arrays at the claimed freelist slots.\n    17→ *\n    18→ * Constant memory used:\n    19→ *   c_sim       -- SimParams (for dt, particle_mass)\n    20→ *   c_materials -- MaterialProps[32] (for steam properties)\n    21→ */\n    22→\n    23→#include \"common.cuh\"\n    24→\n    25→/* ======================================================================\n    26→ * Material IDs (must match materials.py)\n    27→ * ====================================================================== */\n    28→\n    29→#define MAT_DEAD       0\n    30→#define MAT_WATER      5\n    31→#define MAT_STEAM     12\n    32→\n    33→/* ======================================================================\n    34→ * Spawn configuration\n    35→ * ====================================================================== */\n    36→\n    37→#define SPAWN_N          3        // number of steam particles per water particle\n    38→#define SPAWN_TEMP     373.0f     // steam temperature (K)\n    39→#define SPAWN_LIFETIME   5.0f     // steam lifetime (seconds)\n    40→#define SPAWN_UPKICK     2.0f     // upward velocity kick (m/s)\n    41→\n    42→/* ======================================================================\n    43→ * K_SpawnGas kernel\n    44→ *\n    45→ * For each particle with HAS_SPAWN_FLAG set:\n    46→ *   1. atomicSub(&dead_count, N) to claim N freelist slots\n    47→ *   2. If result >= 0, read dead_indices to get target slots\n    48→ *   3. Write spawned steam particles to those slots\n    49→ *   4. Mark source water particle as DEAD and add it to freelist\n    50→ *   5. Clear SPAWN_GAS flag\n    51→ *\n    52→ * If freelist is exhausted (atomicSub result < 0), restore count and skip.\n    53→ * ====================================================================== */\n    54→\n    55→extern \"C\" __global__\n    56→void K_SpawnGas(\n    57→    uint            numParticles,\n    58→    // --- Sorted arrays (read+write in-place) ---\n    59→    uint*           __restrict__ packed_info,\n    60→    float4*         __restrict__ position,\n    61→    float4*         __restrict__ velocity,\n    62→    float4*         __restrict__ veleval,\n    63→    float*          __restrict__ mass,\n    64→    float*          __restrict__ temperature,\n    65→    float*          __restrict__ health,\n    66→    float*          __restrict__ lifetime,\n    67→    float4*         __restrict__ color,\n    68→    unsigned char*  __restrict__ sleep_counter,\n    69→    float*          __restrict__ density,\n    70→    float*          __restrict__ shear_rate,\n    71→    // --- Freelist (shared with Reactions) ---\n    72→    uint*           __restrict__ dead_indices,   // array of dead particle indices\n    73→    uint*           __restrict__ dead_count       // atomic counter\n    74→) {\n    75→    uint i = blockIdx.x * blockDim.x + threadIdx.x;\n    76→    if (i >= numParticles) return;\n    77→\n    78→    uint pi = packed_info[i];\n    79→\n    80→    // Only process particles with SPAWN_GAS flag set\n    81→    if (!HAS_SPAWN_FLAG(pi)) return;\n    82→\n    83→    // Clear the flag regardless of whether spawn succeeds\n    84→    pi = CLEAR_SPAWN_FLAG(pi);\n    85→\n    86→    // Claim N slots from the freelist one at a time.\n    87→    // Each atomicSub claims one slot; if any fails, restore all and abort.\n    88→    uint claimed_slots[SPAWN_N];\n    89→    int n_claimed = 0;\n    90→\n    91→    for (int k = 0; k < SPAWN_N; k++) {\n    92→        int old_val = (int)atomicSub(dead_count, 1u);\n    93→        if (old_val <= 0) {\n    94→            // Not enough -- restore this failed claim\n    95→            atomicAdd(dead_count, 1u);\n    96→            break;\n    97→        }\n    98→        claimed_slots[k] = dead_indices[old_val - 1];\n    99→        n_claimed++;\n   100→    }\n   101→\n   102→    if (n_claimed < SPAWN_N) {\n   103→        // Restore any slots we successfully claimed\n   104→        if (n_claimed > 0) {\n   105→            atomicAdd(dead_count, (uint)n_claimed);\n   106→        }\n   107→        packed_info[i] = pi;\n   108→        return;\n   109→    }\n   110→\n   111→    // All N slots claimed successfully\n   112→    // Read the source particle's properties\n   113→    float4 src_pos = position[i];\n   114→    float4 src_vel = velocity[i];\n   115→    float  src_mass = mass[i];\n   116→\n   117→    // Compute per-spawned-particle mass (conservation of mass)\n   118→    float child_mass = src_mass / (float)SPAWN_N;\n   119→\n   120→    // Steam material packed info\n   121→    uint steam_pi = MAKE_PACKED(MAT_STEAM, GAS);\n   122→\n   123→    // Steam color from c_materials\n   124→    float cr = c_materials[MAT_STEAM].color_r;\n   125→    float cg = c_materials[MAT_STEAM].color_g;\n   126→    float cb = c_materials[MAT_STEAM].color_b;\n   127→\n   128→    // Write spawned particles to the claimed freelist slots\n   129→    for (int k = 0; k < SPAWN_N; k++) {\n   130→        uint slot = claimed_slots[k];\n   131→\n   132→        // Position: same as source (they'll spread via SPH forces)\n   133→        position[slot] = src_pos;\n   134→\n   135→        // Velocity: source velocity + upward kick\n   136→        float4 child_vel;\n   137→        child_vel.x = src_vel.x;\n   138→        child_vel.y = src_vel.y + SPAWN_UPKICK;\n   139→        child_vel.z = src_vel.z;\n   140→        child_vel.w = 0.0f;\n   141→        velocity[slot] = child_vel;\n   142→        veleval[slot] = child_vel;\n   143→\n   144→        // Scalar properties\n   145→        mass[slot] = child_mass;\n   146→        temperature[slot] = SPAWN_TEMP;\n   147→        health[slot] = 1.0f;\n   148→        lifetime[slot] = SPAWN_LIFETIME;\n   149→        density[slot] = c_materials[MAT_STEAM].rest_density;\n   150→        shear_rate[slot] = 0.0f;\n   151→        sleep_counter[slot] = 0;\n   152→\n   153→        // Color\n   154→        float4 child_color;\n   155→        child_color.x = cr;\n   156→        child_color.y = cg;\n   157→        child_color.z = cb;\n   158→        child_color.w = 1.0f;\n   159→        color[slot] = child_color;\n   160→\n   161→        // Material info\n   162→        packed_info[slot] = steam_pi;\n   163→    }\n   164→\n   165→    // Mark source water particle as DEAD\n   166→    // (NOT added back to freelist here -- would race with concurrent reads\n   167→    //  from dead_indices. Compaction (US-029) reclaims dead particles.)\n   168→    packed_info[i] = MAKE_PACKED(MAT_DEAD, FLUID);\n   169→    health[i] = 0.0f;\n   170→    mass[i] = 0.0f;\n   171→}\n   172→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_016myLLq9AYQ6ECjeFvfw5cw","session_id":"d557a6a8-dde9-41cf-ab3a-fa6ac2ce30b6","uuid":"dc85c87f-e118-4d69-a8c5-b802c6840d67"}

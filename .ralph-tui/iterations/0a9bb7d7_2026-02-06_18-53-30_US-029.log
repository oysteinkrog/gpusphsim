{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JwAkBMktCDE5rL6vHkJQMW","type":"tool_result","content":"     1→\"\"\"Spawn/kill kernel: GPU freelist-based particle spawning for phase transitions.\n     2→\n     3→Compiles physics/kernels/spawn.cu via CuPy RawModule and provides\n     4→a function to launch K_SpawnGas which:\n     5→  - Scans sorted particles for HAS_SPAWN_FLAG (set by Reactions for boiling water)\n     6→  - For each flagged particle, claims N slots from the GPU freelist via atomicSub\n     7→  - Writes N steam particles to the claimed slots (mass-conserving)\n     8→  - Marks the source water particle as DEAD and adds it to the freelist\n     9→  - Clears the SPAWN_GAS flag regardless of success\n    10→\n    11→Operates on SORTED arrays, runs after Reactions and before Step2.\n    12→\n    13→Uses shared constant memory from common.cuh:\n    14→  c_sim       -- SimParams\n    15→  c_materials -- MaterialProps[32] (for steam color/rest_density)\n    16→\"\"\"\n    17→\n    18→from __future__ import annotations\n    19→\n    20→import os\n    21→from typing import Optional\n    22→\n    23→import cupy\n    24→import numpy as np\n    25→\n    26→# ---------------------------------------------------------------------------\n    27→# CuPy RawModule compilation\n    28→# ---------------------------------------------------------------------------\n    29→\n    30→_module: Optional[object] = None\n    31→\n    32→\n    33→def _ensure_ptx_if_needed() -> None:\n    34→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    35→    from cupy.cuda import compiler as _compiler\n    36→    from cupy.cuda import device as _device\n    37→\n    38→    gpu_cc = _device.Device().compute_capability\n    39→    nvrtc_max = _compiler._get_max_compute_capability()\n    40→    if int(gpu_cc) > int(nvrtc_max):\n    41→        _compiler._use_ptx = True\n    42→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    43→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    44→        if hasattr(_compiler._get_arch, \"_cache\"):\n    45→            _compiler._get_arch._cache = {}\n    46→\n    47→\n    48→def _get_module() -> \"object\":\n    49→    \"\"\"Compile (or return cached) CuPy RawModule from spawn.cu.\"\"\"\n    50→    global _module\n    51→    if _module is not None:\n    52→        return _module\n    53→\n    54→    _ensure_ptx_if_needed()\n    55→\n    56→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    57→    cu_path = os.path.join(kernel_dir, \"spawn.cu\")\n    58→    with open(cu_path) as f:\n    59→        source = f.read()\n    60→\n    61→    _module = cupy.RawModule(\n    62→        code=source,\n    63→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    64→    )\n    65→    return _module\n    66→\n    67→\n    68→def get_module() -> \"object\":\n    69→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    70→    return _get_module()\n    71→\n    72→\n    73→# ---------------------------------------------------------------------------\n    74→# Constant memory upload\n    75→# ---------------------------------------------------------------------------\n    76→\n    77→\n    78→def upload_sim_params(params: np.ndarray) -> None:\n    79→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    80→    module = _get_module()\n    81→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    82→    cupy.cuda.runtime.memcpy(\n    83→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    84→    )\n    85→\n    86→\n    87→def upload_materials(materials_data: np.ndarray) -> None:\n    88→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    89→    module = _get_module()\n    90→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    91→    cupy.cuda.runtime.memcpy(\n    92→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    93→    )\n    94→\n    95→\n    96→# ---------------------------------------------------------------------------\n    97→# Freelist allocation\n    98→# ---------------------------------------------------------------------------\n    99→\n   100→SPAWN_N = 3  # must match SPAWN_N in spawn.cu\n   101→\n   102→\n   103→def allocate_freelist(max_particles: int) -> tuple:\n   104→    \"\"\"Allocate GPU freelist arrays.\n   105→\n   106→    Returns\n   107→    -------\n   108→    dead_indices : cupy.ndarray, (max_particles,) uint32\n   109→        Array of dead particle indices (stack).\n   110→    dead_count : cupy.ndarray, (1,) uint32\n   111→        Atomic counter for number of entries in dead_indices.\n   112→    \"\"\"\n   113→    dead_indices = cupy.zeros(max_particles, dtype=cupy.uint32)\n   114→    dead_count = cupy.zeros(1, dtype=cupy.uint32)\n   115→    return dead_indices, dead_count\n   116→\n   117→\n   118→def reset_freelist(dead_count: cupy.ndarray) -> None:\n   119→    \"\"\"Reset the freelist counter to 0.\"\"\"\n   120→    dead_count[:] = 0\n   121→\n   122→\n   123→# ---------------------------------------------------------------------------\n   124→# Kernel launch\n   125→# ---------------------------------------------------------------------------\n   126→\n   127→BLOCK_SIZE = 256\n   128→\n   129→\n   130→def compute_spawn(\n   131→    sorted_packed_info: cupy.ndarray,\n   132→    sorted_position: cupy.ndarray,\n   133→    sorted_velocity: cupy.ndarray,\n   134→    sorted_veleval: cupy.ndarray,\n   135→    sorted_mass: cupy.ndarray,\n   136→    sorted_temperature: cupy.ndarray,\n   137→    sorted_health: cupy.ndarray,\n   138→    sorted_lifetime: cupy.ndarray,\n   139→    sorted_color: cupy.ndarray,\n   140→    sorted_sleep_counter: cupy.ndarray,\n   141→    sorted_density: cupy.ndarray,\n   142→    sorted_shear_rate: cupy.ndarray,\n   143→    dead_indices: cupy.ndarray,\n   144→    dead_count: cupy.ndarray,\n   145→) -> None:\n   146→    \"\"\"Launch K_SpawnGas kernel.\n   147→\n   148→    Processes all particles with HAS_SPAWN_FLAG set, spawning steam particles\n   149→    at freelist slots and marking source particles as DEAD.\n   150→\n   151→    All sorted arrays are modified in-place.\n   152→\n   153→    Parameters\n   154→    ----------\n   155→    sorted_packed_info : cupy.ndarray, (N,) uint32\n   156→    sorted_position : cupy.ndarray, (N, 4) float32\n   157→    sorted_velocity : cupy.ndarray, (N, 4) float32\n   158→    sorted_veleval : cupy.ndarray, (N, 4) float32\n   159→    sorted_mass : cupy.ndarray, (N,) float32\n   160→    sorted_temperature : cupy.ndarray, (N,) float32\n   161→    sorted_health : cupy.ndarray, (N,) float32\n   162→    sorted_lifetime : cupy.ndarray, (N,) float32\n   163→    sorted_color : cupy.ndarray, (N, 4) float32\n   164→    sorted_sleep_counter : cupy.ndarray, (N,) uint8\n   165→    sorted_density : cupy.ndarray, (N,) float32\n   166→    sorted_shear_rate : cupy.ndarray, (N,) float32\n   167→    dead_indices : cupy.ndarray, (max_particles,) uint32\n   168→        Freelist of dead particle indices.\n   169→    dead_count : cupy.ndarray, (1,) uint32\n   170→        Atomic counter for freelist size.\n   171→    \"\"\"\n   172→    n = sorted_packed_info.shape[0]\n   173→    if n == 0:\n   174→        return\n   175→\n   176→    module = _get_module()\n   177→    kernel = module.get_function(\"K_SpawnGas\")  # type: ignore[union-attr]\n   178→\n   179→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   180→    block = (BLOCK_SIZE,)\n   181→\n   182→    kernel(\n   183→        grid,\n   184→        block,\n   185→        (\n   186→            np.uint32(n),\n   187→            sorted_packed_info,\n   188→            sorted_position,\n   189→            sorted_velocity,\n   190→            sorted_veleval,\n   191→            sorted_mass,\n   192→            sorted_temperature,\n   193→            sorted_health,\n   194→            sorted_lifetime,\n   195→            sorted_color,\n   196→            sorted_sleep_counter,\n   197→            sorted_density,\n   198→            sorted_shear_rate,\n   199→            dead_indices,\n   200→            dead_count,\n   201→        ),\n   202→    )\n   203→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_016myLLq9AYQ6ECjeFvfw5cw","session_id":"d557a6a8-dde9-41cf-ab3a-fa6ac2ce30b6","uuid":"61567dc1-f3a5-443f-8a53-25ec12583a33"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FjoVbLXS6KAMyE8GvXD1nV","type":"tool_result","content":"     1→\"\"\"Reactions kernel: per-particle phase transitions, combustion, and corrosion.\n     2→\n     3→Compiles physics/kernels/reactions.cu via CuPy RawModule and provides\n     4→a function to launch K_Reactions which performs:\n     5→  - ICE -> WATER (temp > 273K)\n     6→  - LAVA -> STONE (temp < 900K)\n     7→  - WATER -> SPAWN_GAS flag (temp > 373K)\n     8→  - STEAM -> WATER (temp < 373K)\n     9→  - WOOD/OIL/GUNPOWDER -> FIRE (exposure_heat threshold)\n    10→  - Corrosion: health -= exposure_corrode * dt\n    11→  - GAS lifetime decay -> DEAD when expired\n    12→\n    13→Operates on SORTED arrays, runs after Step1 (which computes exposure)\n    14→and before Step2 (which computes forces).\n    15→\n    16→Uses shared constant memory from common.cuh:\n    17→  c_sim       -- SimParams (dt)\n    18→  c_materials -- MaterialProps[32]\n    19→\"\"\"\n    20→\n    21→from __future__ import annotations\n    22→\n    23→import os\n    24→from typing import Optional\n    25→\n    26→import cupy\n    27→import numpy as np\n    28→\n    29→# ---------------------------------------------------------------------------\n    30→# CuPy RawModule compilation\n    31→# ---------------------------------------------------------------------------\n    32→\n    33→_module: Optional[object] = None\n    34→\n    35→\n    36→def _ensure_ptx_if_needed() -> None:\n    37→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    38→    from cupy.cuda import compiler as _compiler\n    39→    from cupy.cuda import device as _device\n    40→\n    41→    gpu_cc = _device.Device().compute_capability\n    42→    nvrtc_max = _compiler._get_max_compute_capability()\n    43→    if int(gpu_cc) > int(nvrtc_max):\n    44→        _compiler._use_ptx = True\n    45→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    46→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    47→        if hasattr(_compiler._get_arch, \"_cache\"):\n    48→            _compiler._get_arch._cache = {}\n    49→\n    50→\n    51→def _get_module() -> \"object\":\n    52→    \"\"\"Compile (or return cached) CuPy RawModule from reactions.cu.\"\"\"\n    53→    global _module\n    54→    if _module is not None:\n    55→        return _module\n    56→\n    57→    _ensure_ptx_if_needed()\n    58→\n    59→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    60→    cu_path = os.path.join(kernel_dir, \"reactions.cu\")\n    61→    with open(cu_path) as f:\n    62→        source = f.read()\n    63→\n    64→    _module = cupy.RawModule(\n    65→        code=source,\n    66→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    67→    )\n    68→    return _module\n    69→\n    70→\n    71→def get_module() -> \"object\":\n    72→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    73→    return _get_module()\n    74→\n    75→\n    76→# ---------------------------------------------------------------------------\n    77→# Constant memory upload\n    78→# ---------------------------------------------------------------------------\n    79→\n    80→\n    81→def upload_sim_params(params: np.ndarray) -> None:\n    82→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    83→    module = _get_module()\n    84→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    85→    cupy.cuda.runtime.memcpy(\n    86→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    87→    )\n    88→\n    89→\n    90→def upload_materials(materials_data: np.ndarray) -> None:\n    91→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    92→    module = _get_module()\n    93→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    94→    cupy.cuda.runtime.memcpy(\n    95→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    96→    )\n    97→\n    98→\n    99→# ---------------------------------------------------------------------------\n   100→# Kernel launch\n   101→# ---------------------------------------------------------------------------\n   102→\n   103→BLOCK_SIZE = 256\n   104→\n   105→\n   106→def compute_reactions(\n   107→    sorted_packed_info: cupy.ndarray,\n   108→    sorted_temperature: cupy.ndarray,\n   109→    sorted_health: cupy.ndarray,\n   110→    sorted_lifetime: cupy.ndarray,\n   111→    sorted_velocity: cupy.ndarray,\n   112→    sorted_exposure_heat: cupy.ndarray,\n   113→    sorted_exposure_corrode: cupy.ndarray,\n   114→    frame: int = 0,\n   115→    dead_indices: Optional[cupy.ndarray] = None,\n   116→    dead_count: Optional[cupy.ndarray] = None,\n   117→) -> None:\n   118→    \"\"\"Launch K_Reactions kernel.\n   119→\n   120→    Modifies sorted arrays in-place: packed_info, temperature, health,\n   121→    lifetime, velocity.\n   122→\n   123→    Parameters\n   124→    ----------\n   125→    sorted_packed_info : cupy.ndarray, (N,) uint32\n   126→        Packed info (material_id + behavior + flags). Modified in-place.\n   127→    sorted_temperature : cupy.ndarray, (N,) float32\n   128→        Particle temperature. Modified in-place.\n   129→    sorted_health : cupy.ndarray, (N,) float32\n   130→        Particle health [0,1]. Modified in-place.\n   131→    sorted_lifetime : cupy.ndarray, (N,) float32\n   132→        Remaining lifetime in seconds. Modified in-place.\n   133→    sorted_velocity : cupy.ndarray, (N, 4) float32\n   134→        Particle velocity. Modified in-place (gunpowder explosion).\n   135→    sorted_exposure_heat : cupy.ndarray, (N,) float32\n   136→        Heat exposure from Step1 (read-only).\n   137→    sorted_exposure_corrode : cupy.ndarray, (N,) float32\n   138→        Corrosion exposure from Step1 (read-only).\n   139→    frame : int\n   140→        Frame counter for RNG seed (gunpowder explosion direction).\n   141→    dead_indices : cupy.ndarray, optional\n   142→        (max_particles,) uint32 freelist array. Dead particle sorted indices\n   143→        are appended here via atomicAdd on dead_count.\n   144→    dead_count : cupy.ndarray, optional\n   145→        (1,) uint32 atomic counter for freelist size.\n   146→    \"\"\"\n   147→    n = sorted_packed_info.shape[0]\n   148→    if n == 0:\n   149→        return\n   150→\n   151→    module = _get_module()\n   152→    kernel = module.get_function(\"K_Reactions\")  # type: ignore[union-attr]\n   153→\n   154→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   155→    block = (BLOCK_SIZE,)\n   156→\n   157→    # Pass null (0) pointers when freelist not provided\n   158→    d_dead_indices = dead_indices if dead_indices is not None else np.intp(0)\n   159→    d_dead_count = dead_count if dead_count is not None else np.intp(0)\n   160→\n   161→    kernel(\n   162→        grid,\n   163→        block,\n   164→        (\n   165→            np.uint32(n),\n   166→            np.uint32(frame),\n   167→            sorted_packed_info,\n   168→            sorted_temperature,\n   169→            sorted_health,\n   170→            sorted_lifetime,\n   171→            sorted_velocity,\n   172→            sorted_exposure_heat,\n   173→            sorted_exposure_corrode,\n   174→            d_dead_indices,\n   175→            d_dead_count,\n   176→        ),\n   177→    )\n   178→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_016myLLq9AYQ6ECjeFvfw5cw","session_id":"d557a6a8-dde9-41cf-ab3a-fa6ac2ce30b6","uuid":"40440f7c-f817-40be-b73d-4002f069d57d"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BBbG8rR97jVXdkdZdTtELo","type":"tool_result","content":"     1→\"\"\"Step1 kernel: SPH density summation + strain-rate tensor + heat diffusion\n     2→+ exposure accumulation.\n     3→\n     4→Compiles physics/kernels/step1.cu via CuPy RawModule and provides\n     5→a function to launch K_Step1 which computes per-particle density\n     6→from the sorted particle positions and masses using neighbor iteration.\n     7→\n     8→Additionally computes heat diffusion dTdt via SPH Laplacian of temperature:\n     9→  dTdt = kappa_i * viscosity_lap_coeff * sum_j (m_j/rho_j) * (T_j - T_i) * (h - |r|)\n    10→\n    11→Exposure accumulation via c_interactions table lookup (no branching):\n    12→  exposure_corrode_i += c_interactions[mat_i][mat_j].reaction_rate * W_poly6(r_sq, h_sq)\n    13→  exposure_heat_i += c_interactions[mat_i][mat_j].heat_exchange * max(T_j - T_i, 0) * W_poly6\n    14→\n    15→For GRANULAR particles, computes the symmetric strain-rate tensor D from\n    16→SPH velocity gradient (spiky kernel) and writes the second invariant\n    17→gamma_dot = sqrt(2 * D:D) to the shear_rate output array.\n    18→Non-GRANULAR particles get shear_rate = 0.\n    19→\n    20→Density formula\n    21→---------------\n    22→density_sum += m_j * (h^2 - |r_ij|^2)^3   for all neighbors j within h\n    23→density_i = max(1.0, poly6_coeff * density_sum)\n    24→\n    25→Self-interaction is included (particle i contributes to its own density).\n    26→Per-particle mass m_j supports multi-material and mass splitting.\n    27→\"\"\"\n    28→\n    29→from __future__ import annotations\n    30→\n    31→import math\n    32→import os\n    33→from typing import Optional\n    34→\n    35→import cupy\n    36→import numpy as np\n    37→\n    38→# ---------------------------------------------------------------------------\n    39→# Numpy dtypes matching constant memory structs in common.cuh\n    40→# ---------------------------------------------------------------------------\n    41→\n    42→# SimParams -- matches struct SimParams in common.cuh\n    43→# struct SimParams {\n    44→#     float  smoothing_length;     //  4 bytes\n    45→#     float  smoothing_length_sq;  //  4 bytes\n    46→#     float  particle_mass;        //  4 bytes\n    47→#     float  particle_spacing;     //  4 bytes\n    48→#     float3 gravity;              // 12 bytes\n    49→#     float  dt;                   //  4 bytes\n    50→#     float  restitution;          //  4 bytes\n    51→#     float  wall_friction;        //  4 bytes\n    52→#     float3 world_min;            // 12 bytes\n    53→#     float3 world_max;            // 12 bytes\n    54→# };                               // Total: 64 bytes\n    55→SIM_PARAMS_DTYPE = np.dtype(\n    56→    [\n    57→        (\"smoothing_length\", np.float32),\n    58→        (\"smoothing_length_sq\", np.float32),\n    59→        (\"particle_mass\", np.float32),\n    60→        (\"particle_spacing\", np.float32),\n    61→        (\"gravity\", np.float32, (3,)),\n    62→        (\"dt\", np.float32),\n    63→        (\"restitution\", np.float32),\n    64→        (\"wall_friction\", np.float32),\n    65→        (\"world_min\", np.float32, (3,)),\n    66→        (\"world_max\", np.float32, (3,)),\n    67→    ],\n    68→    align=False,\n    69→)\n    70→\n    71→# PrecalcParams -- matches struct PrecalcParams in common.cuh\n    72→# struct PrecalcParams {\n    73→#     float poly6_coeff;           //  4 bytes\n    74→#     float spiky_grad_coeff;      //  4 bytes\n    75→#     float viscosity_lap_coeff;   //  4 bytes\n    76→#     float pressure_precalc;      //  4 bytes\n    77→#     float viscosity_precalc;     //  4 bytes\n    78→# };                               // Total: 20 bytes\n    79→PRECALC_PARAMS_DTYPE = np.dtype(\n    80→    [\n    81→        (\"poly6_coeff\", np.float32),\n    82→        (\"spiky_grad_coeff\", np.float32),\n    83→        (\"viscosity_lap_coeff\", np.float32),\n    84→        (\"pressure_precalc\", np.float32),\n    85→        (\"viscosity_precalc\", np.float32),\n    86→    ],\n    87→    align=False,\n    88→)\n    89→\n    90→\n    91→def build_sim_params(\n    92→    smoothing_length: float = 0.04,\n    93→    particle_mass: float = 0.008,\n    94→    particle_spacing: float = 0.02,\n    95→    gravity: tuple = (0.0, -9.8, 0.0),\n    96→    dt: float = 0.001,\n    97→    restitution: float = 0.3,\n    98→    wall_friction: float = 0.5,\n    99→    world_min: tuple = (-1.0, -1.0, -1.0),\n   100→    world_max: tuple = (1.0, 1.0, 1.0),\n   101→) -> np.ndarray:\n   102→    \"\"\"Build a single SimParams struct as a numpy structured array.\"\"\"\n   103→    params = np.zeros(1, dtype=SIM_PARAMS_DTYPE)\n   104→    params[0][\"smoothing_length\"] = smoothing_length\n   105→    params[0][\"smoothing_length_sq\"] = smoothing_length * smoothing_length\n   106→    params[0][\"particle_mass\"] = particle_mass\n   107→    params[0][\"particle_spacing\"] = particle_spacing\n   108→    params[0][\"gravity\"] = gravity\n   109→    params[0][\"dt\"] = dt\n   110→    params[0][\"restitution\"] = restitution\n   111→    params[0][\"wall_friction\"] = wall_friction\n   112→    params[0][\"world_min\"] = world_min\n   113→    params[0][\"world_max\"] = world_max\n   114→    return params\n   115→\n   116→\n   117→def build_precalc_params(\n   118→    smoothing_length: float = 0.04,\n   119→    viscosity: float = 0.001,\n   120→) -> np.ndarray:\n   121→    \"\"\"Build PrecalcParams from smoothing length.\n   122→\n   123→    Parameters\n   124→    ----------\n   125→    smoothing_length : float\n   126→        SPH smoothing length h.\n   127→    viscosity : float\n   128→        Base viscosity mu (Pa*s).\n   129→    \"\"\"\n   130→    h = smoothing_length\n   131→    params = np.zeros(1, dtype=PRECALC_PARAMS_DTYPE)\n   132→    params[0][\"poly6_coeff\"] = np.float32(315.0 / (64.0 * math.pi * h**9))\n   133→    params[0][\"spiky_grad_coeff\"] = np.float32(-45.0 / (math.pi * h**6))\n   134→    params[0][\"viscosity_lap_coeff\"] = np.float32(45.0 / (math.pi * h**6))\n   135→    params[0][\"pressure_precalc\"] = np.float32(45.0 / (math.pi * h**6))\n   136→    params[0][\"viscosity_precalc\"] = np.float32(viscosity * 45.0 / (math.pi * h**6))\n   137→    return params\n   138→\n   139→\n   140→# ---------------------------------------------------------------------------\n   141→# CuPy RawModule compilation\n   142→# ---------------------------------------------------------------------------\n   143→\n   144→_module: Optional[object] = None\n   145→\n   146→\n   147→def _ensure_ptx_if_needed() -> None:\n   148→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n   149→    from cupy.cuda import compiler as _compiler\n   150→    from cupy.cuda import device as _device\n   151→\n   152→    gpu_cc = _device.Device().compute_capability\n   153→    nvrtc_max = _compiler._get_max_compute_capability()\n   154→    if int(gpu_cc) > int(nvrtc_max):\n   155→        _compiler._use_ptx = True\n   156→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n   157→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n   158→        if hasattr(_compiler._get_arch, \"_cache\"):\n   159→            _compiler._get_arch._cache = {}\n   160→\n   161→\n   162→def _get_module() -> \"object\":\n   163→    \"\"\"Compile (or return cached) CuPy RawModule from step1.cu.\"\"\"\n   164→    global _module\n   165→    if _module is not None:\n   166→        return _module\n   167→\n   168→    _ensure_ptx_if_needed()\n   169→\n   170→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   171→    cu_path = os.path.join(kernel_dir, \"step1.cu\")\n   172→    with open(cu_path) as f:\n   173→        source = f.read()\n   174→\n   175→    _module = cupy.RawModule(\n   176→        code=source,\n   177→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n   178→    )\n   179→    return _module\n   180→\n   181→\n   182→def get_module() -> \"object\":\n   183→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n   184→    return _get_module()\n   185→\n   186→\n   187→# ---------------------------------------------------------------------------\n   188→# Constant memory upload\n   189→# ---------------------------------------------------------------------------\n   190→\n   191→\n   192→def upload_grid_params(params: np.ndarray) -> None:\n   193→    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\"\"\"\n   194→    module = _get_module()\n   195→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n   196→    cupy.cuda.runtime.memcpy(\n   197→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   198→    )\n   199→\n   200→\n   201→def upload_sim_params(params: Optional[np.ndarray] = None) -> None:\n   202→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n   203→    if params is None:\n   204→        params = build_sim_params()\n   205→    module = _get_module()\n   206→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n   207→    cupy.cuda.runtime.memcpy(\n   208→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   209→    )\n   210→\n   211→\n   212→def upload_precalc_params(params: Optional[np.ndarray] = None) -> None:\n   213→    \"\"\"Upload PrecalcParams to ``__constant__ PrecalcParams c_precalc``.\"\"\"\n   214→    if params is None:\n   215→        params = build_precalc_params()\n   216→    module = _get_module()\n   217→    d_ptr = module.get_global(\"c_precalc\")  # type: ignore[union-attr]\n   218→    cupy.cuda.runtime.memcpy(\n   219→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   220→    )\n   221→\n   222→\n   223→def upload_materials(materials_data: np.ndarray) -> None:\n   224→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n   225→    module = _get_module()\n   226→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n   227→    cupy.cuda.runtime.memcpy(\n   228→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n   229→    )\n   230→\n   231→\n   232→def upload_interactions(interactions_data: np.ndarray) -> None:\n   233→    \"\"\"Upload Interaction[32][32] to ``__constant__ Interaction c_interactions[32][32]``.\"\"\"\n   234→    module = _get_module()\n   235→    d_ptr = module.get_global(\"c_interactions\")  # type: ignore[union-attr]\n   236→    cupy.cuda.runtime.memcpy(\n   237→        int(d_ptr), interactions_data.ctypes.data, interactions_data.nbytes, 1\n   238→    )\n   239→\n   240→\n   241→# ---------------------------------------------------------------------------\n   242→# Kernel launch\n   243→# ---------------------------------------------------------------------------\n   244→\n   245→BLOCK_SIZE = 128\n   246→\n   247→\n   248→def compute_step1(\n   249→    position: cupy.ndarray,\n   250→    velocity: cupy.ndarray,\n   251→    mass: cupy.ndarray,\n   252→    density_in: Optional[cupy.ndarray],\n   253→    packed_info: cupy.ndarray,\n   254→    temperature_in: cupy.ndarray,\n   255→    cell_start: cupy.ndarray,\n   256→    cell_end: cupy.ndarray,\n   257→    density_out: Optional[cupy.ndarray] = None,\n   258→    shear_rate_out: Optional[cupy.ndarray] = None,\n   259→    dTdt_out: Optional[cupy.ndarray] = None,\n   260→    exposure_heat_out: Optional[cupy.ndarray] = None,\n   261→    exposure_corrode_out: Optional[cupy.ndarray] = None,\n   262→) -> tuple:\n   263→    \"\"\"Launch K_Step1 and return (density, shear_rate, dTdt, exposure_heat, exposure_corrode).\n   264→\n   265→    Parameters\n   266→    ----------\n   267→    position : cupy.ndarray, (N, 4) float32\n   268→        Sorted particle positions.\n   269→    velocity : cupy.ndarray, (N, 4) float32\n   270→        Sorted particle velocities (used for strain-rate computation).\n   271→    mass : cupy.ndarray, (N,) float32\n   272→        Sorted per-particle masses.\n   273→    density_in : cupy.ndarray or None, (N,) float32\n   274→        Density from previous step for m_j/rho_j weighting in strain-rate\n   275→        and heat diffusion. Pass None on first frame (kernel uses rho0=1000 fallback).\n   276→    packed_info : cupy.ndarray, (N,) uint32\n   277→        Sorted packed_info for behavior class and material ID.\n   278→    temperature_in : cupy.ndarray, (N,) float32\n   279→        Sorted temperature per particle (for heat diffusion).\n   280→    cell_start : cupy.ndarray, (num_cells,) uint32\n   281→        Grid cell start indices (0xFFFFFFFF for empty).\n   282→    cell_end : cupy.ndarray, (num_cells,) uint32\n   283→        Grid cell end indices.\n   284→    density_out : cupy.ndarray, optional\n   285→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   286→    shear_rate_out : cupy.ndarray, optional\n   287→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   288→    dTdt_out : cupy.ndarray, optional\n   289→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   290→    exposure_heat_out : cupy.ndarray, optional\n   291→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   292→    exposure_corrode_out : cupy.ndarray, optional\n   293→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   294→\n   295→    Returns\n   296→    -------\n   297→    (density, shear_rate, dTdt, exposure_heat, exposure_corrode) : tuple of cupy.ndarray\n   298→        density: Per-particle density (clamped >= 1.0).\n   299→        shear_rate: Per-particle gamma_dot (0 for non-GRANULAR).\n   300→        dTdt: Per-particle temperature rate of change from heat diffusion.\n   301→        exposure_heat: Per-particle heat exposure from interaction table.\n   302→        exposure_corrode: Per-particle corrosion exposure from interaction table.\n   303→    \"\"\"\n   304→    n = position.shape[0]\n   305→    if density_out is None:\n   306→        density_out = cupy.empty(n, dtype=cupy.float32)\n   307→    if shear_rate_out is None:\n   308→        shear_rate_out = cupy.empty(n, dtype=cupy.float32)\n   309→    if dTdt_out is None:\n   310→        dTdt_out = cupy.empty(n, dtype=cupy.float32)\n   311→    if exposure_heat_out is None:\n   312→        exposure_heat_out = cupy.empty(n, dtype=cupy.float32)\n   313→    if exposure_corrode_out is None:\n   314→        exposure_corrode_out = cupy.empty(n, dtype=cupy.float32)\n   315→\n   316→    # density_in can be None (first frame) -- pass null pointer\n   317→    density_in_ptr = density_in if density_in is not None else cupy.ndarray(0, dtype=cupy.float32)\n   318→\n   319→    module = _get_module()\n   320→    kernel = module.get_function(\"K_Step1\")  # type: ignore[union-attr]\n   321→\n   322→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   323→    block = (BLOCK_SIZE,)\n   324→\n   325→    kernel(\n   326→        grid,\n   327→        block,\n   328→        (\n   329→            np.uint32(n),\n   330→            position,\n   331→            velocity,\n   332→            mass,\n   333→            density_in_ptr,\n   334→            packed_info,\n   335→            temperature_in,\n   336→            cell_start,\n   337→            cell_end,\n   338→            density_out,\n   339→            shear_rate_out,\n   340→            dTdt_out,\n   341→            exposure_heat_out,\n   342→            exposure_corrode_out,\n   343→        ),\n   344→    )\n   345→\n   346→    return density_out, shear_rate_out, dTdt_out, exposure_heat_out, exposure_corrode_out\n   347→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_016myLLq9AYQ6ECjeFvfw5cw","session_id":"d557a6a8-dde9-41cf-ab3a-fa6ac2ce30b6","uuid":"32f6aab5-e868-4259-ae67-e8b7a8cb13c1"}

{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W5VRg6i3JrgHyuUddmZvMn","type":"tool_result","content":"     1→\"\"\"Grid hashing kernel for spatial partitioning of SPH particles.\n     2→\n     3→Compiles physics/kernels/hash_sort.cu via CuPy RawModule and provides\n     4→functions to upload GridParams to ``__constant__ GridParams c_grid`` and\n     5→launch the ``K_CalcHash`` kernel.\n     6→\n     7→Grid sizing (from acceptance criteria)\n     8→--------------------------------------\n     9→- grid_min = (-1, -1, -1), grid_max = (1, 1, 1)\n    10→- cell_size = h = 0.04\n    11→- grid_res  = 50 per axis\n    12→- grid_delta = (25, 25, 25)   (= grid_res / grid_size = 50/2)\n    13→- num_cells  = 125000          (= 50^3)\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import os\n    19→from typing import Optional, Tuple\n    20→\n    21→import cupy\n    22→import numpy as np\n    23→\n    24→# ---------------------------------------------------------------------------\n    25→# Grid constants\n    26→# ---------------------------------------------------------------------------\n    27→\n    28→GRID_MIN = np.array([-1.0, -1.0, -1.0], dtype=np.float32)\n    29→GRID_MAX = np.array([1.0, 1.0, 1.0], dtype=np.float32)\n    30→CELL_SIZE = np.float32(0.04)\n    31→GRID_RES = np.array([50, 50, 50], dtype=np.int32)\n    32→GRID_DELTA = np.array([25.0, 25.0, 25.0], dtype=np.float32)  # grid_res / grid_size\n    33→NUM_CELLS = 125_000  # 50 * 50 * 50\n    34→\n    35→# ---------------------------------------------------------------------------\n    36→# Numpy dtype matching ``struct GridParams`` in common.cuh\n    37→#\n    38→# struct GridParams {\n    39→#     float3 grid_min;    // 12 bytes\n    40→#     float3 grid_max;    // 12 bytes\n    41→#     int3   grid_res;    // 12 bytes\n    42→#     float3 grid_delta;  // 12 bytes\n    43→#     int    num_cells;   //  4 bytes\n    44→# };                      // Total: 52 bytes\n    45→#\n    46→# CUDA float3/int3 are 12 bytes with no trailing pad. align=False required.\n    47→# ---------------------------------------------------------------------------\n    48→\n    49→GRID_PARAMS_DTYPE = np.dtype(\n    50→    [\n    51→        (\"grid_min\", np.float32, (3,)),\n    52→        (\"grid_max\", np.float32, (3,)),\n    53→        (\"grid_res\", np.int32, (3,)),\n    54→        (\"grid_delta\", np.float32, (3,)),\n    55→        (\"num_cells\", np.int32),\n    56→    ],\n    57→    align=False,\n    58→)\n    59→\n    60→assert GRID_PARAMS_DTYPE.itemsize == 52, (\n    61→    f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 52\"\n    62→)\n    63→\n    64→\n    65→def build_grid_params() -> np.ndarray:\n    66→    \"\"\"Build a single GridParams struct as a numpy structured array.\"\"\"\n    67→    params = np.zeros(1, dtype=GRID_PARAMS_DTYPE)\n    68→    params[0][\"grid_min\"] = GRID_MIN\n    69→    params[0][\"grid_max\"] = GRID_MAX\n    70→    params[0][\"grid_res\"] = GRID_RES\n    71→    params[0][\"grid_delta\"] = GRID_DELTA\n    72→    params[0][\"num_cells\"] = NUM_CELLS\n    73→    return params\n    74→\n    75→\n    76→# ---------------------------------------------------------------------------\n    77→# CuPy RawModule compilation\n    78→# ---------------------------------------------------------------------------\n    79→\n    80→_module: Optional[object] = None\n    81→\n    82→\n    83→def _ensure_ptx_if_needed() -> None:\n    84→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    85→    from cupy.cuda import compiler as _compiler\n    86→    from cupy.cuda import device as _device\n    87→\n    88→    gpu_cc = _device.Device().compute_capability\n    89→    nvrtc_max = _compiler._get_max_compute_capability()\n    90→    if int(gpu_cc) > int(nvrtc_max):\n    91→        _compiler._use_ptx = True\n    92→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    93→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    94→        if hasattr(_compiler._get_arch, \"_cache\"):\n    95→            _compiler._get_arch._cache = {}\n    96→\n    97→\n    98→def _get_module() -> \"object\":\n    99→    \"\"\"Compile (or return cached) CuPy RawModule from hash_sort.cu.\"\"\"\n   100→    global _module\n   101→    if _module is not None:\n   102→        return _module\n   103→\n   104→    _ensure_ptx_if_needed()\n   105→\n   106→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   107→    cu_path = os.path.join(kernel_dir, \"hash_sort.cu\")\n   108→    with open(cu_path) as f:\n   109→        source = f.read()\n   110→\n   111→    _module = cupy.RawModule(\n   112→        code=source,\n   113→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n   114→    )\n   115→    return _module\n   116→\n   117→\n   118→def get_module() -> \"object\":\n   119→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n   120→    return _get_module()\n   121→\n   122→\n   123→# ---------------------------------------------------------------------------\n   124→# Constant memory upload\n   125→# ---------------------------------------------------------------------------\n   126→\n   127→\n   128→def upload_grid_params(params: Optional[np.ndarray] = None) -> None:\n   129→    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\n   130→\n   131→    Parameters\n   132→    ----------\n   133→    params : numpy structured array, optional\n   134→        A single GridParams element.  If *None*, uses ``build_grid_params()``.\n   135→    \"\"\"\n   136→    if params is None:\n   137→        params = build_grid_params()\n   138→\n   139→    module = _get_module()\n   140→    d_ptr = module.get_global(\"c_grid\")\n   141→\n   142→    cupy.cuda.runtime.memcpy(\n   143→        int(d_ptr),\n   144→        params.ctypes.data,\n   145→        params.nbytes,\n   146→        1,  # cudaMemcpyHostToDevice\n   147→    )\n   148→\n   149→\n   150→# ---------------------------------------------------------------------------\n   151→# Kernel launch\n   152→# ---------------------------------------------------------------------------\n   153→\n   154→BLOCK_SIZE = 256\n   155→\n   156→\n   157→def calc_hash(\n   158→    positions: cupy.ndarray,\n   159→) -> Tuple[cupy.ndarray, cupy.ndarray]:\n   160→    \"\"\"Launch K_CalcHash and return (hashes, indices) arrays.\n   161→\n   162→    Parameters\n   163→    ----------\n   164→    positions : cupy.ndarray\n   165→        (N, 4) float32 array of particle positions (x, y, z, w).\n   166→\n   167→    Returns\n   168→    -------\n   169→    hashes : cupy.ndarray, shape (N,), dtype uint32\n   170→    indices : cupy.ndarray, shape (N,), dtype uint32\n   171→    \"\"\"\n   172→    n = positions.shape[0]\n   173→    hashes = cupy.empty(n, dtype=cupy.uint32)\n   174→    indices = cupy.empty(n, dtype=cupy.uint32)\n   175→\n   176→    module = _get_module()\n   177→    kernel = module.get_function(\"K_CalcHash\")\n   178→\n   179→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   180→    block = (BLOCK_SIZE,)\n   181→\n   182→    kernel(grid, block, (np.uint32(n), positions, hashes, indices))\n   183→\n   184→    return hashes, indices\n   185→\n   186→\n   187→# ---------------------------------------------------------------------------\n   188→# Sort by hash\n   189→# ---------------------------------------------------------------------------\n   190→\n   191→\n   192→def sort_by_hash(\n   193→    hashes: cupy.ndarray,\n   194→    indices: cupy.ndarray,\n   195→    sorted_hashes_out: Optional[cupy.ndarray] = None,\n   196→    sorted_indices_out: Optional[cupy.ndarray] = None,\n   197→) -> Tuple[cupy.ndarray, cupy.ndarray]:\n   198→    \"\"\"Sort particles by grid hash using CuPy argsort (Thrust radix sort).\n   199→\n   200→    Parameters\n   201→    ----------\n   202→    hashes : cupy.ndarray, shape (N,), dtype uint32\n   203→        Per-particle grid hash values from ``calc_hash()``.\n   204→    indices : cupy.ndarray, shape (N,), dtype uint32\n   205→        Per-particle original indices (0..N-1) from ``calc_hash()``.\n   206→    sorted_hashes_out : cupy.ndarray, optional\n   207→        Pre-allocated output buffer for sorted hashes.  If *None*, allocates.\n   208→    sorted_indices_out : cupy.ndarray, optional\n   209→        Pre-allocated output buffer for sorted original indices.  If *None*,\n   210→        allocates.\n   211→\n   212→    Returns\n   213→    -------\n   214→    sorted_hashes : cupy.ndarray, shape (N,), dtype uint32\n   215→        Hash values in non-decreasing order.\n   216→    sorted_indices : cupy.ndarray, shape (N,), dtype uint32\n   217→        Original particle indices reordered by hash (sorted->original map).\n   218→    \"\"\"\n   219→    n = hashes.shape[0]\n   220→\n   221→    # cupy.argsort uses Thrust radix sort internally for integer dtypes\n   222→    sort_perm = cupy.argsort(hashes)\n   223→\n   224→    # Gather into output buffers\n   225→    if sorted_hashes_out is not None:\n   226→        sorted_hashes_out[:n] = hashes[sort_perm]\n   227→        sorted_hashes = sorted_hashes_out[:n]\n   228→    else:\n   229→        sorted_hashes = hashes[sort_perm]\n   230→\n   231→    if sorted_indices_out is not None:\n   232→        sorted_indices_out[:n] = indices[sort_perm]\n   233→        sorted_indices = sorted_indices_out[:n]\n   234→    else:\n   235→        sorted_indices = indices[sort_perm]\n   236→\n   237→    return sorted_hashes, sorted_indices\n   238→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"20e7fc32-9409-45e1-9ca1-0f98b4ecc786","uuid":"bb1eda1a-28b7-4a0f-90c2-5e07bbb1edb5","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/hash_sort.py","content":"\"\"\"Grid hashing kernel for spatial partitioning of SPH particles.\n\nCompiles physics/kernels/hash_sort.cu via CuPy RawModule and provides\nfunctions to upload GridParams to ``__constant__ GridParams c_grid`` and\nlaunch the ``K_CalcHash`` kernel.\n\nGrid sizing (from acceptance criteria)\n--------------------------------------\n- grid_min = (-1, -1, -1), grid_max = (1, 1, 1)\n- cell_size = h = 0.04\n- grid_res  = 50 per axis\n- grid_delta = (25, 25, 25)   (= grid_res / grid_size = 50/2)\n- num_cells  = 125000          (= 50^3)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom typing import Optional, Tuple\n\nimport cupy\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# Grid constants\n# ---------------------------------------------------------------------------\n\nGRID_MIN = np.array([-1.0, -1.0, -1.0], dtype=np.float32)\nGRID_MAX = np.array([1.0, 1.0, 1.0], dtype=np.float32)\nCELL_SIZE = np.float32(0.04)\nGRID_RES = np.array([50, 50, 50], dtype=np.int32)\nGRID_DELTA = np.array([25.0, 25.0, 25.0], dtype=np.float32)  # grid_res / grid_size\nNUM_CELLS = 125_000  # 50 * 50 * 50\n\n# ---------------------------------------------------------------------------\n# Numpy dtype matching ``struct GridParams`` in common.cuh\n#\n# struct GridParams {\n#     float3 grid_min;    // 12 bytes\n#     float3 grid_max;    // 12 bytes\n#     int3   grid_res;    // 12 bytes\n#     float3 grid_delta;  // 12 bytes\n#     int    num_cells;   //  4 bytes\n# };                      // Total: 52 bytes\n#\n# CUDA float3/int3 are 12 bytes with no trailing pad. align=False required.\n# ---------------------------------------------------------------------------\n\nGRID_PARAMS_DTYPE = np.dtype(\n    [\n        (\"grid_min\", np.float32, (3,)),\n        (\"grid_max\", np.float32, (3,)),\n        (\"grid_res\", np.int32, (3,)),\n        (\"grid_delta\", np.float32, (3,)),\n        (\"num_cells\", np.int32),\n    ],\n    align=False,\n)\n\nassert GRID_PARAMS_DTYPE.itemsize == 52, (\n    f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 52\"\n)\n\n\ndef build_grid_params() -> np.ndarray:\n    \"\"\"Build a single GridParams struct as a numpy structured array.\"\"\"\n    params = np.zeros(1, dtype=GRID_PARAMS_DTYPE)\n    params[0][\"grid_min\"] = GRID_MIN\n    params[0][\"grid_max\"] = GRID_MAX\n    params[0][\"grid_res\"] = GRID_RES\n    params[0][\"grid_delta\"] = GRID_DELTA\n    params[0][\"num_cells\"] = NUM_CELLS\n    return params\n\n\n# ---------------------------------------------------------------------------\n# CuPy RawModule compilation\n# ---------------------------------------------------------------------------\n\n_module: Optional[object] = None\n\n\ndef _ensure_ptx_if_needed() -> None:\n    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    from cupy.cuda import compiler as _compiler\n    from cupy.cuda import device as _device\n\n    gpu_cc = _device.Device().compute_capability\n    nvrtc_max = _compiler._get_max_compute_capability()\n    if int(gpu_cc) > int(nvrtc_max):\n        _compiler._use_ptx = True\n        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n        if hasattr(_compiler._get_arch, \"_cache\"):\n            _compiler._get_arch._cache = {}\n\n\ndef _get_module() -> \"object\":\n    \"\"\"Compile (or return cached) CuPy RawModule from hash_sort.cu.\"\"\"\n    global _module\n    if _module is not None:\n        return _module\n\n    _ensure_ptx_if_needed()\n\n    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    cu_path = os.path.join(kernel_dir, \"hash_sort.cu\")\n    with open(cu_path) as f:\n        source = f.read()\n\n    _module = cupy.RawModule(\n        code=source,\n        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    )\n    return _module\n\n\ndef get_module() -> \"object\":\n    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    return _get_module()\n\n\n# ---------------------------------------------------------------------------\n# Constant memory upload\n# ---------------------------------------------------------------------------\n\n\ndef upload_grid_params(params: Optional[np.ndarray] = None) -> None:\n    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\n\n    Parameters\n    ----------\n    params : numpy structured array, optional\n        A single GridParams element.  If *None*, uses ``build_grid_params()``.\n    \"\"\"\n    if params is None:\n        params = build_grid_params()\n\n    module = _get_module()\n    d_ptr = module.get_global(\"c_grid\")\n\n    cupy.cuda.runtime.memcpy(\n        int(d_ptr),\n        params.ctypes.data,\n        params.nbytes,\n        1,  # cudaMemcpyHostToDevice\n    )\n\n\n# ---------------------------------------------------------------------------\n# Kernel launch\n# ---------------------------------------------------------------------------\n\nBLOCK_SIZE = 256\n\n\ndef calc_hash(\n    positions: cupy.ndarray,\n) -> Tuple[cupy.ndarray, cupy.ndarray]:\n    \"\"\"Launch K_CalcHash and return (hashes, indices) arrays.\n\n    Parameters\n    ----------\n    positions : cupy.ndarray\n        (N, 4) float32 array of particle positions (x, y, z, w).\n\n    Returns\n    -------\n    hashes : cupy.ndarray, shape (N,), dtype uint32\n    indices : cupy.ndarray, shape (N,), dtype uint32\n    \"\"\"\n    n = positions.shape[0]\n    hashes = cupy.empty(n, dtype=cupy.uint32)\n    indices = cupy.empty(n, dtype=cupy.uint32)\n\n    module = _get_module()\n    kernel = module.get_function(\"K_CalcHash\")\n\n    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n    block = (BLOCK_SIZE,)\n\n    kernel(grid, block, (np.uint32(n), positions, hashes, indices))\n\n    return hashes, indices\n\n\n# ---------------------------------------------------------------------------\n# Sort by hash\n# ---------------------------------------------------------------------------\n\n\ndef sort_by_hash(\n    hashes: cupy.ndarray,\n    indices: cupy.ndarray,\n    sorted_hashes_out: Optional[cupy.ndarray] = None,\n    sorted_indices_out: Optional[cupy.ndarray] = None,\n) -> Tuple[cupy.ndarray, cupy.ndarray]:\n    \"\"\"Sort particles by grid hash using CuPy argsort (Thrust radix sort).\n\n    Parameters\n    ----------\n    hashes : cupy.ndarray, shape (N,), dtype uint32\n        Per-particle grid hash values from ``calc_hash()``.\n    indices : cupy.ndarray, shape (N,), dtype uint32\n        Per-particle original indices (0..N-1) from ``calc_hash()``.\n    sorted_hashes_out : cupy.ndarray, optional\n        Pre-allocated output buffer for sorted hashes.  If *None*, allocates.\n    sorted_indices_out : cupy.ndarray, optional\n        Pre-allocated output buffer for sorted original indices.  If *None*,\n        allocates.\n\n    Returns\n    -------\n    sorted_hashes : cupy.ndarray, shape (N,), dtype uint32\n        Hash values in non-decreasing order.\n    sorted_indices : cupy.ndarray, shape (N,), dtype uint32\n        Original particle indices reordered by hash (sorted->original map).\n    \"\"\"\n    n = hashes.shape[0]\n\n    # cupy.argsort uses Thrust radix sort internally for integer dtypes\n    sort_perm = cupy.argsort(hashes)\n\n    # Gather into output buffers\n    if sorted_hashes_out is not None:\n        sorted_hashes_out[:n] = hashes[sort_perm]\n        sorted_hashes = sorted_hashes_out[:n]\n    else:\n        sorted_hashes = hashes[sort_perm]\n\n    if sorted_indices_out is not None:\n        sorted_indices_out[:n] = indices[sort_perm]\n        sorted_indices = sorted_indices_out[:n]\n    else:\n        sorted_indices = indices[sort_perm]\n\n    return sorted_hashes, sorted_indices\n","numLines":238,"startLine":1,"totalLines":238}}}

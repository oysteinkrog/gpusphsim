{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kg8EaVrieFnEuJ3XRRR7yG","type":"tool_result","content":"     1→\"\"\"Falling Sand 3D - Main entry point with GLFW window and orbit camera.\"\"\"\n     2→\n     3→import time\n     4→import glfw\n     5→import numpy as np\n     6→from OpenGL.GL import (\n     7→    glClearColor, glClear, glGetString, glGetError, glViewport,\n     8→    GL_COLOR_BUFFER_BIT, GL_DEPTH_BUFFER_BIT,\n     9→    GL_VERSION, GL_RENDERER, GL_NO_ERROR,\n    10→)\n    11→from camera import OrbitCamera\n    12→from renderer import Renderer\n    13→\n    14→WINDOW_WIDTH = 1280\n    15→WINDOW_HEIGHT = 720\n    16→WINDOW_TITLE = \"Falling Sand 3D\"\n    17→NUM_PARTICLES = 500_000\n    18→\n    19→\n    20→def _apply_ptx_workaround():\n    21→    \"\"\"Force CuPy to emit PTX instead of cubin for forward-compat with newer GPUs.\"\"\"\n    22→    try:\n    23→        import cupy.cuda.compiler as _compiler\n    24→        _compiler._use_ptx = True\n    25→        if hasattr(_compiler._get_arch, '_cache'):\n    26→            _compiler._get_arch._cache = {}\n    27→        if hasattr(_compiler, '_get_arch_for_options_for_nvrtc'):\n    28→            fn = _compiler._get_arch_for_options_for_nvrtc\n    29→            if hasattr(fn, '_cache'):\n    30→                fn._cache = {}\n    31→    except Exception:\n    32→        pass\n    33→\n    34→\n    35→def _fill_particles_dummy(renderer: Renderer):\n    36→    \"\"\"Fill VBOs with 500K particles in a cube with random colors via CuPy.\"\"\"\n    37→    import cupy\n    38→\n    39→    _apply_ptx_workaround()\n    40→\n    41→    n = renderer.num_particles\n    42→\n    43→    # Fill position VBO: random positions in [-0.5, 0.5]^3 cube\n    44→    with renderer.cuda_pos as buf:\n    45→        pos_arr = buf.device_pointer_as_cupy_array((n, 4), np.float32)\n    46→        pos_arr[:, 0] = cupy.random.uniform(-0.5, 0.5, n, dtype=cupy.float32)\n    47→        pos_arr[:, 1] = cupy.random.uniform(-0.5, 0.5, n, dtype=cupy.float32)\n    48→        pos_arr[:, 2] = cupy.random.uniform(-0.5, 0.5, n, dtype=cupy.float32)\n    49→        pos_arr[:, 3] = 1.0\n    50→        cupy.cuda.Device().synchronize()\n    51→\n    52→    # Fill color VBO: random bright colors\n    53→    with renderer.cuda_col as buf:\n    54→        col_arr = buf.device_pointer_as_cupy_array((n, 4), np.float32)\n    55→        col_arr[:, 0] = cupy.random.uniform(0.2, 1.0, n, dtype=cupy.float32)\n    56→        col_arr[:, 1] = cupy.random.uniform(0.2, 1.0, n, dtype=cupy.float32)\n    57→        col_arr[:, 2] = cupy.random.uniform(0.2, 1.0, n, dtype=cupy.float32)\n    58→        col_arr[:, 3] = 1.0\n    59→        cupy.cuda.Device().synchronize()\n    60→\n    61→\n    62→def main():\n    63→    if not glfw.init():\n    64→        raise RuntimeError(\"Failed to initialize GLFW\")\n    65→\n    66→    # Request OpenGL 4.1+ core profile\n    67→    glfw.window_hint(glfw.CONTEXT_VERSION_MAJOR, 4)\n    68→    glfw.window_hint(glfw.CONTEXT_VERSION_MINOR, 1)\n    69→    glfw.window_hint(glfw.OPENGL_PROFILE, glfw.OPENGL_CORE_PROFILE)\n    70→    glfw.window_hint(glfw.OPENGL_FORWARD_COMPAT, glfw.TRUE)\n    71→\n    72→    window = glfw.create_window(WINDOW_WIDTH, WINDOW_HEIGHT, WINDOW_TITLE, None, None)\n    73→    if not window:\n    74→        glfw.terminate()\n    75→        raise RuntimeError(\"Failed to create GLFW window\")\n    76→\n    77→    glfw.make_context_current(window)\n    78→    glfw.swap_interval(0)  # no vsync for FPS measurement\n    79→\n    80→    # Verify OpenGL version\n    81→    gl_version = glGetString(GL_VERSION)\n    82→    gl_renderer = glGetString(GL_RENDERER)\n    83→    if gl_version:\n    84→        print(f\"OpenGL: {gl_version.decode()}\")\n    85→    if gl_renderer:\n    86→        print(f\"Renderer: {gl_renderer.decode()}\")\n    87→\n    88→    # Dark gray background\n    89→    glClearColor(0.15, 0.15, 0.15, 1.0)\n    90→\n    91→    camera = OrbitCamera(distance=2.0, elevation=20.0)\n    92→    camera.set_aspect(WINDOW_WIDTH, WINDOW_HEIGHT)\n    93→\n    94→    # Create renderer and fill with dummy particles\n    95→    renderer = Renderer(NUM_PARTICLES, point_scale=20.0)\n    96→    _fill_particles_dummy(renderer)\n    97→    print(f\"Initialized {NUM_PARTICLES:,} particles\")\n    98→\n    99→    # Input state\n   100→    right_pressed = False\n   101→    middle_pressed = False\n   102→    last_mx, last_my = 0.0, 0.0\n   103→\n   104→    def key_callback(_win, key, _scancode, action, _mods):\n   105→        if key == glfw.KEY_ESCAPE and action == glfw.PRESS:\n   106→            glfw.set_window_should_close(_win, True)\n   107→\n   108→    def mouse_button_callback(_win, button, action, _mods):\n   109→        nonlocal right_pressed, middle_pressed, last_mx, last_my\n   110→        if button == glfw.MOUSE_BUTTON_RIGHT:\n   111→            right_pressed = action == glfw.PRESS\n   112→            if right_pressed:\n   113→                last_mx, last_my = glfw.get_cursor_pos(_win)\n   114→        elif button == glfw.MOUSE_BUTTON_MIDDLE:\n   115→            middle_pressed = action == glfw.PRESS\n   116→            if middle_pressed:\n   117→                last_mx, last_my = glfw.get_cursor_pos(_win)\n   118→\n   119→    def cursor_pos_callback(_win, xpos, ypos):\n   120→        nonlocal last_mx, last_my\n   121→        dx = xpos - last_mx\n   122→        dy = ypos - last_my\n   123→        last_mx, last_my = xpos, ypos\n   124→\n   125→        if right_pressed:\n   126→            camera.orbit(dx, dy)\n   127→        elif middle_pressed:\n   128→            camera.pan(dx, dy)\n   129→\n   130→    def scroll_callback(_win, _xoffset, yoffset):\n   131→        camera.zoom(yoffset)\n   132→\n   133→    def framebuffer_size_callback(_win, width, height):\n   134→        if width > 0 and height > 0:\n   135→            glViewport(0, 0, width, height)\n   136→            camera.set_aspect(width, height)\n   137→\n   138→    glfw.set_key_callback(window, key_callback)\n   139→    glfw.set_mouse_button_callback(window, mouse_button_callback)\n   140→    glfw.set_cursor_pos_callback(window, cursor_pos_callback)\n   141→    glfw.set_scroll_callback(window, scroll_callback)\n   142→    glfw.set_framebuffer_size_callback(window, framebuffer_size_callback)\n   143→\n   144→    # FPS tracking\n   145→    frame_count = 0\n   146→    fps_time = time.perf_counter()\n   147→    fps = 0.0\n   148→\n   149→    while not glfw.window_should_close(window):\n   150→        glfw.poll_events()\n   151→\n   152→        glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)\n   153→\n   154→        view = camera.view_matrix()\n   155→        proj = camera.projection_matrix()\n   156→        renderer.draw(view, proj)\n   157→\n   158→        glfw.swap_buffers(window)\n   159→\n   160→        # FPS counter\n   161→        frame_count += 1\n   162→        now = time.perf_counter()\n   163→        elapsed = now - fps_time\n   164→        if elapsed >= 0.5:\n   165→            fps = frame_count / elapsed\n   166→            frame_count = 0\n   167→            fps_time = now\n   168→            glfw.set_window_title(\n   169→                window,\n   170→                f\"{WINDOW_TITLE} | {NUM_PARTICLES // 1000}K particles | FPS: {fps:.0f}\",\n   171→            )\n   172→\n   173→        # Check GL errors\n   174→        err = glGetError()\n   175→        if err != GL_NO_ERROR:\n   176→            print(f\"GL error: {err}\")\n   177→\n   178→    renderer.close()\n   179→    glfw.destroy_window(window)\n   180→    glfw.terminate()\n   181→\n   182→\n   183→if __name__ == \"__main__\":\n   184→    main()\n   185→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01HNB9ThQmhAKuNXhSk34vjN","session_id":"20e7fc32-9409-45e1-9ca1-0f98b4ecc786","uuid":"2359b927-5758-4831-af5f-3d8b14300686"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XAfJESTKTzhWm1CKCvXr89","type":"tool_result","content":"     1→\"\"\"OpenGL point sprite renderer with CUDA-GL interop VBOs.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import os\n     6→import numpy as np\n     7→from OpenGL.GL import (\n     8→    glCreateShader, glShaderSource, glCompileShader, glGetShaderiv,\n     9→    glGetShaderInfoLog, glCreateProgram, glAttachShader, glLinkProgram,\n    10→    glGetProgramiv, glGetProgramInfoLog, glDeleteShader, glUseProgram,\n    11→    glGetUniformLocation, glUniformMatrix4fv, glUniform1f,\n    12→    glGenVertexArrays, glBindVertexArray, glGenBuffers, glBindBuffer,\n    13→    glBufferData, glEnableVertexAttribArray, glVertexAttribPointer,\n    14→    glDrawArrays, glEnable, glDeleteBuffers, glDeleteVertexArrays,\n    15→    glDeleteProgram, glDepthFunc,\n    16→    GL_VERTEX_SHADER, GL_FRAGMENT_SHADER, GL_COMPILE_STATUS,\n    17→    GL_LINK_STATUS, GL_TRUE, GL_FALSE, GL_ARRAY_BUFFER,\n    18→    GL_DYNAMIC_DRAW, GL_FLOAT, GL_POINTS, GL_PROGRAM_POINT_SIZE,\n    19→    GL_DEPTH_TEST, GL_LESS,\n    20→)\n    21→from OpenGL.GL import shaders as _gl_shaders  # noqa: F401 -- just in case\n    22→\n    23→from gl_cuda_interop import CudaGLBuffer\n    24→\n    25→# Bytes per element\n    26→_FLOAT4_BYTES = 4 * 4  # 16 bytes per float4\n    27→\n    28→\n    29→def _read_shader_source(filename: str) -> str:\n    30→    \"\"\"Read shader source from the shaders/ directory next to this module.\"\"\"\n    31→    shader_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), \"shaders\")\n    32→    path = os.path.join(shader_dir, filename)\n    33→    with open(path, \"r\") as f:\n    34→        return f.read()\n    35→\n    36→\n    37→def _compile_shader(source: str, shader_type: int) -> int:\n    38→    \"\"\"Compile a GLSL shader; raise on error.\"\"\"\n    39→    shader = glCreateShader(shader_type)\n    40→    glShaderSource(shader, source)\n    41→    glCompileShader(shader)\n    42→    if glGetShaderiv(shader, GL_COMPILE_STATUS) != GL_TRUE:\n    43→        log = glGetShaderInfoLog(shader)\n    44→        if isinstance(log, bytes):\n    45→            log = log.decode()\n    46→        raise RuntimeError(f\"Shader compile error:\\n{log}\")\n    47→    return shader\n    48→\n    49→\n    50→def _link_program(vert: int, frag: int) -> int:\n    51→    \"\"\"Link vertex + fragment shaders into a program; raise on error.\"\"\"\n    52→    program = glCreateProgram()\n    53→    glAttachShader(program, vert)\n    54→    glAttachShader(program, frag)\n    55→    glLinkProgram(program)\n    56→    if glGetProgramiv(program, GL_LINK_STATUS) != GL_TRUE:\n    57→        log = glGetProgramInfoLog(program)\n    58→        if isinstance(log, bytes):\n    59→            log = log.decode()\n    60→        raise RuntimeError(f\"Program link error:\\n{log}\")\n    61→    return program\n    62→\n    63→\n    64→class Renderer:\n    65→    \"\"\"Point-sprite renderer backed by two CUDA-GL interop VBOs.\n    66→\n    67→    Parameters\n    68→    ----------\n    69→    num_particles : int\n    70→        Maximum number of particles.\n    71→    point_scale : float\n    72→        Base point size divisor for distance-based sizing.\n    73→    \"\"\"\n    74→\n    75→    def __init__(self, num_particles: int, point_scale: float = 20.0):\n    76→        self.num_particles = num_particles\n    77→        self.num_active = num_particles\n    78→        self.point_scale = point_scale\n    79→\n    80→        # Compile shaders\n    81→        vert_src = _read_shader_source(\"particle.vert\")\n    82→        frag_src = _read_shader_source(\"particle.frag\")\n    83→        vs = _compile_shader(vert_src, GL_VERTEX_SHADER)\n    84→        fs = _compile_shader(frag_src, GL_FRAGMENT_SHADER)\n    85→        self._program = _link_program(vs, fs)\n    86→        glDeleteShader(vs)\n    87→        glDeleteShader(fs)\n    88→\n    89→        # Uniform locations\n    90→        self._u_mvp = glGetUniformLocation(self._program, \"uMVP\")\n    91→        self._u_mv = glGetUniformLocation(self._program, \"uMV\")\n    92→        self._u_point_scale = glGetUniformLocation(self._program, \"uPointScale\")\n    93→\n    94→        # Enable required GL state\n    95→        glEnable(GL_PROGRAM_POINT_SIZE)\n    96→        glEnable(GL_DEPTH_TEST)\n    97→        glDepthFunc(GL_LESS)\n    98→\n    99→        # Create VBOs\n   100→        pos_nbytes = num_particles * _FLOAT4_BYTES\n   101→        col_nbytes = num_particles * _FLOAT4_BYTES\n   102→\n   103→        self._vbo_pos = int(glGenBuffers(1))\n   104→        glBindBuffer(GL_ARRAY_BUFFER, self._vbo_pos)\n   105→        glBufferData(GL_ARRAY_BUFFER, pos_nbytes, None, GL_DYNAMIC_DRAW)\n   106→\n   107→        self._vbo_col = int(glGenBuffers(1))\n   108→        glBindBuffer(GL_ARRAY_BUFFER, self._vbo_col)\n   109→        glBufferData(GL_ARRAY_BUFFER, col_nbytes, None, GL_DYNAMIC_DRAW)\n   110→\n   111→        glBindBuffer(GL_ARRAY_BUFFER, 0)\n   112→\n   113→        # Create VAO\n   114→        self._vao = int(glGenVertexArrays(1))\n   115→        glBindVertexArray(self._vao)\n   116→\n   117→        # Position attribute (location=0): float4\n   118→        glBindBuffer(GL_ARRAY_BUFFER, self._vbo_pos)\n   119→        glEnableVertexAttribArray(0)\n   120→        glVertexAttribPointer(0, 4, GL_FLOAT, GL_FALSE, _FLOAT4_BYTES, None)\n   121→\n   122→        # Color attribute (location=1): float4\n   123→        glBindBuffer(GL_ARRAY_BUFFER, self._vbo_col)\n   124→        glEnableVertexAttribArray(1)\n   125→        glVertexAttribPointer(1, 4, GL_FLOAT, GL_FALSE, _FLOAT4_BYTES, None)\n   126→\n   127→        glBindVertexArray(0)\n   128→        glBindBuffer(GL_ARRAY_BUFFER, 0)\n   129→\n   130→        # Register VBOs with CUDA\n   131→        self.cuda_pos = CudaGLBuffer(self._vbo_pos, pos_nbytes)\n   132→        self.cuda_col = CudaGLBuffer(self._vbo_col, col_nbytes)\n   133→\n   134→    def draw(self, view: np.ndarray, proj: np.ndarray) -> None:\n   135→        \"\"\"Render point sprites.\n   136→\n   137→        Parameters\n   138→        ----------\n   139→        view : np.ndarray\n   140→            4x4 view matrix (float32, row-major as from OrbitCamera).\n   141→        proj : np.ndarray\n   142→            4x4 projection matrix (float32, row-major).\n   143→        \"\"\"\n   144→        mvp = proj @ view\n   145→        mv = view\n   146→\n   147→        glUseProgram(self._program)\n   148→        glUniformMatrix4fv(self._u_mvp, 1, GL_TRUE, mvp)\n   149→        glUniformMatrix4fv(self._u_mv, 1, GL_TRUE, mv)\n   150→        glUniform1f(self._u_point_scale, self.point_scale)\n   151→\n   152→        glBindVertexArray(self._vao)\n   153→        glDrawArrays(GL_POINTS, 0, self.num_active)\n   154→        glBindVertexArray(0)\n   155→        glUseProgram(0)\n   156→\n   157→    def close(self) -> None:\n   158→        \"\"\"Release GPU resources.\"\"\"\n   159→        self.cuda_col.close()\n   160→        self.cuda_pos.close()\n   161→        glDeleteBuffers(2, [self._vbo_pos, self._vbo_col])\n   162→        glDeleteVertexArrays(1, [self._vao])\n   163→        glDeleteProgram(self._program)\n   164→\n   165→    def __del__(self) -> None:\n   166→        try:\n   167→            self.close()\n   168→        except Exception:\n   169→            pass\n   170→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01HNB9ThQmhAKuNXhSk34vjN","session_id":"20e7fc32-9409-45e1-9ca1-0f98b4ecc786","uuid":"788a6be2-a492-43a8-84f4-c763dc283afe"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LSS1JX9G2ZpDnznTFFMV5W","type":"tool_result","content":"     1→\"\"\"World state management for Falling Sand 3D.\n     2→\n     3→Manages CuPy arrays for all per-particle SoA data. Supports configurable\n     4→max_particles at startup, spawning particles in sphere/cube shapes, and\n     5→tracking num_active via counter.\n     6→\n     7→All arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\n     8→DEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→from typing import Tuple\n    14→\n    15→import cupy as cp\n    16→import numpy as np\n    17→\n    18→from materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n    19→\n    20→# packed_info bitfield macros (mirrors common.cuh)\n    21→_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n    22→\n    23→# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\n    24→DEFAULT_SPACING = 0.02\n    25→\n    26→# Default temperatures for hot materials (Kelvin)\n    27→_DEFAULT_TEMPS = {\n    28→    7: 1500.0,   # LAVA\n    29→    14: 1200.0,  # FIRE\n    30→    12: 373.0,   # STEAM\n    31→    13: 500.0,   # SMOKE\n    32→}\n    33→\n    34→# Ambient temperature\n    35→T_AMBIENT = 293.0\n    36→\n    37→\n    38→class World:\n    39→    \"\"\"Manages all per-particle SoA arrays on GPU.\n    40→\n    41→    Parameters\n    42→    ----------\n    43→    max_particles : int\n    44→        Maximum number of particles to allocate for (default 500000).\n    45→    \"\"\"\n    46→\n    47→    def __init__(self, max_particles: int = 500_000) -> None:\n    48→        self.max_particles: int = max_particles\n    49→        self._high_water: int = 0  # one past last allocated slot\n    50→        self._allocate()\n    51→\n    52→    def _allocate(self) -> None:\n    53→        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n    54→        n = self.max_particles\n    55→        # float4 arrays (stored as (n, 4) float32)\n    56→        self.position = cp.zeros((n, 4), dtype=cp.float32)\n    57→        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n    58→        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n    59→        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    60→        self.color = cp.zeros((n, 4), dtype=cp.float32)\n    61→        # float arrays\n    62→        self.density = cp.zeros(n, dtype=cp.float32)\n    63→        self.mass = cp.zeros(n, dtype=cp.float32)\n    64→        self.temperature = cp.zeros(n, dtype=cp.float32)\n    65→        self.health = cp.zeros(n, dtype=cp.float32)\n    66→        self.lifetime = cp.zeros(n, dtype=cp.float32)\n    67→        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n    68→        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n    69→        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    70→        # uint32 arrays\n    71→        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n    72→        # uint8 arrays\n    73→        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    74→\n    75→        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n    76→        # These are the double-buffer targets: after sort+reorder, physics\n    77→        # kernels (Step1/Step2) read from these.  Integrate writes back to\n    78→        # the unsorted arrays above via sort_indexes.\n    79→        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n    80→        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n    81→        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n    82→        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    83→        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n    84→        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n    85→        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n    86→        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n    87→        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n    88→        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n    89→        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n    90→        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n    91→        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    92→        # Sort index arrays (hash + original index, plus sorted versions)\n    93→        self.hashes = cp.zeros(n, dtype=cp.uint32)\n    94→        self.indices = cp.zeros(n, dtype=cp.uint32)\n    95→        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n    96→        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n    97→\n    98→    def resize(self, new_max: int) -> None:\n    99→        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n   100→        self.max_particles = new_max\n   101→        self._high_water = 0\n   102→        self._allocate()\n   103→\n   104→    @property\n   105→    def num_active(self) -> int:\n   106→        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n   107→        if self._high_water == 0:\n   108→            return 0\n   109→        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n   110→\n   111→    def spawn_sphere(\n   112→        self,\n   113→        center: Tuple[float, float, float],\n   114→        radius: float,\n   115→        material_id: int,\n   116→        count: int,\n   117→    ) -> int:\n   118→        \"\"\"Spawn particles with random positions inside a sphere.\n   119→\n   120→        Returns the number of particles actually spawned (may be less than\n   121→        count if max_particles is reached).\n   122→        \"\"\"\n   123→        if material_id not in MATERIALS:\n   124→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   125→\n   126→        available = self.max_particles - self._high_water\n   127→        actual = min(count, available)\n   128→        if actual <= 0:\n   129→            return 0\n   130→\n   131→        mat = MATERIALS[material_id]\n   132→        start = self._high_water\n   133→\n   134→        # Generate random positions in unit sphere using rejection sampling on GPU\n   135→        # Over-generate by ~2x to account for rejection, then take first `actual`\n   136→        needed = actual\n   137→        positions_list = []\n   138→        remaining = needed\n   139→        while remaining > 0:\n   140→            batch = int(remaining * 2.0) + 128\n   141→            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n   142→            r_sq = cp.sum(pts * pts, axis=1)\n   143→            inside = pts[r_sq <= 1.0]\n   144→            take = min(len(inside), remaining)\n   145→            if take > 0:\n   146→                positions_list.append(inside[:take])\n   147→                remaining -= take\n   148→\n   149→        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n   150→        # Scale to desired radius and translate to center\n   151→        cx, cy, cz = center\n   152→        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n   153→        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n   154→        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n   155→\n   156→        sl = slice(start, start + actual)\n   157→        self.position[sl, 0] = sphere_pts[:, 0]\n   158→        self.position[sl, 1] = sphere_pts[:, 1]\n   159→        self.position[sl, 2] = sphere_pts[:, 2]\n   160→        self.position[sl, 3] = 0.0\n   161→\n   162→        self.velocity[sl] = 0.0\n   163→        self.veleval[sl] = 0.0\n   164→        self.sph_force[sl] = 0.0\n   165→\n   166→        # mass = rho0 * spacing^3\n   167→        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n   168→        self.mass[sl] = particle_mass\n   169→\n   170→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   171→        self.packed_info[sl] = cp.uint32(packed)\n   172→\n   173→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   174→        self.temperature[sl] = temp\n   175→        self.health[sl] = 1.0\n   176→        self.lifetime[sl] = 0.0\n   177→        self.shear_rate[sl] = 0.0\n   178→        self.exposure_heat[sl] = 0.0\n   179→        self.exposure_corrode[sl] = 0.0\n   180→\n   181→        self.color[sl, 0] = mat.color_r\n   182→        self.color[sl, 1] = mat.color_g\n   183→        self.color[sl, 2] = mat.color_b\n   184→        self.color[sl, 3] = 1.0\n   185→\n   186→        self.density[sl] = mat.rest_density\n   187→        self.sleep_counter[sl] = 0\n   188→\n   189→        self._high_water += actual\n   190→        return actual\n   191→\n   192→    def spawn_cube(\n   193→        self,\n   194→        min_corner: Tuple[float, float, float],\n   195→        max_corner: Tuple[float, float, float],\n   196→        material_id: int,\n   197→        spacing: float = DEFAULT_SPACING,\n   198→    ) -> int:\n   199→        \"\"\"Spawn particles on a regular grid within a cube.\n   200→\n   201→        Returns the number of particles actually spawned.\n   202→        \"\"\"\n   203→        if material_id not in MATERIALS:\n   204→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   205→\n   206→        # Build grid positions on CPU (small overhead, predictable count)\n   207→        x0, y0, z0 = min_corner\n   208→        x1, y1, z1 = max_corner\n   209→        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n   210→        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n   211→        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n   212→\n   213→        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n   214→            return 0\n   215→\n   216→        total = len(xs) * len(ys) * len(zs)\n   217→        available = self.max_particles - self._high_water\n   218→        actual = min(total, available)\n   219→        if actual <= 0:\n   220→            return 0\n   221→\n   222→        # Generate meshgrid positions\n   223→        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n   224→        positions = np.column_stack([\n   225→            gx.ravel()[:actual],\n   226→            gy.ravel()[:actual],\n   227→            gz.ravel()[:actual],\n   228→        ]).astype(np.float32)\n   229→\n   230→        actual = len(positions)\n   231→        if actual == 0:\n   232→            return 0\n   233→\n   234→        mat = MATERIALS[material_id]\n   235→        start = self._high_water\n   236→        sl = slice(start, start + actual)\n   237→\n   238→        d_positions = cp.asarray(positions)\n   239→        self.position[sl, 0] = d_positions[:, 0]\n   240→        self.position[sl, 1] = d_positions[:, 1]\n   241→        self.position[sl, 2] = d_positions[:, 2]\n   242→        self.position[sl, 3] = 0.0\n   243→\n   244→        self.velocity[sl] = 0.0\n   245→        self.veleval[sl] = 0.0\n   246→        self.sph_force[sl] = 0.0\n   247→\n   248→        particle_mass = mat.rest_density * (spacing ** 3)\n   249→        self.mass[sl] = particle_mass\n   250→\n   251→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   252→        self.packed_info[sl] = cp.uint32(packed)\n   253→\n   254→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   255→        self.temperature[sl] = temp\n   256→        self.health[sl] = 1.0\n   257→        self.lifetime[sl] = 0.0\n   258→        self.shear_rate[sl] = 0.0\n   259→        self.exposure_heat[sl] = 0.0\n   260→        self.exposure_corrode[sl] = 0.0\n   261→\n   262→        self.color[sl, 0] = mat.color_r\n   263→        self.color[sl, 1] = mat.color_g\n   264→        self.color[sl, 2] = mat.color_b\n   265→        self.color[sl, 3] = 1.0\n   266→\n   267→        self.density[sl] = mat.rest_density\n   268→        self.sleep_counter[sl] = 0\n   269→\n   270→        self._high_water += actual\n   271→        return actual\n   272→\n   273→    def kill_in_sphere(\n   274→        self,\n   275→        center: Tuple[float, float, float],\n   276→        radius: float,\n   277→    ) -> int:\n   278→        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n   279→\n   280→        Returns the number of particles killed.\n   281→        \"\"\"\n   282→        if self._high_water == 0:\n   283→            return 0\n   284→\n   285→        n = self._high_water\n   286→        cx, cy, cz = center\n   287→        dx = self.position[:n, 0] - cx\n   288→        dy = self.position[:n, 1] - cy\n   289→        dz = self.position[:n, 2] - cz\n   290→        dist_sq = dx * dx + dy * dy + dz * dz\n   291→\n   292→        mask = dist_sq <= (radius * radius)\n   293→        # Only kill non-DEAD particles\n   294→        mask = mask & (self.packed_info[:n] != 0)\n   295→        killed = int(cp.sum(mask))\n   296→\n   297→        if killed > 0:\n   298→            self.packed_info[:n][mask] = cp.uint32(0)\n   299→\n   300→        return killed\n   301→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01HNB9ThQmhAKuNXhSk34vjN","session_id":"20e7fc32-9409-45e1-9ca1-0f98b4ecc786","uuid":"ef9d2797-a826-4c60-b674-0552ac379303"}

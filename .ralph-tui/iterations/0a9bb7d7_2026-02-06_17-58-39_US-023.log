{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AJYcnaM9SFchx1LzcCwscA","type":"tool_result","content":"     1→/*\n     2→ * common.cuh -- Single source of truth for all GPU data layouts.\n     3→ *\n     4→ * All .cu kernel files include this header. It defines:\n     5→ *   - BehaviorClass enum\n     6→ *   - MaterialProps / Interaction structs + constant memory arrays\n     7→ *   - GridParams struct + constant memory\n     8→ *   - SimParams / PrecalcParams structs + constant memory\n     9→ *   - packed_info bitfield macros\n    10→ *   - Array type conventions (documented in comments)\n    11→ */\n    12→\n    13→#ifndef FALLINGSAND3D_COMMON_CUH\n    14→#define FALLINGSAND3D_COMMON_CUH\n    15→\n    16→typedef unsigned int uint;\n    17→\n    18→/* ======================================================================\n    19→ * Behavior classes\n    20→ * ====================================================================== */\n    21→\n    22→enum BehaviorClass {\n    23→    FLUID   = 0,\n    24→    GRANULAR = 1,\n    25→    GAS     = 2,\n    26→    STATIC  = 3\n    27→};\n    28→\n    29→/* ======================================================================\n    30→ * MaterialProps -- per-material constants uploaded to constant memory.\n    31→ * 16 fields x 4 bytes = 64 bytes (no extra padding needed).\n    32→ * ====================================================================== */\n    33→\n    34→struct MaterialProps {\n    35→    float rest_density;          // kg/m^3\n    36→    float eos_stiffness;         // Tait EOS k\n    37→    float eos_gamma;             // Tait EOS exponent (7 for liquid, 1 for gas)\n    38→    float base_viscosity;        // Pa*s\n    39→    float friction_coeff;        // mu_s for granular friction\n    40→    float cohesion;              // cohesion coefficient\n    41→    float buoyancy_extra;        // extra buoyancy factor for gas\n    42→    float thermal_conductivity;  // W/(m*K)\n    43→    float heat_capacity;         // J/(kg*K)\n    44→    float temp_melt;             // Kelvin\n    45→    float temp_boil;             // Kelvin\n    46→    float temp_ignite;           // Kelvin (0 = non-flammable)\n    47→    int   behavior_class;        // BehaviorClass enum value\n    48→    float color_r;               // default material color R\n    49→    float color_g;               // default material color G\n    50→    float color_b;               // default material color B\n    51→};\n    52→// Static assert: sizeof(MaterialProps) must be 64 bytes\n    53→\n    54→/* ======================================================================\n    55→ * Interaction -- per-pair (i,j) reaction parameters.\n    56→ * 2 fields x 4 bytes = 8 bytes.\n    57→ * ====================================================================== */\n    58→\n    59→struct Interaction {\n    60→    float reaction_rate;   // reaction speed (0 = no reaction)\n    61→    float heat_exchange;   // heat transfer coefficient between pair\n    62→};\n    63→\n    64→/* ======================================================================\n    65→ * Constant memory: materials and interactions\n    66→ * Total: 32*64 + 32*32*8 = 2048 + 8192 = 10240 bytes (well under 64 KB)\n    67→ * ====================================================================== */\n    68→\n    69→__constant__ MaterialProps c_materials[32];\n    70→__constant__ Interaction   c_interactions[32][32];\n    71→\n    72→/* ======================================================================\n    73→ * GridParams -- uniform grid parameters for spatial hashing.\n    74→ *\n    75→ * grid_res uses int3 (not float3 as in the root-level prototype) for\n    76→ * correct integer arithmetic in hash computation.\n    77→ * ====================================================================== */\n    78→\n    79→struct GridParams {\n    80→    float3 grid_min;    // world-space minimum corner\n    81→    float3 grid_max;    // world-space maximum corner\n    82→    int3   grid_res;    // number of cells per axis\n    83→    float3 grid_delta;  // 1 / cell_size = grid_res / grid_size\n    84→    int    num_cells;   // grid_res.x * grid_res.y * grid_res.z\n    85→};\n    86→\n    87→__constant__ GridParams c_grid;\n    88→\n    89→/* ======================================================================\n    90→ * SimParams -- simulation-wide parameters.\n    91→ *\n    92→ * Uploaded once per frame (or when sim config changes).\n    93→ * ====================================================================== */\n    94→\n    95→struct SimParams {\n    96→    float  smoothing_length;     // h\n    97→    float  smoothing_length_sq;  // h^2\n    98→    float  particle_mass;        // uniform mass per particle\n    99→    float  particle_spacing;     // rest spacing between particles\n   100→    float3 gravity;              // (0, -9.8, 0) typically\n   101→    float  dt;                   // simulation timestep\n   102→    float  restitution;          // wall bounce coefficient\n   103→    float  wall_friction;        // wall friction coefficient\n   104→    float3 world_min;            // simulation domain min\n   105→    float3 world_max;            // simulation domain max\n   106→};\n   107→\n   108→__constant__ SimParams c_sim;\n   109→\n   110→/* ======================================================================\n   111→ * PrecalcParams -- kernel coefficients precomputed from smoothing_length.\n   112→ *\n   113→ * These depend on h and are recomputed when h changes. Stored separately\n   114→ * from SimParams to keep the intent clear.\n   115→ *\n   116→ * Sign convention: pressure_precalc is POSITIVE (+45/(pi*h^6)) because\n   117→ * it absorbs the double negative from the SPH momentum equation.\n   118→ * ====================================================================== */\n   119→\n   120→struct PrecalcParams {\n   121→    float poly6_coeff;           // 315 / (64 * pi * h^9)\n   122→    float spiky_grad_coeff;      // -45 / (pi * h^6)  (negative)\n   123→    float viscosity_lap_coeff;   // 45 / (pi * h^6)\n   124→    float pressure_precalc;      // +45 / (pi * h^6)   (positive, see note)\n   125→    float viscosity_precalc;     // mu * 45 / (pi * h^6)\n   126→};\n   127→\n   128→__constant__ PrecalcParams c_precalc;\n   129→\n   130→/* ======================================================================\n   131→ * packed_info bitfield layout (uint32)\n   132→ *\n   133→ *   Bits [7:0]   material_id    (256 materials max, 32 used)\n   134→ *   Bits [9:8]   behavior_class (FLUID=0, GRANULAR=1, GAS=2, STATIC=3)\n   135→ *   Bit  [10]    is_sleeping    (1 = asleep, skip force computation)\n   136→ *   Bit  [11]    spawn_flag     (1 = just spawned, needs initialization)\n   137→ *   Bit  [12]    just_woke      (1 = woke this frame, needs velocity reset)\n   138→ *   Bits [31:13] reserved\n   139→ * ====================================================================== */\n   140→\n   141→#define GET_MATERIAL_ID(p)  ((p) & 0xFF)\n   142→#define GET_BEHAVIOR(p)     (((p) >> 8) & 0x3)\n   143→#define IS_SLEEPING(p)      (((p) >> 10) & 1)\n   144→#define SET_SLEEPING(p)     ((p) | 0x400)\n   145→#define CLEAR_SLEEPING(p)   ((p) & ~0x400)\n   146→#define HAS_SPAWN_FLAG(p)   (((p) >> 11) & 1)\n   147→#define SET_SPAWN_FLAG(p)   ((p) | 0x800)\n   148→#define HAS_JUST_WOKE(p)    (((p) >> 12) & 1)\n   149→#define SET_JUST_WOKE(p)    ((p) | 0x1000)\n   150→#define CLEAR_JUST_WOKE(p)  ((p) & ~0x1000)\n   151→#define MAKE_PACKED(mat, beh) (((mat) & 0xFF) | (((beh) & 0x3) << 8))\n   152→\n   153→/* ======================================================================\n   154→ * Array type conventions (documented per acceptance criteria)\n   155→ *\n   156→ * float4 arrays (w component unused, set to 0):\n   157→ *   position, velocity, veleval, sph_force, color\n   158→ *\n   159→ * float arrays:\n   160→ *   density, mass, temperature, health, lifetime,\n   161→ *   shear_rate, exposure_heat, exposure_corrode\n   162→ *\n   163→ * uint32 arrays:\n   164→ *   packed_info\n   165→ *\n   166→ * uint8 arrays:\n   167→ *   sleep_counter\n   168→ * ====================================================================== */\n   169→\n   170→#endif /* FALLINGSAND3D_COMMON_CUH */\n   171→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f78301fc-4ded-4a94-a553-b435335d3972","uuid":"bcd4193e-322b-4966-9e26-9e8dd530c828","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/physics/kernels/common.cuh","content":"/*\n * common.cuh -- Single source of truth for all GPU data layouts.\n *\n * All .cu kernel files include this header. It defines:\n *   - BehaviorClass enum\n *   - MaterialProps / Interaction structs + constant memory arrays\n *   - GridParams struct + constant memory\n *   - SimParams / PrecalcParams structs + constant memory\n *   - packed_info bitfield macros\n *   - Array type conventions (documented in comments)\n */\n\n#ifndef FALLINGSAND3D_COMMON_CUH\n#define FALLINGSAND3D_COMMON_CUH\n\ntypedef unsigned int uint;\n\n/* ======================================================================\n * Behavior classes\n * ====================================================================== */\n\nenum BehaviorClass {\n    FLUID   = 0,\n    GRANULAR = 1,\n    GAS     = 2,\n    STATIC  = 3\n};\n\n/* ======================================================================\n * MaterialProps -- per-material constants uploaded to constant memory.\n * 16 fields x 4 bytes = 64 bytes (no extra padding needed).\n * ====================================================================== */\n\nstruct MaterialProps {\n    float rest_density;          // kg/m^3\n    float eos_stiffness;         // Tait EOS k\n    float eos_gamma;             // Tait EOS exponent (7 for liquid, 1 for gas)\n    float base_viscosity;        // Pa*s\n    float friction_coeff;        // mu_s for granular friction\n    float cohesion;              // cohesion coefficient\n    float buoyancy_extra;        // extra buoyancy factor for gas\n    float thermal_conductivity;  // W/(m*K)\n    float heat_capacity;         // J/(kg*K)\n    float temp_melt;             // Kelvin\n    float temp_boil;             // Kelvin\n    float temp_ignite;           // Kelvin (0 = non-flammable)\n    int   behavior_class;        // BehaviorClass enum value\n    float color_r;               // default material color R\n    float color_g;               // default material color G\n    float color_b;               // default material color B\n};\n// Static assert: sizeof(MaterialProps) must be 64 bytes\n\n/* ======================================================================\n * Interaction -- per-pair (i,j) reaction parameters.\n * 2 fields x 4 bytes = 8 bytes.\n * ====================================================================== */\n\nstruct Interaction {\n    float reaction_rate;   // reaction speed (0 = no reaction)\n    float heat_exchange;   // heat transfer coefficient between pair\n};\n\n/* ======================================================================\n * Constant memory: materials and interactions\n * Total: 32*64 + 32*32*8 = 2048 + 8192 = 10240 bytes (well under 64 KB)\n * ====================================================================== */\n\n__constant__ MaterialProps c_materials[32];\n__constant__ Interaction   c_interactions[32][32];\n\n/* ======================================================================\n * GridParams -- uniform grid parameters for spatial hashing.\n *\n * grid_res uses int3 (not float3 as in the root-level prototype) for\n * correct integer arithmetic in hash computation.\n * ====================================================================== */\n\nstruct GridParams {\n    float3 grid_min;    // world-space minimum corner\n    float3 grid_max;    // world-space maximum corner\n    int3   grid_res;    // number of cells per axis\n    float3 grid_delta;  // 1 / cell_size = grid_res / grid_size\n    int    num_cells;   // grid_res.x * grid_res.y * grid_res.z\n};\n\n__constant__ GridParams c_grid;\n\n/* ======================================================================\n * SimParams -- simulation-wide parameters.\n *\n * Uploaded once per frame (or when sim config changes).\n * ====================================================================== */\n\nstruct SimParams {\n    float  smoothing_length;     // h\n    float  smoothing_length_sq;  // h^2\n    float  particle_mass;        // uniform mass per particle\n    float  particle_spacing;     // rest spacing between particles\n    float3 gravity;              // (0, -9.8, 0) typically\n    float  dt;                   // simulation timestep\n    float  restitution;          // wall bounce coefficient\n    float  wall_friction;        // wall friction coefficient\n    float3 world_min;            // simulation domain min\n    float3 world_max;            // simulation domain max\n};\n\n__constant__ SimParams c_sim;\n\n/* ======================================================================\n * PrecalcParams -- kernel coefficients precomputed from smoothing_length.\n *\n * These depend on h and are recomputed when h changes. Stored separately\n * from SimParams to keep the intent clear.\n *\n * Sign convention: pressure_precalc is POSITIVE (+45/(pi*h^6)) because\n * it absorbs the double negative from the SPH momentum equation.\n * ====================================================================== */\n\nstruct PrecalcParams {\n    float poly6_coeff;           // 315 / (64 * pi * h^9)\n    float spiky_grad_coeff;      // -45 / (pi * h^6)  (negative)\n    float viscosity_lap_coeff;   // 45 / (pi * h^6)\n    float pressure_precalc;      // +45 / (pi * h^6)   (positive, see note)\n    float viscosity_precalc;     // mu * 45 / (pi * h^6)\n};\n\n__constant__ PrecalcParams c_precalc;\n\n/* ======================================================================\n * packed_info bitfield layout (uint32)\n *\n *   Bits [7:0]   material_id    (256 materials max, 32 used)\n *   Bits [9:8]   behavior_class (FLUID=0, GRANULAR=1, GAS=2, STATIC=3)\n *   Bit  [10]    is_sleeping    (1 = asleep, skip force computation)\n *   Bit  [11]    spawn_flag     (1 = just spawned, needs initialization)\n *   Bit  [12]    just_woke      (1 = woke this frame, needs velocity reset)\n *   Bits [31:13] reserved\n * ====================================================================== */\n\n#define GET_MATERIAL_ID(p)  ((p) & 0xFF)\n#define GET_BEHAVIOR(p)     (((p) >> 8) & 0x3)\n#define IS_SLEEPING(p)      (((p) >> 10) & 1)\n#define SET_SLEEPING(p)     ((p) | 0x400)\n#define CLEAR_SLEEPING(p)   ((p) & ~0x400)\n#define HAS_SPAWN_FLAG(p)   (((p) >> 11) & 1)\n#define SET_SPAWN_FLAG(p)   ((p) | 0x800)\n#define HAS_JUST_WOKE(p)    (((p) >> 12) & 1)\n#define SET_JUST_WOKE(p)    ((p) | 0x1000)\n#define CLEAR_JUST_WOKE(p)  ((p) & ~0x1000)\n#define MAKE_PACKED(mat, beh) (((mat) & 0xFF) | (((beh) & 0x3) << 8))\n\n/* ======================================================================\n * Array type conventions (documented per acceptance criteria)\n *\n * float4 arrays (w component unused, set to 0):\n *   position, velocity, veleval, sph_force, color\n *\n * float arrays:\n *   density, mass, temperature, health, lifetime,\n *   shear_rate, exposure_heat, exposure_corrode\n *\n * uint32 arrays:\n *   packed_info\n *\n * uint8 arrays:\n *   sleep_counter\n * ====================================================================== */\n\n#endif /* FALLINGSAND3D_COMMON_CUH */\n","numLines":171,"startLine":1,"totalLines":171}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ALC9kvCXRLk4jevWwvkihc","type":"tool_result","content":"     1→/*\n     2→ * reactions.cu -- K_Reactions kernel: per-particle state machine for\n     3→ * phase transitions, combustion, corrosion, and gas lifetime.\n     4→ *\n     5→ * No neighbor loop -- each thread processes one particle independently.\n     6→ * Reads exposure accumulators from Step1, checks temperature and exposure\n     7→ * thresholds, and modifies material type, behavior class, temperature,\n     8→ * health, lifetime, and velocity as needed.\n     9→ *\n    10→ * Runs on SORTED arrays, between Step1 (which computes exposure) and\n    11→ * Step2 (which computes forces). Modifications to sorted_packed_info\n    12→ * flow through Step2 and Integrate naturally.\n    13→ *\n    14→ * Constant memory used:\n    15→ *   c_sim       -- SimParams (dt)\n    16→ *   c_materials -- MaterialProps[32] (for looking up current material props)\n    17→ */\n    18→\n    19→#include \"common.cuh\"\n    20→\n    21→/* ======================================================================\n    22→ * Material IDs (must match materials.py)\n    23→ * ====================================================================== */\n    24→\n    25→#define MAT_DEAD       0\n    26→#define MAT_STONE      1\n    27→#define MAT_WATER      5\n    28→#define MAT_OIL        6\n    29→#define MAT_LAVA       7\n    30→#define MAT_WOOD       9\n    31→#define MAT_ICE       11\n    32→#define MAT_STEAM     12\n    33→#define MAT_FIRE      14\n    34→#define MAT_GUNPOWDER 15\n    35→\n    36→/* ======================================================================\n    37→ * Reaction thresholds\n    38→ * ====================================================================== */\n    39→\n    40→#define ICE_MELT_TEMP         273.0f   // ICE -> WATER above this\n    41→#define LAVA_SOLIDIFY_TEMP    900.0f   // LAVA -> STONE below this\n    42→#define WATER_BOIL_TEMP       373.0f   // WATER -> SPAWN_GAS flag above this\n    43→#define STEAM_CONDENSE_TEMP   373.0f   // STEAM -> WATER below this\n    44→\n    45→#define WOOD_IGNITE_EXPOSURE  0.5f     // WOOD -> FIRE above this exposure_heat\n    46→#define OIL_IGNITE_EXPOSURE   0.3f     // OIL  -> FIRE above this exposure_heat\n    47→#define GUNPOWDER_EXPOSURE    0.1f     // GUNPOWDER -> FIRE above this exposure_heat\n    48→\n    49→#define FIRE_TEMPERATURE     1200.0f   // temperature set on combustion\n    50→#define WOOD_FIRE_LIFETIME      1.0f   // seconds\n    51→#define OIL_FIRE_LIFETIME       1.5f   // seconds\n    52→#define GUNPOWDER_FIRE_LIFETIME 0.3f   // seconds\n    53→\n    54→#define EXPLOSION_SPEED        5.0f    // velocity magnitude for gunpowder burst\n    55→\n    56→/* ======================================================================\n    57→ * Wang hash RNG for explosion direction\n    58→ * ====================================================================== */\n    59→\n    60→__device__ inline uint wang_hash(uint seed) {\n    61→    seed = (seed ^ 61u) ^ (seed >> 16u);\n    62→    seed *= 9u;\n    63→    seed = seed ^ (seed >> 4u);\n    64→    seed *= 0x27d4eb2du;\n    65→    seed = seed ^ (seed >> 15u);\n    66→    return seed;\n    67→}\n    68→\n    69→__device__ inline float hash_to_float(uint h) {\n    70→    // Map hash to [-1, 1]\n    71→    return (float)(h & 0xFFFFu) / 32767.5f - 1.0f;\n    72→}\n    73→\n    74→/* ======================================================================\n    75→ * K_Reactions kernel\n    76→ * ====================================================================== */\n    77→\n    78→extern \"C\" __global__\n    79→void K_Reactions(\n    80→    uint            numParticles,\n    81→    uint            frame,           // for RNG seed\n    82→    // --- Sorted arrays (read+write in-place) ---\n    83→    uint*           __restrict__ packed_info,       // material_id + behavior + flags\n    84→    float*          __restrict__ temperature,       // particle temperature\n    85→    float*          __restrict__ health,            // particle health [0,1]\n    86→    float*          __restrict__ lifetime,          // remaining lifetime (seconds)\n    87→    float4*         __restrict__ velocity,          // particle velocity (for explosion)\n    88→    // --- Sorted inputs (read-only, from Step1) ---\n    89→    const float*    __restrict__ exposure_heat,     // heat exposure accumulator\n    90→    const float*    __restrict__ exposure_corrode   // corrosion exposure accumulator\n    91→) {\n    92→    uint i = blockIdx.x * blockDim.x + threadIdx.x;\n    93→    if (i >= numParticles) return;\n    94→\n    95→    uint pi = packed_info[i];\n    96→    uint mat_id = GET_MATERIAL_ID(pi);\n    97→\n    98→    // Skip DEAD particles\n    99→    if (mat_id == MAT_DEAD) return;\n   100→\n   101→    float temp = temperature[i];\n   102→    float hlth = health[i];\n   103→    float lt = lifetime[i];\n   104→    float exp_heat = exposure_heat[i];\n   105→    float exp_corrode = exposure_corrode[i];\n   106→    float dt = c_sim.dt;\n   107→\n   108→    // ---- Phase transitions based on temperature ----\n   109→\n   110→    // ICE (mat=11, temp > 273K) -> WATER (in-place, small density ratio)\n   111→    if (mat_id == MAT_ICE && temp > ICE_MELT_TEMP) {\n   112→        pi = MAKE_PACKED(MAT_WATER, FLUID);\n   113→        packed_info[i] = pi;\n   114→        temperature[i] = temp;\n   115→        return;  // done with this particle\n   116→    }\n   117→\n   118→    // LAVA (mat=7, temp < 900K) -> STONE (in-place)\n   119→    if (mat_id == MAT_LAVA && temp < LAVA_SOLIDIFY_TEMP) {\n   120→        pi = MAKE_PACKED(MAT_STONE, STATIC);\n   121→        packed_info[i] = pi;\n   122→        temperature[i] = temp;\n   123→        return;\n   124→    }\n   125→\n   126→    // WATER (mat=5, temp > 373K) -> set SPAWN_GAS flag (large density ratio, US-023)\n   127→    if (mat_id == MAT_WATER && temp > WATER_BOIL_TEMP) {\n   128→        pi = SET_SPAWN_FLAG(pi);\n   129→        packed_info[i] = pi;\n   130→        return;\n   131→    }\n   132→\n   133→    // STEAM (mat=12, temp < 373K) -> WATER (in-place)\n   134→    if (mat_id == MAT_STEAM && temp < STEAM_CONDENSE_TEMP) {\n   135→        pi = MAKE_PACKED(MAT_WATER, FLUID);\n   136→        packed_info[i] = pi;\n   137→        temperature[i] = temp;\n   138→        return;\n   139→    }\n   140→\n   141→    // ---- Combustion transitions based on exposure_heat ----\n   142→\n   143→    // WOOD (mat=9, exposure_heat > 0.5) -> FIRE\n   144→    if (mat_id == MAT_WOOD && exp_heat > WOOD_IGNITE_EXPOSURE) {\n   145→        pi = MAKE_PACKED(MAT_FIRE, GAS);\n   146→        packed_info[i] = pi;\n   147→        temperature[i] = FIRE_TEMPERATURE;\n   148→        lifetime[i] = WOOD_FIRE_LIFETIME;\n   149→        return;\n   150→    }\n   151→\n   152→    // OIL (mat=6, exposure_heat > 0.3) -> FIRE\n   153→    if (mat_id == MAT_OIL && exp_heat > OIL_IGNITE_EXPOSURE) {\n   154→        pi = MAKE_PACKED(MAT_FIRE, GAS);\n   155→        packed_info[i] = pi;\n   156→        temperature[i] = FIRE_TEMPERATURE;\n   157→        lifetime[i] = OIL_FIRE_LIFETIME;\n   158→        return;\n   159→    }\n   160→\n   161→    // GUNPOWDER (mat=15, exposure_heat > 0.1) -> FIRE + explosion\n   162→    if (mat_id == MAT_GUNPOWDER && exp_heat > GUNPOWDER_EXPOSURE) {\n   163→        pi = MAKE_PACKED(MAT_FIRE, GAS);\n   164→        packed_info[i] = pi;\n   165→        temperature[i] = FIRE_TEMPERATURE;\n   166→        lifetime[i] = GUNPOWDER_FIRE_LIFETIME;\n   167→\n   168→        // Random outward burst using wang_hash RNG\n   169→        uint h1 = wang_hash(i + frame * 0x9E3779B9u);\n   170→        uint h2 = wang_hash(h1);\n   171→        uint h3 = wang_hash(h2);\n   172→        float dx = hash_to_float(h1);\n   173→        float dy = hash_to_float(h2);\n   174→        float dz = hash_to_float(h3);\n   175→        // Normalize and scale\n   176→        float len = sqrtf(dx * dx + dy * dy + dz * dz);\n   177→        if (len > 1e-6f) {\n   178→            float inv_len = EXPLOSION_SPEED / len;\n   179→            float4 v = velocity[i];\n   180→            v.x += dx * inv_len;\n   181→            v.y += dy * inv_len;\n   182→            v.z += dz * inv_len;\n   183→            velocity[i] = v;\n   184→        }\n   185→        return;\n   186→    }\n   187→\n   188→    // ---- Corrosion: health -= exposure_corrode * dt ----\n   189→    if (exp_corrode > 0.0f) {\n   190→        hlth -= exp_corrode * dt;\n   191→        if (hlth <= 0.0f) {\n   192→            // Particle dies from corrosion\n   193→            packed_info[i] = MAKE_PACKED(MAT_DEAD, STATIC);\n   194→            health[i] = 0.0f;\n   195→            return;\n   196→        }\n   197→        health[i] = hlth;\n   198→    }\n   199→\n   200→    // ---- GAS lifetime decay ----\n   201→    int behavior = GET_BEHAVIOR(pi);\n   202→    if (behavior == GAS && lt > 0.0f) {\n   203→        lt -= dt;\n   204→        if (lt <= 0.0f) {\n   205→            // Gas particle expired\n   206→            packed_info[i] = MAKE_PACKED(MAT_DEAD, STATIC);\n   207→            lifetime[i] = 0.0f;\n   208→            health[i] = 0.0f;\n   209→            return;\n   210→        }\n   211→        lifetime[i] = lt;\n   212→    }\n   213→}\n   214→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f78301fc-4ded-4a94-a553-b435335d3972","uuid":"0e0a23b0-79b4-4a34-af45-0e515b1e84ea","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/physics/kernels/reactions.cu","content":"/*\n * reactions.cu -- K_Reactions kernel: per-particle state machine for\n * phase transitions, combustion, corrosion, and gas lifetime.\n *\n * No neighbor loop -- each thread processes one particle independently.\n * Reads exposure accumulators from Step1, checks temperature and exposure\n * thresholds, and modifies material type, behavior class, temperature,\n * health, lifetime, and velocity as needed.\n *\n * Runs on SORTED arrays, between Step1 (which computes exposure) and\n * Step2 (which computes forces). Modifications to sorted_packed_info\n * flow through Step2 and Integrate naturally.\n *\n * Constant memory used:\n *   c_sim       -- SimParams (dt)\n *   c_materials -- MaterialProps[32] (for looking up current material props)\n */\n\n#include \"common.cuh\"\n\n/* ======================================================================\n * Material IDs (must match materials.py)\n * ====================================================================== */\n\n#define MAT_DEAD       0\n#define MAT_STONE      1\n#define MAT_WATER      5\n#define MAT_OIL        6\n#define MAT_LAVA       7\n#define MAT_WOOD       9\n#define MAT_ICE       11\n#define MAT_STEAM     12\n#define MAT_FIRE      14\n#define MAT_GUNPOWDER 15\n\n/* ======================================================================\n * Reaction thresholds\n * ====================================================================== */\n\n#define ICE_MELT_TEMP         273.0f   // ICE -> WATER above this\n#define LAVA_SOLIDIFY_TEMP    900.0f   // LAVA -> STONE below this\n#define WATER_BOIL_TEMP       373.0f   // WATER -> SPAWN_GAS flag above this\n#define STEAM_CONDENSE_TEMP   373.0f   // STEAM -> WATER below this\n\n#define WOOD_IGNITE_EXPOSURE  0.5f     // WOOD -> FIRE above this exposure_heat\n#define OIL_IGNITE_EXPOSURE   0.3f     // OIL  -> FIRE above this exposure_heat\n#define GUNPOWDER_EXPOSURE    0.1f     // GUNPOWDER -> FIRE above this exposure_heat\n\n#define FIRE_TEMPERATURE     1200.0f   // temperature set on combustion\n#define WOOD_FIRE_LIFETIME      1.0f   // seconds\n#define OIL_FIRE_LIFETIME       1.5f   // seconds\n#define GUNPOWDER_FIRE_LIFETIME 0.3f   // seconds\n\n#define EXPLOSION_SPEED        5.0f    // velocity magnitude for gunpowder burst\n\n/* ======================================================================\n * Wang hash RNG for explosion direction\n * ====================================================================== */\n\n__device__ inline uint wang_hash(uint seed) {\n    seed = (seed ^ 61u) ^ (seed >> 16u);\n    seed *= 9u;\n    seed = seed ^ (seed >> 4u);\n    seed *= 0x27d4eb2du;\n    seed = seed ^ (seed >> 15u);\n    return seed;\n}\n\n__device__ inline float hash_to_float(uint h) {\n    // Map hash to [-1, 1]\n    return (float)(h & 0xFFFFu) / 32767.5f - 1.0f;\n}\n\n/* ======================================================================\n * K_Reactions kernel\n * ====================================================================== */\n\nextern \"C\" __global__\nvoid K_Reactions(\n    uint            numParticles,\n    uint            frame,           // for RNG seed\n    // --- Sorted arrays (read+write in-place) ---\n    uint*           __restrict__ packed_info,       // material_id + behavior + flags\n    float*          __restrict__ temperature,       // particle temperature\n    float*          __restrict__ health,            // particle health [0,1]\n    float*          __restrict__ lifetime,          // remaining lifetime (seconds)\n    float4*         __restrict__ velocity,          // particle velocity (for explosion)\n    // --- Sorted inputs (read-only, from Step1) ---\n    const float*    __restrict__ exposure_heat,     // heat exposure accumulator\n    const float*    __restrict__ exposure_corrode   // corrosion exposure accumulator\n) {\n    uint i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= numParticles) return;\n\n    uint pi = packed_info[i];\n    uint mat_id = GET_MATERIAL_ID(pi);\n\n    // Skip DEAD particles\n    if (mat_id == MAT_DEAD) return;\n\n    float temp = temperature[i];\n    float hlth = health[i];\n    float lt = lifetime[i];\n    float exp_heat = exposure_heat[i];\n    float exp_corrode = exposure_corrode[i];\n    float dt = c_sim.dt;\n\n    // ---- Phase transitions based on temperature ----\n\n    // ICE (mat=11, temp > 273K) -> WATER (in-place, small density ratio)\n    if (mat_id == MAT_ICE && temp > ICE_MELT_TEMP) {\n        pi = MAKE_PACKED(MAT_WATER, FLUID);\n        packed_info[i] = pi;\n        temperature[i] = temp;\n        return;  // done with this particle\n    }\n\n    // LAVA (mat=7, temp < 900K) -> STONE (in-place)\n    if (mat_id == MAT_LAVA && temp < LAVA_SOLIDIFY_TEMP) {\n        pi = MAKE_PACKED(MAT_STONE, STATIC);\n        packed_info[i] = pi;\n        temperature[i] = temp;\n        return;\n    }\n\n    // WATER (mat=5, temp > 373K) -> set SPAWN_GAS flag (large density ratio, US-023)\n    if (mat_id == MAT_WATER && temp > WATER_BOIL_TEMP) {\n        pi = SET_SPAWN_FLAG(pi);\n        packed_info[i] = pi;\n        return;\n    }\n\n    // STEAM (mat=12, temp < 373K) -> WATER (in-place)\n    if (mat_id == MAT_STEAM && temp < STEAM_CONDENSE_TEMP) {\n        pi = MAKE_PACKED(MAT_WATER, FLUID);\n        packed_info[i] = pi;\n        temperature[i] = temp;\n        return;\n    }\n\n    // ---- Combustion transitions based on exposure_heat ----\n\n    // WOOD (mat=9, exposure_heat > 0.5) -> FIRE\n    if (mat_id == MAT_WOOD && exp_heat > WOOD_IGNITE_EXPOSURE) {\n        pi = MAKE_PACKED(MAT_FIRE, GAS);\n        packed_info[i] = pi;\n        temperature[i] = FIRE_TEMPERATURE;\n        lifetime[i] = WOOD_FIRE_LIFETIME;\n        return;\n    }\n\n    // OIL (mat=6, exposure_heat > 0.3) -> FIRE\n    if (mat_id == MAT_OIL && exp_heat > OIL_IGNITE_EXPOSURE) {\n        pi = MAKE_PACKED(MAT_FIRE, GAS);\n        packed_info[i] = pi;\n        temperature[i] = FIRE_TEMPERATURE;\n        lifetime[i] = OIL_FIRE_LIFETIME;\n        return;\n    }\n\n    // GUNPOWDER (mat=15, exposure_heat > 0.1) -> FIRE + explosion\n    if (mat_id == MAT_GUNPOWDER && exp_heat > GUNPOWDER_EXPOSURE) {\n        pi = MAKE_PACKED(MAT_FIRE, GAS);\n        packed_info[i] = pi;\n        temperature[i] = FIRE_TEMPERATURE;\n        lifetime[i] = GUNPOWDER_FIRE_LIFETIME;\n\n        // Random outward burst using wang_hash RNG\n        uint h1 = wang_hash(i + frame * 0x9E3779B9u);\n        uint h2 = wang_hash(h1);\n        uint h3 = wang_hash(h2);\n        float dx = hash_to_float(h1);\n        float dy = hash_to_float(h2);\n        float dz = hash_to_float(h3);\n        // Normalize and scale\n        float len = sqrtf(dx * dx + dy * dy + dz * dz);\n        if (len > 1e-6f) {\n            float inv_len = EXPLOSION_SPEED / len;\n            float4 v = velocity[i];\n            v.x += dx * inv_len;\n            v.y += dy * inv_len;\n            v.z += dz * inv_len;\n            velocity[i] = v;\n        }\n        return;\n    }\n\n    // ---- Corrosion: health -= exposure_corrode * dt ----\n    if (exp_corrode > 0.0f) {\n        hlth -= exp_corrode * dt;\n        if (hlth <= 0.0f) {\n            // Particle dies from corrosion\n            packed_info[i] = MAKE_PACKED(MAT_DEAD, STATIC);\n            health[i] = 0.0f;\n            return;\n        }\n        health[i] = hlth;\n    }\n\n    // ---- GAS lifetime decay ----\n    int behavior = GET_BEHAVIOR(pi);\n    if (behavior == GAS && lt > 0.0f) {\n        lt -= dt;\n        if (lt <= 0.0f) {\n            // Gas particle expired\n            packed_info[i] = MAKE_PACKED(MAT_DEAD, STATIC);\n            lifetime[i] = 0.0f;\n            health[i] = 0.0f;\n            return;\n        }\n        lifetime[i] = lt;\n    }\n}\n","numLines":214,"startLine":1,"totalLines":214}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019NAZfpYnXiC9ZBpqdahFjQ","type":"tool_result","content":"     1→\"\"\"Reactions kernel: per-particle phase transitions, combustion, and corrosion.\n     2→\n     3→Compiles physics/kernels/reactions.cu via CuPy RawModule and provides\n     4→a function to launch K_Reactions which performs:\n     5→  - ICE -> WATER (temp > 273K)\n     6→  - LAVA -> STONE (temp < 900K)\n     7→  - WATER -> SPAWN_GAS flag (temp > 373K)\n     8→  - STEAM -> WATER (temp < 373K)\n     9→  - WOOD/OIL/GUNPOWDER -> FIRE (exposure_heat threshold)\n    10→  - Corrosion: health -= exposure_corrode * dt\n    11→  - GAS lifetime decay -> DEAD when expired\n    12→\n    13→Operates on SORTED arrays, runs after Step1 (which computes exposure)\n    14→and before Step2 (which computes forces).\n    15→\n    16→Uses shared constant memory from common.cuh:\n    17→  c_sim       -- SimParams (dt)\n    18→  c_materials -- MaterialProps[32]\n    19→\"\"\"\n    20→\n    21→from __future__ import annotations\n    22→\n    23→import os\n    24→from typing import Optional\n    25→\n    26→import cupy\n    27→import numpy as np\n    28→\n    29→# ---------------------------------------------------------------------------\n    30→# CuPy RawModule compilation\n    31→# ---------------------------------------------------------------------------\n    32→\n    33→_module: Optional[object] = None\n    34→\n    35→\n    36→def _ensure_ptx_if_needed() -> None:\n    37→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    38→    from cupy.cuda import compiler as _compiler\n    39→    from cupy.cuda import device as _device\n    40→\n    41→    gpu_cc = _device.Device().compute_capability\n    42→    nvrtc_max = _compiler._get_max_compute_capability()\n    43→    if int(gpu_cc) > int(nvrtc_max):\n    44→        _compiler._use_ptx = True\n    45→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    46→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    47→        if hasattr(_compiler._get_arch, \"_cache\"):\n    48→            _compiler._get_arch._cache = {}\n    49→\n    50→\n    51→def _get_module() -> \"object\":\n    52→    \"\"\"Compile (or return cached) CuPy RawModule from reactions.cu.\"\"\"\n    53→    global _module\n    54→    if _module is not None:\n    55→        return _module\n    56→\n    57→    _ensure_ptx_if_needed()\n    58→\n    59→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    60→    cu_path = os.path.join(kernel_dir, \"reactions.cu\")\n    61→    with open(cu_path) as f:\n    62→        source = f.read()\n    63→\n    64→    _module = cupy.RawModule(\n    65→        code=source,\n    66→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    67→    )\n    68→    return _module\n    69→\n    70→\n    71→def get_module() -> \"object\":\n    72→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    73→    return _get_module()\n    74→\n    75→\n    76→# ---------------------------------------------------------------------------\n    77→# Constant memory upload\n    78→# ---------------------------------------------------------------------------\n    79→\n    80→\n    81→def upload_sim_params(params: np.ndarray) -> None:\n    82→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    83→    module = _get_module()\n    84→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    85→    cupy.cuda.runtime.memcpy(\n    86→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    87→    )\n    88→\n    89→\n    90→def upload_materials(materials_data: np.ndarray) -> None:\n    91→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    92→    module = _get_module()\n    93→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    94→    cupy.cuda.runtime.memcpy(\n    95→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    96→    )\n    97→\n    98→\n    99→# ---------------------------------------------------------------------------\n   100→# Kernel launch\n   101→# ---------------------------------------------------------------------------\n   102→\n   103→BLOCK_SIZE = 256\n   104→\n   105→\n   106→def compute_reactions(\n   107→    sorted_packed_info: cupy.ndarray,\n   108→    sorted_temperature: cupy.ndarray,\n   109→    sorted_health: cupy.ndarray,\n   110→    sorted_lifetime: cupy.ndarray,\n   111→    sorted_velocity: cupy.ndarray,\n   112→    sorted_exposure_heat: cupy.ndarray,\n   113→    sorted_exposure_corrode: cupy.ndarray,\n   114→    frame: int = 0,\n   115→) -> None:\n   116→    \"\"\"Launch K_Reactions kernel.\n   117→\n   118→    Modifies sorted arrays in-place: packed_info, temperature, health,\n   119→    lifetime, velocity.\n   120→\n   121→    Parameters\n   122→    ----------\n   123→    sorted_packed_info : cupy.ndarray, (N,) uint32\n   124→        Packed info (material_id + behavior + flags). Modified in-place.\n   125→    sorted_temperature : cupy.ndarray, (N,) float32\n   126→        Particle temperature. Modified in-place.\n   127→    sorted_health : cupy.ndarray, (N,) float32\n   128→        Particle health [0,1]. Modified in-place.\n   129→    sorted_lifetime : cupy.ndarray, (N,) float32\n   130→        Remaining lifetime in seconds. Modified in-place.\n   131→    sorted_velocity : cupy.ndarray, (N, 4) float32\n   132→        Particle velocity. Modified in-place (gunpowder explosion).\n   133→    sorted_exposure_heat : cupy.ndarray, (N,) float32\n   134→        Heat exposure from Step1 (read-only).\n   135→    sorted_exposure_corrode : cupy.ndarray, (N,) float32\n   136→        Corrosion exposure from Step1 (read-only).\n   137→    frame : int\n   138→        Frame counter for RNG seed (gunpowder explosion direction).\n   139→    \"\"\"\n   140→    n = sorted_packed_info.shape[0]\n   141→    if n == 0:\n   142→        return\n   143→\n   144→    module = _get_module()\n   145→    kernel = module.get_function(\"K_Reactions\")  # type: ignore[union-attr]\n   146→\n   147→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   148→    block = (BLOCK_SIZE,)\n   149→\n   150→    kernel(\n   151→        grid,\n   152→        block,\n   153→        (\n   154→            np.uint32(n),\n   155→            np.uint32(frame),\n   156→            sorted_packed_info,\n   157→            sorted_temperature,\n   158→            sorted_health,\n   159→            sorted_lifetime,\n   160→            sorted_velocity,\n   161→            sorted_exposure_heat,\n   162→            sorted_exposure_corrode,\n   163→        ),\n   164→    )\n   165→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f78301fc-4ded-4a94-a553-b435335d3972","uuid":"86d3d68f-fb05-4628-bd53-aad4cb112ad9","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/reactions.py","content":"\"\"\"Reactions kernel: per-particle phase transitions, combustion, and corrosion.\n\nCompiles physics/kernels/reactions.cu via CuPy RawModule and provides\na function to launch K_Reactions which performs:\n  - ICE -> WATER (temp > 273K)\n  - LAVA -> STONE (temp < 900K)\n  - WATER -> SPAWN_GAS flag (temp > 373K)\n  - STEAM -> WATER (temp < 373K)\n  - WOOD/OIL/GUNPOWDER -> FIRE (exposure_heat threshold)\n  - Corrosion: health -= exposure_corrode * dt\n  - GAS lifetime decay -> DEAD when expired\n\nOperates on SORTED arrays, runs after Step1 (which computes exposure)\nand before Step2 (which computes forces).\n\nUses shared constant memory from common.cuh:\n  c_sim       -- SimParams (dt)\n  c_materials -- MaterialProps[32]\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom typing import Optional\n\nimport cupy\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# CuPy RawModule compilation\n# ---------------------------------------------------------------------------\n\n_module: Optional[object] = None\n\n\ndef _ensure_ptx_if_needed() -> None:\n    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    from cupy.cuda import compiler as _compiler\n    from cupy.cuda import device as _device\n\n    gpu_cc = _device.Device().compute_capability\n    nvrtc_max = _compiler._get_max_compute_capability()\n    if int(gpu_cc) > int(nvrtc_max):\n        _compiler._use_ptx = True\n        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n        if hasattr(_compiler._get_arch, \"_cache\"):\n            _compiler._get_arch._cache = {}\n\n\ndef _get_module() -> \"object\":\n    \"\"\"Compile (or return cached) CuPy RawModule from reactions.cu.\"\"\"\n    global _module\n    if _module is not None:\n        return _module\n\n    _ensure_ptx_if_needed()\n\n    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    cu_path = os.path.join(kernel_dir, \"reactions.cu\")\n    with open(cu_path) as f:\n        source = f.read()\n\n    _module = cupy.RawModule(\n        code=source,\n        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    )\n    return _module\n\n\ndef get_module() -> \"object\":\n    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    return _get_module()\n\n\n# ---------------------------------------------------------------------------\n# Constant memory upload\n# ---------------------------------------------------------------------------\n\n\ndef upload_sim_params(params: np.ndarray) -> None:\n    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    module = _get_module()\n    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    cupy.cuda.runtime.memcpy(\n        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    )\n\n\ndef upload_materials(materials_data: np.ndarray) -> None:\n    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    module = _get_module()\n    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    cupy.cuda.runtime.memcpy(\n        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    )\n\n\n# ---------------------------------------------------------------------------\n# Kernel launch\n# ---------------------------------------------------------------------------\n\nBLOCK_SIZE = 256\n\n\ndef compute_reactions(\n    sorted_packed_info: cupy.ndarray,\n    sorted_temperature: cupy.ndarray,\n    sorted_health: cupy.ndarray,\n    sorted_lifetime: cupy.ndarray,\n    sorted_velocity: cupy.ndarray,\n    sorted_exposure_heat: cupy.ndarray,\n    sorted_exposure_corrode: cupy.ndarray,\n    frame: int = 0,\n) -> None:\n    \"\"\"Launch K_Reactions kernel.\n\n    Modifies sorted arrays in-place: packed_info, temperature, health,\n    lifetime, velocity.\n\n    Parameters\n    ----------\n    sorted_packed_info : cupy.ndarray, (N,) uint32\n        Packed info (material_id + behavior + flags). Modified in-place.\n    sorted_temperature : cupy.ndarray, (N,) float32\n        Particle temperature. Modified in-place.\n    sorted_health : cupy.ndarray, (N,) float32\n        Particle health [0,1]. Modified in-place.\n    sorted_lifetime : cupy.ndarray, (N,) float32\n        Remaining lifetime in seconds. Modified in-place.\n    sorted_velocity : cupy.ndarray, (N, 4) float32\n        Particle velocity. Modified in-place (gunpowder explosion).\n    sorted_exposure_heat : cupy.ndarray, (N,) float32\n        Heat exposure from Step1 (read-only).\n    sorted_exposure_corrode : cupy.ndarray, (N,) float32\n        Corrosion exposure from Step1 (read-only).\n    frame : int\n        Frame counter for RNG seed (gunpowder explosion direction).\n    \"\"\"\n    n = sorted_packed_info.shape[0]\n    if n == 0:\n        return\n\n    module = _get_module()\n    kernel = module.get_function(\"K_Reactions\")  # type: ignore[union-attr]\n\n    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n    block = (BLOCK_SIZE,)\n\n    kernel(\n        grid,\n        block,\n        (\n            np.uint32(n),\n            np.uint32(frame),\n            sorted_packed_info,\n            sorted_temperature,\n            sorted_health,\n            sorted_lifetime,\n            sorted_velocity,\n            sorted_exposure_heat,\n            sorted_exposure_corrode,\n        ),\n    )\n","numLines":165,"startLine":1,"totalLines":165}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016vM3yK8pK5qHnoivcmjG6i","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter\n     5→and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n     9→  2. Run sim_steps simulation substeps\n    10→  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import time\n    16→from typing import Optional\n    17→\n    18→import cupy as cp\n    19→import numpy as np\n    20→\n    21→from world import World\n    22→from materials import (\n    23→    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n    24→)\n    25→\n    26→import hash_sort\n    27→import fused_reorder\n    28→import build_grid\n    29→import step1\n    30→import step2\n    31→import integrate\n    32→import reactions\n    33→import wake\n    34→\n    35→\n    36→class Simulation:\n    37→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    38→\n    39→    Parameters\n    40→    ----------\n    41→    world : World\n    42→        Particle state manager.\n    43→    dt : float\n    44→        Fixed simulation timestep (seconds).\n    45→    speed : float\n    46→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    47→    max_substeps : int\n    48→        Maximum substeps per render frame to prevent spiral-of-death.\n    49→    \"\"\"\n    50→\n    51→    def __init__(\n    52→        self,\n    53→        world: World,\n    54→        dt: float = 0.001,\n    55→        speed: float = 1.0,\n    56→        max_substeps: int = 20,\n    57→    ) -> None:\n    58→        self.world = world\n    59→        self.dt = dt\n    60→        self.speed = speed\n    61→        self.max_substeps = max_substeps\n    62→        self._paused = False\n    63→        self._prev_speed = speed\n    64→        self._last_frame_time: Optional[float] = None\n    65→        self._last_substeps = 0\n    66→        self.sim_time = 0.0\n    67→        self._frame_counter = 0\n    68→\n    69→        # Grid cell tables (pre-allocated, reused every frame)\n    70→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    71→\n    72→        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n    73→        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n    74→\n    75→        # Compile all kernel modules and upload constant memory\n    76→        self._upload_constants()\n    77→\n    78→    def _upload_constants(self) -> None:\n    79→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n    80→        # Build shared param structs\n    81→        grid_params = hash_sort.build_grid_params()\n    82→        sim_params = step1.build_sim_params(\n    83→            smoothing_length=0.04,\n    84→            particle_mass=0.008,\n    85→            particle_spacing=0.02,\n    86→            gravity=(0.0, -9.8, 0.0),\n    87→            dt=self.dt,\n    88→            restitution=0.3,\n    89→            wall_friction=0.5,\n    90→            world_min=(-1.0, -1.0, -1.0),\n    91→            world_max=(1.0, 1.0, 1.0),\n    92→        )\n    93→        precalc_params = step1.build_precalc_params(\n    94→            smoothing_length=0.04,\n    95→            viscosity=1.0,\n    96→        )\n    97→        granular_params = step2.build_granular_params()\n    98→        materials_data = build_material_array()\n    99→        interactions_data = build_interaction_matrix()\n   100→\n   101→        # --- hash_sort module: c_grid ---\n   102→        hash_sort.upload_grid_params(grid_params)\n   103→\n   104→        # --- fused_reorder module: no constant memory needed ---\n   105→        fused_reorder.get_module()  # just compile\n   106→\n   107→        # --- build_grid module: c_grid ---\n   108→        build_grid.upload_grid_params(grid_params)\n   109→\n   110→        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n   111→        step1.upload_grid_params(grid_params)\n   112→        step1.upload_sim_params(sim_params)\n   113→        step1.upload_precalc_params(precalc_params)\n   114→        step1.upload_materials(materials_data)\n   115→        step1.upload_interactions(interactions_data)\n   116→\n   117→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   118→        step2.upload_grid_params(grid_params)\n   119→        step2.upload_sim_params(sim_params)\n   120→        step2.upload_precalc_params(precalc_params)\n   121→        step2.upload_materials(materials_data)\n   122→        step2.upload_granular_params(granular_params)\n   123→\n   124→        # --- integrate module: c_sim, c_materials ---\n   125→        integrate.upload_sim_params(sim_params)\n   126→        integrate.upload_materials(materials_data)\n   127→\n   128→        # --- reactions module: c_sim, c_materials ---\n   129→        reactions.upload_sim_params(sim_params)\n   130→        reactions.upload_materials(materials_data)\n   131→\n   132→        # --- wake module: c_grid ---\n   133→        wake.upload_grid_params(grid_params)\n   134→\n   135→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   136→        upload_to_gpu()\n   137→\n   138→    def _sim_step(self, n: int) -> None:\n   139→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   140→        w = self.world\n   141→\n   142→        # 1. Hash particle positions\n   143→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   144→\n   145→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   146→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   147→            hashes, indices,\n   148→            sorted_hashes_out=w.sorted_hashes,\n   149→            sorted_indices_out=w.sorted_indices,\n   150→        )\n   151→\n   152→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   153→        fused_reorder.fused_reorder(\n   154→            n, sorted_indices,\n   155→            w.position, w.velocity, w.veleval,\n   156→            w.mass, w.packed_info, w.temperature,\n   157→            w.health, w.lifetime, w.color,\n   158→            w.sleep_counter, w.shear_rate,\n   159→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   160→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   161→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   162→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   163→        )\n   164→\n   165→        # 4. Build grid data structure (cell_start / cell_end tables)\n   166→        build_grid.build_data_struct(\n   167→            sorted_hashes[:n], self._cell_start, self._cell_end\n   168→        )\n   169→\n   170→        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n   171→        step1.compute_step1(\n   172→            w.sorted_position[:n],\n   173→            w.sorted_velocity[:n],\n   174→            w.sorted_mass[:n],\n   175→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   176→            w.sorted_packed_info[:n],\n   177→            w.sorted_temperature[:n],\n   178→            self._cell_start,\n   179→            self._cell_end,\n   180→            density_out=w.sorted_density,\n   181→            shear_rate_out=w.sorted_shear_rate,\n   182→            dTdt_out=w.sorted_dTdt,\n   183→            exposure_heat_out=w.sorted_exposure_heat,\n   184→            exposure_corrode_out=w.sorted_exposure_corrode,\n   185→        )\n   186→        w._density_initialized = True\n   187→\n   188→        # 5b. Reactions: phase transitions, combustion, corrosion, gas lifetime\n   189→        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n   190→        #     lifetime/velocity in-place before Step2 sees them.\n   191→        reactions.compute_reactions(\n   192→            w.sorted_packed_info[:n],\n   193→            w.sorted_temperature[:n],\n   194→            w.sorted_health[:n],\n   195→            w.sorted_lifetime[:n],\n   196→            w.sorted_velocity[:n],\n   197→            w.sorted_exposure_heat[:n],\n   198→            w.sorted_exposure_corrode[:n],\n   199→            frame=self._frame_counter,\n   200→        )\n   201→\n   202→        # 6. Step2: pressure + viscosity + XSPH forces\n   203→        step2.compute_step2(\n   204→            w.sorted_position[:n],\n   205→            w.sorted_velocity[:n],\n   206→            w.sorted_density[:n],\n   207→            w.sorted_mass[:n],\n   208→            w.sorted_packed_info[:n],\n   209→            self._cell_start,\n   210→            self._cell_end,\n   211→            sph_force_out=w.sorted_sph_force,\n   212→            veleval_out=w.sorted_veleval,\n   213→        )\n   214→\n   215→        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n   216→        #    Writes back to UNSORTED arrays via sort_indexes\n   217→        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n   218→        integrate.integrate(\n   219→            w.sorted_position[:n],\n   220→            w.sorted_velocity[:n],\n   221→            w.sorted_veleval[:n],\n   222→            w.sorted_sph_force[:n],\n   223→            w.sorted_mass[:n],\n   224→            w.sorted_packed_info[:n],\n   225→            w.sorted_temperature[:n],\n   226→            w.sorted_health[:n],\n   227→            sorted_density=w.sorted_density[:n],\n   228→            sorted_shear_rate=w.sorted_shear_rate[:n],\n   229→            sorted_dTdt=w.sorted_dTdt[:n],\n   230→            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n   231→            sort_indexes=sorted_indices[:n],\n   232→            position_out=w.position,\n   233→            velocity_out=w.velocity,\n   234→            color_out=w.color,\n   235→            packed_info_out=w.packed_info,\n   236→            sleep_counter_out=w.sleep_counter,\n   237→            temperature_out=w.temperature,\n   238→        )\n   239→\n   240→        # 8. Wake propagation: mark cells near just-woke particles,\n   241→        #    wake sleeping neighbors, clear JUST_WOKE flags\n   242→        wake.run_wake_propagation(\n   243→            w.position[:n],\n   244→            w.packed_info[:n],\n   245→            w.sleep_counter[:n],\n   246→            self._cell_wake_flags,\n   247→            num_particles=n,\n   248→        )\n   249→\n   250→        self.sim_time += self.dt\n   251→        self._frame_counter += 1\n   252→\n   253→    def step_frame(self) -> int:\n   254→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   255→        now = time.perf_counter()\n   256→        if self._last_frame_time is None:\n   257→            self._last_frame_time = now\n   258→            return 0\n   259→\n   260→        wall_dt = now - self._last_frame_time\n   261→        self._last_frame_time = now\n   262→\n   263→        if self._paused or self.speed <= 0.0:\n   264→            self._last_substeps = 0\n   265→            return 0\n   266→\n   267→        n = self.world._high_water\n   268→        if n == 0:\n   269→            self._last_substeps = 0\n   270→            return 0\n   271→\n   272→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   273→        sim_steps = max(0, min(\n   274→            self.max_substeps,\n   275→            round(self.speed * wall_dt / self.dt),\n   276→        ))\n   277→\n   278→        for _ in range(sim_steps):\n   279→            self._sim_step(n)\n   280→\n   281→        self._last_substeps = sim_steps\n   282→        return sim_steps\n   283→\n   284→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   285→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   286→\n   287→        Parameters\n   288→        ----------\n   289→        cuda_pos : CudaGLBuffer\n   290→            Position VBO wrapper (must be context-managed externally).\n   291→        cuda_col : CudaGLBuffer\n   292→            Color VBO wrapper (must be context-managed externally).\n   293→        \"\"\"\n   294→        n = self.world._high_water\n   295→        if n == 0:\n   296→            return\n   297→\n   298→        # Position: world pos (float4) -> VBO pos (float4)\n   299→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   300→            (cuda_pos.nbytes // 16, 4), np.float32,\n   301→        )\n   302→        pos_arr[:n] = self.world.position[:n]\n   303→\n   304→        # Color: world color (float4) -> VBO color (float4)\n   305→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   306→            (cuda_col.nbytes // 16, 4), np.float32,\n   307→        )\n   308→        col_arr[:n] = self.world.color[:n]\n   309→\n   310→    @property\n   311→    def paused(self) -> bool:\n   312→        return self._paused\n   313→\n   314→    def toggle_pause(self) -> None:\n   315→        self._paused = not self._paused\n   316→\n   317→    def adjust_speed(self, delta: float) -> None:\n   318→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   319→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   320→\n   321→    @property\n   322→    def last_substeps(self) -> int:\n   323→        return self._last_substeps\n   324→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f78301fc-4ded-4a94-a553-b435335d3972","uuid":"4cfa979f-b418-4317-ae68-bd32cba95e7e","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/simulation.py","content":"\"\"\"SPH simulation orchestrator.\n\nWires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\nStep2 -> Integrate.  Decouples simulation from rendering via a speed parameter\nand substep budget.\n\nEach render frame:\n  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n  2. Run sim_steps simulation substeps\n  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Optional\n\nimport cupy as cp\nimport numpy as np\n\nfrom world import World\nfrom materials import (\n    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n)\n\nimport hash_sort\nimport fused_reorder\nimport build_grid\nimport step1\nimport step2\nimport integrate\nimport reactions\nimport wake\n\n\nclass Simulation:\n    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n\n    Parameters\n    ----------\n    world : World\n        Particle state manager.\n    dt : float\n        Fixed simulation timestep (seconds).\n    speed : float\n        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    max_substeps : int\n        Maximum substeps per render frame to prevent spiral-of-death.\n    \"\"\"\n\n    def __init__(\n        self,\n        world: World,\n        dt: float = 0.001,\n        speed: float = 1.0,\n        max_substeps: int = 20,\n    ) -> None:\n        self.world = world\n        self.dt = dt\n        self.speed = speed\n        self.max_substeps = max_substeps\n        self._paused = False\n        self._prev_speed = speed\n        self._last_frame_time: Optional[float] = None\n        self._last_substeps = 0\n        self.sim_time = 0.0\n        self._frame_counter = 0\n\n        # Grid cell tables (pre-allocated, reused every frame)\n        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n\n        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n\n        # Compile all kernel modules and upload constant memory\n        self._upload_constants()\n\n    def _upload_constants(self) -> None:\n        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n        # Build shared param structs\n        grid_params = hash_sort.build_grid_params()\n        sim_params = step1.build_sim_params(\n            smoothing_length=0.04,\n            particle_mass=0.008,\n            particle_spacing=0.02,\n            gravity=(0.0, -9.8, 0.0),\n            dt=self.dt,\n            restitution=0.3,\n            wall_friction=0.5,\n            world_min=(-1.0, -1.0, -1.0),\n            world_max=(1.0, 1.0, 1.0),\n        )\n        precalc_params = step1.build_precalc_params(\n            smoothing_length=0.04,\n            viscosity=1.0,\n        )\n        granular_params = step2.build_granular_params()\n        materials_data = build_material_array()\n        interactions_data = build_interaction_matrix()\n\n        # --- hash_sort module: c_grid ---\n        hash_sort.upload_grid_params(grid_params)\n\n        # --- fused_reorder module: no constant memory needed ---\n        fused_reorder.get_module()  # just compile\n\n        # --- build_grid module: c_grid ---\n        build_grid.upload_grid_params(grid_params)\n\n        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n        step1.upload_grid_params(grid_params)\n        step1.upload_sim_params(sim_params)\n        step1.upload_precalc_params(precalc_params)\n        step1.upload_materials(materials_data)\n        step1.upload_interactions(interactions_data)\n\n        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n        step2.upload_grid_params(grid_params)\n        step2.upload_sim_params(sim_params)\n        step2.upload_precalc_params(precalc_params)\n        step2.upload_materials(materials_data)\n        step2.upload_granular_params(granular_params)\n\n        # --- integrate module: c_sim, c_materials ---\n        integrate.upload_sim_params(sim_params)\n        integrate.upload_materials(materials_data)\n\n        # --- reactions module: c_sim, c_materials ---\n        reactions.upload_sim_params(sim_params)\n        reactions.upload_materials(materials_data)\n\n        # --- wake module: c_grid ---\n        wake.upload_grid_params(grid_params)\n\n        # --- materials module (its own internal module): c_materials, c_interactions ---\n        upload_to_gpu()\n\n    def _sim_step(self, n: int) -> None:\n        \"\"\"Run one simulation substep on n particles.\"\"\"\n        w = self.world\n\n        # 1. Hash particle positions\n        hashes, indices = hash_sort.calc_hash(w.position[:n])\n\n        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n            hashes, indices,\n            sorted_hashes_out=w.sorted_hashes,\n            sorted_indices_out=w.sorted_indices,\n        )\n\n        # 3. Fused reorder: gather all unsorted arrays into sorted order\n        fused_reorder.fused_reorder(\n            n, sorted_indices,\n            w.position, w.velocity, w.veleval,\n            w.mass, w.packed_info, w.temperature,\n            w.health, w.lifetime, w.color,\n            w.sleep_counter, w.shear_rate,\n            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n            w.sorted_sleep_counter, w.sorted_shear_rate,\n        )\n\n        # 4. Build grid data structure (cell_start / cell_end tables)\n        build_grid.build_data_struct(\n            sorted_hashes[:n], self._cell_start, self._cell_end\n        )\n\n        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n        step1.compute_step1(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_mass[:n],\n            w.sorted_density if hasattr(w, '_density_initialized') else None,\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            self._cell_start,\n            self._cell_end,\n            density_out=w.sorted_density,\n            shear_rate_out=w.sorted_shear_rate,\n            dTdt_out=w.sorted_dTdt,\n            exposure_heat_out=w.sorted_exposure_heat,\n            exposure_corrode_out=w.sorted_exposure_corrode,\n        )\n        w._density_initialized = True\n\n        # 5b. Reactions: phase transitions, combustion, corrosion, gas lifetime\n        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n        #     lifetime/velocity in-place before Step2 sees them.\n        reactions.compute_reactions(\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            w.sorted_lifetime[:n],\n            w.sorted_velocity[:n],\n            w.sorted_exposure_heat[:n],\n            w.sorted_exposure_corrode[:n],\n            frame=self._frame_counter,\n        )\n\n        # 6. Step2: pressure + viscosity + XSPH forces\n        step2.compute_step2(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_density[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            sph_force_out=w.sorted_sph_force,\n            veleval_out=w.sorted_veleval,\n        )\n\n        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n        #    Writes back to UNSORTED arrays via sort_indexes\n        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n        integrate.integrate(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_sph_force[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            sorted_density=w.sorted_density[:n],\n            sorted_shear_rate=w.sorted_shear_rate[:n],\n            sorted_dTdt=w.sorted_dTdt[:n],\n            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n            sort_indexes=sorted_indices[:n],\n            position_out=w.position,\n            velocity_out=w.velocity,\n            color_out=w.color,\n            packed_info_out=w.packed_info,\n            sleep_counter_out=w.sleep_counter,\n            temperature_out=w.temperature,\n        )\n\n        # 8. Wake propagation: mark cells near just-woke particles,\n        #    wake sleeping neighbors, clear JUST_WOKE flags\n        wake.run_wake_propagation(\n            w.position[:n],\n            w.packed_info[:n],\n            w.sleep_counter[:n],\n            self._cell_wake_flags,\n            num_particles=n,\n        )\n\n        self.sim_time += self.dt\n        self._frame_counter += 1\n\n    def step_frame(self) -> int:\n        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n        now = time.perf_counter()\n        if self._last_frame_time is None:\n            self._last_frame_time = now\n            return 0\n\n        wall_dt = now - self._last_frame_time\n        self._last_frame_time = now\n\n        if self._paused or self.speed <= 0.0:\n            self._last_substeps = 0\n            return 0\n\n        n = self.world._high_water\n        if n == 0:\n            self._last_substeps = 0\n            return 0\n\n        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n        sim_steps = max(0, min(\n            self.max_substeps,\n            round(self.speed * wall_dt / self.dt),\n        ))\n\n        for _ in range(sim_steps):\n            self._sim_step(n)\n\n        self._last_substeps = sim_steps\n        return sim_steps\n\n    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n\n        Parameters\n        ----------\n        cuda_pos : CudaGLBuffer\n            Position VBO wrapper (must be context-managed externally).\n        cuda_col : CudaGLBuffer\n            Color VBO wrapper (must be context-managed externally).\n        \"\"\"\n        n = self.world._high_water\n        if n == 0:\n            return\n\n        # Position: world pos (float4) -> VBO pos (float4)\n        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n            (cuda_pos.nbytes // 16, 4), np.float32,\n        )\n        pos_arr[:n] = self.world.position[:n]\n\n        # Color: world color (float4) -> VBO color (float4)\n        col_arr = cuda_col.device_pointer_as_cupy_array(\n            (cuda_col.nbytes // 16, 4), np.float32,\n        )\n        col_arr[:n] = self.world.color[:n]\n\n    @property\n    def paused(self) -> bool:\n        return self._paused\n\n    def toggle_pause(self) -> None:\n        self._paused = not self._paused\n\n    def adjust_speed(self, delta: float) -> None:\n        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n        self.speed = max(0.1, min(10.0, self.speed + delta))\n\n    @property\n    def last_substeps(self) -> int:\n        return self._last_substeps\n","numLines":324,"startLine":1,"totalLines":324}}}

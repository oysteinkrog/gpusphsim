g kernel\ndebug_src = r\"\"\"\n#include \"common.cuh\"\n\nextern \"C\" __global__\nvoid K_Debug(\n    uint* __restrict__ packed_info,\n    uint* __restrict__ dead_indices,\n    uint  old_count,  // simulated\n    uint  steam_pi\n) {\n    // Simulate what spawn does for the thread with this old_count\n    for (int k = 0; k < 3; k++) {\n        uint slot = dead_indices[old_count - 1 - k];\n        packed_info[slot] = steam_pi;\n    }\n}\n\"\"\"\nkernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\nmod = cupy.RawModule(code=debug_src, options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"))\ndebug_fn = mod.get_function(\"K_Debug\")\n\nn = 20\npi = cupy.zeros(n, dtype=cupy.uint32)\ndi = cupy.zeros(n, dtype=cupy.uint32)\n\n# Fill dead_indices: [10,11,12,13,14,15]\nfor j in range(6):\n    di[j] = 10+j\n\n# Mark targets as 0x300\nfor idx in range(10,16):\n    pi[idx] = 0x300\n\nsteam_pi = (12 & 0xFF) | ((2 & 0x3) << 8)  # MAKE_PACKED(STEAM, GAS)\n\n# Simulate thread with old_count=6 (should write to indices 15,14,13)\nprint(\"Debug kernel: old_count=6, expected writes to 15,14,13\")\ndebug_fn((1,), (1,), (pi, di, np.uint32(6), np.uint32(steam_pi)))\ncupy.cuda.Device().synchronize()\n\npi_h = pi.get()\nfor i in range(10,16):\n    print(f\"  [{i}] mat={pi_h[i] & 0xFF} pi={hex(int(pi_h[i]))}\")\n\n# Reset and try old_count=3\npi[:] = 0\nfor idx in range(10,16):\n    pi[idx] = 0x300\n\nprint(\"\\nDebug kernel: old_count=3, expected writes to 12,11,10\")\ndebug_fn((1,), (1,), (pi, di, np.uint32(3), np.uint32(steam_pi)))\ncupy.cuda.Device().synchronize()\n\npi_h = pi.get()\nfor i in range(10,16):\n    print(f\"  [{i}] mat={pi_h[i] & 0xFF} pi={hex(int(pi_h[i]))}\")\n","structuredPatch":[{"oldStart":10,"oldLines":83,"newStart":10,"newLines":60,"lines":[" upload_sim_params(sim_params)"," upload_materials(materials)"," ","-# Single spawn - should work perfectly","-n = 10","+# Test: write to 3 specific indices using a debug kernel","+debug_src =
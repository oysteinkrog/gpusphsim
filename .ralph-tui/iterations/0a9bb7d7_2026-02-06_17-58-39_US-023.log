n        child_color.y = cg;\n        child_color.z = cb;\n        child_color.w = 1.0f;\n        color[slot] = child_color;\n\n        // Material info\n        packed_info[slot] = steam_pi;\n    }\n\n    // Mark source water particle as DEAD\n    packed_info[i] = MAKE_PACKED(MAT_DEAD, FLUID);\n    health[i] = 0.0f;\n    mass[i] = 0.0f;\n\n    // Add source particle to freelist (it's now dead)\n    uint dead_slot = atomicAdd((unsigned int*)dead_count, 1);\n    dead_indices[dead_slot] = i;\n}\n","structuredPatch":[],"originalFile":null}}

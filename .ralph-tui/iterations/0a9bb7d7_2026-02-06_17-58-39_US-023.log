,18]","+for j, idx in enumerate(targets):","+    di[j] = idx","+    pi[idx] = MAKE_PACKED(0, 3)","+dc[0] = len(targets)","+","+compute_spawn(pi[:n], pos[:n], vel[:n], veleval[:n], mass[:n], temp[:n], health[:n], lt[:n], color[:n], sc[:n], dens[:n], sr[:n], di, dc)","+cupy.cuda.Device().synchronize()","+","+pi_h = pi.get()","+steam_at = [i for i in range(10,19) if (pi_h[i] & 0xFF) == 12]","+dead_at = [i for i in [0,1] if (pi_h[i] & 0xFF) == 0]","+print(f\"  dead_sources={dead_at} steam_at={steam_at} dc={int(dc.get()[0])}\")","+for i in range(10,19):","+    mat = pi_h[i] & 0xFF","+    print(f\"  [{i}] mat={mat} pi={hex(int(pi_h[i]))}\")"]}],"originalFile":"import sys, os\nsys.path.insert(0, os.path.dirname(__file__))\nimport cupy, numpy as np\nfrom spawn import compute_spawn, upload_sim_params, upload_materials, allocate_freelist, get_module\nfrom materials import build_material_array\nfrom step1 import build_sim_params\n\nsim_params = build_sim_params(smoothing_length=0.04, particle_mass=0.008, particle_spacing=0.02, gravity=(0.0,-9.8,0.0), dt=0.001, restitution=0.3, wall_friction=0.5, world_min=(-1.0,-1.0,-1.0), world_max=(1.0,1.0,1.0))\nmaterials = build_material_array()\nupload_sim_params(sim_params)\nupload_materials(materials)\n\n# Run 10 times to check for consistency\nfor trial in range(10):\n    n = 20\n    pi = cupy.zeros(n, dtype=cupy.uint32)\n    pos = cupy.zeros((n,4), dtype=cupy.float32)\n    vel = cupy.zeros((n,4), dtype=cupy.float32)\n    veleval = cupy.zeros((n,4), dtype=cupy.float32)\n    mass = cupy.zeros(n, dtype=cupy.float32)\n    temp = cupy.full(n, 293.0, dtype=cupy.float32)\n    health = cupy.ones(n, dtype=cupy.float32)\n    lt = cupy.zeros(n, dtype=cupy.float32)\n    color = cupy.zeros((n,4), dtype=cupy.float32)\n    sc = cupy.zeros(n, dtype=cupy.uint8)\n    dens = cupy.full(n, 1000.0, dtype=cupy.float32)\n    sr = cupy.zeros(n, dtype=cupy.float32)\n\n    MAKE_PACKED = lambda m,b: (m & 0xFF) | ((b & 0x3) << 8)\n    SET_SPAWN = lambda p: p | 0x800\n\n    for i in [0,1]:\n        pi[i] = SET_SPAWN(MAKE_PACKED(5, 0))\n        mass[i] = 0.006\n        vel[i] = cupy.array([0.0, -1.0, 0.0, 0.0], dtype=cupy.float32)\n\n    di, dc = allocate_freelist(n)\n    for j in range(6):\n        di[j] = 10+j\n        pi[10+j] = MAKE_PACKED(0, 3)\n    dc[0] = 6\n\n    compute_spawn(pi[:n], pos[:n], vel[:n], veleval[:n], mass[:n], temp[:n], health[:n], lt[:n], color[:n], sc[:n], dens[:n], sr[:n], di, dc)\n    cupy.cuda.Device().synchronize()\n\n    pi_h = pi.get()\n    steam_indices = [i for i in range(10,16) if (pi_h[i] & 0xFF) == 12]\n    dead_sources = [i for i in [0,1] if (pi_h[i] & 0xFF) == 0]\n    print(f\"Trial {trial}: dc={int(dc.get()[0])} dead_sources={dead_sources} steam_at={steam_indices}\")\n"}}

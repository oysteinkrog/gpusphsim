+debug_fn((1,), (1,), (pi, di, np.uint32(3), np.uint32(steam_pi)))"," cupy.cuda.Device().synchronize()"," "," pi_h = pi.get()","-steam_at = [i for i in range(10,19) if (pi_h[i] & 0xFF) == 12]","-dead_at = [i for i in [0,1] if (pi_h[i] & 0xFF) == 0]","-print(f\"  dead_sources={dead_at} steam_at={steam_at} dc={int(dc.get()[0])}\")","-for i in range(10,19):","-    mat = pi_h[i] & 0xFF","-    print(f\"  [{i}] mat={mat} pi={hex(int(pi_h[i]))}\")","+for i in range(10,16):","+    print(f\"  [{i}] mat={pi_h[i] & 0xFF} pi={hex(int(pi_h[i]))}\")"]}],"originalFile":"import sys, os\nsys.path.insert(0, os.path.dirname(__file__))\nimport cupy, numpy as np\nfrom spawn import compute_spawn, upload_sim_params, upload_materials, allocate_freelist, get_module\nfrom materials import build_material_array\nfrom step1 import build_sim_params\n\nsim_params = build_sim_params(smoothing_length=0.04, particle_mass=0.008, particle_spacing=0.02, gravity=(0.0,-9.8,0.0), dt=0.001, restitution=0.3, wall_friction=0.5, world_min=(-1.0,-1.0,-1.0), world_max=(1.0,1.0,1.0))\nmaterials = build_material_array()\nupload_sim_params(sim_params)\nupload_materials(materials)\n\n# Single spawn - should work perfectly\nn = 10\npi = cupy.zeros(n, dtype=cupy.uint32)\npos = cupy.zeros((n,4), dtype=cupy.float32)\nvel = cupy.zeros((n,4), dtype=cupy.float32)\nveleval = cupy.zeros((n,4), dtype=cupy.float32)\nmass = cupy.zeros(n, dtype=cupy.float32)\ntemp = cupy.full(n, 293.0, dtype=cupy.float32)\nhealth = cupy.ones(n, dtype=cupy.float32)\nlt = cupy.zeros(n, dtype=cupy.float32)\ncolor = cupy.zeros((n,4), dtype=cupy.float32)\nsc = cupy.zeros(n, dtype=cupy.uint8)\ndens = cupy.full(n, 1000.0, dtype=cupy.float32)\nsr = cupy.zeros(n, dtype=cupy.float32)\n\nMAKE_PACKED = lambda m,b: (m & 0xFF) | ((b & 0x3) << 8)\nSET_SPAWN = lambda p: p | 0x800\n\n# Only 1 water at index 0\npi[0] = SET_SPAWN(MAKE_PACKED(5, 0))\nmass[0] = 0.006\n\n# 3 dead slots at indices 3, 5, 7 (scattered)\ndi, dc = allocate_freelist(n)\ndi[0] = 3\ndi[1] = 5\ndi[2] = 7\ndc[0] = 3\n\nprint(\"Test 1: Single spawn with scattered indices [3,5,7]\")\ncompute_spawn(pi[:n], pos[:n], vel[:n], veleval[:n], mass[:n], temp[:n], health[:n], lt[:n], color[:n], sc[:n], dens[:n], sr[:n], di, dc)\ncupy.cuda.Device().synchronize()\n\npi_h = pi.get()\nfor i in range(n):\n    mat = pi_h[i] & 0xFF\n    if mat != 0 or i in [0,3,5,7]:\n        print(f\"  [{i}] mat={mat} pi={hex(int(pi_h[i]))}\")\n\nprint(f\"  dc={int(dc.get()[0])}\")\n\n# Now test: 2 spawns, larger freelist, non-overlapping\nprint(\"\\nTest 2: Two spawns with separate freelist ranges\")\nn = 30\npi = cupy.zeros(n, dtype=cupy.uint32)\npos = cupy.zeros((n,4), dtype=cupy.float32)\nvel = cupy.zeros((n,4), dtype=cupy.float32)\nveleval = cupy.zeros((n,4), dtype=cupy.float32)\nmass = cupy.zeros(n, dtype=cupy.float32)\ntemp = cupy.full(n, 293.0, dtype=cupy.float32)\nhealth = cupy.ones(n, dtype=cupy.float32)\nlt = cupy.zeros(n, dtype=cupy.float32)\ncolor = cupy.zeros((n,4), dtype=cupy.float32)\nsc = cupy.zeros(n, dtype=cupy.uint8)\ndens = cupy.full(n, 1000.0, dtype=cupy.float32)\nsr = cupy.zeros(n, dtype=cupy.float32)\n\n# 2 water particles at indices 0 and 1\nfor i in [0,1]:\n    pi[i] = SET_SPAWN(MAKE_PACKED(5, 0))\n    mass[i] = 0.006\n\n# 9 dead slots (3 extra for safety)\ndi, dc = allocate_freelist(n)\ntargets = [10,11,12,13,14,15,16,17,18]\nfor j, idx in enumerate(targets):\n    di[j] = idx\n    pi[idx] = MAKE_PACKED(0, 3)\ndc[0] = len(targets)\n\ncompute_spawn(pi[:n], pos[:n], vel[:n], veleval[:n], mass[:n], temp[:n], health[:n], lt[:n], color[:n], sc[:n], dens[:n], sr[:n], di, dc)\ncupy.cuda.Device().synchronize()\n\npi_h = pi.get()\nsteam_at = [i for i in range(10,19) if (pi_h[i] & 0xFF) == 12]\ndead_at = [i for i in [0,1] if (pi_h[i] & 0xFF) == 0]\nprint(f\"  dead_sources={dead_at} steam_at={steam_at} dc={int(dc.get()[0])}\")\nfor i in range(10,19):\n    mat = pi_h[i] & 0xFF\n    print(f\"  [{i}] mat={mat} pi={hex(int(pi_h[i]))}\")\n"}}

\"][:n],\n        arrays[\"temperature\"][:n],\n        arrays[\"health\"][:n],\n        arrays[\"lifetime\"][:n],\n        arrays[\"color\"][:n],\n        arrays[\"sleep_counter\"][:n],\n        arrays[\"density\"][:n],\n        arrays[\"shear_rate\"][:n],\n        dead_indices,\n        dead_count,\n    )\n    cupy.cuda.Device().synchronize()\n\n    pi = arrays[\"packed_info\"].get()\n    mass = arrays[\"mass\"].get()\n    temp = arrays[\"temperature\"].get()\n\n    # Most source particles should be DEAD (some may fail due to atomic contention\n    # when exactly 30K slots serve exactly 10K*3 concurrent claims)\n    dead_count_source = 0\n    for i in range(spawn_start, spawn_end):\n        if GET_MATERIAL_ID(int(pi[i])) == DEAD:\n            dead_count_source += 1\n    # Allow up to 5% failure from atomic contention at exact capacity\n    assert dead_count_source >= 9_000, \\\n        f\"Expected >= 9K dead source particles, got {dead_count_source}\"\n\n    # Count STEAM particles at dead slots\n    steam_count = 0\n    for i in range(dead_start, dead_end):\n        if GET_MATERIAL_ID(int(pi[i])) == STEAM:\n            steam_count += 1\n    # Should be 3x the number of successful spawns\n    assert steam_count == dead_count_source * 3, \\\n        f\"Expected {dead_count_source*3} steam particles, got {steam_count}\"\n\n    # No NaN in mass or temperature\n    assert not np.any(np.isnan(mass)), \"NaN in mass\"\n    assert not np.any(np.isnan(temp)), \"NaN in temperature\"\n\n    # Normal water and sand should be unchanged\n    for i in range(water_start, min(water_start + 10, water_end)):\n        assert GET_MATERIAL_ID(int(pi[i])) == WATER\n    for i in range(sand_start, min(sand_start + 10, sand_end)):\n        assert GET_MATERIAL_ID(int(pi[i])) == SAND\n\n    print(\"PASS: test_500k_stress\")\n\n\n# ---------------------------------------------------------------------------\n# Main\n# ---------------------------------------------------------------------------\n\nif __name__ == \"__main__\":\n    tests = [\n        test_compilation,\n        test_block_size,\n        test_spawn_n_value,\n        test_water_spawns_steam,\n        test_spawn_flag_cleared,\n        test_freelist_exhausted,\n        test_freelist_partial_exhaustion,\n        test_scattered_freelist_indices,\n        test_source_added_to_freelist,\n        test_no_spawn_flag_unchanged,\n        test_multiple_spawns,\n        test_reactions_populates_freelist,\n        test_reactions_gas_lifetime_freelist,\n        test_reactions_backward_compat,\n        test_end_to_end_boil_spawn,\n        test_500k_stress,\n    ]\n\n    passed = 0\n    failed = 0\n    for t in tests:\n        try:\n            t()\n            passed += 1\n        except Exception as e:\n            print(f\"FAIL: {t.__name__}: {e}\")\n            import traceback\n            traceback.print_exc()\n            failed += 1\n\n    print(f\"\\n{passed}/{passed+failed} tests passed.\")\n    if failed:\n        sys.exit(1)\n","structuredPatch":[{"oldStart":843,"oldLines":24,"newStart":843,"newLines":20,"lines":["     mass = arrays[\"mass\"].get()","     temp = arrays[\"temperature\"].get()"," ","-    # Most source particles should be DEAD (some may fail due to atomic contention","-    # when exactly 30K slots serve exactly 10K*3 concurrent claims)","+    # All 10K source particles should be DEAD (with 40K headroom, contention is negligible)","     dead_count_source = 0","     for i in range(spawn_start, spawn_end):","         if GET_MATERIAL_ID(int(pi[i])) == DEAD:","             dead_count_source += 1","-    # Allow up to 5% failure from atomic contention at exact capacity","-    assert dead_count_source >= 9_000, \\","-        f\"Expected >= 9K dead source particles, got {dead_count_source}\"","+    assert dead_count_source == 10_000, \\","+        f\"Expected 10K dead source particles, got {dead_count_source}\""," ","     # Count STEAM particles at dead slots","     steam_count = 0","     for
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DpuBLVsktvjVAQGdGcBR37","type":"tool_result","content":"     1→\"\"\"World state management for Falling Sand 3D.\n     2→\n     3→Manages CuPy arrays for all per-particle SoA data. Supports configurable\n     4→max_particles at startup, spawning particles in sphere/cube shapes, and\n     5→tracking num_active via counter.\n     6→\n     7→All arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\n     8→DEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→from typing import Tuple\n    14→\n    15→import cupy as cp\n    16→import numpy as np\n    17→\n    18→from materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n    19→\n    20→# packed_info bitfield macros (mirrors common.cuh)\n    21→_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n    22→\n    23→# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\n    24→DEFAULT_SPACING = 0.02\n    25→\n    26→# Default temperatures for hot materials (Kelvin)\n    27→_DEFAULT_TEMPS = {\n    28→    7: 1500.0,   # LAVA\n    29→    14: 1200.0,  # FIRE\n    30→    12: 373.0,   # STEAM\n    31→    13: 500.0,   # SMOKE\n    32→}\n    33→\n    34→# Ambient temperature\n    35→T_AMBIENT = 293.0\n    36→\n    37→\n    38→class World:\n    39→    \"\"\"Manages all per-particle SoA arrays on GPU.\n    40→\n    41→    Parameters\n    42→    ----------\n    43→    max_particles : int\n    44→        Maximum number of particles to allocate for (default 500000).\n    45→    \"\"\"\n    46→\n    47→    def __init__(self, max_particles: int = 500_000) -> None:\n    48→        self.max_particles: int = max_particles\n    49→        self._high_water: int = 0  # one past last allocated slot\n    50→        self._allocate()\n    51→\n    52→    def _allocate(self) -> None:\n    53→        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n    54→        n = self.max_particles\n    55→        # float4 arrays (stored as (n, 4) float32)\n    56→        self.position = cp.zeros((n, 4), dtype=cp.float32)\n    57→        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n    58→        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n    59→        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    60→        self.color = cp.zeros((n, 4), dtype=cp.float32)\n    61→        # float arrays\n    62→        self.density = cp.zeros(n, dtype=cp.float32)\n    63→        self.mass = cp.zeros(n, dtype=cp.float32)\n    64→        self.temperature = cp.zeros(n, dtype=cp.float32)\n    65→        self.health = cp.zeros(n, dtype=cp.float32)\n    66→        self.lifetime = cp.zeros(n, dtype=cp.float32)\n    67→        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n    68→        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n    69→        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    70→        # uint32 arrays\n    71→        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n    72→        # uint8 arrays\n    73→        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    74→\n    75→        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n    76→        # These are the double-buffer targets: after sort+reorder, physics\n    77→        # kernels (Step1/Step2) read from these.  Integrate writes back to\n    78→        # the unsorted arrays above via sort_indexes.\n    79→        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n    80→        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n    81→        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n    82→        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    83→        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n    84→        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n    85→        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n    86→        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n    87→        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n    88→        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n    89→        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n    90→        self.sorted_dTdt = cp.zeros(n, dtype=cp.float32)\n    91→        self.sorted_exposure_heat = cp.zeros(n, dtype=cp.float32)\n    92→        self.sorted_exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    93→        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n    94→        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    95→        # Sort index arrays (hash + original index, plus sorted versions)\n    96→        self.hashes = cp.zeros(n, dtype=cp.uint32)\n    97→        self.indices = cp.zeros(n, dtype=cp.uint32)\n    98→        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n    99→        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n   100→\n   101→    def resize(self, new_max: int) -> None:\n   102→        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n   103→        self.max_particles = new_max\n   104→        self._high_water = 0\n   105→        self._allocate()\n   106→\n   107→    @property\n   108→    def num_active(self) -> int:\n   109→        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n   110→        if self._high_water == 0:\n   111→            return 0\n   112→        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n   113→\n   114→    def spawn_sphere(\n   115→        self,\n   116→        center: Tuple[float, float, float],\n   117→        radius: float,\n   118→        material_id: int,\n   119→        count: int,\n   120→    ) -> int:\n   121→        \"\"\"Spawn particles with random positions inside a sphere.\n   122→\n   123→        Returns the number of particles actually spawned (may be less than\n   124→        count if max_particles is reached).\n   125→        \"\"\"\n   126→        if material_id not in MATERIALS:\n   127→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   128→\n   129→        available = self.max_particles - self._high_water\n   130→        actual = min(count, available)\n   131→        if actual <= 0:\n   132→            return 0\n   133→\n   134→        mat = MATERIALS[material_id]\n   135→        start = self._high_water\n   136→\n   137→        # Generate random positions in unit sphere using rejection sampling on GPU\n   138→        # Over-generate by ~2x to account for rejection, then take first `actual`\n   139→        needed = actual\n   140→        positions_list = []\n   141→        remaining = needed\n   142→        while remaining > 0:\n   143→            batch = int(remaining * 2.0) + 128\n   144→            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n   145→            r_sq = cp.sum(pts * pts, axis=1)\n   146→            inside = pts[r_sq <= 1.0]\n   147→            take = min(len(inside), remaining)\n   148→            if take > 0:\n   149→                positions_list.append(inside[:take])\n   150→                remaining -= take\n   151→\n   152→        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n   153→        # Scale to desired radius and translate to center\n   154→        cx, cy, cz = center\n   155→        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n   156→        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n   157→        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n   158→\n   159→        sl = slice(start, start + actual)\n   160→        self.position[sl, 0] = sphere_pts[:, 0]\n   161→        self.position[sl, 1] = sphere_pts[:, 1]\n   162→        self.position[sl, 2] = sphere_pts[:, 2]\n   163→        self.position[sl, 3] = 0.0\n   164→\n   165→        self.velocity[sl] = 0.0\n   166→        self.veleval[sl] = 0.0\n   167→        self.sph_force[sl] = 0.0\n   168→\n   169→        # mass = rho0 * spacing^3\n   170→        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n   171→        self.mass[sl] = particle_mass\n   172→\n   173→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   174→        self.packed_info[sl] = cp.uint32(packed)\n   175→\n   176→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   177→        self.temperature[sl] = temp\n   178→        self.health[sl] = 1.0\n   179→        self.lifetime[sl] = 0.0\n   180→        self.shear_rate[sl] = 0.0\n   181→        self.exposure_heat[sl] = 0.0\n   182→        self.exposure_corrode[sl] = 0.0\n   183→\n   184→        self.color[sl, 0] = mat.color_r\n   185→        self.color[sl, 1] = mat.color_g\n   186→        self.color[sl, 2] = mat.color_b\n   187→        self.color[sl, 3] = 1.0\n   188→\n   189→        self.density[sl] = mat.rest_density\n   190→        self.sleep_counter[sl] = 0\n   191→\n   192→        self._high_water += actual\n   193→        return actual\n   194→\n   195→    def spawn_cube(\n   196→        self,\n   197→        min_corner: Tuple[float, float, float],\n   198→        max_corner: Tuple[float, float, float],\n   199→        material_id: int,\n   200→        spacing: float = DEFAULT_SPACING,\n   201→    ) -> int:\n   202→        \"\"\"Spawn particles on a regular grid within a cube.\n   203→\n   204→        Returns the number of particles actually spawned.\n   205→        \"\"\"\n   206→        if material_id not in MATERIALS:\n   207→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   208→\n   209→        # Build grid positions on CPU (small overhead, predictable count)\n   210→        x0, y0, z0 = min_corner\n   211→        x1, y1, z1 = max_corner\n   212→        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n   213→        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n   214→        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n   215→\n   216→        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n   217→            return 0\n   218→\n   219→        total = len(xs) * len(ys) * len(zs)\n   220→        available = self.max_particles - self._high_water\n   221→        actual = min(total, available)\n   222→        if actual <= 0:\n   223→            return 0\n   224→\n   225→        # Generate meshgrid positions\n   226→        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n   227→        positions = np.column_stack([\n   228→            gx.ravel()[:actual],\n   229→            gy.ravel()[:actual],\n   230→            gz.ravel()[:actual],\n   231→        ]).astype(np.float32)\n   232→\n   233→        actual = len(positions)\n   234→        if actual == 0:\n   235→            return 0\n   236→\n   237→        mat = MATERIALS[material_id]\n   238→        start = self._high_water\n   239→        sl = slice(start, start + actual)\n   240→\n   241→        d_positions = cp.asarray(positions)\n   242→        self.position[sl, 0] = d_positions[:, 0]\n   243→        self.position[sl, 1] = d_positions[:, 1]\n   244→        self.position[sl, 2] = d_positions[:, 2]\n   245→        self.position[sl, 3] = 0.0\n   246→\n   247→        self.velocity[sl] = 0.0\n   248→        self.veleval[sl] = 0.0\n   249→        self.sph_force[sl] = 0.0\n   250→\n   251→        particle_mass = mat.rest_density * (spacing ** 3)\n   252→        self.mass[sl] = particle_mass\n   253→\n   254→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   255→        self.packed_info[sl] = cp.uint32(packed)\n   256→\n   257→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   258→        self.temperature[sl] = temp\n   259→        self.health[sl] = 1.0\n   260→        self.lifetime[sl] = 0.0\n   261→        self.shear_rate[sl] = 0.0\n   262→        self.exposure_heat[sl] = 0.0\n   263→        self.exposure_corrode[sl] = 0.0\n   264→\n   265→        self.color[sl, 0] = mat.color_r\n   266→        self.color[sl, 1] = mat.color_g\n   267→        self.color[sl, 2] = mat.color_b\n   268→        self.color[sl, 3] = 1.0\n   269→\n   270→        self.density[sl] = mat.rest_density\n   271→        self.sleep_counter[sl] = 0\n   272→\n   273→        self._high_water += actual\n   274→        return actual\n   275→\n   276→    def kill_in_sphere(\n   277→        self,\n   278→        center: Tuple[float, float, float],\n   279→        radius: float,\n   280→    ) -> int:\n   281→        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n   282→\n   283→        Returns the number of particles killed.\n   284→        \"\"\"\n   285→        if self._high_water == 0:\n   286→            return 0\n   287→\n   288→        n = self._high_water\n   289→        cx, cy, cz = center\n   290→        dx = self.position[:n, 0] - cx\n   291→        dy = self.position[:n, 1] - cy\n   292→        dz = self.position[:n, 2] - cz\n   293→        dist_sq = dx * dx + dy * dy + dz * dz\n   294→\n   295→        mask = dist_sq <= (radius * radius)\n   296→        # Only kill non-DEAD particles\n   297→        mask = mask & (self.packed_info[:n] != 0)\n   298→        killed = int(cp.sum(mask))\n   299→\n   300→        if killed > 0:\n   301→            self.packed_info[:n][mask] = cp.uint32(0)\n   302→\n   303→        return killed\n   304→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f78301fc-4ded-4a94-a553-b435335d3972","uuid":"ce6706b9-4969-4e1c-bdba-970ddbc45144","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/world.py","content":"\"\"\"World state management for Falling Sand 3D.\n\nManages CuPy arrays for all per-particle SoA data. Supports configurable\nmax_particles at startup, spawning particles in sphere/cube shapes, and\ntracking num_active via counter.\n\nAll arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\nDEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Tuple\n\nimport cupy as cp\nimport numpy as np\n\nfrom materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n\n# packed_info bitfield macros (mirrors common.cuh)\n_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n\n# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\nDEFAULT_SPACING = 0.02\n\n# Default temperatures for hot materials (Kelvin)\n_DEFAULT_TEMPS = {\n    7: 1500.0,   # LAVA\n    14: 1200.0,  # FIRE\n    12: 373.0,   # STEAM\n    13: 500.0,   # SMOKE\n}\n\n# Ambient temperature\nT_AMBIENT = 293.0\n\n\nclass World:\n    \"\"\"Manages all per-particle SoA arrays on GPU.\n\n    Parameters\n    ----------\n    max_particles : int\n        Maximum number of particles to allocate for (default 500000).\n    \"\"\"\n\n    def __init__(self, max_particles: int = 500_000) -> None:\n        self.max_particles: int = max_particles\n        self._high_water: int = 0  # one past last allocated slot\n        self._allocate()\n\n    def _allocate(self) -> None:\n        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n        n = self.max_particles\n        # float4 arrays (stored as (n, 4) float32)\n        self.position = cp.zeros((n, 4), dtype=cp.float32)\n        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n        self.color = cp.zeros((n, 4), dtype=cp.float32)\n        # float arrays\n        self.density = cp.zeros(n, dtype=cp.float32)\n        self.mass = cp.zeros(n, dtype=cp.float32)\n        self.temperature = cp.zeros(n, dtype=cp.float32)\n        self.health = cp.zeros(n, dtype=cp.float32)\n        self.lifetime = cp.zeros(n, dtype=cp.float32)\n        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n        # uint32 arrays\n        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n        # uint8 arrays\n        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n\n        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n        # These are the double-buffer targets: after sort+reorder, physics\n        # kernels (Step1/Step2) read from these.  Integrate writes back to\n        # the unsorted arrays above via sort_indexes.\n        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n        self.sorted_dTdt = cp.zeros(n, dtype=cp.float32)\n        self.sorted_exposure_heat = cp.zeros(n, dtype=cp.float32)\n        self.sorted_exposure_corrode = cp.zeros(n, dtype=cp.float32)\n        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n        # Sort index arrays (hash + original index, plus sorted versions)\n        self.hashes = cp.zeros(n, dtype=cp.uint32)\n        self.indices = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n\n    def resize(self, new_max: int) -> None:\n        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n        self.max_particles = new_max\n        self._high_water = 0\n        self._allocate()\n\n    @property\n    def num_active(self) -> int:\n        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n        if self._high_water == 0:\n            return 0\n        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n\n    def spawn_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n        material_id: int,\n        count: int,\n    ) -> int:\n        \"\"\"Spawn particles with random positions inside a sphere.\n\n        Returns the number of particles actually spawned (may be less than\n        count if max_particles is reached).\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        available = self.max_particles - self._high_water\n        actual = min(count, available)\n        if actual <= 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n\n        # Generate random positions in unit sphere using rejection sampling on GPU\n        # Over-generate by ~2x to account for rejection, then take first `actual`\n        needed = actual\n        positions_list = []\n        remaining = needed\n        while remaining > 0:\n            batch = int(remaining * 2.0) + 128\n            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n            r_sq = cp.sum(pts * pts, axis=1)\n            inside = pts[r_sq <= 1.0]\n            take = min(len(inside), remaining)\n            if take > 0:\n                positions_list.append(inside[:take])\n                remaining -= take\n\n        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n        # Scale to desired radius and translate to center\n        cx, cy, cz = center\n        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n\n        sl = slice(start, start + actual)\n        self.position[sl, 0] = sphere_pts[:, 0]\n        self.position[sl, 1] = sphere_pts[:, 1]\n        self.position[sl, 2] = sphere_pts[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        # mass = rho0 * spacing^3\n        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def spawn_cube(\n        self,\n        min_corner: Tuple[float, float, float],\n        max_corner: Tuple[float, float, float],\n        material_id: int,\n        spacing: float = DEFAULT_SPACING,\n    ) -> int:\n        \"\"\"Spawn particles on a regular grid within a cube.\n\n        Returns the number of particles actually spawned.\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        # Build grid positions on CPU (small overhead, predictable count)\n        x0, y0, z0 = min_corner\n        x1, y1, z1 = max_corner\n        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n\n        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n            return 0\n\n        total = len(xs) * len(ys) * len(zs)\n        available = self.max_particles - self._high_water\n        actual = min(total, available)\n        if actual <= 0:\n            return 0\n\n        # Generate meshgrid positions\n        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n        positions = np.column_stack([\n            gx.ravel()[:actual],\n            gy.ravel()[:actual],\n            gz.ravel()[:actual],\n        ]).astype(np.float32)\n\n        actual = len(positions)\n        if actual == 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n        sl = slice(start, start + actual)\n\n        d_positions = cp.asarray(positions)\n        self.position[sl, 0] = d_positions[:, 0]\n        self.position[sl, 1] = d_positions[:, 1]\n        self.position[sl, 2] = d_positions[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        particle_mass = mat.rest_density * (spacing ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def kill_in_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n    ) -> int:\n        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n\n        Returns the number of particles killed.\n        \"\"\"\n        if self._high_water == 0:\n            return 0\n\n        n = self._high_water\n        cx, cy, cz = center\n        dx = self.position[:n, 0] - cx\n        dy = self.position[:n, 1] - cy\n        dz = self.position[:n, 2] - cz\n        dist_sq = dx * dx + dy * dy + dz * dz\n\n        mask = dist_sq <= (radius * radius)\n        # Only kill non-DEAD particles\n        mask = mask & (self.packed_info[:n] != 0)\n        killed = int(cp.sum(mask))\n\n        if killed > 0:\n            self.packed_info[:n][mask] = cp.uint32(0)\n\n        return killed\n","numLines":304,"startLine":1,"totalLines":304}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WiepuHNghR3UJvxpDo5mE8","type":"tool_result","content":"     1→\"\"\"Material property table and interaction matrix for multi-material SPH.\n     2→\n     3→Defines 16 materials (IDs 0-15) as Python dataclasses, a 32x32 interaction\n     4→matrix, and an upload_to_gpu() function that copies both tables to CUDA\n     5→constant memory via CuPy RawModule symbol lookup.\n     6→\n     7→Struct layout matches fallingsand3d/physics/kernels/common.cuh exactly.\n     8→\n     9→Constant-memory symbols\n    10→-----------------------\n    11→- ``c_materials``   : MaterialProps[32]\n    12→- ``c_interactions`` : Interaction[32][32]\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import dataclasses\n    18→import os\n    19→from typing import Dict, List, Optional, Tuple\n    20→\n    21→import numpy as np\n    22→\n    23→# ---------------------------------------------------------------------------\n    24→# Numpy structured dtypes matching the C structs in common.cuh\n    25→# ---------------------------------------------------------------------------\n    26→\n    27→MATERIAL_PROPS_DTYPE = np.dtype(\n    28→    [\n    29→        (\"rest_density\", np.float32),\n    30→        (\"eos_stiffness\", np.float32),\n    31→        (\"eos_gamma\", np.float32),\n    32→        (\"base_viscosity\", np.float32),\n    33→        (\"friction_coeff\", np.float32),\n    34→        (\"cohesion\", np.float32),\n    35→        (\"buoyancy_extra\", np.float32),\n    36→        (\"thermal_conductivity\", np.float32),\n    37→        (\"heat_capacity\", np.float32),\n    38→        (\"temp_melt\", np.float32),\n    39→        (\"temp_boil\", np.float32),\n    40→        (\"temp_ignite\", np.float32),\n    41→        (\"behavior_class\", np.int32),\n    42→        (\"color_r\", np.float32),\n    43→        (\"color_g\", np.float32),\n    44→        (\"color_b\", np.float32),\n    45→    ],\n    46→    align=True,\n    47→)\n    48→\n    49→INTERACTION_DTYPE = np.dtype(\n    50→    [\n    51→        (\"reaction_rate\", np.float32),\n    52→        (\"heat_exchange\", np.float32),\n    53→    ],\n    54→    align=True,\n    55→)\n    56→\n    57→# Compile-time size checks (must match sizeof(MaterialProps) and sizeof(Interaction))\n    58→assert MATERIAL_PROPS_DTYPE.itemsize == 64, (\n    59→    f\"MaterialProps size mismatch: {MATERIAL_PROPS_DTYPE.itemsize} != 64\"\n    60→)\n    61→assert INTERACTION_DTYPE.itemsize == 8, (\n    62→    f\"Interaction size mismatch: {INTERACTION_DTYPE.itemsize} != 8\"\n    63→)\n    64→\n    65→MAX_MATERIALS = 32  # slots in constant memory (IDs 0-31)\n    66→NUM_DEFINED = 16  # IDs 0-15 are defined; 16-31 reserved (zeroed)\n    67→\n    68→# ---------------------------------------------------------------------------\n    69→# BehaviorClass enum (mirrors common.cuh)\n    70→# ---------------------------------------------------------------------------\n    71→\n    72→FLUID = 0\n    73→GRANULAR = 1\n    74→GAS = 2\n    75→STATIC = 3\n    76→\n    77→# ---------------------------------------------------------------------------\n    78→# MaterialDef dataclass\n    79→# ---------------------------------------------------------------------------\n    80→\n    81→\n    82→@dataclasses.dataclass\n    83→class MaterialDef:\n    84→    \"\"\"Python-side definition of a single material.\n    85→\n    86→    Field names and semantics match the ``MaterialProps`` C struct in common.cuh.\n    87→    \"\"\"\n    88→\n    89→    id: int\n    90→    name: str  # human-readable label (not uploaded to GPU)\n    91→    rest_density: float  # kg/m^3\n    92→    eos_stiffness: float  # Tait EOS k\n    93→    eos_gamma: float  # Tait EOS exponent (7 for liquid, 1 for gas)\n    94→    base_viscosity: float  # Pa*s\n    95→    friction_coeff: float  # mu_s for granular friction\n    96→    cohesion: float  # cohesion coefficient\n    97→    buoyancy_extra: float  # extra buoyancy factor for gas\n    98→    thermal_conductivity: float  # W/(m*K)\n    99→    heat_capacity: float  # J/(kg*K)\n   100→    temp_melt: float  # Kelvin\n   101→    temp_boil: float  # Kelvin\n   102→    temp_ignite: float  # Kelvin (0 = non-flammable)\n   103→    behavior_class: int  # BehaviorClass enum value\n   104→    color_r: float  # default material color R [0,1]\n   105→    color_g: float  # default material color G [0,1]\n   106→    color_b: float  # default material color B [0,1]\n   107→\n   108→    def to_numpy(self) -> np.void:\n   109→        \"\"\"Pack into a single numpy structured-array element.\"\"\"\n   110→        return np.array(\n   111→            (\n   112→                self.rest_density,\n   113→                self.eos_stiffness,\n   114→                self.eos_gamma,\n   115→                self.base_viscosity,\n   116→                self.friction_coeff,\n   117→                self.cohesion,\n   118→                self.buoyancy_extra,\n   119→                self.thermal_conductivity,\n   120→                self.heat_capacity,\n   121→                self.temp_melt,\n   122→                self.temp_boil,\n   123→                self.temp_ignite,\n   124→                self.behavior_class,\n   125→                self.color_r,\n   126→                self.color_g,\n   127→                self.color_b,\n   128→            ),\n   129→            dtype=MATERIAL_PROPS_DTYPE,\n   130→        )\n   131→\n   132→\n   133→# ---------------------------------------------------------------------------\n   134→# Material ID constants\n   135→# ---------------------------------------------------------------------------\n   136→\n   137→DEAD = 0\n   138→STONE = 1\n   139→SAND = 2\n   140→DIRT = 3\n   141→GRAVEL = 4\n   142→WATER = 5\n   143→OIL = 6\n   144→LAVA = 7\n   145→ACID = 8\n   146→WOOD = 9\n   147→METAL = 10\n   148→ICE = 11\n   149→STEAM = 12\n   150→SMOKE = 13\n   151→FIRE = 14\n   152→GUNPOWDER = 15\n   153→\n   154→# ---------------------------------------------------------------------------\n   155→# Material definitions (16 entries, IDs 0-15)\n   156→#\n   157→# Property values chosen for a falling-sand / multi-material SPH game:\n   158→#   - rest_density in kg/m^3 (approximate real-world)\n   159→#   - eos_stiffness: Tait EOS pressure coefficient (game-tuned)\n   160→#   - eos_gamma: 7 for FLUID/GRANULAR, 1 for GAS, 0 for STATIC/DEAD\n   161→#   - base_viscosity in Pa*s (scaled for game feel)\n   162→#   - temperatures in Kelvin\n   163→# ---------------------------------------------------------------------------\n   164→\n   165→MATERIALS: Dict[int, MaterialDef] = {\n   166→    DEAD: MaterialDef(\n   167→        id=DEAD, name=\"DEAD\",\n   168→        rest_density=0.0, eos_stiffness=0.0, eos_gamma=0.0,\n   169→        base_viscosity=0.0, friction_coeff=0.0, cohesion=0.0,\n   170→        buoyancy_extra=0.0, thermal_conductivity=0.0, heat_capacity=0.0,\n   171→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   172→        behavior_class=STATIC,\n   173→        color_r=0.0, color_g=0.0, color_b=0.0,\n   174→    ),\n   175→    STONE: MaterialDef(\n   176→        id=STONE, name=\"STONE\",\n   177→        rest_density=2600.0, eos_stiffness=50.0, eos_gamma=7.0,\n   178→        base_viscosity=0.0, friction_coeff=0.7, cohesion=0.5,\n   179→        buoyancy_extra=0.0, thermal_conductivity=2.0, heat_capacity=800.0,\n   180→        temp_melt=1500.0, temp_boil=3000.0, temp_ignite=0.0,\n   181→        behavior_class=STATIC,\n   182→        color_r=0.5, color_g=0.5, color_b=0.5,\n   183→    ),\n   184→    SAND: MaterialDef(\n   185→        id=SAND, name=\"SAND\",\n   186→        rest_density=1600.0, eos_stiffness=20.0, eos_gamma=7.0,\n   187→        base_viscosity=0.5, friction_coeff=0.6, cohesion=0.0,\n   188→        buoyancy_extra=0.0, thermal_conductivity=0.3, heat_capacity=830.0,\n   189→        temp_melt=1700.0, temp_boil=2500.0, temp_ignite=0.0,\n   190→        behavior_class=GRANULAR,\n   191→        color_r=0.76, color_g=0.70, color_b=0.50,\n   192→    ),\n   193→    DIRT: MaterialDef(\n   194→        id=DIRT, name=\"DIRT\",\n   195→        rest_density=1500.0, eos_stiffness=18.0, eos_gamma=7.0,\n   196→        base_viscosity=0.8, friction_coeff=0.5, cohesion=0.1,\n   197→        buoyancy_extra=0.0, thermal_conductivity=0.25, heat_capacity=900.0,\n   198→        temp_melt=1400.0, temp_boil=2200.0, temp_ignite=0.0,\n   199→        behavior_class=GRANULAR,\n   200→        color_r=0.55, color_g=0.35, color_b=0.17,\n   201→    ),\n   202→    GRAVEL: MaterialDef(\n   203→        id=GRAVEL, name=\"GRAVEL\",\n   204→        rest_density=1800.0, eos_stiffness=25.0, eos_gamma=7.0,\n   205→        base_viscosity=0.3, friction_coeff=0.65, cohesion=0.0,\n   206→        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=840.0,\n   207→        temp_melt=1500.0, temp_boil=2800.0, temp_ignite=0.0,\n   208→        behavior_class=GRANULAR,\n   209→        color_r=0.45, color_g=0.42, color_b=0.40,\n   210→    ),\n   211→    WATER: MaterialDef(\n   212→        id=WATER, name=\"WATER\",\n   213→        rest_density=1000.0, eos_stiffness=10.0, eos_gamma=7.0,\n   214→        base_viscosity=1.0, friction_coeff=0.0, cohesion=0.0,\n   215→        buoyancy_extra=0.0, thermal_conductivity=0.6, heat_capacity=4186.0,\n   216→        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n   217→        behavior_class=FLUID,\n   218→        color_r=0.2, color_g=0.5, color_b=0.9,\n   219→    ),\n   220→    OIL: MaterialDef(\n   221→        id=OIL, name=\"OIL\",\n   222→        rest_density=800.0, eos_stiffness=8.0, eos_gamma=7.0,\n   223→        base_viscosity=5.0, friction_coeff=0.0, cohesion=0.0,\n   224→        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=2000.0,\n   225→        temp_melt=250.0, temp_boil=570.0, temp_ignite=480.0,\n   226→        behavior_class=FLUID,\n   227→        color_r=0.15, color_g=0.10, color_b=0.05,\n   228→    ),\n   229→    LAVA: MaterialDef(\n   230→        id=LAVA, name=\"LAVA\",\n   231→        rest_density=2500.0, eos_stiffness=30.0, eos_gamma=7.0,\n   232→        base_viscosity=100.0, friction_coeff=0.0, cohesion=0.0,\n   233→        buoyancy_extra=0.0, thermal_conductivity=1.5, heat_capacity=1000.0,\n   234→        temp_melt=1000.0, temp_boil=2500.0, temp_ignite=0.0,\n   235→        behavior_class=FLUID,\n   236→        color_r=1.0, color_g=0.3, color_b=0.0,\n   237→    ),\n   238→    ACID: MaterialDef(\n   239→        id=ACID, name=\"ACID\",\n   240→        rest_density=1200.0, eos_stiffness=10.0, eos_gamma=7.0,\n   241→        base_viscosity=1.5, friction_coeff=0.0, cohesion=0.0,\n   242→        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=2500.0,\n   243→        temp_melt=250.0, temp_boil=380.0, temp_ignite=0.0,\n   244→        behavior_class=FLUID,\n   245→        color_r=0.4, color_g=1.0, color_b=0.1,\n   246→    ),\n   247→    WOOD: MaterialDef(\n   248→        id=WOOD, name=\"WOOD\",\n   249→        rest_density=600.0, eos_stiffness=15.0, eos_gamma=7.0,\n   250→        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.3,\n   251→        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=1700.0,\n   252→        temp_melt=0.0, temp_boil=0.0, temp_ignite=570.0,\n   253→        behavior_class=STATIC,\n   254→        color_r=0.55, color_g=0.35, color_b=0.12,\n   255→    ),\n   256→    METAL: MaterialDef(\n   257→        id=METAL, name=\"METAL\",\n   258→        rest_density=7800.0, eos_stiffness=100.0, eos_gamma=7.0,\n   259→        base_viscosity=0.0, friction_coeff=0.6, cohesion=1.0,\n   260→        buoyancy_extra=0.0, thermal_conductivity=50.0, heat_capacity=450.0,\n   261→        temp_melt=1800.0, temp_boil=3300.0, temp_ignite=0.0,\n   262→        behavior_class=STATIC,\n   263→        color_r=0.7, color_g=0.7, color_b=0.75,\n   264→    ),\n   265→    ICE: MaterialDef(\n   266→        id=ICE, name=\"ICE\",\n   267→        rest_density=917.0, eos_stiffness=15.0, eos_gamma=7.0,\n   268→        base_viscosity=0.0, friction_coeff=0.1, cohesion=0.2,\n   269→        buoyancy_extra=0.0, thermal_conductivity=2.2, heat_capacity=2090.0,\n   270→        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n   271→        behavior_class=STATIC,\n   272→        color_r=0.7, color_g=0.9, color_b=1.0,\n   273→    ),\n   274→    STEAM: MaterialDef(\n   275→        id=STEAM, name=\"STEAM\",\n   276→        rest_density=0.6, eos_stiffness=3.0, eos_gamma=1.0,\n   277→        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n   278→        buoyancy_extra=0.01, thermal_conductivity=0.025, heat_capacity=2010.0,\n   279→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   280→        behavior_class=GAS,\n   281→        color_r=0.85, color_g=0.85, color_b=0.90,\n   282→    ),\n   283→    SMOKE: MaterialDef(\n   284→        id=SMOKE, name=\"SMOKE\",\n   285→        rest_density=0.3, eos_stiffness=2.5, eos_gamma=1.0,\n   286→        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n   287→        buoyancy_extra=0.005, thermal_conductivity=0.02, heat_capacity=1000.0,\n   288→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   289→        behavior_class=GAS,\n   290→        color_r=0.3, color_g=0.3, color_b=0.3,\n   291→    ),\n   292→    FIRE: MaterialDef(\n   293→        id=FIRE, name=\"FIRE\",\n   294→        rest_density=0.2, eos_stiffness=4.0, eos_gamma=1.0,\n   295→        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n   296→        buoyancy_extra=0.02, thermal_conductivity=0.05, heat_capacity=1000.0,\n   297→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   298→        behavior_class=GAS,\n   299→        color_r=1.0, color_g=0.6, color_b=0.1,\n   300→    ),\n   301→    GUNPOWDER: MaterialDef(\n   302→        id=GUNPOWDER, name=\"GUNPOWDER\",\n   303→        rest_density=1700.0, eos_stiffness=20.0, eos_gamma=7.0,\n   304→        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.0,\n   305→        buoyancy_extra=0.0, thermal_conductivity=0.2, heat_capacity=800.0,\n   306→        temp_melt=0.0, temp_boil=0.0, temp_ignite=480.0,\n   307→        behavior_class=GRANULAR,\n   308→        color_r=0.2, color_g=0.2, color_b=0.2,\n   309→    ),\n   310→}\n   311→\n   312→assert len(MATERIALS) == NUM_DEFINED\n   313→\n   314→# ---------------------------------------------------------------------------\n   315→# 32x32 Interaction matrix\n   316→#\n   317→# Each (i, j) pair stores reaction_rate and heat_exchange.\n   318→# Only non-trivial pairs are listed; everything else defaults to zero.\n   319→# Symmetric: both (a,b) and (b,a) are set.\n   320→#\n   321→# Key interactions:\n   322→#   water + lava   -> steam (high heat exchange)\n   323→#   acid  + metal  -> reaction_rate 0.3\n   324→#   acid  + stone  -> slow corrosion\n   325→#   acid  + wood   -> slow corrosion\n   326→#   fire  + wood   -> burning\n   327→#   fire  + oil    -> fast burning\n   328→#   fire  + gunpowder -> explosion\n   329→#   lava  + ice    -> steam + stone\n   330→#   lava  + wood   -> burning\n   331→#   water + ice    -> melting\n   332→# ---------------------------------------------------------------------------\n   333→\n   334→# (mat_a, mat_b): (reaction_rate, heat_exchange)\n   335→_INTERACTION_PAIRS: List[Tuple[int, int, float, float]] = [\n   336→    # water interactions\n   337→    (WATER, LAVA, 0.5, 5.0),         # water + lava -> steam, cools lava\n   338→    (WATER, ICE, 0.1, 2.0),          # water near ice -> freezing/melting\n   339→    (WATER, FIRE, 0.8, 3.0),         # water extinguishes fire\n   340→    (WATER, ACID, 0.05, 0.5),        # water dilutes acid slowly\n   341→    # lava interactions\n   342→    (LAVA, ICE, 0.6, 6.0),           # lava melts ice rapidly\n   343→    (LAVA, WOOD, 0.7, 4.0),          # lava ignites wood\n   344→    (LAVA, METAL, 0.05, 3.0),        # lava heats metal\n   345→    (LAVA, STONE, 0.0, 2.0),         # lava heats stone (no reaction, just heat)\n   346→    (LAVA, OIL, 0.8, 5.0),           # lava ignites oil\n   347→    (LAVA, GUNPOWDER, 0.9, 5.0),     # lava detonates gunpowder\n   348→    # acid interactions\n   349→    (ACID, STONE, 0.15, 0.3),        # acid slowly corrodes stone\n   350→    (ACID, METAL, 0.3, 0.5),         # acid corrodes metal\n   351→    (ACID, WOOD, 0.2, 0.2),          # acid corrodes wood\n   352→    (ACID, DIRT, 0.1, 0.1),          # acid dissolves dirt\n   353→    (ACID, ICE, 0.2, 1.0),           # acid melts ice\n   354→    # fire interactions\n   355→    (FIRE, WOOD, 0.6, 2.0),          # fire burns wood\n   356→    (FIRE, OIL, 0.8, 3.0),           # fire burns oil quickly\n   357→    (FIRE, GUNPOWDER, 0.9, 4.0),     # fire detonates gunpowder\n   358→    (FIRE, ICE, 0.3, 2.5),           # fire melts ice\n   359→    (FIRE, SMOKE, 0.0, 0.5),         # fire produces smoke (heat only)\n   360→    # oil interactions\n   361→    (OIL, WATER, 0.0, 0.3),          # oil floats on water (no reaction, low heat)\n   362→    # ice + steam\n   363→    (ICE, STEAM, 0.2, 1.5),          # steam melts ice\n   364→    # metal + fire\n   365→    (FIRE, METAL, 0.0, 2.0),         # fire heats metal (no reaction, heat only)\n   366→    # stone + fire\n   367→    (FIRE, STONE, 0.0, 0.5),         # fire heats stone slowly\n   368→]\n   369→\n   370→\n   371→def build_interaction_matrix() -> np.ndarray:\n   372→    \"\"\"Build the 32x32 interaction matrix as a numpy structured array.\n   373→\n   374→    Returns a (32, 32) array of Interaction structs. Interactions are\n   375→    symmetric: setting (a, b) also sets (b, a).\n   376→    \"\"\"\n   377→    matrix = np.zeros((MAX_MATERIALS, MAX_MATERIALS), dtype=INTERACTION_DTYPE)\n   378→    for a, b, rate, heat in _INTERACTION_PAIRS:\n   379→        matrix[a][b][\"reaction_rate\"] = rate\n   380→        matrix[a][b][\"heat_exchange\"] = heat\n   381→        matrix[b][a][\"reaction_rate\"] = rate\n   382→        matrix[b][a][\"heat_exchange\"] = heat\n   383→    return matrix\n   384→\n   385→\n   386→def build_material_array() -> np.ndarray:\n   387→    \"\"\"Build the MaterialProps[32] array as a numpy structured array.\n   388→\n   389→    IDs 0-15 come from MATERIALS; IDs 16-31 are zeroed (reserved).\n   390→    \"\"\"\n   391→    arr = np.zeros(MAX_MATERIALS, dtype=MATERIAL_PROPS_DTYPE)\n   392→    for mat_id, mat_def in MATERIALS.items():\n   393→        arr[mat_id] = mat_def.to_numpy()\n   394→    return arr\n   395→\n   396→\n   397→# ---------------------------------------------------------------------------\n   398→# GPU upload via CuPy RawModule\n   399→# ---------------------------------------------------------------------------\n   400→\n   401→# Cached CuPy RawModule (compiled on first use)\n   402→_module: Optional[object] = None\n   403→\n   404→\n   405→def _ensure_ptx_if_needed() -> None:\n   406→    \"\"\"Force PTX compilation when the GPU arch exceeds NVRTC's max sm target.\"\"\"\n   407→    from cupy.cuda import compiler as _compiler\n   408→    from cupy.cuda import device as _device\n   409→\n   410→    gpu_cc = _device.Device().compute_capability\n   411→    nvrtc_max = _compiler._get_max_compute_capability()\n   412→    if int(gpu_cc) > int(nvrtc_max):\n   413→        _compiler._use_ptx = True\n   414→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n   415→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n   416→        if hasattr(_compiler._get_arch, \"_cache\"):\n   417→            _compiler._get_arch._cache = {}\n   418→\n   419→\n   420→def _get_module() -> \"object\":\n   421→    \"\"\"Compile (or return cached) CuPy RawModule with common.cuh included.\"\"\"\n   422→    global _module\n   423→    if _module is None:\n   424→        import cupy\n   425→\n   426→        _ensure_ptx_if_needed()\n   427→        kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   428→        # Minimal CUDA source that includes common.cuh for its constant memory\n   429→        # declarations, plus a test kernel for verification.\n   430→        source = r\"\"\"\n   431→#include \"common.cuh\"\n   432→\n   433→extern \"C\" __global__\n   434→void test_read_materials(float* out) {\n   435→    // out[0] = c_materials[5].rest_density   (water -> 1000.0)\n   436→    // out[1] = c_interactions[8][10].reaction_rate  (acid-metal -> 0.3)\n   437→    out[0] = c_materials[5].rest_density;\n   438→    out[1] = c_interactions[8][10].reaction_rate;\n   439→}\n   440→\"\"\"\n   441→        _module = cupy.RawModule(\n   442→            code=source,\n   443→            options=(\"--std=c++11\", f\"-I{kernel_dir}\"),\n   444→        )\n   445→    return _module\n   446→\n   447→\n   448→def upload_to_gpu(module: Optional[object] = None) -> None:\n   449→    \"\"\"Copy MaterialProps[32] and Interaction[32][32] to CUDA constant memory.\n   450→\n   451→    Parameters\n   452→    ----------\n   453→    module : CuPy RawModule, optional\n   454→        If provided, upload to this module's constant memory symbols.\n   455→        If None, uses the internal module from _get_module().\n   456→    \"\"\"\n   457→    import cupy\n   458→\n   459→    cudaMemcpyHostToDevice = 1\n   460→\n   461→    if module is None:\n   462→        module = _get_module()\n   463→\n   464→    h_materials = build_material_array()\n   465→    h_interactions = build_interaction_matrix()\n   466→\n   467→    d_materials_ptr = module.get_global(\"c_materials\")\n   468→    d_interactions_ptr = module.get_global(\"c_interactions\")\n   469→\n   470→    cupy.cuda.runtime.memcpy(\n   471→        int(d_materials_ptr),\n   472→        h_materials.ctypes.data,\n   473→        h_materials.nbytes,\n   474→        cudaMemcpyHostToDevice,\n   475→    )\n   476→\n   477→    cupy.cuda.runtime.memcpy(\n   478→        int(d_interactions_ptr),\n   479→        h_interactions.ctypes.data,\n   480→        h_interactions.nbytes,\n   481→        cudaMemcpyHostToDevice,\n   482→    )\n   483→\n   484→\n   485→def get_module() -> \"object\":\n   486→    \"\"\"Return the compiled CuPy RawModule (public accessor for tests).\"\"\"\n   487→    return _get_module()\n   488→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f78301fc-4ded-4a94-a553-b435335d3972","uuid":"b9deb212-c781-441e-9be0-c50a40b8e898","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/materials.py","content":"\"\"\"Material property table and interaction matrix for multi-material SPH.\n\nDefines 16 materials (IDs 0-15) as Python dataclasses, a 32x32 interaction\nmatrix, and an upload_to_gpu() function that copies both tables to CUDA\nconstant memory via CuPy RawModule symbol lookup.\n\nStruct layout matches fallingsand3d/physics/kernels/common.cuh exactly.\n\nConstant-memory symbols\n-----------------------\n- ``c_materials``   : MaterialProps[32]\n- ``c_interactions`` : Interaction[32][32]\n\"\"\"\n\nfrom __future__ import annotations\n\nimport dataclasses\nimport os\nfrom typing import Dict, List, Optional, Tuple\n\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# Numpy structured dtypes matching the C structs in common.cuh\n# ---------------------------------------------------------------------------\n\nMATERIAL_PROPS_DTYPE = np.dtype(\n    [\n        (\"rest_density\", np.float32),\n        (\"eos_stiffness\", np.float32),\n        (\"eos_gamma\", np.float32),\n        (\"base_viscosity\", np.float32),\n        (\"friction_coeff\", np.float32),\n        (\"cohesion\", np.float32),\n        (\"buoyancy_extra\", np.float32),\n        (\"thermal_conductivity\", np.float32),\n        (\"heat_capacity\", np.float32),\n        (\"temp_melt\", np.float32),\n        (\"temp_boil\", np.float32),\n        (\"temp_ignite\", np.float32),\n        (\"behavior_class\", np.int32),\n        (\"color_r\", np.float32),\n        (\"color_g\", np.float32),\n        (\"color_b\", np.float32),\n    ],\n    align=True,\n)\n\nINTERACTION_DTYPE = np.dtype(\n    [\n        (\"reaction_rate\", np.float32),\n        (\"heat_exchange\", np.float32),\n    ],\n    align=True,\n)\n\n# Compile-time size checks (must match sizeof(MaterialProps) and sizeof(Interaction))\nassert MATERIAL_PROPS_DTYPE.itemsize == 64, (\n    f\"MaterialProps size mismatch: {MATERIAL_PROPS_DTYPE.itemsize} != 64\"\n)\nassert INTERACTION_DTYPE.itemsize == 8, (\n    f\"Interaction size mismatch: {INTERACTION_DTYPE.itemsize} != 8\"\n)\n\nMAX_MATERIALS = 32  # slots in constant memory (IDs 0-31)\nNUM_DEFINED = 16  # IDs 0-15 are defined; 16-31 reserved (zeroed)\n\n# ---------------------------------------------------------------------------\n# BehaviorClass enum (mirrors common.cuh)\n# ---------------------------------------------------------------------------\n\nFLUID = 0\nGRANULAR = 1\nGAS = 2\nSTATIC = 3\n\n# ---------------------------------------------------------------------------\n# MaterialDef dataclass\n# ---------------------------------------------------------------------------\n\n\n@dataclasses.dataclass\nclass MaterialDef:\n    \"\"\"Python-side definition of a single material.\n\n    Field names and semantics match the ``MaterialProps`` C struct in common.cuh.\n    \"\"\"\n\n    id: int\n    name: str  # human-readable label (not uploaded to GPU)\n    rest_density: float  # kg/m^3\n    eos_stiffness: float  # Tait EOS k\n    eos_gamma: float  # Tait EOS exponent (7 for liquid, 1 for gas)\n    base_viscosity: float  # Pa*s\n    friction_coeff: float  # mu_s for granular friction\n    cohesion: float  # cohesion coefficient\n    buoyancy_extra: float  # extra buoyancy factor for gas\n    thermal_conductivity: float  # W/(m*K)\n    heat_capacity: float  # J/(kg*K)\n    temp_melt: float  # Kelvin\n    temp_boil: float  # Kelvin\n    temp_ignite: float  # Kelvin (0 = non-flammable)\n    behavior_class: int  # BehaviorClass enum value\n    color_r: float  # default material color R [0,1]\n    color_g: float  # default material color G [0,1]\n    color_b: float  # default material color B [0,1]\n\n    def to_numpy(self) -> np.void:\n        \"\"\"Pack into a single numpy structured-array element.\"\"\"\n        return np.array(\n            (\n                self.rest_density,\n                self.eos_stiffness,\n                self.eos_gamma,\n                self.base_viscosity,\n                self.friction_coeff,\n                self.cohesion,\n                self.buoyancy_extra,\n                self.thermal_conductivity,\n                self.heat_capacity,\n                self.temp_melt,\n                self.temp_boil,\n                self.temp_ignite,\n                self.behavior_class,\n                self.color_r,\n                self.color_g,\n                self.color_b,\n            ),\n            dtype=MATERIAL_PROPS_DTYPE,\n        )\n\n\n# ---------------------------------------------------------------------------\n# Material ID constants\n# ---------------------------------------------------------------------------\n\nDEAD = 0\nSTONE = 1\nSAND = 2\nDIRT = 3\nGRAVEL = 4\nWATER = 5\nOIL = 6\nLAVA = 7\nACID = 8\nWOOD = 9\nMETAL = 10\nICE = 11\nSTEAM = 12\nSMOKE = 13\nFIRE = 14\nGUNPOWDER = 15\n\n# ---------------------------------------------------------------------------\n# Material definitions (16 entries, IDs 0-15)\n#\n# Property values chosen for a falling-sand / multi-material SPH game:\n#   - rest_density in kg/m^3 (approximate real-world)\n#   - eos_stiffness: Tait EOS pressure coefficient (game-tuned)\n#   - eos_gamma: 7 for FLUID/GRANULAR, 1 for GAS, 0 for STATIC/DEAD\n#   - base_viscosity in Pa*s (scaled for game feel)\n#   - temperatures in Kelvin\n# ---------------------------------------------------------------------------\n\nMATERIALS: Dict[int, MaterialDef] = {\n    DEAD: MaterialDef(\n        id=DEAD, name=\"DEAD\",\n        rest_density=0.0, eos_stiffness=0.0, eos_gamma=0.0,\n        base_viscosity=0.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.0, heat_capacity=0.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.0, color_g=0.0, color_b=0.0,\n    ),\n    STONE: MaterialDef(\n        id=STONE, name=\"STONE\",\n        rest_density=2600.0, eos_stiffness=50.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.7, cohesion=0.5,\n        buoyancy_extra=0.0, thermal_conductivity=2.0, heat_capacity=800.0,\n        temp_melt=1500.0, temp_boil=3000.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.5, color_g=0.5, color_b=0.5,\n    ),\n    SAND: MaterialDef(\n        id=SAND, name=\"SAND\",\n        rest_density=1600.0, eos_stiffness=20.0, eos_gamma=7.0,\n        base_viscosity=0.5, friction_coeff=0.6, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.3, heat_capacity=830.0,\n        temp_melt=1700.0, temp_boil=2500.0, temp_ignite=0.0,\n        behavior_class=GRANULAR,\n        color_r=0.76, color_g=0.70, color_b=0.50,\n    ),\n    DIRT: MaterialDef(\n        id=DIRT, name=\"DIRT\",\n        rest_density=1500.0, eos_stiffness=18.0, eos_gamma=7.0,\n        base_viscosity=0.8, friction_coeff=0.5, cohesion=0.1,\n        buoyancy_extra=0.0, thermal_conductivity=0.25, heat_capacity=900.0,\n        temp_melt=1400.0, temp_boil=2200.0, temp_ignite=0.0,\n        behavior_class=GRANULAR,\n        color_r=0.55, color_g=0.35, color_b=0.17,\n    ),\n    GRAVEL: MaterialDef(\n        id=GRAVEL, name=\"GRAVEL\",\n        rest_density=1800.0, eos_stiffness=25.0, eos_gamma=7.0,\n        base_viscosity=0.3, friction_coeff=0.65, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=840.0,\n        temp_melt=1500.0, temp_boil=2800.0, temp_ignite=0.0,\n        behavior_class=GRANULAR,\n        color_r=0.45, color_g=0.42, color_b=0.40,\n    ),\n    WATER: MaterialDef(\n        id=WATER, name=\"WATER\",\n        rest_density=1000.0, eos_stiffness=10.0, eos_gamma=7.0,\n        base_viscosity=1.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.6, heat_capacity=4186.0,\n        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n        behavior_class=FLUID,\n        color_r=0.2, color_g=0.5, color_b=0.9,\n    ),\n    OIL: MaterialDef(\n        id=OIL, name=\"OIL\",\n        rest_density=800.0, eos_stiffness=8.0, eos_gamma=7.0,\n        base_viscosity=5.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=2000.0,\n        temp_melt=250.0, temp_boil=570.0, temp_ignite=480.0,\n        behavior_class=FLUID,\n        color_r=0.15, color_g=0.10, color_b=0.05,\n    ),\n    LAVA: MaterialDef(\n        id=LAVA, name=\"LAVA\",\n        rest_density=2500.0, eos_stiffness=30.0, eos_gamma=7.0,\n        base_viscosity=100.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=1.5, heat_capacity=1000.0,\n        temp_melt=1000.0, temp_boil=2500.0, temp_ignite=0.0,\n        behavior_class=FLUID,\n        color_r=1.0, color_g=0.3, color_b=0.0,\n    ),\n    ACID: MaterialDef(\n        id=ACID, name=\"ACID\",\n        rest_density=1200.0, eos_stiffness=10.0, eos_gamma=7.0,\n        base_viscosity=1.5, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=2500.0,\n        temp_melt=250.0, temp_boil=380.0, temp_ignite=0.0,\n        behavior_class=FLUID,\n        color_r=0.4, color_g=1.0, color_b=0.1,\n    ),\n    WOOD: MaterialDef(\n        id=WOOD, name=\"WOOD\",\n        rest_density=600.0, eos_stiffness=15.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.3,\n        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=1700.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=570.0,\n        behavior_class=STATIC,\n        color_r=0.55, color_g=0.35, color_b=0.12,\n    ),\n    METAL: MaterialDef(\n        id=METAL, name=\"METAL\",\n        rest_density=7800.0, eos_stiffness=100.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.6, cohesion=1.0,\n        buoyancy_extra=0.0, thermal_conductivity=50.0, heat_capacity=450.0,\n        temp_melt=1800.0, temp_boil=3300.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.7, color_g=0.7, color_b=0.75,\n    ),\n    ICE: MaterialDef(\n        id=ICE, name=\"ICE\",\n        rest_density=917.0, eos_stiffness=15.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.1, cohesion=0.2,\n        buoyancy_extra=0.0, thermal_conductivity=2.2, heat_capacity=2090.0,\n        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.7, color_g=0.9, color_b=1.0,\n    ),\n    STEAM: MaterialDef(\n        id=STEAM, name=\"STEAM\",\n        rest_density=0.6, eos_stiffness=3.0, eos_gamma=1.0,\n        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.01, thermal_conductivity=0.025, heat_capacity=2010.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=GAS,\n        color_r=0.85, color_g=0.85, color_b=0.90,\n    ),\n    SMOKE: MaterialDef(\n        id=SMOKE, name=\"SMOKE\",\n        rest_density=0.3, eos_stiffness=2.5, eos_gamma=1.0,\n        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.005, thermal_conductivity=0.02, heat_capacity=1000.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=GAS,\n        color_r=0.3, color_g=0.3, color_b=0.3,\n    ),\n    FIRE: MaterialDef(\n        id=FIRE, name=\"FIRE\",\n        rest_density=0.2, eos_stiffness=4.0, eos_gamma=1.0,\n        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.02, thermal_conductivity=0.05, heat_capacity=1000.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=GAS,\n        color_r=1.0, color_g=0.6, color_b=0.1,\n    ),\n    GUNPOWDER: MaterialDef(\n        id=GUNPOWDER, name=\"GUNPOWDER\",\n        rest_density=1700.0, eos_stiffness=20.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.2, heat_capacity=800.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=480.0,\n        behavior_class=GRANULAR,\n        color_r=0.2, color_g=0.2, color_b=0.2,\n    ),\n}\n\nassert len(MATERIALS) == NUM_DEFINED\n\n# ---------------------------------------------------------------------------\n# 32x32 Interaction matrix\n#\n# Each (i, j) pair stores reaction_rate and heat_exchange.\n# Only non-trivial pairs are listed; everything else defaults to zero.\n# Symmetric: both (a,b) and (b,a) are set.\n#\n# Key interactions:\n#   water + lava   -> steam (high heat exchange)\n#   acid  + metal  -> reaction_rate 0.3\n#   acid  + stone  -> slow corrosion\n#   acid  + wood   -> slow corrosion\n#   fire  + wood   -> burning\n#   fire  + oil    -> fast burning\n#   fire  + gunpowder -> explosion\n#   lava  + ice    -> steam + stone\n#   lava  + wood   -> burning\n#   water + ice    -> melting\n# ---------------------------------------------------------------------------\n\n# (mat_a, mat_b): (reaction_rate, heat_exchange)\n_INTERACTION_PAIRS: List[Tuple[int, int, float, float]] = [\n    # water interactions\n    (WATER, LAVA, 0.5, 5.0),         # water + lava -> steam, cools lava\n    (WATER, ICE, 0.1, 2.0),          # water near ice -> freezing/melting\n    (WATER, FIRE, 0.8, 3.0),         # water extinguishes fire\n    (WATER, ACID, 0.05, 0.5),        # water dilutes acid slowly\n    # lava interactions\n    (LAVA, ICE, 0.6, 6.0),           # lava melts ice rapidly\n    (LAVA, WOOD, 0.7, 4.0),          # lava ignites wood\n    (LAVA, METAL, 0.05, 3.0),        # lava heats metal\n    (LAVA, STONE, 0.0, 2.0),         # lava heats stone (no reaction, just heat)\n    (LAVA, OIL, 0.8, 5.0),           # lava ignites oil\n    (LAVA, GUNPOWDER, 0.9, 5.0),     # lava detonates gunpowder\n    # acid interactions\n    (ACID, STONE, 0.15, 0.3),        # acid slowly corrodes stone\n    (ACID, METAL, 0.3, 0.5),         # acid corrodes metal\n    (ACID, WOOD, 0.2, 0.2),          # acid corrodes wood\n    (ACID, DIRT, 0.1, 0.1),          # acid dissolves dirt\n    (ACID, ICE, 0.2, 1.0),           # acid melts ice\n    # fire interactions\n    (FIRE, WOOD, 0.6, 2.0),          # fire burns wood\n    (FIRE, OIL, 0.8, 3.0),           # fire burns oil quickly\n    (FIRE, GUNPOWDER, 0.9, 4.0),     # fire detonates gunpowder\n    (FIRE, ICE, 0.3, 2.5),           # fire melts ice\n    (FIRE, SMOKE, 0.0, 0.5),         # fire produces smoke (heat only)\n    # oil interactions\n    (OIL, WATER, 0.0, 0.3),          # oil floats on water (no reaction, low heat)\n    # ice + steam\n    (ICE, STEAM, 0.2, 1.5),          # steam melts ice\n    # metal + fire\n    (FIRE, METAL, 0.0, 2.0),         # fire heats metal (no reaction, heat only)\n    # stone + fire\n    (FIRE, STONE, 0.0, 0.5),         # fire heats stone slowly\n]\n\n\ndef build_interaction_matrix() -> np.ndarray:\n    \"\"\"Build the 32x32 interaction matrix as a numpy structured array.\n\n    Returns a (32, 32) array of Interaction structs. Interactions are\n    symmetric: setting (a, b) also sets (b, a).\n    \"\"\"\n    matrix = np.zeros((MAX_MATERIALS, MAX_MATERIALS), dtype=INTERACTION_DTYPE)\n    for a, b, rate, heat in _INTERACTION_PAIRS:\n        matrix[a][b][\"reaction_rate\"] = rate\n        matrix[a][b][\"heat_exchange\"] = heat\n        matrix[b][a][\"reaction_rate\"] = rate\n        matrix[b][a][\"heat_exchange\"] = heat\n    return matrix\n\n\ndef build_material_array() -> np.ndarray:\n    \"\"\"Build the MaterialProps[32] array as a numpy structured array.\n\n    IDs 0-15 come from MATERIALS; IDs 16-31 are zeroed (reserved).\n    \"\"\"\n    arr = np.zeros(MAX_MATERIALS, dtype=MATERIAL_PROPS_DTYPE)\n    for mat_id, mat_def in MATERIALS.items():\n        arr[mat_id] = mat_def.to_numpy()\n    return arr\n\n\n# ---------------------------------------------------------------------------\n# GPU upload via CuPy RawModule\n# ---------------------------------------------------------------------------\n\n# Cached CuPy RawModule (compiled on first use)\n_module: Optional[object] = None\n\n\ndef _ensure_ptx_if_needed() -> None:\n    \"\"\"Force PTX compilation when the GPU arch exceeds NVRTC's max sm target.\"\"\"\n    from cupy.cuda import compiler as _compiler\n    from cupy.cuda import device as _device\n\n    gpu_cc = _device.Device().compute_capability\n    nvrtc_max = _compiler._get_max_compute_capability()\n    if int(gpu_cc) > int(nvrtc_max):\n        _compiler._use_ptx = True\n        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n        if hasattr(_compiler._get_arch, \"_cache\"):\n            _compiler._get_arch._cache = {}\n\n\ndef _get_module() -> \"object\":\n    \"\"\"Compile (or return cached) CuPy RawModule with common.cuh included.\"\"\"\n    global _module\n    if _module is None:\n        import cupy\n\n        _ensure_ptx_if_needed()\n        kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n        # Minimal CUDA source that includes common.cuh for its constant memory\n        # declarations, plus a test kernel for verification.\n        source = r\"\"\"\n#include \"common.cuh\"\n\nextern \"C\" __global__\nvoid test_read_materials(float* out) {\n    // out[0] = c_materials[5].rest_density   (water -> 1000.0)\n    // out[1] = c_interactions[8][10].reaction_rate  (acid-metal -> 0.3)\n    out[0] = c_materials[5].rest_density;\n    out[1] = c_interactions[8][10].reaction_rate;\n}\n\"\"\"\n        _module = cupy.RawModule(\n            code=source,\n            options=(\"--std=c++11\", f\"-I{kernel_dir}\"),\n        )\n    return _module\n\n\ndef upload_to_gpu(module: Optional[object] = None) -> None:\n    \"\"\"Copy MaterialProps[32] and Interaction[32][32] to CUDA constant memory.\n\n    Parameters\n    ----------\n    module : CuPy RawModule, optional\n        If provided, upload to this module's constant memory symbols.\n        If None, uses the internal module from _get_module().\n    \"\"\"\n    import cupy\n\n    cudaMemcpyHostToDevice = 1\n\n    if module is None:\n        module = _get_module()\n\n    h_materials = build_material_array()\n    h_interactions = build_interaction_matrix()\n\n    d_materials_ptr = module.get_global(\"c_materials\")\n    d_interactions_ptr = module.get_global(\"c_interactions\")\n\n    cupy.cuda.runtime.memcpy(\n        int(d_materials_ptr),\n        h_materials.ctypes.data,\n        h_materials.nbytes,\n        cudaMemcpyHostToDevice,\n    )\n\n    cupy.cuda.runtime.memcpy(\n        int(d_interactions_ptr),\n        h_interactions.ctypes.data,\n        h_interactions.nbytes,\n        cudaMemcpyHostToDevice,\n    )\n\n\ndef get_module() -> \"object\":\n    \"\"\"Return the compiled CuPy RawModule (public accessor for tests).\"\"\"\n    return _get_module()\n","numLines":488,"startLine":1,"totalLines":488}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Piq1sth8LNVa3pGixgKC9W","type":"tool_result","content":"     1→\"\"\"Integration tests for reactions.py -- K_Reactions kernel.\n     2→\n     3→Acceptance criteria:\n     4→  - ICE (mat=11, temp > 273K) -> WATER (mat=5, FLUID)\n     5→  - LAVA (mat=7, temp < 900K) -> STONE (mat=1, STATIC)\n     6→  - WATER (mat=5, temp > 373K) -> set SPAWN_GAS flag\n     7→  - WOOD (mat=9, exposure_heat > 0.5) -> FIRE (mat=14, GAS, T=1200K, lifetime=1.0s)\n     8→  - OIL (mat=6, exposure_heat > 0.3) -> FIRE (mat=14, GAS, T=1200K, lifetime=1.5s)\n     9→  - GUNPOWDER (mat=15, exposure_heat > 0.1) -> FIRE + explosion velocity\n    10→  - Corrosion: health -= exposure_corrode * dt; health <= 0 -> DEAD\n    11→  - GAS lifetime: lifetime -= dt; lifetime <= 0 -> DEAD\n    12→  - STEAM (mat=12, temp < 373K) -> WATER (mat=5, FLUID)\n    13→  - Exposure accumulators reset to 0 after use (inherent: sorted ephemeral arrays)\n    14→  - Block size = 256, kernel runs without errors\n    15→\n    16→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    17→\"\"\"\n    18→\n    19→from __future__ import annotations\n    20→\n    21→import os\n    22→import sys\n    23→\n    24→sys.path.insert(0, os.path.dirname(__file__))\n    25→\n    26→import cupy\n    27→import numpy as np\n    28→\n    29→from step1 import (\n    30→    SIM_PARAMS_DTYPE,\n    31→    build_sim_params,\n    32→)\n    33→from materials import (\n    34→    FLUID, GRANULAR, GAS, STATIC,\n    35→    DEAD, STONE, SAND, WATER, OIL, LAVA, WOOD, METAL, ICE, STEAM, FIRE, GUNPOWDER,\n    36→    build_material_array,\n    37→)\n    38→from reactions import (\n    39→    BLOCK_SIZE,\n    40→    get_module,\n    41→    compute_reactions,\n    42→    upload_sim_params,\n    43→    upload_materials,\n    44→)\n    45→\n    46→# ---------------------------------------------------------------------------\n    47→# Constants\n    48→# ---------------------------------------------------------------------------\n    49→\n    50→H = 0.04\n    51→SPACING = 0.02\n    52→DT = 0.001\n    53→\n    54→# packed_info helpers (mirror common.cuh)\n    55→def MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    56→    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n    57→\n    58→def GET_MATERIAL_ID(p: int) -> int:\n    59→    return p & 0xFF\n    60→\n    61→def GET_BEHAVIOR(p: int) -> int:\n    62→    return (p >> 8) & 0x3\n    63→\n    64→def HAS_SPAWN_FLAG(p: int) -> int:\n    65→    return (p >> 11) & 1\n    66→\n    67→# ---------------------------------------------------------------------------\n    68→# Helper: upload params for all tests\n    69→# ---------------------------------------------------------------------------\n    70→\n    71→def setup_params(dt=DT):\n    72→    \"\"\"Upload SimParams and materials to reactions module's constant memory.\"\"\"\n    73→    sim_params = build_sim_params(\n    74→        smoothing_length=H,\n    75→        particle_mass=0.008,\n    76→        particle_spacing=SPACING,\n    77→        gravity=(0.0, -9.8, 0.0),\n    78→        dt=dt,\n    79→        restitution=0.3,\n    80→        wall_friction=0.5,\n    81→        world_min=(-1.0, -1.0, -1.0),\n    82→        world_max=(1.0, 1.0, 1.0),\n    83→    )\n    84→    upload_sim_params(sim_params)\n    85→    materials = build_material_array()\n    86→    upload_materials(materials)\n    87→\n    88→\n    89→def make_particles(n, mat_id, behavior, temp=293.0, health=1.0, lifetime=0.0,\n    90→                   vel=None, exposure_heat=0.0, exposure_corrode=0.0):\n    91→    \"\"\"Create sorted particle arrays for testing reactions kernel.\"\"\"\n    92→    packed_info = np.full(n, MAKE_PACKED(mat_id, behavior), dtype=np.uint32)\n    93→    temperature = np.full(n, temp, dtype=np.float32)\n    94→    hlth = np.full(n, health, dtype=np.float32)\n    95→    lt = np.full(n, lifetime, dtype=np.float32)\n    96→\n    97→    if vel is None:\n    98→        velocity = np.zeros((n, 4), dtype=np.float32)\n    99→    else:\n   100→        velocity = np.array(vel, dtype=np.float32).reshape(n, 4)\n   101→\n   102→    exp_heat = np.full(n, exposure_heat, dtype=np.float32)\n   103→    exp_corrode = np.full(n, exposure_corrode, dtype=np.float32)\n   104→\n   105→    return {\n   106→        \"sorted_packed_info\": cupy.asarray(packed_info),\n   107→        \"sorted_temperature\": cupy.asarray(temperature),\n   108→        \"sorted_health\": cupy.asarray(hlth),\n   109→        \"sorted_lifetime\": cupy.asarray(lt),\n   110→        \"sorted_velocity\": cupy.asarray(velocity),\n   111→        \"sorted_exposure_heat\": cupy.asarray(exp_heat),\n   112→        \"sorted_exposure_corrode\": cupy.asarray(exp_corrode),\n   113→    }\n   114→\n   115→\n   116→# ---------------------------------------------------------------------------\n   117→# Tests\n   118→# ---------------------------------------------------------------------------\n   119→\n   120→def test_compilation():\n   121→    \"\"\"Kernel compiles without errors.\"\"\"\n   122→    module = get_module()\n   123→    kernel = module.get_function(\"K_Reactions\")\n   124→    assert kernel is not None\n   125→    print(\"PASS: test_compilation\")\n   126→\n   127→\n   128→def test_block_size():\n   129→    \"\"\"Block size is 256.\"\"\"\n   130→    assert BLOCK_SIZE == 256\n   131→    print(\"PASS: test_block_size\")\n   132→\n   133→\n   134→def test_ice_melts_to_water():\n   135→    \"\"\"ICE at temp > 273K transitions to WATER (FLUID).\"\"\"\n   136→    setup_params()\n   137→    d = make_particles(100, ICE, STATIC, temp=280.0)\n   138→    compute_reactions(**d)\n   139→\n   140→    pi = d[\"sorted_packed_info\"].get()\n   141→    for i in range(100):\n   142→        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"Particle {i}: expected WATER, got {GET_MATERIAL_ID(int(pi[i]))}\"\n   143→        assert GET_BEHAVIOR(int(pi[i])) == FLUID, f\"Particle {i}: expected FLUID\"\n   144→    print(\"PASS: test_ice_melts_to_water\")\n   145→\n   146→\n   147→def test_ice_stays_frozen():\n   148→    \"\"\"ICE at temp < 273K stays as ICE.\"\"\"\n   149→    setup_params()\n   150→    d = make_particles(100, ICE, STATIC, temp=200.0)\n   151→    compute_reactions(**d)\n   152→\n   153→    pi = d[\"sorted_packed_info\"].get()\n   154→    for i in range(100):\n   155→        assert GET_MATERIAL_ID(int(pi[i])) == ICE, f\"Particle {i}: should stay ICE\"\n   156→    print(\"PASS: test_ice_stays_frozen\")\n   157→\n   158→\n   159→def test_lava_solidifies_to_stone():\n   160→    \"\"\"LAVA at temp < 900K transitions to STONE (STATIC).\"\"\"\n   161→    setup_params()\n   162→    d = make_particles(100, LAVA, FLUID, temp=800.0)\n   163→    compute_reactions(**d)\n   164→\n   165→    pi = d[\"sorted_packed_info\"].get()\n   166→    for i in range(100):\n   167→        assert GET_MATERIAL_ID(int(pi[i])) == STONE, f\"Particle {i}: expected STONE\"\n   168→        assert GET_BEHAVIOR(int(pi[i])) == STATIC, f\"Particle {i}: expected STATIC\"\n   169→    print(\"PASS: test_lava_solidifies_to_stone\")\n   170→\n   171→\n   172→def test_lava_stays_liquid():\n   173→    \"\"\"LAVA at temp > 900K stays as LAVA.\"\"\"\n   174→    setup_params()\n   175→    d = make_particles(100, LAVA, FLUID, temp=1500.0)\n   176→    compute_reactions(**d)\n   177→\n   178→    pi = d[\"sorted_packed_info\"].get()\n   179→    for i in range(100):\n   180→        assert GET_MATERIAL_ID(int(pi[i])) == LAVA, f\"Particle {i}: should stay LAVA\"\n   181→    print(\"PASS: test_lava_stays_liquid\")\n   182→\n   183→\n   184→def test_water_boils_sets_spawn_flag():\n   185→    \"\"\"WATER at temp > 373K gets SPAWN_GAS flag set.\"\"\"\n   186→    setup_params()\n   187→    d = make_particles(100, WATER, FLUID, temp=400.0)\n   188→    compute_reactions(**d)\n   189→\n   190→    pi = d[\"sorted_packed_info\"].get()\n   191→    for i in range(100):\n   192→        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"Particle {i}: should still be WATER\"\n   193→        assert HAS_SPAWN_FLAG(int(pi[i])) == 1, f\"Particle {i}: SPAWN_GAS flag not set\"\n   194→    print(\"PASS: test_water_boils_sets_spawn_flag\")\n   195→\n   196→\n   197→def test_water_cool_no_spawn():\n   198→    \"\"\"WATER at temp < 373K does NOT get SPAWN_GAS flag.\"\"\"\n   199→    setup_params()\n   200→    d = make_particles(100, WATER, FLUID, temp=300.0)\n   201→    compute_reactions(**d)\n   202→\n   203→    pi = d[\"sorted_packed_info\"].get()\n   204→    for i in range(100):\n   205→        assert HAS_SPAWN_FLAG(int(pi[i])) == 0, f\"Particle {i}: should not have SPAWN_GAS\"\n   206→    print(\"PASS: test_water_cool_no_spawn\")\n   207→\n   208→\n   209→def test_steam_condenses_to_water():\n   210→    \"\"\"STEAM at temp < 373K transitions to WATER (FLUID).\"\"\"\n   211→    setup_params()\n   212→    d = make_particles(100, STEAM, GAS, temp=350.0)\n   213→    compute_reactions(**d)\n   214→\n   215→    pi = d[\"sorted_packed_info\"].get()\n   216→    for i in range(100):\n   217→        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"Particle {i}: expected WATER\"\n   218→        assert GET_BEHAVIOR(int(pi[i])) == FLUID, f\"Particle {i}: expected FLUID\"\n   219→    print(\"PASS: test_steam_condenses_to_water\")\n   220→\n   221→\n   222→def test_steam_stays_gas():\n   223→    \"\"\"STEAM at temp > 373K stays as STEAM.\"\"\"\n   224→    setup_params()\n   225→    d = make_particles(100, STEAM, GAS, temp=400.0)\n   226→    compute_reactions(**d)\n   227→\n   228→    pi = d[\"sorted_packed_info\"].get()\n   229→    for i in range(100):\n   230→        assert GET_MATERIAL_ID(int(pi[i])) == STEAM, f\"Particle {i}: should stay STEAM\"\n   231→    print(\"PASS: test_steam_stays_gas\")\n   232→\n   233→\n   234→def test_wood_ignites():\n   235→    \"\"\"WOOD with exposure_heat > 0.5 transitions to FIRE (GAS, T=1200K, lifetime=1.0s).\"\"\"\n   236→    setup_params()\n   237→    d = make_particles(100, WOOD, STATIC, exposure_heat=0.6)\n   238→    compute_reactions(**d)\n   239→\n   240→    pi = d[\"sorted_packed_info\"].get()\n   241→    temp = d[\"sorted_temperature\"].get()\n   242→    lt = d[\"sorted_lifetime\"].get()\n   243→    for i in range(100):\n   244→        assert GET_MATERIAL_ID(int(pi[i])) == FIRE, f\"Particle {i}: expected FIRE\"\n   245→        assert GET_BEHAVIOR(int(pi[i])) == GAS, f\"Particle {i}: expected GAS\"\n   246→        assert abs(temp[i] - 1200.0) < 1.0, f\"Particle {i}: temp={temp[i]}, expected 1200\"\n   247→        assert abs(lt[i] - 1.0) < 0.01, f\"Particle {i}: lifetime={lt[i]}, expected 1.0\"\n   248→    print(\"PASS: test_wood_ignites\")\n   249→\n   250→\n   251→def test_wood_no_ignite():\n   252→    \"\"\"WOOD with exposure_heat < 0.5 stays as WOOD.\"\"\"\n   253→    setup_params()\n   254→    d = make_particles(100, WOOD, STATIC, exposure_heat=0.3)\n   255→    compute_reactions(**d)\n   256→\n   257→    pi = d[\"sorted_packed_info\"].get()\n   258→    for i in range(100):\n   259→        assert GET_MATERIAL_ID(int(pi[i])) == WOOD, f\"Particle {i}: should stay WOOD\"\n   260→    print(\"PASS: test_wood_no_ignite\")\n   261→\n   262→\n   263→def test_oil_ignites():\n   264→    \"\"\"OIL with exposure_heat > 0.3 transitions to FIRE (GAS, T=1200K, lifetime=1.5s).\"\"\"\n   265→    setup_params()\n   266→    d = make_particles(100, OIL, FLUID, exposure_heat=0.4)\n   267→    compute_reactions(**d)\n   268→\n   269→    pi = d[\"sorted_packed_info\"].get()\n   270→    temp = d[\"sorted_temperature\"].get()\n   271→    lt = d[\"sorted_lifetime\"].get()\n   272→    for i in range(100):\n   273→        assert GET_MATERIAL_ID(int(pi[i])) == FIRE, f\"Particle {i}: expected FIRE\"\n   274→        assert GET_BEHAVIOR(int(pi[i])) == GAS, f\"Particle {i}: expected GAS\"\n   275→        assert abs(temp[i] - 1200.0) < 1.0, f\"Particle {i}: temp={temp[i]}, expected 1200\"\n   276→        assert abs(lt[i] - 1.5) < 0.01, f\"Particle {i}: lifetime={lt[i]}, expected 1.5\"\n   277→    print(\"PASS: test_oil_ignites\")\n   278→\n   279→\n   280→def test_gunpowder_explodes():\n   281→    \"\"\"GUNPOWDER with exposure_heat > 0.1 transitions to FIRE + random velocity burst.\"\"\"\n   282→    setup_params()\n   283→    d = make_particles(100, GUNPOWDER, GRANULAR, exposure_heat=0.2)\n   284→    compute_reactions(**d, frame=42)\n   285→\n   286→    pi = d[\"sorted_packed_info\"].get()\n   287→    temp = d[\"sorted_temperature\"].get()\n   288→    lt = d[\"sorted_lifetime\"].get()\n   289→    vel = d[\"sorted_velocity\"].get()\n   290→\n   291→    for i in range(100):\n   292→        assert GET_MATERIAL_ID(int(pi[i])) == FIRE, f\"Particle {i}: expected FIRE\"\n   293→        assert GET_BEHAVIOR(int(pi[i])) == GAS, f\"Particle {i}: expected GAS\"\n   294→        assert abs(temp[i] - 1200.0) < 1.0\n   295→        assert abs(lt[i] - 0.3) < 0.01\n   296→\n   297→    # Check velocity burst: at least some particles have non-zero velocity\n   298→    vel_mag = np.sqrt(vel[:, 0]**2 + vel[:, 1]**2 + vel[:, 2]**2)\n   299→    assert np.all(vel_mag > 1.0), \"All particles should have explosion velocity\"\n   300→    # Velocities should vary (random directions)\n   301→    assert np.std(vel[:, 0]) > 0.1, \"X velocities should vary due to random RNG\"\n   302→    print(\"PASS: test_gunpowder_explodes\")\n   303→\n   304→\n   305→def test_corrosion_reduces_health():\n   306→    \"\"\"Corrosion reduces health by exposure_corrode * dt.\"\"\"\n   307→    setup_params(dt=0.01)\n   308→    d = make_particles(100, METAL, STATIC, health=1.0, exposure_corrode=5.0)\n   309→    compute_reactions(**d)\n   310→\n   311→    hlth = d[\"sorted_health\"].get()\n   312→    # health should be 1.0 - 5.0 * 0.01 = 0.95\n   313→    for i in range(100):\n   314→        assert abs(hlth[i] - 0.95) < 0.01, f\"Particle {i}: health={hlth[i]}, expected ~0.95\"\n   315→    # Material should still be METAL\n   316→    pi = d[\"sorted_packed_info\"].get()\n   317→    for i in range(100):\n   318→        assert GET_MATERIAL_ID(int(pi[i])) == METAL\n   319→    print(\"PASS: test_corrosion_reduces_health\")\n   320→\n   321→\n   322→def test_corrosion_kills_particle():\n   323→    \"\"\"Corrosion kills particle when health reaches 0.\"\"\"\n   324→    setup_params(dt=0.1)\n   325→    d = make_particles(100, METAL, STATIC, health=0.05, exposure_corrode=1.0)\n   326→    compute_reactions(**d)\n   327→\n   328→    hlth = d[\"sorted_health\"].get()\n   329→    pi = d[\"sorted_packed_info\"].get()\n   330→    # health = 0.05 - 1.0 * 0.1 = -0.05 -> dead\n   331→    for i in range(100):\n   332→        assert hlth[i] <= 0.01, f\"Particle {i}: health={hlth[i]}, expected <= 0\"\n   333→        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: expected DEAD\"\n   334→    print(\"PASS: test_corrosion_kills_particle\")\n   335→\n   336→\n   337→def test_gas_lifetime_decay():\n   338→    \"\"\"GAS particles with lifetime > 0 have it decremented by dt.\"\"\"\n   339→    setup_params(dt=0.01)\n   340→    d = make_particles(100, FIRE, GAS, lifetime=1.0)\n   341→    compute_reactions(**d)\n   342→\n   343→    lt = d[\"sorted_lifetime\"].get()\n   344→    # lifetime should be 1.0 - 0.01 = 0.99\n   345→    for i in range(100):\n   346→        assert abs(lt[i] - 0.99) < 0.001, f\"Particle {i}: lifetime={lt[i]}, expected ~0.99\"\n   347→    # Should still be FIRE\n   348→    pi = d[\"sorted_packed_info\"].get()\n   349→    for i in range(100):\n   350→        assert GET_MATERIAL_ID(int(pi[i])) == FIRE\n   351→    print(\"PASS: test_gas_lifetime_decay\")\n   352→\n   353→\n   354→def test_gas_lifetime_expires():\n   355→    \"\"\"GAS particles die when lifetime reaches 0.\"\"\"\n   356→    setup_params(dt=0.1)\n   357→    d = make_particles(100, FIRE, GAS, lifetime=0.05)\n   358→    compute_reactions(**d)\n   359→\n   360→    lt = d[\"sorted_lifetime\"].get()\n   361→    pi = d[\"sorted_packed_info\"].get()\n   362→    for i in range(100):\n   363→        assert lt[i] <= 0.01, f\"Particle {i}: lifetime={lt[i]}, should be <= 0\"\n   364→        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: expected DEAD\"\n   365→    print(\"PASS: test_gas_lifetime_expires\")\n   366→\n   367→\n   368→def test_dead_particles_unchanged():\n   369→    \"\"\"DEAD particles are skipped entirely.\"\"\"\n   370→    setup_params()\n   371→    d = make_particles(100, DEAD, STATIC, exposure_heat=1.0, exposure_corrode=1.0)\n   372→    compute_reactions(**d)\n   373→\n   374→    pi = d[\"sorted_packed_info\"].get()\n   375→    hlth = d[\"sorted_health\"].get()\n   376→    for i in range(100):\n   377→        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: should stay DEAD\"\n   378→        assert hlth[i] == 1.0, f\"Particle {i}: health should be unchanged\"\n   379→    print(\"PASS: test_dead_particles_unchanged\")\n   380→\n   381→\n   382→def test_ice_lava_together():\n   383→    \"\"\"Ice and lava together: ice melts to water, lava solidifies to stone.\"\"\"\n   384→    setup_params()\n   385→    n = 200\n   386→    packed_info = np.zeros(n, dtype=np.uint32)\n   387→    temperature = np.zeros(n, dtype=np.float32)\n   388→    health = np.ones(n, dtype=np.float32)\n   389→    lifetime = np.zeros(n, dtype=np.float32)\n   390→    velocity = np.zeros((n, 4), dtype=np.float32)\n   391→    exp_heat = np.zeros(n, dtype=np.float32)\n   392→    exp_corrode = np.zeros(n, dtype=np.float32)\n   393→\n   394→    # First 100: ICE at 300K (above 273K -> should melt)\n   395→    for i in range(100):\n   396→        packed_info[i] = MAKE_PACKED(ICE, STATIC)\n   397→        temperature[i] = 300.0\n   398→\n   399→    # Next 100: LAVA at 800K (below 900K -> should solidify)\n   400→    for i in range(100, 200):\n   401→        packed_info[i] = MAKE_PACKED(LAVA, FLUID)\n   402→        temperature[i] = 800.0\n   403→\n   404→    d = {\n   405→        \"sorted_packed_info\": cupy.asarray(packed_info),\n   406→        \"sorted_temperature\": cupy.asarray(temperature),\n   407→        \"sorted_health\": cupy.asarray(health),\n   408→        \"sorted_lifetime\": cupy.asarray(lifetime),\n   409→        \"sorted_velocity\": cupy.asarray(velocity),\n   410→        \"sorted_exposure_heat\": cupy.asarray(exp_heat),\n   411→        \"sorted_exposure_corrode\": cupy.asarray(exp_corrode),\n   412→    }\n   413→    compute_reactions(**d)\n   414→\n   415→    pi = d[\"sorted_packed_info\"].get()\n   416→    # First 100: ICE -> WATER\n   417→    for i in range(100):\n   418→        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"ICE particle {i}: expected WATER\"\n   419→        assert GET_BEHAVIOR(int(pi[i])) == FLUID\n   420→\n   421→    # Next 100: LAVA -> STONE\n   422→    for i in range(100, 200):\n   423→        assert GET_MATERIAL_ID(int(pi[i])) == STONE, f\"LAVA particle {i}: expected STONE\"\n   424→        assert GET_BEHAVIOR(int(pi[i])) == STATIC\n   425→\n   426→    print(\"PASS: test_ice_lava_together\")\n   427→\n   428→\n   429→def test_acid_metal_corrosion():\n   430→    \"\"\"Acid near metal: metal health reduces over multiple steps.\"\"\"\n   431→    setup_params(dt=0.001)\n   432→    d = make_particles(100, METAL, STATIC, health=1.0, exposure_corrode=10.0)\n   433→\n   434→    # Run 110 steps of reactions (slightly more than needed to ensure death)\n   435→    for step in range(110):\n   436→        # Re-apply exposure each step (simulating continuous acid contact)\n   437→        d[\"sorted_exposure_corrode\"] = cupy.full(100, 10.0, dtype=cupy.float32)\n   438→        compute_reactions(**d, frame=step)\n   439→\n   440→    hlth = d[\"sorted_health\"].get()\n   441→    # health should be <= 0 after 100+ steps at 0.01/step\n   442→    for i in range(100):\n   443→        assert hlth[i] <= 0.01, f\"Particle {i}: health={hlth[i]}, expected ~0\"\n   444→\n   445→    pi = d[\"sorted_packed_info\"].get()\n   446→    for i in range(100):\n   447→        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: expected DEAD after corrosion\"\n   448→    print(\"PASS: test_acid_metal_corrosion\")\n   449→\n   450→\n   451→def test_500k_stress():\n   452→    \"\"\"500K particles run without errors or NaN.\"\"\"\n   453→    setup_params()\n   454→    n = 500_000\n   455→\n   456→    # Mix of materials\n   457→    packed_info = np.zeros(n, dtype=np.uint32)\n   458→    temperature = np.full(n, 293.0, dtype=np.float32)\n   459→    health = np.ones(n, dtype=np.float32)\n   460→    lifetime = np.zeros(n, dtype=np.float32)\n   461→    velocity = np.zeros((n, 4), dtype=np.float32)\n   462→    exp_heat = np.zeros(n, dtype=np.float32)\n   463→    exp_corrode = np.zeros(n, dtype=np.float32)\n   464→\n   465→    chunk = n // 5\n   466→    # Water at room temp\n   467→    packed_info[:chunk] = MAKE_PACKED(WATER, FLUID)\n   468→    # Sand\n   469→    packed_info[chunk:2*chunk] = MAKE_PACKED(SAND, GRANULAR)\n   470→    # ICE at 280K (should melt)\n   471→    packed_info[2*chunk:3*chunk] = MAKE_PACKED(ICE, STATIC)\n   472→    temperature[2*chunk:3*chunk] = 280.0\n   473→    # FIRE with lifetime\n   474→    packed_info[3*chunk:4*chunk] = MAKE_PACKED(FIRE, GAS)\n   475→    lifetime[3*chunk:4*chunk] = 1.0\n   476→    # METAL with some corrosion\n   477→    packed_info[4*chunk:] = MAKE_PACKED(METAL, STATIC)\n   478→    exp_corrode[4*chunk:] = 0.5\n   479→\n   480→    d = {\n   481→        \"sorted_packed_info\": cupy.asarray(packed_info),\n   482→        \"sorted_temperature\": cupy.asarray(temperature),\n   483→        \"sorted_health\": cupy.asarray(health),\n   484→        \"sorted_lifetime\": cupy.asarray(lifetime),\n   485→        \"sorted_velocity\": cupy.asarray(velocity),\n   486→        \"sorted_exposure_heat\": cupy.asarray(exp_heat),\n   487→        \"sorted_exposure_corrode\": cupy.asarray(exp_corrode),\n   488→    }\n   489→\n   490→    compute_reactions(**d, frame=0)\n   491→    cupy.cuda.Device().synchronize()\n   492→\n   493→    # Check no NaN in temperature\n   494→    temp_out = d[\"sorted_temperature\"].get()\n   495→    assert not np.any(np.isnan(temp_out)), \"NaN in temperature\"\n   496→\n   497→    # Check no NaN in health\n   498→    hlth_out = d[\"sorted_health\"].get()\n   499→    assert not np.any(np.isnan(hlth_out)), \"NaN in health\"\n   500→\n   501→    # Check ICE melted\n   502→    pi = d[\"sorted_packed_info\"].get()\n   503→    for i in range(2*chunk, 3*chunk):\n   504→        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"ICE particle {i}: expected WATER\"\n   505→\n   506→    # Check FIRE lifetime decremented\n   507→    lt = d[\"sorted_lifetime\"].get()\n   508→    for i in range(3*chunk, 4*chunk):\n   509→        assert abs(lt[i] - 0.999) < 0.01, f\"FIRE particle {i}: lifetime={lt[i]}\"\n   510→\n   511→    print(\"PASS: test_500k_stress\")\n   512→\n   513→\n   514→# ---------------------------------------------------------------------------\n   515→# Main\n   516→# ---------------------------------------------------------------------------\n   517→\n   518→if __name__ == \"__main__\":\n   519→    tests = [\n   520→        test_compilation,\n   521→        test_block_size,\n   522→        test_ice_melts_to_water,\n   523→        test_ice_stays_frozen,\n   524→        test_lava_solidifies_to_stone,\n   525→        test_lava_stays_liquid,\n   526→        test_water_boils_sets_spawn_flag,\n   527→        test_water_cool_no_spawn,\n   528→        test_steam_condenses_to_water,\n   529→        test_steam_stays_gas,\n   530→        test_wood_ignites,\n   531→        test_wood_no_ignite,\n   532→        test_oil_ignites,\n   533→        test_gunpowder_explodes,\n   534→        test_corrosion_reduces_health,\n   535→        test_corrosion_kills_particle,\n   536→        test_gas_lifetime_decay,\n   537→        test_gas_lifetime_expires,\n   538→        test_dead_particles_unchanged,\n   539→        test_ice_lava_together,\n   540→        test_acid_metal_corrosion,\n   541→        test_500k_stress,\n   542→    ]\n   543→\n   544→    passed = 0\n   545→    failed = 0\n   546→    for t in tests:\n   547→        try:\n   548→            t()\n   549→            passed += 1\n   550→        except Exception as e:\n   551→            print(f\"FAIL: {t.__name__}: {e}\")\n   552→            import traceback\n   553→            traceback.print_exc()\n   554→            failed += 1\n   555→\n   556→    print(f\"\\n{passed}/{passed+failed} tests passed.\")\n   557→    if failed:\n   558→        sys.exit(1)\n   559→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f78301fc-4ded-4a94-a553-b435335d3972","uuid":"3e9f4cea-b830-4bd9-bcab-e27dbbb097fc","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_reactions.py","content":"\"\"\"Integration tests for reactions.py -- K_Reactions kernel.\n\nAcceptance criteria:\n  - ICE (mat=11, temp > 273K) -> WATER (mat=5, FLUID)\n  - LAVA (mat=7, temp < 900K) -> STONE (mat=1, STATIC)\n  - WATER (mat=5, temp > 373K) -> set SPAWN_GAS flag\n  - WOOD (mat=9, exposure_heat > 0.5) -> FIRE (mat=14, GAS, T=1200K, lifetime=1.0s)\n  - OIL (mat=6, exposure_heat > 0.3) -> FIRE (mat=14, GAS, T=1200K, lifetime=1.5s)\n  - GUNPOWDER (mat=15, exposure_heat > 0.1) -> FIRE + explosion velocity\n  - Corrosion: health -= exposure_corrode * dt; health <= 0 -> DEAD\n  - GAS lifetime: lifetime -= dt; lifetime <= 0 -> DEAD\n  - STEAM (mat=12, temp < 373K) -> WATER (mat=5, FLUID)\n  - Exposure accumulators reset to 0 after use (inherent: sorted ephemeral arrays)\n  - Block size = 256, kernel runs without errors\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nimport sys\n\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom step1 import (\n    SIM_PARAMS_DTYPE,\n    build_sim_params,\n)\nfrom materials import (\n    FLUID, GRANULAR, GAS, STATIC,\n    DEAD, STONE, SAND, WATER, OIL, LAVA, WOOD, METAL, ICE, STEAM, FIRE, GUNPOWDER,\n    build_material_array,\n)\nfrom reactions import (\n    BLOCK_SIZE,\n    get_module,\n    compute_reactions,\n    upload_sim_params,\n    upload_materials,\n)\n\n# ---------------------------------------------------------------------------\n# Constants\n# ---------------------------------------------------------------------------\n\nH = 0.04\nSPACING = 0.02\nDT = 0.001\n\n# packed_info helpers (mirror common.cuh)\ndef MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n\ndef GET_MATERIAL_ID(p: int) -> int:\n    return p & 0xFF\n\ndef GET_BEHAVIOR(p: int) -> int:\n    return (p >> 8) & 0x3\n\ndef HAS_SPAWN_FLAG(p: int) -> int:\n    return (p >> 11) & 1\n\n# ---------------------------------------------------------------------------\n# Helper: upload params for all tests\n# ---------------------------------------------------------------------------\n\ndef setup_params(dt=DT):\n    \"\"\"Upload SimParams and materials to reactions module's constant memory.\"\"\"\n    sim_params = build_sim_params(\n        smoothing_length=H,\n        particle_mass=0.008,\n        particle_spacing=SPACING,\n        gravity=(0.0, -9.8, 0.0),\n        dt=dt,\n        restitution=0.3,\n        wall_friction=0.5,\n        world_min=(-1.0, -1.0, -1.0),\n        world_max=(1.0, 1.0, 1.0),\n    )\n    upload_sim_params(sim_params)\n    materials = build_material_array()\n    upload_materials(materials)\n\n\ndef make_particles(n, mat_id, behavior, temp=293.0, health=1.0, lifetime=0.0,\n                   vel=None, exposure_heat=0.0, exposure_corrode=0.0):\n    \"\"\"Create sorted particle arrays for testing reactions kernel.\"\"\"\n    packed_info = np.full(n, MAKE_PACKED(mat_id, behavior), dtype=np.uint32)\n    temperature = np.full(n, temp, dtype=np.float32)\n    hlth = np.full(n, health, dtype=np.float32)\n    lt = np.full(n, lifetime, dtype=np.float32)\n\n    if vel is None:\n        velocity = np.zeros((n, 4), dtype=np.float32)\n    else:\n        velocity = np.array(vel, dtype=np.float32).reshape(n, 4)\n\n    exp_heat = np.full(n, exposure_heat, dtype=np.float32)\n    exp_corrode = np.full(n, exposure_corrode, dtype=np.float32)\n\n    return {\n        \"sorted_packed_info\": cupy.asarray(packed_info),\n        \"sorted_temperature\": cupy.asarray(temperature),\n        \"sorted_health\": cupy.asarray(hlth),\n        \"sorted_lifetime\": cupy.asarray(lt),\n        \"sorted_velocity\": cupy.asarray(velocity),\n        \"sorted_exposure_heat\": cupy.asarray(exp_heat),\n        \"sorted_exposure_corrode\": cupy.asarray(exp_corrode),\n    }\n\n\n# ---------------------------------------------------------------------------\n# Tests\n# ---------------------------------------------------------------------------\n\ndef test_compilation():\n    \"\"\"Kernel compiles without errors.\"\"\"\n    module = get_module()\n    kernel = module.get_function(\"K_Reactions\")\n    assert kernel is not None\n    print(\"PASS: test_compilation\")\n\n\ndef test_block_size():\n    \"\"\"Block size is 256.\"\"\"\n    assert BLOCK_SIZE == 256\n    print(\"PASS: test_block_size\")\n\n\ndef test_ice_melts_to_water():\n    \"\"\"ICE at temp > 273K transitions to WATER (FLUID).\"\"\"\n    setup_params()\n    d = make_particles(100, ICE, STATIC, temp=280.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"Particle {i}: expected WATER, got {GET_MATERIAL_ID(int(pi[i]))}\"\n        assert GET_BEHAVIOR(int(pi[i])) == FLUID, f\"Particle {i}: expected FLUID\"\n    print(\"PASS: test_ice_melts_to_water\")\n\n\ndef test_ice_stays_frozen():\n    \"\"\"ICE at temp < 273K stays as ICE.\"\"\"\n    setup_params()\n    d = make_particles(100, ICE, STATIC, temp=200.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == ICE, f\"Particle {i}: should stay ICE\"\n    print(\"PASS: test_ice_stays_frozen\")\n\n\ndef test_lava_solidifies_to_stone():\n    \"\"\"LAVA at temp < 900K transitions to STONE (STATIC).\"\"\"\n    setup_params()\n    d = make_particles(100, LAVA, FLUID, temp=800.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == STONE, f\"Particle {i}: expected STONE\"\n        assert GET_BEHAVIOR(int(pi[i])) == STATIC, f\"Particle {i}: expected STATIC\"\n    print(\"PASS: test_lava_solidifies_to_stone\")\n\n\ndef test_lava_stays_liquid():\n    \"\"\"LAVA at temp > 900K stays as LAVA.\"\"\"\n    setup_params()\n    d = make_particles(100, LAVA, FLUID, temp=1500.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == LAVA, f\"Particle {i}: should stay LAVA\"\n    print(\"PASS: test_lava_stays_liquid\")\n\n\ndef test_water_boils_sets_spawn_flag():\n    \"\"\"WATER at temp > 373K gets SPAWN_GAS flag set.\"\"\"\n    setup_params()\n    d = make_particles(100, WATER, FLUID, temp=400.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"Particle {i}: should still be WATER\"\n        assert HAS_SPAWN_FLAG(int(pi[i])) == 1, f\"Particle {i}: SPAWN_GAS flag not set\"\n    print(\"PASS: test_water_boils_sets_spawn_flag\")\n\n\ndef test_water_cool_no_spawn():\n    \"\"\"WATER at temp < 373K does NOT get SPAWN_GAS flag.\"\"\"\n    setup_params()\n    d = make_particles(100, WATER, FLUID, temp=300.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert HAS_SPAWN_FLAG(int(pi[i])) == 0, f\"Particle {i}: should not have SPAWN_GAS\"\n    print(\"PASS: test_water_cool_no_spawn\")\n\n\ndef test_steam_condenses_to_water():\n    \"\"\"STEAM at temp < 373K transitions to WATER (FLUID).\"\"\"\n    setup_params()\n    d = make_particles(100, STEAM, GAS, temp=350.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"Particle {i}: expected WATER\"\n        assert GET_BEHAVIOR(int(pi[i])) == FLUID, f\"Particle {i}: expected FLUID\"\n    print(\"PASS: test_steam_condenses_to_water\")\n\n\ndef test_steam_stays_gas():\n    \"\"\"STEAM at temp > 373K stays as STEAM.\"\"\"\n    setup_params()\n    d = make_particles(100, STEAM, GAS, temp=400.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == STEAM, f\"Particle {i}: should stay STEAM\"\n    print(\"PASS: test_steam_stays_gas\")\n\n\ndef test_wood_ignites():\n    \"\"\"WOOD with exposure_heat > 0.5 transitions to FIRE (GAS, T=1200K, lifetime=1.0s).\"\"\"\n    setup_params()\n    d = make_particles(100, WOOD, STATIC, exposure_heat=0.6)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    temp = d[\"sorted_temperature\"].get()\n    lt = d[\"sorted_lifetime\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == FIRE, f\"Particle {i}: expected FIRE\"\n        assert GET_BEHAVIOR(int(pi[i])) == GAS, f\"Particle {i}: expected GAS\"\n        assert abs(temp[i] - 1200.0) < 1.0, f\"Particle {i}: temp={temp[i]}, expected 1200\"\n        assert abs(lt[i] - 1.0) < 0.01, f\"Particle {i}: lifetime={lt[i]}, expected 1.0\"\n    print(\"PASS: test_wood_ignites\")\n\n\ndef test_wood_no_ignite():\n    \"\"\"WOOD with exposure_heat < 0.5 stays as WOOD.\"\"\"\n    setup_params()\n    d = make_particles(100, WOOD, STATIC, exposure_heat=0.3)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == WOOD, f\"Particle {i}: should stay WOOD\"\n    print(\"PASS: test_wood_no_ignite\")\n\n\ndef test_oil_ignites():\n    \"\"\"OIL with exposure_heat > 0.3 transitions to FIRE (GAS, T=1200K, lifetime=1.5s).\"\"\"\n    setup_params()\n    d = make_particles(100, OIL, FLUID, exposure_heat=0.4)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    temp = d[\"sorted_temperature\"].get()\n    lt = d[\"sorted_lifetime\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == FIRE, f\"Particle {i}: expected FIRE\"\n        assert GET_BEHAVIOR(int(pi[i])) == GAS, f\"Particle {i}: expected GAS\"\n        assert abs(temp[i] - 1200.0) < 1.0, f\"Particle {i}: temp={temp[i]}, expected 1200\"\n        assert abs(lt[i] - 1.5) < 0.01, f\"Particle {i}: lifetime={lt[i]}, expected 1.5\"\n    print(\"PASS: test_oil_ignites\")\n\n\ndef test_gunpowder_explodes():\n    \"\"\"GUNPOWDER with exposure_heat > 0.1 transitions to FIRE + random velocity burst.\"\"\"\n    setup_params()\n    d = make_particles(100, GUNPOWDER, GRANULAR, exposure_heat=0.2)\n    compute_reactions(**d, frame=42)\n\n    pi = d[\"sorted_packed_info\"].get()\n    temp = d[\"sorted_temperature\"].get()\n    lt = d[\"sorted_lifetime\"].get()\n    vel = d[\"sorted_velocity\"].get()\n\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == FIRE, f\"Particle {i}: expected FIRE\"\n        assert GET_BEHAVIOR(int(pi[i])) == GAS, f\"Particle {i}: expected GAS\"\n        assert abs(temp[i] - 1200.0) < 1.0\n        assert abs(lt[i] - 0.3) < 0.01\n\n    # Check velocity burst: at least some particles have non-zero velocity\n    vel_mag = np.sqrt(vel[:, 0]**2 + vel[:, 1]**2 + vel[:, 2]**2)\n    assert np.all(vel_mag > 1.0), \"All particles should have explosion velocity\"\n    # Velocities should vary (random directions)\n    assert np.std(vel[:, 0]) > 0.1, \"X velocities should vary due to random RNG\"\n    print(\"PASS: test_gunpowder_explodes\")\n\n\ndef test_corrosion_reduces_health():\n    \"\"\"Corrosion reduces health by exposure_corrode * dt.\"\"\"\n    setup_params(dt=0.01)\n    d = make_particles(100, METAL, STATIC, health=1.0, exposure_corrode=5.0)\n    compute_reactions(**d)\n\n    hlth = d[\"sorted_health\"].get()\n    # health should be 1.0 - 5.0 * 0.01 = 0.95\n    for i in range(100):\n        assert abs(hlth[i] - 0.95) < 0.01, f\"Particle {i}: health={hlth[i]}, expected ~0.95\"\n    # Material should still be METAL\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == METAL\n    print(\"PASS: test_corrosion_reduces_health\")\n\n\ndef test_corrosion_kills_particle():\n    \"\"\"Corrosion kills particle when health reaches 0.\"\"\"\n    setup_params(dt=0.1)\n    d = make_particles(100, METAL, STATIC, health=0.05, exposure_corrode=1.0)\n    compute_reactions(**d)\n\n    hlth = d[\"sorted_health\"].get()\n    pi = d[\"sorted_packed_info\"].get()\n    # health = 0.05 - 1.0 * 0.1 = -0.05 -> dead\n    for i in range(100):\n        assert hlth[i] <= 0.01, f\"Particle {i}: health={hlth[i]}, expected <= 0\"\n        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: expected DEAD\"\n    print(\"PASS: test_corrosion_kills_particle\")\n\n\ndef test_gas_lifetime_decay():\n    \"\"\"GAS particles with lifetime > 0 have it decremented by dt.\"\"\"\n    setup_params(dt=0.01)\n    d = make_particles(100, FIRE, GAS, lifetime=1.0)\n    compute_reactions(**d)\n\n    lt = d[\"sorted_lifetime\"].get()\n    # lifetime should be 1.0 - 0.01 = 0.99\n    for i in range(100):\n        assert abs(lt[i] - 0.99) < 0.001, f\"Particle {i}: lifetime={lt[i]}, expected ~0.99\"\n    # Should still be FIRE\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == FIRE\n    print(\"PASS: test_gas_lifetime_decay\")\n\n\ndef test_gas_lifetime_expires():\n    \"\"\"GAS particles die when lifetime reaches 0.\"\"\"\n    setup_params(dt=0.1)\n    d = make_particles(100, FIRE, GAS, lifetime=0.05)\n    compute_reactions(**d)\n\n    lt = d[\"sorted_lifetime\"].get()\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert lt[i] <= 0.01, f\"Particle {i}: lifetime={lt[i]}, should be <= 0\"\n        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: expected DEAD\"\n    print(\"PASS: test_gas_lifetime_expires\")\n\n\ndef test_dead_particles_unchanged():\n    \"\"\"DEAD particles are skipped entirely.\"\"\"\n    setup_params()\n    d = make_particles(100, DEAD, STATIC, exposure_heat=1.0, exposure_corrode=1.0)\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    hlth = d[\"sorted_health\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: should stay DEAD\"\n        assert hlth[i] == 1.0, f\"Particle {i}: health should be unchanged\"\n    print(\"PASS: test_dead_particles_unchanged\")\n\n\ndef test_ice_lava_together():\n    \"\"\"Ice and lava together: ice melts to water, lava solidifies to stone.\"\"\"\n    setup_params()\n    n = 200\n    packed_info = np.zeros(n, dtype=np.uint32)\n    temperature = np.zeros(n, dtype=np.float32)\n    health = np.ones(n, dtype=np.float32)\n    lifetime = np.zeros(n, dtype=np.float32)\n    velocity = np.zeros((n, 4), dtype=np.float32)\n    exp_heat = np.zeros(n, dtype=np.float32)\n    exp_corrode = np.zeros(n, dtype=np.float32)\n\n    # First 100: ICE at 300K (above 273K -> should melt)\n    for i in range(100):\n        packed_info[i] = MAKE_PACKED(ICE, STATIC)\n        temperature[i] = 300.0\n\n    # Next 100: LAVA at 800K (below 900K -> should solidify)\n    for i in range(100, 200):\n        packed_info[i] = MAKE_PACKED(LAVA, FLUID)\n        temperature[i] = 800.0\n\n    d = {\n        \"sorted_packed_info\": cupy.asarray(packed_info),\n        \"sorted_temperature\": cupy.asarray(temperature),\n        \"sorted_health\": cupy.asarray(health),\n        \"sorted_lifetime\": cupy.asarray(lifetime),\n        \"sorted_velocity\": cupy.asarray(velocity),\n        \"sorted_exposure_heat\": cupy.asarray(exp_heat),\n        \"sorted_exposure_corrode\": cupy.asarray(exp_corrode),\n    }\n    compute_reactions(**d)\n\n    pi = d[\"sorted_packed_info\"].get()\n    # First 100: ICE -> WATER\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"ICE particle {i}: expected WATER\"\n        assert GET_BEHAVIOR(int(pi[i])) == FLUID\n\n    # Next 100: LAVA -> STONE\n    for i in range(100, 200):\n        assert GET_MATERIAL_ID(int(pi[i])) == STONE, f\"LAVA particle {i}: expected STONE\"\n        assert GET_BEHAVIOR(int(pi[i])) == STATIC\n\n    print(\"PASS: test_ice_lava_together\")\n\n\ndef test_acid_metal_corrosion():\n    \"\"\"Acid near metal: metal health reduces over multiple steps.\"\"\"\n    setup_params(dt=0.001)\n    d = make_particles(100, METAL, STATIC, health=1.0, exposure_corrode=10.0)\n\n    # Run 110 steps of reactions (slightly more than needed to ensure death)\n    for step in range(110):\n        # Re-apply exposure each step (simulating continuous acid contact)\n        d[\"sorted_exposure_corrode\"] = cupy.full(100, 10.0, dtype=cupy.float32)\n        compute_reactions(**d, frame=step)\n\n    hlth = d[\"sorted_health\"].get()\n    # health should be <= 0 after 100+ steps at 0.01/step\n    for i in range(100):\n        assert hlth[i] <= 0.01, f\"Particle {i}: health={hlth[i]}, expected ~0\"\n\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(100):\n        assert GET_MATERIAL_ID(int(pi[i])) == DEAD, f\"Particle {i}: expected DEAD after corrosion\"\n    print(\"PASS: test_acid_metal_corrosion\")\n\n\ndef test_500k_stress():\n    \"\"\"500K particles run without errors or NaN.\"\"\"\n    setup_params()\n    n = 500_000\n\n    # Mix of materials\n    packed_info = np.zeros(n, dtype=np.uint32)\n    temperature = np.full(n, 293.0, dtype=np.float32)\n    health = np.ones(n, dtype=np.float32)\n    lifetime = np.zeros(n, dtype=np.float32)\n    velocity = np.zeros((n, 4), dtype=np.float32)\n    exp_heat = np.zeros(n, dtype=np.float32)\n    exp_corrode = np.zeros(n, dtype=np.float32)\n\n    chunk = n // 5\n    # Water at room temp\n    packed_info[:chunk] = MAKE_PACKED(WATER, FLUID)\n    # Sand\n    packed_info[chunk:2*chunk] = MAKE_PACKED(SAND, GRANULAR)\n    # ICE at 280K (should melt)\n    packed_info[2*chunk:3*chunk] = MAKE_PACKED(ICE, STATIC)\n    temperature[2*chunk:3*chunk] = 280.0\n    # FIRE with lifetime\n    packed_info[3*chunk:4*chunk] = MAKE_PACKED(FIRE, GAS)\n    lifetime[3*chunk:4*chunk] = 1.0\n    # METAL with some corrosion\n    packed_info[4*chunk:] = MAKE_PACKED(METAL, STATIC)\n    exp_corrode[4*chunk:] = 0.5\n\n    d = {\n        \"sorted_packed_info\": cupy.asarray(packed_info),\n        \"sorted_temperature\": cupy.asarray(temperature),\n        \"sorted_health\": cupy.asarray(health),\n        \"sorted_lifetime\": cupy.asarray(lifetime),\n        \"sorted_velocity\": cupy.asarray(velocity),\n        \"sorted_exposure_heat\": cupy.asarray(exp_heat),\n        \"sorted_exposure_corrode\": cupy.asarray(exp_corrode),\n    }\n\n    compute_reactions(**d, frame=0)\n    cupy.cuda.Device().synchronize()\n\n    # Check no NaN in temperature\n    temp_out = d[\"sorted_temperature\"].get()\n    assert not np.any(np.isnan(temp_out)), \"NaN in temperature\"\n\n    # Check no NaN in health\n    hlth_out = d[\"sorted_health\"].get()\n    assert not np.any(np.isnan(hlth_out)), \"NaN in health\"\n\n    # Check ICE melted\n    pi = d[\"sorted_packed_info\"].get()\n    for i in range(2*chunk, 3*chunk):\n        assert GET_MATERIAL_ID(int(pi[i])) == WATER, f\"ICE particle {i}: expected WATER\"\n\n    # Check FIRE lifetime decremented\n    lt = d[\"sorted_lifetime\"].get()\n    for i in range(3*chunk, 4*chunk):\n        assert abs(lt[i] - 0.999) < 0.01, f\"FIRE particle {i}: lifetime={lt[i]}\"\n\n    print(\"PASS: test_500k_stress\")\n\n\n# ---------------------------------------------------------------------------\n# Main\n# ---------------------------------------------------------------------------\n\nif __name__ == \"__main__\":\n    tests = [\n        test_compilation,\n        test_block_size,\n        test_ice_melts_to_water,\n        test_ice_stays_frozen,\n        test_lava_solidifies_to_stone,\n        test_lava_stays_liquid,\n        test_water_boils_sets_spawn_flag,\n        test_water_cool_no_spawn,\n        test_steam_condenses_to_water,\n        test_steam_stays_gas,\n        test_wood_ignites,\n        test_wood_no_ignite,\n        test_oil_ignites,\n        test_gunpowder_explodes,\n        test_corrosion_reduces_health,\n        test_corrosion_kills_particle,\n        test_gas_lifetime_decay,\n        test_gas_lifetime_expires,\n        test_dead_particles_unchanged,\n        test_ice_lava_together,\n        test_acid_metal_corrosion,\n        test_500k_stress,\n    ]\n\n    passed = 0\n    failed = 0\n    for t in tests:\n        try:\n            t()\n            passed += 1\n        except Exception as e:\n            print(f\"FAIL: {t.__name__}: {e}\")\n            import traceback\n            traceback.print_exc()\n            failed += 1\n\n    print(f\"\\n{passed}/{passed+failed} tests passed.\")\n    if failed:\n        sys.exit(1)\n","numLines":559,"startLine":1,"totalLines":559}}}

{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SzoYHAztg16gRvb5Akms6d","type":"tool_result","content":"     1→\"\"\"Material property table and interaction matrix for multi-material SPH.\n     2→\n     3→Defines 16 materials (IDs 0-15) as Python dataclasses, a 32x32 interaction\n     4→matrix, and an upload_to_gpu() function that copies both tables to CUDA\n     5→constant memory via CuPy RawModule symbol lookup.\n     6→\n     7→Struct layout matches fallingsand3d/physics/kernels/common.cuh exactly.\n     8→\n     9→Constant-memory symbols\n    10→-----------------------\n    11→- ``c_materials``   : MaterialProps[32]\n    12→- ``c_interactions`` : Interaction[32][32]\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import dataclasses\n    18→import os\n    19→from typing import Dict, List, Optional, Tuple\n    20→\n    21→import numpy as np\n    22→\n    23→# ---------------------------------------------------------------------------\n    24→# Numpy structured dtypes matching the C structs in common.cuh\n    25→# ---------------------------------------------------------------------------\n    26→\n    27→MATERIAL_PROPS_DTYPE = np.dtype(\n    28→    [\n    29→        (\"rest_density\", np.float32),\n    30→        (\"eos_stiffness\", np.float32),\n    31→        (\"eos_gamma\", np.float32),\n    32→        (\"base_viscosity\", np.float32),\n    33→        (\"friction_coeff\", np.float32),\n    34→        (\"cohesion\", np.float32),\n    35→        (\"buoyancy_extra\", np.float32),\n    36→        (\"thermal_conductivity\", np.float32),\n    37→        (\"heat_capacity\", np.float32),\n    38→        (\"temp_melt\", np.float32),\n    39→        (\"temp_boil\", np.float32),\n    40→        (\"temp_ignite\", np.float32),\n    41→        (\"behavior_class\", np.int32),\n    42→        (\"color_r\", np.float32),\n    43→        (\"color_g\", np.float32),\n    44→        (\"color_b\", np.float32),\n    45→    ],\n    46→    align=True,\n    47→)\n    48→\n    49→INTERACTION_DTYPE = np.dtype(\n    50→    [\n    51→        (\"reaction_rate\", np.float32),\n    52→        (\"heat_exchange\", np.float32),\n    53→    ],\n    54→    align=True,\n    55→)\n    56→\n    57→# Compile-time size checks (must match sizeof(MaterialProps) and sizeof(Interaction))\n    58→assert MATERIAL_PROPS_DTYPE.itemsize == 64, (\n    59→    f\"MaterialProps size mismatch: {MATERIAL_PROPS_DTYPE.itemsize} != 64\"\n    60→)\n    61→assert INTERACTION_DTYPE.itemsize == 8, (\n    62→    f\"Interaction size mismatch: {INTERACTION_DTYPE.itemsize} != 8\"\n    63→)\n    64→\n    65→MAX_MATERIALS = 32  # slots in constant memory (IDs 0-31)\n    66→NUM_DEFINED = 16  # IDs 0-15 are defined; 16-31 reserved (zeroed)\n    67→\n    68→# ---------------------------------------------------------------------------\n    69→# BehaviorClass enum (mirrors common.cuh)\n    70→# ---------------------------------------------------------------------------\n    71→\n    72→FLUID = 0\n    73→GRANULAR = 1\n    74→GAS = 2\n    75→STATIC = 3\n    76→\n    77→# ---------------------------------------------------------------------------\n    78→# MaterialDef dataclass\n    79→# ---------------------------------------------------------------------------\n    80→\n    81→\n    82→@dataclasses.dataclass\n    83→class MaterialDef:\n    84→    \"\"\"Python-side definition of a single material.\n    85→\n    86→    Field names and semantics match the ``MaterialProps`` C struct in common.cuh.\n    87→    \"\"\"\n    88→\n    89→    id: int\n    90→    name: str  # human-readable label (not uploaded to GPU)\n    91→    rest_density: float  # kg/m^3\n    92→    eos_stiffness: float  # Tait EOS k\n    93→    eos_gamma: float  # Tait EOS exponent (7 for liquid, 1 for gas)\n    94→    base_viscosity: float  # Pa*s\n    95→    friction_coeff: float  # mu_s for granular friction\n    96→    cohesion: float  # cohesion coefficient\n    97→    buoyancy_extra: float  # extra buoyancy factor for gas\n    98→    thermal_conductivity: float  # W/(m*K)\n    99→    heat_capacity: float  # J/(kg*K)\n   100→    temp_melt: float  # Kelvin\n   101→    temp_boil: float  # Kelvin\n   102→    temp_ignite: float  # Kelvin (0 = non-flammable)\n   103→    behavior_class: int  # BehaviorClass enum value\n   104→    color_r: float  # default material color R [0,1]\n   105→    color_g: float  # default material color G [0,1]\n   106→    color_b: float  # default material color B [0,1]\n   107→\n   108→    def to_numpy(self) -> np.void:\n   109→        \"\"\"Pack into a single numpy structured-array element.\"\"\"\n   110→        return np.array(\n   111→            (\n   112→                self.rest_density,\n   113→                self.eos_stiffness,\n   114→                self.eos_gamma,\n   115→                self.base_viscosity,\n   116→                self.friction_coeff,\n   117→                self.cohesion,\n   118→                self.buoyancy_extra,\n   119→                self.thermal_conductivity,\n   120→                self.heat_capacity,\n   121→                self.temp_melt,\n   122→                self.temp_boil,\n   123→                self.temp_ignite,\n   124→                self.behavior_class,\n   125→                self.color_r,\n   126→                self.color_g,\n   127→                self.color_b,\n   128→            ),\n   129→            dtype=MATERIAL_PROPS_DTYPE,\n   130→        )\n   131→\n   132→\n   133→# ---------------------------------------------------------------------------\n   134→# Material ID constants\n   135→# ---------------------------------------------------------------------------\n   136→\n   137→DEAD = 0\n   138→STONE = 1\n   139→SAND = 2\n   140→DIRT = 3\n   141→GRAVEL = 4\n   142→WATER = 5\n   143→OIL = 6\n   144→LAVA = 7\n   145→ACID = 8\n   146→WOOD = 9\n   147→METAL = 10\n   148→ICE = 11\n   149→STEAM = 12\n   150→SMOKE = 13\n   151→FIRE = 14\n   152→GUNPOWDER = 15\n   153→\n   154→# ---------------------------------------------------------------------------\n   155→# Material definitions (16 entries, IDs 0-15)\n   156→#\n   157→# Property values chosen for a falling-sand / multi-material SPH game:\n   158→#   - rest_density in kg/m^3 (approximate real-world)\n   159→#   - eos_stiffness: Tait EOS pressure coefficient (game-tuned)\n   160→#   - eos_gamma: 7 for FLUID/GRANULAR, 1 for GAS, 0 for STATIC/DEAD\n   161→#   - base_viscosity in Pa*s (scaled for game feel)\n   162→#   - temperatures in Kelvin\n   163→# ---------------------------------------------------------------------------\n   164→\n   165→MATERIALS: Dict[int, MaterialDef] = {\n   166→    DEAD: MaterialDef(\n   167→        id=DEAD, name=\"DEAD\",\n   168→        rest_density=0.0, eos_stiffness=0.0, eos_gamma=0.0,\n   169→        base_viscosity=0.0, friction_coeff=0.0, cohesion=0.0,\n   170→        buoyancy_extra=0.0, thermal_conductivity=0.0, heat_capacity=0.0,\n   171→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   172→        behavior_class=STATIC,\n   173→        color_r=0.0, color_g=0.0, color_b=0.0,\n   174→    ),\n   175→    STONE: MaterialDef(\n   176→        id=STONE, name=\"STONE\",\n   177→        rest_density=2600.0, eos_stiffness=50.0, eos_gamma=7.0,\n   178→        base_viscosity=0.0, friction_coeff=0.7, cohesion=0.5,\n   179→        buoyancy_extra=0.0, thermal_conductivity=2.0, heat_capacity=800.0,\n   180→        temp_melt=1500.0, temp_boil=3000.0, temp_ignite=0.0,\n   181→        behavior_class=STATIC,\n   182→        color_r=0.5, color_g=0.5, color_b=0.5,\n   183→    ),\n   184→    SAND: MaterialDef(\n   185→        id=SAND, name=\"SAND\",\n   186→        rest_density=1600.0, eos_stiffness=20.0, eos_gamma=7.0,\n   187→        base_viscosity=0.5, friction_coeff=0.6, cohesion=0.0,\n   188→        buoyancy_extra=0.0, thermal_conductivity=0.3, heat_capacity=830.0,\n   189→        temp_melt=1700.0, temp_boil=2500.0, temp_ignite=0.0,\n   190→        behavior_class=GRANULAR,\n   191→        color_r=0.76, color_g=0.70, color_b=0.50,\n   192→    ),\n   193→    DIRT: MaterialDef(\n   194→        id=DIRT, name=\"DIRT\",\n   195→        rest_density=1500.0, eos_stiffness=18.0, eos_gamma=7.0,\n   196→        base_viscosity=0.8, friction_coeff=0.5, cohesion=0.1,\n   197→        buoyancy_extra=0.0, thermal_conductivity=0.25, heat_capacity=900.0,\n   198→        temp_melt=1400.0, temp_boil=2200.0, temp_ignite=0.0,\n   199→        behavior_class=GRANULAR,\n   200→        color_r=0.55, color_g=0.35, color_b=0.17,\n   201→    ),\n   202→    GRAVEL: MaterialDef(\n   203→        id=GRAVEL, name=\"GRAVEL\",\n   204→        rest_density=1800.0, eos_stiffness=25.0, eos_gamma=7.0,\n   205→        base_viscosity=0.3, friction_coeff=0.65, cohesion=0.0,\n   206→        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=840.0,\n   207→        temp_melt=1500.0, temp_boil=2800.0, temp_ignite=0.0,\n   208→        behavior_class=GRANULAR,\n   209→        color_r=0.45, color_g=0.42, color_b=0.40,\n   210→    ),\n   211→    WATER: MaterialDef(\n   212→        id=WATER, name=\"WATER\",\n   213→        rest_density=1000.0, eos_stiffness=10.0, eos_gamma=7.0,\n   214→        base_viscosity=1.0, friction_coeff=0.0, cohesion=0.0,\n   215→        buoyancy_extra=0.0, thermal_conductivity=0.6, heat_capacity=4186.0,\n   216→        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n   217→        behavior_class=FLUID,\n   218→        color_r=0.2, color_g=0.5, color_b=0.9,\n   219→    ),\n   220→    OIL: MaterialDef(\n   221→        id=OIL, name=\"OIL\",\n   222→        rest_density=800.0, eos_stiffness=8.0, eos_gamma=7.0,\n   223→        base_viscosity=5.0, friction_coeff=0.0, cohesion=0.0,\n   224→        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=2000.0,\n   225→        temp_melt=250.0, temp_boil=570.0, temp_ignite=480.0,\n   226→        behavior_class=FLUID,\n   227→        color_r=0.15, color_g=0.10, color_b=0.05,\n   228→    ),\n   229→    LAVA: MaterialDef(\n   230→        id=LAVA, name=\"LAVA\",\n   231→        rest_density=2500.0, eos_stiffness=30.0, eos_gamma=7.0,\n   232→        base_viscosity=100.0, friction_coeff=0.0, cohesion=0.0,\n   233→        buoyancy_extra=0.0, thermal_conductivity=1.5, heat_capacity=1000.0,\n   234→        temp_melt=1000.0, temp_boil=2500.0, temp_ignite=0.0,\n   235→        behavior_class=FLUID,\n   236→        color_r=1.0, color_g=0.3, color_b=0.0,\n   237→    ),\n   238→    ACID: MaterialDef(\n   239→        id=ACID, name=\"ACID\",\n   240→        rest_density=1200.0, eos_stiffness=10.0, eos_gamma=7.0,\n   241→        base_viscosity=1.5, friction_coeff=0.0, cohesion=0.0,\n   242→        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=2500.0,\n   243→        temp_melt=250.0, temp_boil=380.0, temp_ignite=0.0,\n   244→        behavior_class=FLUID,\n   245→        color_r=0.4, color_g=1.0, color_b=0.1,\n   246→    ),\n   247→    WOOD: MaterialDef(\n   248→        id=WOOD, name=\"WOOD\",\n   249→        rest_density=600.0, eos_stiffness=15.0, eos_gamma=7.0,\n   250→        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.3,\n   251→        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=1700.0,\n   252→        temp_melt=0.0, temp_boil=0.0, temp_ignite=570.0,\n   253→        behavior_class=STATIC,\n   254→        color_r=0.55, color_g=0.35, color_b=0.12,\n   255→    ),\n   256→    METAL: MaterialDef(\n   257→        id=METAL, name=\"METAL\",\n   258→        rest_density=7800.0, eos_stiffness=100.0, eos_gamma=7.0,\n   259→        base_viscosity=0.0, friction_coeff=0.6, cohesion=1.0,\n   260→        buoyancy_extra=0.0, thermal_conductivity=50.0, heat_capacity=450.0,\n   261→        temp_melt=1800.0, temp_boil=3300.0, temp_ignite=0.0,\n   262→        behavior_class=STATIC,\n   263→        color_r=0.7, color_g=0.7, color_b=0.75,\n   264→    ),\n   265→    ICE: MaterialDef(\n   266→        id=ICE, name=\"ICE\",\n   267→        rest_density=917.0, eos_stiffness=15.0, eos_gamma=7.0,\n   268→        base_viscosity=0.0, friction_coeff=0.1, cohesion=0.2,\n   269→        buoyancy_extra=0.0, thermal_conductivity=2.2, heat_capacity=2090.0,\n   270→        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n   271→        behavior_class=STATIC,\n   272→        color_r=0.7, color_g=0.9, color_b=1.0,\n   273→    ),\n   274→    STEAM: MaterialDef(\n   275→        id=STEAM, name=\"STEAM\",\n   276→        rest_density=0.6, eos_stiffness=3.0, eos_gamma=1.0,\n   277→        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n   278→        buoyancy_extra=0.01, thermal_conductivity=0.025, heat_capacity=2010.0,\n   279→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   280→        behavior_class=GAS,\n   281→        color_r=0.85, color_g=0.85, color_b=0.90,\n   282→    ),\n   283→    SMOKE: MaterialDef(\n   284→        id=SMOKE, name=\"SMOKE\",\n   285→        rest_density=0.3, eos_stiffness=2.5, eos_gamma=1.0,\n   286→        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n   287→        buoyancy_extra=0.005, thermal_conductivity=0.02, heat_capacity=1000.0,\n   288→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   289→        behavior_class=GAS,\n   290→        color_r=0.3, color_g=0.3, color_b=0.3,\n   291→    ),\n   292→    FIRE: MaterialDef(\n   293→        id=FIRE, name=\"FIRE\",\n   294→        rest_density=0.2, eos_stiffness=4.0, eos_gamma=1.0,\n   295→        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n   296→        buoyancy_extra=0.02, thermal_conductivity=0.05, heat_capacity=1000.0,\n   297→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   298→        behavior_class=GAS,\n   299→        color_r=1.0, color_g=0.6, color_b=0.1,\n   300→    ),\n   301→    GUNPOWDER: MaterialDef(\n   302→        id=GUNPOWDER, name=\"GUNPOWDER\",\n   303→        rest_density=1700.0, eos_stiffness=20.0, eos_gamma=7.0,\n   304→        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.0,\n   305→        buoyancy_extra=0.0, thermal_conductivity=0.2, heat_capacity=800.0,\n   306→        temp_melt=0.0, temp_boil=0.0, temp_ignite=480.0,\n   307→        behavior_class=GRANULAR,\n   308→        color_r=0.2, color_g=0.2, color_b=0.2,\n   309→    ),\n   310→}\n   311→\n   312→assert len(MATERIALS) == NUM_DEFINED\n   313→\n   314→# ---------------------------------------------------------------------------\n   315→# 32x32 Interaction matrix\n   316→#\n   317→# Each (i, j) pair stores reaction_rate and heat_exchange.\n   318→# Only non-trivial pairs are listed; everything else defaults to zero.\n   319→# Symmetric: both (a,b) and (b,a) are set.\n   320→#\n   321→# Key interactions:\n   322→#   water + lava   -> steam (high heat exchange)\n   323→#   acid  + metal  -> reaction_rate 0.3\n   324→#   acid  + stone  -> slow corrosion\n   325→#   acid  + wood   -> slow corrosion\n   326→#   fire  + wood   -> burning\n   327→#   fire  + oil    -> fast burning\n   328→#   fire  + gunpowder -> explosion\n   329→#   lava  + ice    -> steam + stone\n   330→#   lava  + wood   -> burning\n   331→#   water + ice    -> melting\n   332→# ---------------------------------------------------------------------------\n   333→\n   334→# (mat_a, mat_b): (reaction_rate, heat_exchange)\n   335→_INTERACTION_PAIRS: List[Tuple[int, int, float, float]] = [\n   336→    # water interactions\n   337→    (WATER, LAVA, 0.5, 5.0),         # water + lava -> steam, cools lava\n   338→    (WATER, ICE, 0.1, 2.0),          # water near ice -> freezing/melting\n   339→    (WATER, FIRE, 0.8, 3.0),         # water extinguishes fire\n   340→    (WATER, ACID, 0.05, 0.5),        # water dilutes acid slowly\n   341→    # lava interactions\n   342→    (LAVA, ICE, 0.6, 6.0),           # lava melts ice rapidly\n   343→    (LAVA, WOOD, 0.7, 4.0),          # lava ignites wood\n   344→    (LAVA, METAL, 0.05, 3.0),        # lava heats metal\n   345→    (LAVA, STONE, 0.0, 2.0),         # lava heats stone (no reaction, just heat)\n   346→    (LAVA, OIL, 0.8, 5.0),           # lava ignites oil\n   347→    (LAVA, GUNPOWDER, 0.9, 5.0),     # lava detonates gunpowder\n   348→    # acid interactions\n   349→    (ACID, STONE, 0.15, 0.3),        # acid slowly corrodes stone\n   350→    (ACID, METAL, 0.3, 0.5),         # acid corrodes metal\n   351→    (ACID, WOOD, 0.2, 0.2),          # acid corrodes wood\n   352→    (ACID, DIRT, 0.1, 0.1),          # acid dissolves dirt\n   353→    (ACID, ICE, 0.2, 1.0),           # acid melts ice\n   354→    # fire interactions\n   355→    (FIRE, WOOD, 0.6, 2.0),          # fire burns wood\n   356→    (FIRE, OIL, 0.8, 3.0),           # fire burns oil quickly\n   357→    (FIRE, GUNPOWDER, 0.9, 4.0),     # fire detonates gunpowder\n   358→    (FIRE, ICE, 0.3, 2.5),           # fire melts ice\n   359→    (FIRE, SMOKE, 0.0, 0.5),         # fire produces smoke (heat only)\n   360→    # oil interactions\n   361→    (OIL, WATER, 0.0, 0.3),          # oil floats on water (no reaction, low heat)\n   362→    # ice + steam\n   363→    (ICE, STEAM, 0.2, 1.5),          # steam melts ice\n   364→    # metal + fire\n   365→    (FIRE, METAL, 0.0, 2.0),         # fire heats metal (no reaction, heat only)\n   366→    # stone + fire\n   367→    (FIRE, STONE, 0.0, 0.5),         # fire heats stone slowly\n   368→]\n   369→\n   370→\n   371→def build_interaction_matrix() -> np.ndarray:\n   372→    \"\"\"Build the 32x32 interaction matrix as a numpy structured array.\n   373→\n   374→    Returns a (32, 32) array of Interaction structs. Interactions are\n   375→    symmetric: setting (a, b) also sets (b, a).\n   376→    \"\"\"\n   377→    matrix = np.zeros((MAX_MATERIALS, MAX_MATERIALS), dtype=INTERACTION_DTYPE)\n   378→    for a, b, rate, heat in _INTERACTION_PAIRS:\n   379→        matrix[a][b][\"reaction_rate\"] = rate\n   380→        matrix[a][b][\"heat_exchange\"] = heat\n   381→        matrix[b][a][\"reaction_rate\"] = rate\n   382→        matrix[b][a][\"heat_exchange\"] = heat\n   383→    return matrix\n   384→\n   385→\n   386→def build_material_array() -> np.ndarray:\n   387→    \"\"\"Build the MaterialProps[32] array as a numpy structured array.\n   388→\n   389→    IDs 0-15 come from MATERIALS; IDs 16-31 are zeroed (reserved).\n   390→    \"\"\"\n   391→    arr = np.zeros(MAX_MATERIALS, dtype=MATERIAL_PROPS_DTYPE)\n   392→    for mat_id, mat_def in MATERIALS.items():\n   393→        arr[mat_id] = mat_def.to_numpy()\n   394→    return arr\n   395→\n   396→\n   397→# ---------------------------------------------------------------------------\n   398→# GPU upload via CuPy RawModule\n   399→# ---------------------------------------------------------------------------\n   400→\n   401→# Cached CuPy RawModule (compiled on first use)\n   402→_module: Optional[object] = None\n   403→\n   404→\n   405→def _ensure_ptx_if_needed() -> None:\n   406→    \"\"\"Force PTX compilation when the GPU arch exceeds NVRTC's max sm target.\"\"\"\n   407→    from cupy.cuda import compiler as _compiler\n   408→    from cupy.cuda import device as _device\n   409→\n   410→    gpu_cc = _device.Device().compute_capability\n   411→    nvrtc_max = _compiler._get_max_compute_capability()\n   412→    if int(gpu_cc) > int(nvrtc_max):\n   413→        _compiler._use_ptx = True\n   414→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n   415→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n   416→        if hasattr(_compiler._get_arch, \"_cache\"):\n   417→            _compiler._get_arch._cache = {}\n   418→\n   419→\n   420→def _get_module() -> \"object\":\n   421→    \"\"\"Compile (or return cached) CuPy RawModule with common.cuh included.\"\"\"\n   422→    global _module\n   423→    if _module is None:\n   424→        import cupy\n   425→\n   426→        _ensure_ptx_if_needed()\n   427→        kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   428→        # Minimal CUDA source that includes common.cuh for its constant memory\n   429→        # declarations, plus a test kernel for verification.\n   430→        source = r\"\"\"\n   431→#include \"common.cuh\"\n   432→\n   433→extern \"C\" __global__\n   434→void test_read_materials(float* out) {\n   435→    // out[0] = c_materials[5].rest_density   (water -> 1000.0)\n   436→    // out[1] = c_interactions[8][10].reaction_rate  (acid-metal -> 0.3)\n   437→    out[0] = c_materials[5].rest_density;\n   438→    out[1] = c_interactions[8][10].reaction_rate;\n   439→}\n   440→\"\"\"\n   441→        _module = cupy.RawModule(\n   442→            code=source,\n   443→            options=(\"--std=c++11\", f\"-I{kernel_dir}\"),\n   444→        )\n   445→    return _module\n   446→\n   447→\n   448→def upload_to_gpu(module: Optional[object] = None) -> None:\n   449→    \"\"\"Copy MaterialProps[32] and Interaction[32][32] to CUDA constant memory.\n   450→\n   451→    Parameters\n   452→    ----------\n   453→    module : CuPy RawModule, optional\n   454→        If provided, upload to this module's constant memory symbols.\n   455→        If None, uses the internal module from _get_module().\n   456→    \"\"\"\n   457→    import cupy\n   458→\n   459→    cudaMemcpyHostToDevice = 1\n   460→\n   461→    if module is None:\n   462→        module = _get_module()\n   463→\n   464→    h_materials = build_material_array()\n   465→    h_interactions = build_interaction_matrix()\n   466→\n   467→    d_materials_ptr = module.get_global(\"c_materials\")\n   468→    d_interactions_ptr = module.get_global(\"c_interactions\")\n   469→\n   470→    cupy.cuda.runtime.memcpy(\n   471→        int(d_materials_ptr),\n   472→        h_materials.ctypes.data,\n   473→        h_materials.nbytes,\n   474→        cudaMemcpyHostToDevice,\n   475→    )\n   476→\n   477→    cupy.cuda.runtime.memcpy(\n   478→        int(d_interactions_ptr),\n   479→        h_interactions.ctypes.data,\n   480→        h_interactions.nbytes,\n   481→        cudaMemcpyHostToDevice,\n   482→    )\n   483→\n   484→\n   485→def get_module() -> \"object\":\n   486→    \"\"\"Return the compiled CuPy RawModule (public accessor for tests).\"\"\"\n   487→    return _get_module()\n   488→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"4866d367-d48b-4a34-81f5-869c2bcf590b","uuid":"447d229b-4bb5-4cf9-8654-98639b88f46d","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/materials.py","content":"\"\"\"Material property table and interaction matrix for multi-material SPH.\n\nDefines 16 materials (IDs 0-15) as Python dataclasses, a 32x32 interaction\nmatrix, and an upload_to_gpu() function that copies both tables to CUDA\nconstant memory via CuPy RawModule symbol lookup.\n\nStruct layout matches fallingsand3d/physics/kernels/common.cuh exactly.\n\nConstant-memory symbols\n-----------------------\n- ``c_materials``   : MaterialProps[32]\n- ``c_interactions`` : Interaction[32][32]\n\"\"\"\n\nfrom __future__ import annotations\n\nimport dataclasses\nimport os\nfrom typing import Dict, List, Optional, Tuple\n\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# Numpy structured dtypes matching the C structs in common.cuh\n# ---------------------------------------------------------------------------\n\nMATERIAL_PROPS_DTYPE = np.dtype(\n    [\n        (\"rest_density\", np.float32),\n        (\"eos_stiffness\", np.float32),\n        (\"eos_gamma\", np.float32),\n        (\"base_viscosity\", np.float32),\n        (\"friction_coeff\", np.float32),\n        (\"cohesion\", np.float32),\n        (\"buoyancy_extra\", np.float32),\n        (\"thermal_conductivity\", np.float32),\n        (\"heat_capacity\", np.float32),\n        (\"temp_melt\", np.float32),\n        (\"temp_boil\", np.float32),\n        (\"temp_ignite\", np.float32),\n        (\"behavior_class\", np.int32),\n        (\"color_r\", np.float32),\n        (\"color_g\", np.float32),\n        (\"color_b\", np.float32),\n    ],\n    align=True,\n)\n\nINTERACTION_DTYPE = np.dtype(\n    [\n        (\"reaction_rate\", np.float32),\n        (\"heat_exchange\", np.float32),\n    ],\n    align=True,\n)\n\n# Compile-time size checks (must match sizeof(MaterialProps) and sizeof(Interaction))\nassert MATERIAL_PROPS_DTYPE.itemsize == 64, (\n    f\"MaterialProps size mismatch: {MATERIAL_PROPS_DTYPE.itemsize} != 64\"\n)\nassert INTERACTION_DTYPE.itemsize == 8, (\n    f\"Interaction size mismatch: {INTERACTION_DTYPE.itemsize} != 8\"\n)\n\nMAX_MATERIALS = 32  # slots in constant memory (IDs 0-31)\nNUM_DEFINED = 16  # IDs 0-15 are defined; 16-31 reserved (zeroed)\n\n# ---------------------------------------------------------------------------\n# BehaviorClass enum (mirrors common.cuh)\n# ---------------------------------------------------------------------------\n\nFLUID = 0\nGRANULAR = 1\nGAS = 2\nSTATIC = 3\n\n# ---------------------------------------------------------------------------\n# MaterialDef dataclass\n# ---------------------------------------------------------------------------\n\n\n@dataclasses.dataclass\nclass MaterialDef:\n    \"\"\"Python-side definition of a single material.\n\n    Field names and semantics match the ``MaterialProps`` C struct in common.cuh.\n    \"\"\"\n\n    id: int\n    name: str  # human-readable label (not uploaded to GPU)\n    rest_density: float  # kg/m^3\n    eos_stiffness: float  # Tait EOS k\n    eos_gamma: float  # Tait EOS exponent (7 for liquid, 1 for gas)\n    base_viscosity: float  # Pa*s\n    friction_coeff: float  # mu_s for granular friction\n    cohesion: float  # cohesion coefficient\n    buoyancy_extra: float  # extra buoyancy factor for gas\n    thermal_conductivity: float  # W/(m*K)\n    heat_capacity: float  # J/(kg*K)\n    temp_melt: float  # Kelvin\n    temp_boil: float  # Kelvin\n    temp_ignite: float  # Kelvin (0 = non-flammable)\n    behavior_class: int  # BehaviorClass enum value\n    color_r: float  # default material color R [0,1]\n    color_g: float  # default material color G [0,1]\n    color_b: float  # default material color B [0,1]\n\n    def to_numpy(self) -> np.void:\n        \"\"\"Pack into a single numpy structured-array element.\"\"\"\n        return np.array(\n            (\n                self.rest_density,\n                self.eos_stiffness,\n                self.eos_gamma,\n                self.base_viscosity,\n                self.friction_coeff,\n                self.cohesion,\n                self.buoyancy_extra,\n                self.thermal_conductivity,\n                self.heat_capacity,\n                self.temp_melt,\n                self.temp_boil,\n                self.temp_ignite,\n                self.behavior_class,\n                self.color_r,\n                self.color_g,\n                self.color_b,\n            ),\n            dtype=MATERIAL_PROPS_DTYPE,\n        )\n\n\n# ---------------------------------------------------------------------------\n# Material ID constants\n# ---------------------------------------------------------------------------\n\nDEAD = 0\nSTONE = 1\nSAND = 2\nDIRT = 3\nGRAVEL = 4\nWATER = 5\nOIL = 6\nLAVA = 7\nACID = 8\nWOOD = 9\nMETAL = 10\nICE = 11\nSTEAM = 12\nSMOKE = 13\nFIRE = 14\nGUNPOWDER = 15\n\n# ---------------------------------------------------------------------------\n# Material definitions (16 entries, IDs 0-15)\n#\n# Property values chosen for a falling-sand / multi-material SPH game:\n#   - rest_density in kg/m^3 (approximate real-world)\n#   - eos_stiffness: Tait EOS pressure coefficient (game-tuned)\n#   - eos_gamma: 7 for FLUID/GRANULAR, 1 for GAS, 0 for STATIC/DEAD\n#   - base_viscosity in Pa*s (scaled for game feel)\n#   - temperatures in Kelvin\n# ---------------------------------------------------------------------------\n\nMATERIALS: Dict[int, MaterialDef] = {\n    DEAD: MaterialDef(\n        id=DEAD, name=\"DEAD\",\n        rest_density=0.0, eos_stiffness=0.0, eos_gamma=0.0,\n        base_viscosity=0.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.0, heat_capacity=0.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.0, color_g=0.0, color_b=0.0,\n    ),\n    STONE: MaterialDef(\n        id=STONE, name=\"STONE\",\n        rest_density=2600.0, eos_stiffness=50.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.7, cohesion=0.5,\n        buoyancy_extra=0.0, thermal_conductivity=2.0, heat_capacity=800.0,\n        temp_melt=1500.0, temp_boil=3000.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.5, color_g=0.5, color_b=0.5,\n    ),\n    SAND: MaterialDef(\n        id=SAND, name=\"SAND\",\n        rest_density=1600.0, eos_stiffness=20.0, eos_gamma=7.0,\n        base_viscosity=0.5, friction_coeff=0.6, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.3, heat_capacity=830.0,\n        temp_melt=1700.0, temp_boil=2500.0, temp_ignite=0.0,\n        behavior_class=GRANULAR,\n        color_r=0.76, color_g=0.70, color_b=0.50,\n    ),\n    DIRT: MaterialDef(\n        id=DIRT, name=\"DIRT\",\n        rest_density=1500.0, eos_stiffness=18.0, eos_gamma=7.0,\n        base_viscosity=0.8, friction_coeff=0.5, cohesion=0.1,\n        buoyancy_extra=0.0, thermal_conductivity=0.25, heat_capacity=900.0,\n        temp_melt=1400.0, temp_boil=2200.0, temp_ignite=0.0,\n        behavior_class=GRANULAR,\n        color_r=0.55, color_g=0.35, color_b=0.17,\n    ),\n    GRAVEL: MaterialDef(\n        id=GRAVEL, name=\"GRAVEL\",\n        rest_density=1800.0, eos_stiffness=25.0, eos_gamma=7.0,\n        base_viscosity=0.3, friction_coeff=0.65, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=840.0,\n        temp_melt=1500.0, temp_boil=2800.0, temp_ignite=0.0,\n        behavior_class=GRANULAR,\n        color_r=0.45, color_g=0.42, color_b=0.40,\n    ),\n    WATER: MaterialDef(\n        id=WATER, name=\"WATER\",\n        rest_density=1000.0, eos_stiffness=10.0, eos_gamma=7.0,\n        base_viscosity=1.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.6, heat_capacity=4186.0,\n        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n        behavior_class=FLUID,\n        color_r=0.2, color_g=0.5, color_b=0.9,\n    ),\n    OIL: MaterialDef(\n        id=OIL, name=\"OIL\",\n        rest_density=800.0, eos_stiffness=8.0, eos_gamma=7.0,\n        base_viscosity=5.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=2000.0,\n        temp_melt=250.0, temp_boil=570.0, temp_ignite=480.0,\n        behavior_class=FLUID,\n        color_r=0.15, color_g=0.10, color_b=0.05,\n    ),\n    LAVA: MaterialDef(\n        id=LAVA, name=\"LAVA\",\n        rest_density=2500.0, eos_stiffness=30.0, eos_gamma=7.0,\n        base_viscosity=100.0, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=1.5, heat_capacity=1000.0,\n        temp_melt=1000.0, temp_boil=2500.0, temp_ignite=0.0,\n        behavior_class=FLUID,\n        color_r=1.0, color_g=0.3, color_b=0.0,\n    ),\n    ACID: MaterialDef(\n        id=ACID, name=\"ACID\",\n        rest_density=1200.0, eos_stiffness=10.0, eos_gamma=7.0,\n        base_viscosity=1.5, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.5, heat_capacity=2500.0,\n        temp_melt=250.0, temp_boil=380.0, temp_ignite=0.0,\n        behavior_class=FLUID,\n        color_r=0.4, color_g=1.0, color_b=0.1,\n    ),\n    WOOD: MaterialDef(\n        id=WOOD, name=\"WOOD\",\n        rest_density=600.0, eos_stiffness=15.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.3,\n        buoyancy_extra=0.0, thermal_conductivity=0.15, heat_capacity=1700.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=570.0,\n        behavior_class=STATIC,\n        color_r=0.55, color_g=0.35, color_b=0.12,\n    ),\n    METAL: MaterialDef(\n        id=METAL, name=\"METAL\",\n        rest_density=7800.0, eos_stiffness=100.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.6, cohesion=1.0,\n        buoyancy_extra=0.0, thermal_conductivity=50.0, heat_capacity=450.0,\n        temp_melt=1800.0, temp_boil=3300.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.7, color_g=0.7, color_b=0.75,\n    ),\n    ICE: MaterialDef(\n        id=ICE, name=\"ICE\",\n        rest_density=917.0, eos_stiffness=15.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.1, cohesion=0.2,\n        buoyancy_extra=0.0, thermal_conductivity=2.2, heat_capacity=2090.0,\n        temp_melt=273.0, temp_boil=373.0, temp_ignite=0.0,\n        behavior_class=STATIC,\n        color_r=0.7, color_g=0.9, color_b=1.0,\n    ),\n    STEAM: MaterialDef(\n        id=STEAM, name=\"STEAM\",\n        rest_density=0.6, eos_stiffness=3.0, eos_gamma=1.0,\n        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.01, thermal_conductivity=0.025, heat_capacity=2010.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=GAS,\n        color_r=0.85, color_g=0.85, color_b=0.90,\n    ),\n    SMOKE: MaterialDef(\n        id=SMOKE, name=\"SMOKE\",\n        rest_density=0.3, eos_stiffness=2.5, eos_gamma=1.0,\n        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.005, thermal_conductivity=0.02, heat_capacity=1000.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=GAS,\n        color_r=0.3, color_g=0.3, color_b=0.3,\n    ),\n    FIRE: MaterialDef(\n        id=FIRE, name=\"FIRE\",\n        rest_density=0.2, eos_stiffness=4.0, eos_gamma=1.0,\n        base_viscosity=0.01, friction_coeff=0.0, cohesion=0.0,\n        buoyancy_extra=0.02, thermal_conductivity=0.05, heat_capacity=1000.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n        behavior_class=GAS,\n        color_r=1.0, color_g=0.6, color_b=0.1,\n    ),\n    GUNPOWDER: MaterialDef(\n        id=GUNPOWDER, name=\"GUNPOWDER\",\n        rest_density=1700.0, eos_stiffness=20.0, eos_gamma=7.0,\n        base_viscosity=0.0, friction_coeff=0.5, cohesion=0.0,\n        buoyancy_extra=0.0, thermal_conductivity=0.2, heat_capacity=800.0,\n        temp_melt=0.0, temp_boil=0.0, temp_ignite=480.0,\n        behavior_class=GRANULAR,\n        color_r=0.2, color_g=0.2, color_b=0.2,\n    ),\n}\n\nassert len(MATERIALS) == NUM_DEFINED\n\n# ---------------------------------------------------------------------------\n# 32x32 Interaction matrix\n#\n# Each (i, j) pair stores reaction_rate and heat_exchange.\n# Only non-trivial pairs are listed; everything else defaults to zero.\n# Symmetric: both (a,b) and (b,a) are set.\n#\n# Key interactions:\n#   water + lava   -> steam (high heat exchange)\n#   acid  + metal  -> reaction_rate 0.3\n#   acid  + stone  -> slow corrosion\n#   acid  + wood   -> slow corrosion\n#   fire  + wood   -> burning\n#   fire  + oil    -> fast burning\n#   fire  + gunpowder -> explosion\n#   lava  + ice    -> steam + stone\n#   lava  + wood   -> burning\n#   water + ice    -> melting\n# ---------------------------------------------------------------------------\n\n# (mat_a, mat_b): (reaction_rate, heat_exchange)\n_INTERACTION_PAIRS: List[Tuple[int, int, float, float]] = [\n    # water interactions\n    (WATER, LAVA, 0.5, 5.0),         # water + lava -> steam, cools lava\n    (WATER, ICE, 0.1, 2.0),          # water near ice -> freezing/melting\n    (WATER, FIRE, 0.8, 3.0),         # water extinguishes fire\n    (WATER, ACID, 0.05, 0.5),        # water dilutes acid slowly\n    # lava interactions\n    (LAVA, ICE, 0.6, 6.0),           # lava melts ice rapidly\n    (LAVA, WOOD, 0.7, 4.0),          # lava ignites wood\n    (LAVA, METAL, 0.05, 3.0),        # lava heats metal\n    (LAVA, STONE, 0.0, 2.0),         # lava heats stone (no reaction, just heat)\n    (LAVA, OIL, 0.8, 5.0),           # lava ignites oil\n    (LAVA, GUNPOWDER, 0.9, 5.0),     # lava detonates gunpowder\n    # acid interactions\n    (ACID, STONE, 0.15, 0.3),        # acid slowly corrodes stone\n    (ACID, METAL, 0.3, 0.5),         # acid corrodes metal\n    (ACID, WOOD, 0.2, 0.2),          # acid corrodes wood\n    (ACID, DIRT, 0.1, 0.1),          # acid dissolves dirt\n    (ACID, ICE, 0.2, 1.0),           # acid melts ice\n    # fire interactions\n    (FIRE, WOOD, 0.6, 2.0),          # fire burns wood\n    (FIRE, OIL, 0.8, 3.0),           # fire burns oil quickly\n    (FIRE, GUNPOWDER, 0.9, 4.0),     # fire detonates gunpowder\n    (FIRE, ICE, 0.3, 2.5),           # fire melts ice\n    (FIRE, SMOKE, 0.0, 0.5),         # fire produces smoke (heat only)\n    # oil interactions\n    (OIL, WATER, 0.0, 0.3),          # oil floats on water (no reaction, low heat)\n    # ice + steam\n    (ICE, STEAM, 0.2, 1.5),          # steam melts ice\n    # metal + fire\n    (FIRE, METAL, 0.0, 2.0),         # fire heats metal (no reaction, heat only)\n    # stone + fire\n    (FIRE, STONE, 0.0, 0.5),         # fire heats stone slowly\n]\n\n\ndef build_interaction_matrix() -> np.ndarray:\n    \"\"\"Build the 32x32 interaction matrix as a numpy structured array.\n\n    Returns a (32, 32) array of Interaction structs. Interactions are\n    symmetric: setting (a, b) also sets (b, a).\n    \"\"\"\n    matrix = np.zeros((MAX_MATERIALS, MAX_MATERIALS), dtype=INTERACTION_DTYPE)\n    for a, b, rate, heat in _INTERACTION_PAIRS:\n        matrix[a][b][\"reaction_rate\"] = rate\n        matrix[a][b][\"heat_exchange\"] = heat\n        matrix[b][a][\"reaction_rate\"] = rate\n        matrix[b][a][\"heat_exchange\"] = heat\n    return matrix\n\n\ndef build_material_array() -> np.ndarray:\n    \"\"\"Build the MaterialProps[32] array as a numpy structured array.\n\n    IDs 0-15 come from MATERIALS; IDs 16-31 are zeroed (reserved).\n    \"\"\"\n    arr = np.zeros(MAX_MATERIALS, dtype=MATERIAL_PROPS_DTYPE)\n    for mat_id, mat_def in MATERIALS.items():\n        arr[mat_id] = mat_def.to_numpy()\n    return arr\n\n\n# ---------------------------------------------------------------------------\n# GPU upload via CuPy RawModule\n# ---------------------------------------------------------------------------\n\n# Cached CuPy RawModule (compiled on first use)\n_module: Optional[object] = None\n\n\ndef _ensure_ptx_if_needed() -> None:\n    \"\"\"Force PTX compilation when the GPU arch exceeds NVRTC's max sm target.\"\"\"\n    from cupy.cuda import compiler as _compiler\n    from cupy.cuda import device as _device\n\n    gpu_cc = _device.Device().compute_capability\n    nvrtc_max = _compiler._get_max_compute_capability()\n    if int(gpu_cc) > int(nvrtc_max):\n        _compiler._use_ptx = True\n        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n        if hasattr(_compiler._get_arch, \"_cache\"):\n            _compiler._get_arch._cache = {}\n\n\ndef _get_module() -> \"object\":\n    \"\"\"Compile (or return cached) CuPy RawModule with common.cuh included.\"\"\"\n    global _module\n    if _module is None:\n        import cupy\n\n        _ensure_ptx_if_needed()\n        kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n        # Minimal CUDA source that includes common.cuh for its constant memory\n        # declarations, plus a test kernel for verification.\n        source = r\"\"\"\n#include \"common.cuh\"\n\nextern \"C\" __global__\nvoid test_read_materials(float* out) {\n    // out[0] = c_materials[5].rest_density   (water -> 1000.0)\n    // out[1] = c_interactions[8][10].reaction_rate  (acid-metal -> 0.3)\n    out[0] = c_materials[5].rest_density;\n    out[1] = c_interactions[8][10].reaction_rate;\n}\n\"\"\"\n        _module = cupy.RawModule(\n            code=source,\n            options=(\"--std=c++11\", f\"-I{kernel_dir}\"),\n        )\n    return _module\n\n\ndef upload_to_gpu(module: Optional[object] = None) -> None:\n    \"\"\"Copy MaterialProps[32] and Interaction[32][32] to CUDA constant memory.\n\n    Parameters\n    ----------\n    module : CuPy RawModule, optional\n        If provided, upload to this module's constant memory symbols.\n        If None, uses the internal module from _get_module().\n    \"\"\"\n    import cupy\n\n    cudaMemcpyHostToDevice = 1\n\n    if module is None:\n        module = _get_module()\n\n    h_materials = build_material_array()\n    h_interactions = build_interaction_matrix()\n\n    d_materials_ptr = module.get_global(\"c_materials\")\n    d_interactions_ptr = module.get_global(\"c_interactions\")\n\n    cupy.cuda.runtime.memcpy(\n        int(d_materials_ptr),\n        h_materials.ctypes.data,\n        h_materials.nbytes,\n        cudaMemcpyHostToDevice,\n    )\n\n    cupy.cuda.runtime.memcpy(\n        int(d_interactions_ptr),\n        h_interactions.ctypes.data,\n        h_interactions.nbytes,\n        cudaMemcpyHostToDevice,\n    )\n\n\ndef get_module() -> \"object\":\n    \"\"\"Return the compiled CuPy RawModule (public accessor for tests).\"\"\"\n    return _get_module()\n","numLines":488,"startLine":1,"totalLines":488}}}

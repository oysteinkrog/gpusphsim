{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CYLPeQUYeMJjqTCniRErce","type":"tool_result","content":"     1→\"\"\"CUDA-GL interop via ctypes bindings for cudart64_12.dll (Windows/NVIDIA).\n     2→\n     3→Provides Python wrappers around CUDA runtime GL interop functions so that\n     4→an OpenGL VBO can be shared with CUDA (and written to by CuPy kernels)\n     5→without any CPU round-trip.\n     6→\n     7→Exported API\n     8→------------\n     9→- register_buffer(vbo_id, nbytes, flags) -> cudaGraphicsResource*\n    10→- map_buffer(resource)\n    11→- get_mapped_pointer(resource) -> (dev_ptr, size)\n    12→- unmap_buffer(resource)\n    13→- CudaGLBuffer  -- convenience class wrapping the lifecycle\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import ctypes\n    19→import ctypes.util\n    20→import platform\n    21→from ctypes import (\n    22→    POINTER,\n    23→    byref,\n    24→    c_int,\n    25→    c_size_t,\n    26→    c_uint,\n    27→    c_void_p,\n    28→)\n    29→from typing import Optional\n    30→\n    31→# ---------------------------------------------------------------------------\n    32→# Load the CUDA runtime library\n    33→# ---------------------------------------------------------------------------\n    34→\n    35→# Opaque handle -- cudaGraphicsResource*\n    36→_cudaGraphicsResource_p = c_void_p\n    37→\n    38→# cudaError_t is an int enum in the CUDA headers\n    39→_cudaError_t = c_int\n    40→\n    41→# cudaGraphicsRegisterFlags / cudaGraphicsMapFlags\n    42→cudaGraphicsRegisterFlagsNone = 0\n    43→cudaGraphicsRegisterFlagsWriteDiscard = 2\n    44→cudaGraphicsMapFlagsNone = 0\n    45→cudaGraphicsMapFlagsReadOnly = 1\n    46→cudaGraphicsMapFlagsWriteDiscard = 2\n    47→\n    48→cudaSuccess = 0\n    49→\n    50→\n    51→def _load_cudart() -> ctypes.CDLL:\n    52→    \"\"\"Locate and load the CUDA runtime shared library.\"\"\"\n    53→    if platform.system() == \"Windows\":\n    54→        # Try CUDA 12.x first, then 11.x\n    55→        for ver in (\"12\", \"11\"):\n    56→            name = f\"cudart64_{ver}\"\n    57→            try:\n    58→                return ctypes.CDLL(name)\n    59→            except OSError:\n    60→                pass\n    61→        # Fallback: let ctypes.util find it\n    62→        path = ctypes.util.find_library(\"cudart64_12\") or ctypes.util.find_library(\n    63→            \"cudart\"\n    64→        )\n    65→        if path:\n    66→            return ctypes.CDLL(path)\n    67→        raise OSError(\n    68→            \"Cannot find cudart64_12.dll (or cudart64_11.dll). \"\n    69→            \"Make sure the NVIDIA CUDA Toolkit bin directory is on PATH.\"\n    70→        )\n    71→    else:\n    72→        # Linux / other\n    73→        for name in (\"libcudart.so.12\", \"libcudart.so.11\", \"libcudart.so\"):\n    74→            try:\n    75→                return ctypes.CDLL(name)\n    76→            except OSError:\n    77→                pass\n    78→        path = ctypes.util.find_library(\"cudart\")\n    79→        if path:\n    80→            return ctypes.CDLL(path)\n    81→        raise OSError(\"Cannot find libcudart.so. Is the CUDA Toolkit installed?\")\n    82→\n    83→\n    84→_cudart = _load_cudart()\n    85→\n    86→# ---------------------------------------------------------------------------\n    87→# Declare function signatures\n    88→# ---------------------------------------------------------------------------\n    89→\n    90→# cudaError_t cudaGraphicsGLRegisterBuffer(\n    91→#     cudaGraphicsResource **resource, GLuint buffer, unsigned int flags);\n    92→_cudart.cudaGraphicsGLRegisterBuffer.restype = _cudaError_t\n    93→_cudart.cudaGraphicsGLRegisterBuffer.argtypes = [\n    94→    POINTER(c_void_p),  # cudaGraphicsResource **resource\n    95→    c_uint,  # GLuint buffer\n    96→    c_uint,  # unsigned int flags\n    97→]\n    98→\n    99→# cudaError_t cudaGraphicsUnregisterResource(cudaGraphicsResource *resource);\n   100→_cudart.cudaGraphicsUnregisterResource.restype = _cudaError_t\n   101→_cudart.cudaGraphicsUnregisterResource.argtypes = [c_void_p]\n   102→\n   103→# cudaError_t cudaGraphicsMapResources(\n   104→#     int count, cudaGraphicsResource **resources, cudaStream_t stream);\n   105→_cudart.cudaGraphicsMapResources.restype = _cudaError_t\n   106→_cudart.cudaGraphicsMapResources.argtypes = [\n   107→    c_int,  # int count\n   108→    POINTER(c_void_p),  # cudaGraphicsResource **resources\n   109→    c_void_p,  # cudaStream_t stream (0 = default)\n   110→]\n   111→\n   112→# cudaError_t cudaGraphicsUnmapResources(\n   113→#     int count, cudaGraphicsResource **resources, cudaStream_t stream);\n   114→_cudart.cudaGraphicsUnmapResources.restype = _cudaError_t\n   115→_cudart.cudaGraphicsUnmapResources.argtypes = [\n   116→    c_int,\n   117→    POINTER(c_void_p),\n   118→    c_void_p,\n   119→]\n   120→\n   121→# cudaError_t cudaGraphicsResourceGetMappedPointer(\n   122→#     void **devPtr, size_t *size, cudaGraphicsResource *mappedResource);\n   123→_cudart.cudaGraphicsResourceGetMappedPointer.restype = _cudaError_t\n   124→_cudart.cudaGraphicsResourceGetMappedPointer.argtypes = [\n   125→    POINTER(c_void_p),  # void **devPtr\n   126→    POINTER(c_size_t),  # size_t *size\n   127→    c_void_p,  # cudaGraphicsResource *mappedResource\n   128→]\n   129→\n   130→# cudaError_t cudaGetLastError(void);\n   131→_cudart.cudaGetLastError.restype = _cudaError_t\n   132→_cudart.cudaGetLastError.argtypes = []\n   133→\n   134→# const char* cudaGetErrorString(cudaError_t error);\n   135→_cudart.cudaGetErrorString.restype = ctypes.c_char_p\n   136→_cudart.cudaGetErrorString.argtypes = [_cudaError_t]\n   137→\n   138→# cudaError_t cudaSetDevice(int device);\n   139→_cudart.cudaSetDevice.restype = _cudaError_t\n   140→_cudart.cudaSetDevice.argtypes = [c_int]\n   141→\n   142→# ---------------------------------------------------------------------------\n   143→# Error checking\n   144→# ---------------------------------------------------------------------------\n   145→\n   146→\n   147→class CudaError(RuntimeError):\n   148→    \"\"\"Raised when a CUDA runtime call returns a non-success error code.\"\"\"\n   149→\n   150→    def __init__(self, err_code: int, context: str = \"\"):\n   151→        err_name = _cudart.cudaGetErrorString(err_code)\n   152→        if isinstance(err_name, bytes):\n   153→            err_name = err_name.decode(\"utf-8\", errors=\"replace\")\n   154→        msg = f\"CUDA error {err_code}: {err_name}\"\n   155→        if context:\n   156→            msg = f\"{context} -- {msg}\"\n   157→        super().__init__(msg)\n   158→        self.err_code = err_code\n   159→\n   160→\n   161→def _check(err: int, context: str = \"\") -> None:\n   162→    \"\"\"Raise CudaError if *err* != cudaSuccess.\"\"\"\n   163→    if err != cudaSuccess:\n   164→        raise CudaError(err, context)\n   165→\n   166→\n   167→def check_last_error(context: str = \"\") -> None:\n   168→    \"\"\"Call cudaGetLastError and raise on failure.\"\"\"\n   169→    _check(_cudart.cudaGetLastError(), context)\n   170→\n   171→\n   172→# ---------------------------------------------------------------------------\n   173→# Public thin wrappers\n   174→# ---------------------------------------------------------------------------\n   175→\n   176→\n   177→def register_buffer(\n   178→    vbo_id: int,\n   179→    flags: int = cudaGraphicsRegisterFlagsWriteDiscard,\n   180→) -> int:\n   181→    \"\"\"Register an OpenGL buffer object for access by CUDA.\n   182→\n   183→    Parameters\n   184→    ----------\n   185→    vbo_id : int\n   186→        The OpenGL VBO name (GLuint).\n   187→    flags : int\n   188→        Registration flags.  Default is ``cudaGraphicsRegisterFlagsWriteDiscard``.\n   189→\n   190→    Returns\n   191→    -------\n   192→    int\n   193→        Opaque handle (cudaGraphicsResource pointer as integer).\n   194→    \"\"\"\n   195→    resource = c_void_p(0)\n   196→    err = _cudart.cudaGraphicsGLRegisterBuffer(\n   197→        byref(resource), c_uint(vbo_id), c_uint(flags)\n   198→    )\n   199→    _check(err, \"cudaGraphicsGLRegisterBuffer\")\n   200→    check_last_error(\"cudaGraphicsGLRegisterBuffer (post)\")\n   201→    return resource.value\n   202→\n   203→\n   204→def unregister_buffer(resource: int) -> None:\n   205→    \"\"\"Unregister a previously registered GL buffer.\"\"\"\n   206→    err = _cudart.cudaGraphicsUnregisterResource(c_void_p(resource))\n   207→    _check(err, \"cudaGraphicsUnregisterResource\")\n   208→    check_last_error(\"cudaGraphicsUnregisterResource (post)\")\n   209→\n   210→\n   211→def map_buffer(resource: int) -> None:\n   212→    \"\"\"Map a registered resource for access by CUDA kernels.\n   213→\n   214→    Must be followed by :func:`unmap_buffer` before OpenGL can use the\n   215→    buffer again.\n   216→    \"\"\"\n   217→    res_ptr = c_void_p(resource)\n   218→    err = _cudart.cudaGraphicsMapResources(1, byref(res_ptr), c_void_p(0))\n   219→    _check(err, \"cudaGraphicsMapResources\")\n   220→    check_last_error(\"cudaGraphicsMapResources (post)\")\n   221→\n   222→\n   223→def get_mapped_pointer(resource: int) -> tuple[int, int]:\n   224→    \"\"\"Retrieve the device pointer and byte size of a mapped resource.\n   225→\n   226→    Returns\n   227→    -------\n   228→    (dev_ptr, nbytes) : tuple[int, int]\n   229→    \"\"\"\n   230→    dev_ptr = c_void_p(0)\n   231→    size = c_size_t(0)\n   232→    err = _cudart.cudaGraphicsResourceGetMappedPointer(\n   233→        byref(dev_ptr), byref(size), c_void_p(resource)\n   234→    )\n   235→    _check(err, \"cudaGraphicsResourceGetMappedPointer\")\n   236→    check_last_error(\"cudaGraphicsResourceGetMappedPointer (post)\")\n   237→    return dev_ptr.value, size.value\n   238→\n   239→\n   240→def unmap_buffer(resource: int) -> None:\n   241→    \"\"\"Unmap a previously mapped resource so OpenGL can access it again.\"\"\"\n   242→    res_ptr = c_void_p(resource)\n   243→    err = _cudart.cudaGraphicsUnmapResources(1, byref(res_ptr), c_void_p(0))\n   244→    _check(err, \"cudaGraphicsUnmapResources\")\n   245→    check_last_error(\"cudaGraphicsUnmapResources (post)\")\n   246→\n   247→\n   248→# ---------------------------------------------------------------------------\n   249→# CudaGLBuffer -- high-level RAII-style wrapper\n   250→# ---------------------------------------------------------------------------\n   251→\n   252→\n   253→class CudaGLBuffer:\n   254→    \"\"\"Manage the lifecycle of a CUDA-registered OpenGL buffer.\n   255→\n   256→    Usage::\n   257→\n   258→        buf = CudaGLBuffer(vbo_id, nbytes)\n   259→        with buf:\n   260→            ptr, size = buf.mapped_pointer()\n   261→            # ... write to ptr via CuPy ...\n   262→        # buffer is unmapped; GL can draw it\n   263→\n   264→    When the object is deleted (or :meth:`close` is called), the buffer\n   265→    is unregistered from CUDA.\n   266→    \"\"\"\n   267→\n   268→    def __init__(\n   269→        self,\n   270→        vbo_id: int,\n   271→        nbytes: int,\n   272→        flags: int = cudaGraphicsRegisterFlagsWriteDiscard,\n   273→    ) -> None:\n   274→        self.vbo_id = vbo_id\n   275→        self.nbytes = nbytes\n   276→        self._resource: Optional[int] = register_buffer(vbo_id, flags)\n   277→        self._mapped = False\n   278→\n   279→    # -- context manager for map / unmap ----------------------------------\n   280→\n   281→    def __enter__(self) -> \"CudaGLBuffer\":\n   282→        self.map()\n   283→        return self\n   284→\n   285→    def __exit__(self, *exc_info: object) -> None:\n   286→        self.unmap()\n   287→\n   288→    # -- core operations ---------------------------------------------------\n   289→\n   290→    def map(self) -> None:\n   291→        if self._mapped:\n   292→            return\n   293→        if self._resource is None:\n   294→            raise RuntimeError(\"CudaGLBuffer: resource already closed\")\n   295→        map_buffer(self._resource)\n   296→        self._mapped = True\n   297→\n   298→    def unmap(self) -> None:\n   299→        if not self._mapped:\n   300→            return\n   301→        if self._resource is None:\n   302→            raise RuntimeError(\"CudaGLBuffer: resource already closed\")\n   303→        unmap_buffer(self._resource)\n   304→        self._mapped = False\n   305→\n   306→    def mapped_pointer(self) -> tuple[int, int]:\n   307→        \"\"\"Return ``(device_ptr, byte_size)`` of the mapped buffer.\"\"\"\n   308→        if not self._mapped:\n   309→            raise RuntimeError(\"CudaGLBuffer: buffer is not mapped\")\n   310→        return get_mapped_pointer(self._resource)\n   311→\n   312→    def device_pointer_as_cupy_array(\n   313→        self,\n   314→        shape: tuple[int, ...],\n   315→        dtype: \"object\" = None,\n   316→    ) -> \"object\":\n   317→        \"\"\"Wrap the mapped device pointer as a CuPy ndarray (zero-copy).\n   318→\n   319→        Parameters\n   320→        ----------\n   321→        shape : tuple[int, ...]\n   322→            Desired array shape.\n   323→        dtype : numpy/cupy dtype\n   324→            Element type.  Defaults to ``float32``.\n   325→\n   326→        Returns\n   327→        -------\n   328→        cupy.ndarray\n   329→        \"\"\"\n   330→        import cupy  # type: ignore[import-untyped]\n   331→        import numpy as np\n   332→\n   333→        if dtype is None:\n   334→            dtype = np.float32\n   335→\n   336→        dev_ptr, size = self.mapped_pointer()\n   337→        mem = cupy.cuda.UnownedMemory(dev_ptr, size, owner=None)\n   338→        memptr = cupy.cuda.MemoryPointer(mem, 0)\n   339→        return cupy.ndarray(shape, dtype=dtype, memptr=memptr)\n   340→\n   341→    # -- cleanup -----------------------------------------------------------\n   342→\n   343→    def close(self) -> None:\n   344→        \"\"\"Unmap (if needed) and unregister the buffer.\"\"\"\n   345→        if self._mapped:\n   346→            self.unmap()\n   347→        if self._resource is not None:\n   348→            unregister_buffer(self._resource)\n   349→            self._resource = None\n   350→\n   351→    def __del__(self) -> None:\n   352→        try:\n   353→            self.close()\n   354→        except Exception:\n   355→            pass\n   356→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"43b95bdc-1f0d-4fe8-a9b3-bf0ba5f21d30","uuid":"565ba4c8-3f40-4786-bdf9-6593ba1f1229","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/gl_cuda_interop.py","content":"\"\"\"CUDA-GL interop via ctypes bindings for cudart64_12.dll (Windows/NVIDIA).\n\nProvides Python wrappers around CUDA runtime GL interop functions so that\nan OpenGL VBO can be shared with CUDA (and written to by CuPy kernels)\nwithout any CPU round-trip.\n\nExported API\n------------\n- register_buffer(vbo_id, nbytes, flags) -> cudaGraphicsResource*\n- map_buffer(resource)\n- get_mapped_pointer(resource) -> (dev_ptr, size)\n- unmap_buffer(resource)\n- CudaGLBuffer  -- convenience class wrapping the lifecycle\n\"\"\"\n\nfrom __future__ import annotations\n\nimport ctypes\nimport ctypes.util\nimport platform\nfrom ctypes import (\n    POINTER,\n    byref,\n    c_int,\n    c_size_t,\n    c_uint,\n    c_void_p,\n)\nfrom typing import Optional\n\n# ---------------------------------------------------------------------------\n# Load the CUDA runtime library\n# ---------------------------------------------------------------------------\n\n# Opaque handle -- cudaGraphicsResource*\n_cudaGraphicsResource_p = c_void_p\n\n# cudaError_t is an int enum in the CUDA headers\n_cudaError_t = c_int\n\n# cudaGraphicsRegisterFlags / cudaGraphicsMapFlags\ncudaGraphicsRegisterFlagsNone = 0\ncudaGraphicsRegisterFlagsWriteDiscard = 2\ncudaGraphicsMapFlagsNone = 0\ncudaGraphicsMapFlagsReadOnly = 1\ncudaGraphicsMapFlagsWriteDiscard = 2\n\ncudaSuccess = 0\n\n\ndef _load_cudart() -> ctypes.CDLL:\n    \"\"\"Locate and load the CUDA runtime shared library.\"\"\"\n    if platform.system() == \"Windows\":\n        # Try CUDA 12.x first, then 11.x\n        for ver in (\"12\", \"11\"):\n            name = f\"cudart64_{ver}\"\n            try:\n                return ctypes.CDLL(name)\n            except OSError:\n                pass\n        # Fallback: let ctypes.util find it\n        path = ctypes.util.find_library(\"cudart64_12\") or ctypes.util.find_library(\n            \"cudart\"\n        )\n        if path:\n            return ctypes.CDLL(path)\n        raise OSError(\n            \"Cannot find cudart64_12.dll (or cudart64_11.dll). \"\n            \"Make sure the NVIDIA CUDA Toolkit bin directory is on PATH.\"\n        )\n    else:\n        # Linux / other\n        for name in (\"libcudart.so.12\", \"libcudart.so.11\", \"libcudart.so\"):\n            try:\n                return ctypes.CDLL(name)\n            except OSError:\n                pass\n        path = ctypes.util.find_library(\"cudart\")\n        if path:\n            return ctypes.CDLL(path)\n        raise OSError(\"Cannot find libcudart.so. Is the CUDA Toolkit installed?\")\n\n\n_cudart = _load_cudart()\n\n# ---------------------------------------------------------------------------\n# Declare function signatures\n# ---------------------------------------------------------------------------\n\n# cudaError_t cudaGraphicsGLRegisterBuffer(\n#     cudaGraphicsResource **resource, GLuint buffer, unsigned int flags);\n_cudart.cudaGraphicsGLRegisterBuffer.restype = _cudaError_t\n_cudart.cudaGraphicsGLRegisterBuffer.argtypes = [\n    POINTER(c_void_p),  # cudaGraphicsResource **resource\n    c_uint,  # GLuint buffer\n    c_uint,  # unsigned int flags\n]\n\n# cudaError_t cudaGraphicsUnregisterResource(cudaGraphicsResource *resource);\n_cudart.cudaGraphicsUnregisterResource.restype = _cudaError_t\n_cudart.cudaGraphicsUnregisterResource.argtypes = [c_void_p]\n\n# cudaError_t cudaGraphicsMapResources(\n#     int count, cudaGraphicsResource **resources, cudaStream_t stream);\n_cudart.cudaGraphicsMapResources.restype = _cudaError_t\n_cudart.cudaGraphicsMapResources.argtypes = [\n    c_int,  # int count\n    POINTER(c_void_p),  # cudaGraphicsResource **resources\n    c_void_p,  # cudaStream_t stream (0 = default)\n]\n\n# cudaError_t cudaGraphicsUnmapResources(\n#     int count, cudaGraphicsResource **resources, cudaStream_t stream);\n_cudart.cudaGraphicsUnmapResources.restype = _cudaError_t\n_cudart.cudaGraphicsUnmapResources.argtypes = [\n    c_int,\n    POINTER(c_void_p),\n    c_void_p,\n]\n\n# cudaError_t cudaGraphicsResourceGetMappedPointer(\n#     void **devPtr, size_t *size, cudaGraphicsResource *mappedResource);\n_cudart.cudaGraphicsResourceGetMappedPointer.restype = _cudaError_t\n_cudart.cudaGraphicsResourceGetMappedPointer.argtypes = [\n    POINTER(c_void_p),  # void **devPtr\n    POINTER(c_size_t),  # size_t *size\n    c_void_p,  # cudaGraphicsResource *mappedResource\n]\n\n# cudaError_t cudaGetLastError(void);\n_cudart.cudaGetLastError.restype = _cudaError_t\n_cudart.cudaGetLastError.argtypes = []\n\n# const char* cudaGetErrorString(cudaError_t error);\n_cudart.cudaGetErrorString.restype = ctypes.c_char_p\n_cudart.cudaGetErrorString.argtypes = [_cudaError_t]\n\n# cudaError_t cudaSetDevice(int device);\n_cudart.cudaSetDevice.restype = _cudaError_t\n_cudart.cudaSetDevice.argtypes = [c_int]\n\n# ---------------------------------------------------------------------------\n# Error checking\n# ---------------------------------------------------------------------------\n\n\nclass CudaError(RuntimeError):\n    \"\"\"Raised when a CUDA runtime call returns a non-success error code.\"\"\"\n\n    def __init__(self, err_code: int, context: str = \"\"):\n        err_name = _cudart.cudaGetErrorString(err_code)\n        if isinstance(err_name, bytes):\n            err_name = err_name.decode(\"utf-8\", errors=\"replace\")\n        msg = f\"CUDA error {err_code}: {err_name}\"\n        if context:\n            msg = f\"{context} -- {msg}\"\n        super().__init__(msg)\n        self.err_code = err_code\n\n\ndef _check(err: int, context: str = \"\") -> None:\n    \"\"\"Raise CudaError if *err* != cudaSuccess.\"\"\"\n    if err != cudaSuccess:\n        raise CudaError(err, context)\n\n\ndef check_last_error(context: str = \"\") -> None:\n    \"\"\"Call cudaGetLastError and raise on failure.\"\"\"\n    _check(_cudart.cudaGetLastError(), context)\n\n\n# ---------------------------------------------------------------------------\n# Public thin wrappers\n# ---------------------------------------------------------------------------\n\n\ndef register_buffer(\n    vbo_id: int,\n    flags: int = cudaGraphicsRegisterFlagsWriteDiscard,\n) -> int:\n    \"\"\"Register an OpenGL buffer object for access by CUDA.\n\n    Parameters\n    ----------\n    vbo_id : int\n        The OpenGL VBO name (GLuint).\n    flags : int\n        Registration flags.  Default is ``cudaGraphicsRegisterFlagsWriteDiscard``.\n\n    Returns\n    -------\n    int\n        Opaque handle (cudaGraphicsResource pointer as integer).\n    \"\"\"\n    resource = c_void_p(0)\n    err = _cudart.cudaGraphicsGLRegisterBuffer(\n        byref(resource), c_uint(vbo_id), c_uint(flags)\n    )\n    _check(err, \"cudaGraphicsGLRegisterBuffer\")\n    check_last_error(\"cudaGraphicsGLRegisterBuffer (post)\")\n    return resource.value\n\n\ndef unregister_buffer(resource: int) -> None:\n    \"\"\"Unregister a previously registered GL buffer.\"\"\"\n    err = _cudart.cudaGraphicsUnregisterResource(c_void_p(resource))\n    _check(err, \"cudaGraphicsUnregisterResource\")\n    check_last_error(\"cudaGraphicsUnregisterResource (post)\")\n\n\ndef map_buffer(resource: int) -> None:\n    \"\"\"Map a registered resource for access by CUDA kernels.\n\n    Must be followed by :func:`unmap_buffer` before OpenGL can use the\n    buffer again.\n    \"\"\"\n    res_ptr = c_void_p(resource)\n    err = _cudart.cudaGraphicsMapResources(1, byref(res_ptr), c_void_p(0))\n    _check(err, \"cudaGraphicsMapResources\")\n    check_last_error(\"cudaGraphicsMapResources (post)\")\n\n\ndef get_mapped_pointer(resource: int) -> tuple[int, int]:\n    \"\"\"Retrieve the device pointer and byte size of a mapped resource.\n\n    Returns\n    -------\n    (dev_ptr, nbytes) : tuple[int, int]\n    \"\"\"\n    dev_ptr = c_void_p(0)\n    size = c_size_t(0)\n    err = _cudart.cudaGraphicsResourceGetMappedPointer(\n        byref(dev_ptr), byref(size), c_void_p(resource)\n    )\n    _check(err, \"cudaGraphicsResourceGetMappedPointer\")\n    check_last_error(\"cudaGraphicsResourceGetMappedPointer (post)\")\n    return dev_ptr.value, size.value\n\n\ndef unmap_buffer(resource: int) -> None:\n    \"\"\"Unmap a previously mapped resource so OpenGL can access it again.\"\"\"\n    res_ptr = c_void_p(resource)\n    err = _cudart.cudaGraphicsUnmapResources(1, byref(res_ptr), c_void_p(0))\n    _check(err, \"cudaGraphicsUnmapResources\")\n    check_last_error(\"cudaGraphicsUnmapResources (post)\")\n\n\n# ---------------------------------------------------------------------------\n# CudaGLBuffer -- high-level RAII-style wrapper\n# ---------------------------------------------------------------------------\n\n\nclass CudaGLBuffer:\n    \"\"\"Manage the lifecycle of a CUDA-registered OpenGL buffer.\n\n    Usage::\n\n        buf = CudaGLBuffer(vbo_id, nbytes)\n        with buf:\n            ptr, size = buf.mapped_pointer()\n            # ... write to ptr via CuPy ...\n        # buffer is unmapped; GL can draw it\n\n    When the object is deleted (or :meth:`close` is called), the buffer\n    is unregistered from CUDA.\n    \"\"\"\n\n    def __init__(\n        self,\n        vbo_id: int,\n        nbytes: int,\n        flags: int = cudaGraphicsRegisterFlagsWriteDiscard,\n    ) -> None:\n        self.vbo_id = vbo_id\n        self.nbytes = nbytes\n        self._resource: Optional[int] = register_buffer(vbo_id, flags)\n        self._mapped = False\n\n    # -- context manager for map / unmap ----------------------------------\n\n    def __enter__(self) -> \"CudaGLBuffer\":\n        self.map()\n        return self\n\n    def __exit__(self, *exc_info: object) -> None:\n        self.unmap()\n\n    # -- core operations ---------------------------------------------------\n\n    def map(self) -> None:\n        if self._mapped:\n            return\n        if self._resource is None:\n            raise RuntimeError(\"CudaGLBuffer: resource already closed\")\n        map_buffer(self._resource)\n        self._mapped = True\n\n    def unmap(self) -> None:\n        if not self._mapped:\n            return\n        if self._resource is None:\n            raise RuntimeError(\"CudaGLBuffer: resource already closed\")\n        unmap_buffer(self._resource)\n        self._mapped = False\n\n    def mapped_pointer(self) -> tuple[int, int]:\n        \"\"\"Return ``(device_ptr, byte_size)`` of the mapped buffer.\"\"\"\n        if not self._mapped:\n            raise RuntimeError(\"CudaGLBuffer: buffer is not mapped\")\n        return get_mapped_pointer(self._resource)\n\n    def device_pointer_as_cupy_array(\n        self,\n        shape: tuple[int, ...],\n        dtype: \"object\" = None,\n    ) -> \"object\":\n        \"\"\"Wrap the mapped device pointer as a CuPy ndarray (zero-copy).\n\n        Parameters\n        ----------\n        shape : tuple[int, ...]\n            Desired array shape.\n        dtype : numpy/cupy dtype\n            Element type.  Defaults to ``float32``.\n\n        Returns\n        -------\n        cupy.ndarray\n        \"\"\"\n        import cupy  # type: ignore[import-untyped]\n        import numpy as np\n\n        if dtype is None:\n            dtype = np.float32\n\n        dev_ptr, size = self.mapped_pointer()\n        mem = cupy.cuda.UnownedMemory(dev_ptr, size, owner=None)\n        memptr = cupy.cuda.MemoryPointer(mem, 0)\n        return cupy.ndarray(shape, dtype=dtype, memptr=memptr)\n\n    # -- cleanup -----------------------------------------------------------\n\n    def close(self) -> None:\n        \"\"\"Unmap (if needed) and unregister the buffer.\"\"\"\n        if self._mapped:\n            self.unmap()\n        if self._resource is not None:\n            unregister_buffer(self._resource)\n            self._resource = None\n\n    def __del__(self) -> None:\n        try:\n            self.close()\n        except Exception:\n            pass\n","numLines":356,"startLine":1,"totalLines":356}}}

esource = None\n\n    def __del__(self) -> None:\n        try:\n            self.close()\n        except Exception:\n            pass\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":395,"cache_read_input_tokens":61364,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":395},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"43b95bdc-1f0d-4fe8-a9b3-bf0ba5f21d30","uuid":"45588df7-84d0-4998-a902-5c423460a9c1"}

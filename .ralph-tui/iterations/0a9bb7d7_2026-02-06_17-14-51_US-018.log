           print(f\"FAIL: {test.__name__}: {e}\")\n            import traceback\n            traceback.print_exc()\n            failed += 1\n\n    print(f\"\\n{'='*60}\")\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)}\")\n    if failed > 0:\n        sys.exit(1)\n    print(\"All tests passed!\")\n","structuredPatch":[{"oldStart":228,"oldLines":7,"newStart":228,"newLines":7,"lines":["     pos2 = np.array([[0.0, -0.995, 0.0, 1.0]], dtype=np.float32)","     vel2 = np.array([[0.0, -10.0, 0.0, 0.0]], dtype=np.float32)","     d2 = make_simple_particles(n, WATER, FLUID, pos=pos2, vel=vel2)","-    pos_out2, vel_out2, _ = integrate(**d2)","+    pos_out2, vel_out2, _, _, _ = integrate(**d2)"," ","     vel_h2 = vel_out2.get()","     pos_h2 = pos_out2.get()"]}],"userModified":false,"replaceAll":true}}

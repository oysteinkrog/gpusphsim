{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015qznmkMV99NvgLwnYEYQYx","type":"tool_result","content":"     1→\"\"\"Integrate kernel: symplectic Euler with SDF boundaries and color update.\n     2→\n     3→Compiles physics/kernels/integrate.cu via CuPy RawModule and provides\n     4→a function to launch K_Integrate which performs:\n     5→  - Symplectic Euler velocity/position integration\n     6→  - Impulse-style SDF box boundary collisions (restitution + Coulomb friction)\n     7→  - GAS buoyancy and drag\n     8→  - Velocity magnitude clamping\n     9→  - Particle color computation from material, temperature, and health\n    10→  - Writeback to UNSORTED arrays via sort_indexes permutation\n    11→\n    12→Uses shared constant memory from common.cuh:\n    13→  c_sim       -- SimParams (gravity, dt, restitution, wall_friction, world bounds)\n    14→  c_materials -- MaterialProps[32] (for color lookup)\n    15→\"\"\"\n    16→\n    17→from __future__ import annotations\n    18→\n    19→import os\n    20→from typing import Optional\n    21→\n    22→import cupy\n    23→import numpy as np\n    24→\n    25→# ---------------------------------------------------------------------------\n    26→# CuPy RawModule compilation\n    27→# ---------------------------------------------------------------------------\n    28→\n    29→_module: Optional[object] = None\n    30→\n    31→\n    32→def _ensure_ptx_if_needed() -> None:\n    33→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    34→    from cupy.cuda import compiler as _compiler\n    35→    from cupy.cuda import device as _device\n    36→\n    37→    gpu_cc = _device.Device().compute_capability\n    38→    nvrtc_max = _compiler._get_max_compute_capability()\n    39→    if int(gpu_cc) > int(nvrtc_max):\n    40→        _compiler._use_ptx = True\n    41→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    42→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    43→        if hasattr(_compiler._get_arch, \"_cache\"):\n    44→            _compiler._get_arch._cache = {}\n    45→\n    46→\n    47→def _get_module() -> \"object\":\n    48→    \"\"\"Compile (or return cached) CuPy RawModule from integrate.cu.\"\"\"\n    49→    global _module\n    50→    if _module is not None:\n    51→        return _module\n    52→\n    53→    _ensure_ptx_if_needed()\n    54→\n    55→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    56→    cu_path = os.path.join(kernel_dir, \"integrate.cu\")\n    57→    with open(cu_path) as f:\n    58→        source = f.read()\n    59→\n    60→    _module = cupy.RawModule(\n    61→        code=source,\n    62→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    63→    )\n    64→    return _module\n    65→\n    66→\n    67→def get_module() -> \"object\":\n    68→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    69→    return _get_module()\n    70→\n    71→\n    72→# ---------------------------------------------------------------------------\n    73→# Constant memory upload\n    74→# ---------------------------------------------------------------------------\n    75→\n    76→\n    77→def upload_sim_params(params: np.ndarray) -> None:\n    78→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    79→    module = _get_module()\n    80→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    81→    cupy.cuda.runtime.memcpy(\n    82→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    83→    )\n    84→\n    85→\n    86→def upload_materials(materials_data: np.ndarray) -> None:\n    87→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    88→    module = _get_module()\n    89→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    90→    cupy.cuda.runtime.memcpy(\n    91→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    92→    )\n    93→\n    94→\n    95→# ---------------------------------------------------------------------------\n    96→# Kernel launch\n    97→# ---------------------------------------------------------------------------\n    98→\n    99→BLOCK_SIZE = 256\n   100→\n   101→\n   102→def integrate(\n   103→    sorted_position: cupy.ndarray,\n   104→    sorted_velocity: cupy.ndarray,\n   105→    sorted_veleval: cupy.ndarray,\n   106→    sorted_sph_force: cupy.ndarray,\n   107→    sorted_mass: cupy.ndarray,\n   108→    sorted_packed_info: cupy.ndarray,\n   109→    sorted_temperature: cupy.ndarray,\n   110→    sorted_health: cupy.ndarray,\n   111→    sorted_density: \"Optional[cupy.ndarray]\" = None,\n   112→    sorted_shear_rate: \"Optional[cupy.ndarray]\" = None,\n   113→    sort_indexes: \"Optional[cupy.ndarray]\" = None,\n   114→    position_out: \"Optional[cupy.ndarray]\" = None,\n   115→    velocity_out: \"Optional[cupy.ndarray]\" = None,\n   116→    color_out: \"Optional[cupy.ndarray]\" = None,\n   117→) -> tuple:\n   118→    \"\"\"Launch K_Integrate and return (position_out, velocity_out, color_out).\n   119→\n   120→    All sorted_* inputs are in sorted (grid) order.\n   121→    Outputs are written to UNSORTED arrays via sort_indexes[i] mapping.\n   122→\n   123→    Parameters\n   124→    ----------\n   125→    sorted_position : cupy.ndarray, (N, 4) float32\n   126→    sorted_velocity : cupy.ndarray, (N, 4) float32\n   127→    sorted_veleval : cupy.ndarray, (N, 4) float32\n   128→        XSPH-corrected veleval for FLUID; original velocity for others.\n   129→    sorted_sph_force : cupy.ndarray, (N, 4) float32\n   130→    sorted_mass : cupy.ndarray, (N,) float32\n   131→    sorted_packed_info : cupy.ndarray, (N,) uint32\n   132→    sorted_temperature : cupy.ndarray, (N,) float32\n   133→    sorted_health : cupy.ndarray, (N,) float32\n   134→    sorted_density : cupy.ndarray, optional, (N,) float32\n   135→        Density from Step1. Used for GRANULAR anti-creep check.\n   136→        If None, a zeros array is used (anti-creep won't trigger).\n   137→    sorted_shear_rate : cupy.ndarray, optional, (N,) float32\n   138→        Shear rate from Step1. Used for GRANULAR anti-creep check.\n   139→        If None, a zeros array is used (anti-creep won't trigger).\n   140→    sort_indexes : cupy.ndarray, (N,) uint32\n   141→        sort_indexes[sorted_i] = original unsorted index.\n   142→    position_out : cupy.ndarray, optional\n   143→        Pre-allocated (M, 4) float32 unsorted output.\n   144→    velocity_out : cupy.ndarray, optional\n   145→        Pre-allocated (M, 4) float32 unsorted output.\n   146→    color_out : cupy.ndarray, optional\n   147→        Pre-allocated (M, 4) float32 unsorted output.\n   148→\n   149→    Returns\n   150→    -------\n   151→    position_out, velocity_out, color_out : cupy.ndarray\n   152→    \"\"\"\n   153→    n = sorted_position.shape[0]\n   154→    if n == 0:\n   155→        return position_out, velocity_out, color_out\n   156→\n   157→    # Default density/shear_rate to zeros if not provided (anti-creep won't trigger)\n   158→    if sorted_density is None:\n   159→        sorted_density = cupy.zeros(n, dtype=cupy.float32)\n   160→    if sorted_shear_rate is None:\n   161→        sorted_shear_rate = cupy.zeros(n, dtype=cupy.float32)\n   162→\n   163→    # Allocate outputs if not provided\n   164→    if position_out is None:\n   165→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   166→        position_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n   167→    if velocity_out is None:\n   168→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   169→        velocity_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n   170→    if color_out is None:\n   171→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   172→        color_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n   173→\n   174→    module = _get_module()\n   175→    kernel = module.get_function(\"K_Integrate\")  # type: ignore[union-attr]\n   176→\n   177→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   178→    block = (BLOCK_SIZE,)\n   179→\n   180→    kernel(\n   181→        grid,\n   182→        block,\n   183→        (\n   184→            np.uint32(n),\n   185→            sorted_position,\n   186→            sorted_velocity,\n   187→            sorted_veleval,\n   188→            sorted_sph_force,\n   189→            sorted_mass,\n   190→            sorted_packed_info,\n   191→            sorted_temperature,\n   192→            sorted_health,\n   193→            sorted_density,\n   194→            sorted_shear_rate,\n   195→            sort_indexes,\n   196→            position_out,\n   197→            velocity_out,\n   198→            color_out,\n   199→        ),\n   200→    )\n   201→\n   202→    return position_out, velocity_out, color_out\n   203→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f40960f-027e-4191-b9d0-267c1a3715c8","uuid":"897569ce-1a16-4ad9-a223-b84db7643a22","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/integrate.py","content":"\"\"\"Integrate kernel: symplectic Euler with SDF boundaries and color update.\n\nCompiles physics/kernels/integrate.cu via CuPy RawModule and provides\na function to launch K_Integrate which performs:\n  - Symplectic Euler velocity/position integration\n  - Impulse-style SDF box boundary collisions (restitution + Coulomb friction)\n  - GAS buoyancy and drag\n  - Velocity magnitude clamping\n  - Particle color computation from material, temperature, and health\n  - Writeback to UNSORTED arrays via sort_indexes permutation\n\nUses shared constant memory from common.cuh:\n  c_sim       -- SimParams (gravity, dt, restitution, wall_friction, world bounds)\n  c_materials -- MaterialProps[32] (for color lookup)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom typing import Optional\n\nimport cupy\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# CuPy RawModule compilation\n# ---------------------------------------------------------------------------\n\n_module: Optional[object] = None\n\n\ndef _ensure_ptx_if_needed() -> None:\n    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    from cupy.cuda import compiler as _compiler\n    from cupy.cuda import device as _device\n\n    gpu_cc = _device.Device().compute_capability\n    nvrtc_max = _compiler._get_max_compute_capability()\n    if int(gpu_cc) > int(nvrtc_max):\n        _compiler._use_ptx = True\n        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n        if hasattr(_compiler._get_arch, \"_cache\"):\n            _compiler._get_arch._cache = {}\n\n\ndef _get_module() -> \"object\":\n    \"\"\"Compile (or return cached) CuPy RawModule from integrate.cu.\"\"\"\n    global _module\n    if _module is not None:\n        return _module\n\n    _ensure_ptx_if_needed()\n\n    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    cu_path = os.path.join(kernel_dir, \"integrate.cu\")\n    with open(cu_path) as f:\n        source = f.read()\n\n    _module = cupy.RawModule(\n        code=source,\n        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    )\n    return _module\n\n\ndef get_module() -> \"object\":\n    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    return _get_module()\n\n\n# ---------------------------------------------------------------------------\n# Constant memory upload\n# ---------------------------------------------------------------------------\n\n\ndef upload_sim_params(params: np.ndarray) -> None:\n    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    module = _get_module()\n    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    cupy.cuda.runtime.memcpy(\n        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    )\n\n\ndef upload_materials(materials_data: np.ndarray) -> None:\n    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    module = _get_module()\n    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    cupy.cuda.runtime.memcpy(\n        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    )\n\n\n# ---------------------------------------------------------------------------\n# Kernel launch\n# ---------------------------------------------------------------------------\n\nBLOCK_SIZE = 256\n\n\ndef integrate(\n    sorted_position: cupy.ndarray,\n    sorted_velocity: cupy.ndarray,\n    sorted_veleval: cupy.ndarray,\n    sorted_sph_force: cupy.ndarray,\n    sorted_mass: cupy.ndarray,\n    sorted_packed_info: cupy.ndarray,\n    sorted_temperature: cupy.ndarray,\n    sorted_health: cupy.ndarray,\n    sorted_density: \"Optional[cupy.ndarray]\" = None,\n    sorted_shear_rate: \"Optional[cupy.ndarray]\" = None,\n    sort_indexes: \"Optional[cupy.ndarray]\" = None,\n    position_out: \"Optional[cupy.ndarray]\" = None,\n    velocity_out: \"Optional[cupy.ndarray]\" = None,\n    color_out: \"Optional[cupy.ndarray]\" = None,\n) -> tuple:\n    \"\"\"Launch K_Integrate and return (position_out, velocity_out, color_out).\n\n    All sorted_* inputs are in sorted (grid) order.\n    Outputs are written to UNSORTED arrays via sort_indexes[i] mapping.\n\n    Parameters\n    ----------\n    sorted_position : cupy.ndarray, (N, 4) float32\n    sorted_velocity : cupy.ndarray, (N, 4) float32\n    sorted_veleval : cupy.ndarray, (N, 4) float32\n        XSPH-corrected veleval for FLUID; original velocity for others.\n    sorted_sph_force : cupy.ndarray, (N, 4) float32\n    sorted_mass : cupy.ndarray, (N,) float32\n    sorted_packed_info : cupy.ndarray, (N,) uint32\n    sorted_temperature : cupy.ndarray, (N,) float32\n    sorted_health : cupy.ndarray, (N,) float32\n    sorted_density : cupy.ndarray, optional, (N,) float32\n        Density from Step1. Used for GRANULAR anti-creep check.\n        If None, a zeros array is used (anti-creep won't trigger).\n    sorted_shear_rate : cupy.ndarray, optional, (N,) float32\n        Shear rate from Step1. Used for GRANULAR anti-creep check.\n        If None, a zeros array is used (anti-creep won't trigger).\n    sort_indexes : cupy.ndarray, (N,) uint32\n        sort_indexes[sorted_i] = original unsorted index.\n    position_out : cupy.ndarray, optional\n        Pre-allocated (M, 4) float32 unsorted output.\n    velocity_out : cupy.ndarray, optional\n        Pre-allocated (M, 4) float32 unsorted output.\n    color_out : cupy.ndarray, optional\n        Pre-allocated (M, 4) float32 unsorted output.\n\n    Returns\n    -------\n    position_out, velocity_out, color_out : cupy.ndarray\n    \"\"\"\n    n = sorted_position.shape[0]\n    if n == 0:\n        return position_out, velocity_out, color_out\n\n    # Default density/shear_rate to zeros if not provided (anti-creep won't trigger)\n    if sorted_density is None:\n        sorted_density = cupy.zeros(n, dtype=cupy.float32)\n    if sorted_shear_rate is None:\n        sorted_shear_rate = cupy.zeros(n, dtype=cupy.float32)\n\n    # Allocate outputs if not provided\n    if position_out is None:\n        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n        position_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n    if velocity_out is None:\n        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n        velocity_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n    if color_out is None:\n        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n        color_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n\n    module = _get_module()\n    kernel = module.get_function(\"K_Integrate\")  # type: ignore[union-attr]\n\n    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n    block = (BLOCK_SIZE,)\n\n    kernel(\n        grid,\n        block,\n        (\n            np.uint32(n),\n            sorted_position,\n            sorted_velocity,\n            sorted_veleval,\n            sorted_sph_force,\n            sorted_mass,\n            sorted_packed_info,\n            sorted_temperature,\n            sorted_health,\n            sorted_density,\n            sorted_shear_rate,\n            sort_indexes,\n            position_out,\n            velocity_out,\n            color_out,\n        ),\n    )\n\n    return position_out, velocity_out, color_out\n","numLines":203,"startLine":1,"totalLines":203}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q5XRxgkQK9kpRPbogyQkV7","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter\n     5→and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n     9→  2. Run sim_steps simulation substeps\n    10→  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import time\n    16→from typing import Optional\n    17→\n    18→import cupy as cp\n    19→import numpy as np\n    20→\n    21→from world import World\n    22→from materials import (\n    23→    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n    24→)\n    25→\n    26→import hash_sort\n    27→import fused_reorder\n    28→import build_grid\n    29→import step1\n    30→import step2\n    31→import integrate\n    32→\n    33→\n    34→class Simulation:\n    35→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    36→\n    37→    Parameters\n    38→    ----------\n    39→    world : World\n    40→        Particle state manager.\n    41→    dt : float\n    42→        Fixed simulation timestep (seconds).\n    43→    speed : float\n    44→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    45→    max_substeps : int\n    46→        Maximum substeps per render frame to prevent spiral-of-death.\n    47→    \"\"\"\n    48→\n    49→    def __init__(\n    50→        self,\n    51→        world: World,\n    52→        dt: float = 0.001,\n    53→        speed: float = 1.0,\n    54→        max_substeps: int = 20,\n    55→    ) -> None:\n    56→        self.world = world\n    57→        self.dt = dt\n    58→        self.speed = speed\n    59→        self.max_substeps = max_substeps\n    60→        self._paused = False\n    61→        self._prev_speed = speed\n    62→        self._last_frame_time: Optional[float] = None\n    63→        self._last_substeps = 0\n    64→        self.sim_time = 0.0\n    65→\n    66→        # Grid cell tables (pre-allocated, reused every frame)\n    67→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    68→\n    69→        # Compile all kernel modules and upload constant memory\n    70→        self._upload_constants()\n    71→\n    72→    def _upload_constants(self) -> None:\n    73→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n    74→        # Build shared param structs\n    75→        grid_params = hash_sort.build_grid_params()\n    76→        sim_params = step1.build_sim_params(\n    77→            smoothing_length=0.04,\n    78→            particle_mass=0.008,\n    79→            particle_spacing=0.02,\n    80→            gravity=(0.0, -9.8, 0.0),\n    81→            dt=self.dt,\n    82→            restitution=0.3,\n    83→            wall_friction=0.5,\n    84→            world_min=(-1.0, -1.0, -1.0),\n    85→            world_max=(1.0, 1.0, 1.0),\n    86→        )\n    87→        precalc_params = step1.build_precalc_params(\n    88→            smoothing_length=0.04,\n    89→            viscosity=1.0,\n    90→        )\n    91→        granular_params = step2.build_granular_params()\n    92→        materials_data = build_material_array()\n    93→        interactions_data = build_interaction_matrix()\n    94→\n    95→        # --- hash_sort module: c_grid ---\n    96→        hash_sort.upload_grid_params(grid_params)\n    97→\n    98→        # --- fused_reorder module: no constant memory needed ---\n    99→        fused_reorder.get_module()  # just compile\n   100→\n   101→        # --- build_grid module: c_grid ---\n   102→        build_grid.upload_grid_params(grid_params)\n   103→\n   104→        # --- step1 module: c_grid, c_sim, c_precalc ---\n   105→        step1.upload_grid_params(grid_params)\n   106→        step1.upload_sim_params(sim_params)\n   107→        step1.upload_precalc_params(precalc_params)\n   108→\n   109→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   110→        step2.upload_grid_params(grid_params)\n   111→        step2.upload_sim_params(sim_params)\n   112→        step2.upload_precalc_params(precalc_params)\n   113→        step2.upload_materials(materials_data)\n   114→        step2.upload_granular_params(granular_params)\n   115→\n   116→        # --- integrate module: c_sim, c_materials ---\n   117→        integrate.upload_sim_params(sim_params)\n   118→        integrate.upload_materials(materials_data)\n   119→\n   120→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   121→        upload_to_gpu()\n   122→\n   123→    def _sim_step(self, n: int) -> None:\n   124→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   125→        w = self.world\n   126→\n   127→        # 1. Hash particle positions\n   128→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   129→\n   130→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   131→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   132→            hashes, indices,\n   133→            sorted_hashes_out=w.sorted_hashes,\n   134→            sorted_indices_out=w.sorted_indices,\n   135→        )\n   136→\n   137→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   138→        fused_reorder.fused_reorder(\n   139→            n, sorted_indices,\n   140→            w.position, w.velocity, w.veleval,\n   141→            w.mass, w.packed_info, w.temperature,\n   142→            w.health, w.lifetime, w.color,\n   143→            w.sleep_counter, w.shear_rate,\n   144→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   145→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   146→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   147→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   148→        )\n   149→\n   150→        # 4. Build grid data structure (cell_start / cell_end tables)\n   151→        build_grid.build_data_struct(\n   152→            sorted_hashes[:n], self._cell_start, self._cell_end\n   153→        )\n   154→\n   155→        # 5. Step1: density summation + strain-rate tensor\n   156→        step1.compute_step1(\n   157→            w.sorted_position[:n],\n   158→            w.sorted_velocity[:n],\n   159→            w.sorted_mass[:n],\n   160→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   161→            w.sorted_packed_info[:n],\n   162→            self._cell_start,\n   163→            self._cell_end,\n   164→            density_out=w.sorted_density,\n   165→            shear_rate_out=w.sorted_shear_rate,\n   166→        )\n   167→        w._density_initialized = True\n   168→\n   169→        # 6. Step2: pressure + viscosity + XSPH forces\n   170→        step2.compute_step2(\n   171→            w.sorted_position[:n],\n   172→            w.sorted_velocity[:n],\n   173→            w.sorted_density[:n],\n   174→            w.sorted_mass[:n],\n   175→            w.sorted_packed_info[:n],\n   176→            self._cell_start,\n   177→            self._cell_end,\n   178→            sph_force_out=w.sorted_sph_force,\n   179→            veleval_out=w.sorted_veleval,\n   180→        )\n   181→\n   182→        # 7. Integrate: symplectic Euler + SDF boundaries + color update\n   183→        #    Writes back to UNSORTED arrays via sort_indexes\n   184→        integrate.integrate(\n   185→            w.sorted_position[:n],\n   186→            w.sorted_velocity[:n],\n   187→            w.sorted_veleval[:n],\n   188→            w.sorted_sph_force[:n],\n   189→            w.sorted_mass[:n],\n   190→            w.sorted_packed_info[:n],\n   191→            w.sorted_temperature[:n],\n   192→            w.sorted_health[:n],\n   193→            sorted_density=w.sorted_density[:n],\n   194→            sorted_shear_rate=w.sorted_shear_rate[:n],\n   195→            sort_indexes=sorted_indices[:n],\n   196→            position_out=w.position,\n   197→            velocity_out=w.velocity,\n   198→            color_out=w.color,\n   199→        )\n   200→\n   201→        self.sim_time += self.dt\n   202→\n   203→    def step_frame(self) -> int:\n   204→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   205→        now = time.perf_counter()\n   206→        if self._last_frame_time is None:\n   207→            self._last_frame_time = now\n   208→            return 0\n   209→\n   210→        wall_dt = now - self._last_frame_time\n   211→        self._last_frame_time = now\n   212→\n   213→        if self._paused or self.speed <= 0.0:\n   214→            self._last_substeps = 0\n   215→            return 0\n   216→\n   217→        n = self.world._high_water\n   218→        if n == 0:\n   219→            self._last_substeps = 0\n   220→            return 0\n   221→\n   222→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   223→        sim_steps = max(0, min(\n   224→            self.max_substeps,\n   225→            round(self.speed * wall_dt / self.dt),\n   226→        ))\n   227→\n   228→        for _ in range(sim_steps):\n   229→            self._sim_step(n)\n   230→\n   231→        self._last_substeps = sim_steps\n   232→        return sim_steps\n   233→\n   234→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   235→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   236→\n   237→        Parameters\n   238→        ----------\n   239→        cuda_pos : CudaGLBuffer\n   240→            Position VBO wrapper (must be context-managed externally).\n   241→        cuda_col : CudaGLBuffer\n   242→            Color VBO wrapper (must be context-managed externally).\n   243→        \"\"\"\n   244→        n = self.world._high_water\n   245→        if n == 0:\n   246→            return\n   247→\n   248→        # Position: world pos (float4) -> VBO pos (float4)\n   249→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   250→            (cuda_pos.nbytes // 16, 4), np.float32,\n   251→        )\n   252→        pos_arr[:n] = self.world.position[:n]\n   253→\n   254→        # Color: world color (float4) -> VBO color (float4)\n   255→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   256→            (cuda_col.nbytes // 16, 4), np.float32,\n   257→        )\n   258→        col_arr[:n] = self.world.color[:n]\n   259→\n   260→    @property\n   261→    def paused(self) -> bool:\n   262→        return self._paused\n   263→\n   264→    def toggle_pause(self) -> None:\n   265→        self._paused = not self._paused\n   266→\n   267→    def adjust_speed(self, delta: float) -> None:\n   268→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   269→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   270→\n   271→    @property\n   272→    def last_substeps(self) -> int:\n   273→        return self._last_substeps\n   274→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f40960f-027e-4191-b9d0-267c1a3715c8","uuid":"57105d59-a2b3-4fbd-ac65-1b77e1fae1fc","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/simulation.py","content":"\"\"\"SPH simulation orchestrator.\n\nWires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\nStep2 -> Integrate.  Decouples simulation from rendering via a speed parameter\nand substep budget.\n\nEach render frame:\n  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n  2. Run sim_steps simulation substeps\n  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Optional\n\nimport cupy as cp\nimport numpy as np\n\nfrom world import World\nfrom materials import (\n    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n)\n\nimport hash_sort\nimport fused_reorder\nimport build_grid\nimport step1\nimport step2\nimport integrate\n\n\nclass Simulation:\n    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n\n    Parameters\n    ----------\n    world : World\n        Particle state manager.\n    dt : float\n        Fixed simulation timestep (seconds).\n    speed : float\n        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    max_substeps : int\n        Maximum substeps per render frame to prevent spiral-of-death.\n    \"\"\"\n\n    def __init__(\n        self,\n        world: World,\n        dt: float = 0.001,\n        speed: float = 1.0,\n        max_substeps: int = 20,\n    ) -> None:\n        self.world = world\n        self.dt = dt\n        self.speed = speed\n        self.max_substeps = max_substeps\n        self._paused = False\n        self._prev_speed = speed\n        self._last_frame_time: Optional[float] = None\n        self._last_substeps = 0\n        self.sim_time = 0.0\n\n        # Grid cell tables (pre-allocated, reused every frame)\n        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n\n        # Compile all kernel modules and upload constant memory\n        self._upload_constants()\n\n    def _upload_constants(self) -> None:\n        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n        # Build shared param structs\n        grid_params = hash_sort.build_grid_params()\n        sim_params = step1.build_sim_params(\n            smoothing_length=0.04,\n            particle_mass=0.008,\n            particle_spacing=0.02,\n            gravity=(0.0, -9.8, 0.0),\n            dt=self.dt,\n            restitution=0.3,\n            wall_friction=0.5,\n            world_min=(-1.0, -1.0, -1.0),\n            world_max=(1.0, 1.0, 1.0),\n        )\n        precalc_params = step1.build_precalc_params(\n            smoothing_length=0.04,\n            viscosity=1.0,\n        )\n        granular_params = step2.build_granular_params()\n        materials_data = build_material_array()\n        interactions_data = build_interaction_matrix()\n\n        # --- hash_sort module: c_grid ---\n        hash_sort.upload_grid_params(grid_params)\n\n        # --- fused_reorder module: no constant memory needed ---\n        fused_reorder.get_module()  # just compile\n\n        # --- build_grid module: c_grid ---\n        build_grid.upload_grid_params(grid_params)\n\n        # --- step1 module: c_grid, c_sim, c_precalc ---\n        step1.upload_grid_params(grid_params)\n        step1.upload_sim_params(sim_params)\n        step1.upload_precalc_params(precalc_params)\n\n        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n        step2.upload_grid_params(grid_params)\n        step2.upload_sim_params(sim_params)\n        step2.upload_precalc_params(precalc_params)\n        step2.upload_materials(materials_data)\n        step2.upload_granular_params(granular_params)\n\n        # --- integrate module: c_sim, c_materials ---\n        integrate.upload_sim_params(sim_params)\n        integrate.upload_materials(materials_data)\n\n        # --- materials module (its own internal module): c_materials, c_interactions ---\n        upload_to_gpu()\n\n    def _sim_step(self, n: int) -> None:\n        \"\"\"Run one simulation substep on n particles.\"\"\"\n        w = self.world\n\n        # 1. Hash particle positions\n        hashes, indices = hash_sort.calc_hash(w.position[:n])\n\n        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n            hashes, indices,\n            sorted_hashes_out=w.sorted_hashes,\n            sorted_indices_out=w.sorted_indices,\n        )\n\n        # 3. Fused reorder: gather all unsorted arrays into sorted order\n        fused_reorder.fused_reorder(\n            n, sorted_indices,\n            w.position, w.velocity, w.veleval,\n            w.mass, w.packed_info, w.temperature,\n            w.health, w.lifetime, w.color,\n            w.sleep_counter, w.shear_rate,\n            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n            w.sorted_sleep_counter, w.sorted_shear_rate,\n        )\n\n        # 4. Build grid data structure (cell_start / cell_end tables)\n        build_grid.build_data_struct(\n            sorted_hashes[:n], self._cell_start, self._cell_end\n        )\n\n        # 5. Step1: density summation + strain-rate tensor\n        step1.compute_step1(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_mass[:n],\n            w.sorted_density if hasattr(w, '_density_initialized') else None,\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            density_out=w.sorted_density,\n            shear_rate_out=w.sorted_shear_rate,\n        )\n        w._density_initialized = True\n\n        # 6. Step2: pressure + viscosity + XSPH forces\n        step2.compute_step2(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_density[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            sph_force_out=w.sorted_sph_force,\n            veleval_out=w.sorted_veleval,\n        )\n\n        # 7. Integrate: symplectic Euler + SDF boundaries + color update\n        #    Writes back to UNSORTED arrays via sort_indexes\n        integrate.integrate(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_sph_force[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            sorted_density=w.sorted_density[:n],\n            sorted_shear_rate=w.sorted_shear_rate[:n],\n            sort_indexes=sorted_indices[:n],\n            position_out=w.position,\n            velocity_out=w.velocity,\n            color_out=w.color,\n        )\n\n        self.sim_time += self.dt\n\n    def step_frame(self) -> int:\n        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n        now = time.perf_counter()\n        if self._last_frame_time is None:\n            self._last_frame_time = now\n            return 0\n\n        wall_dt = now - self._last_frame_time\n        self._last_frame_time = now\n\n        if self._paused or self.speed <= 0.0:\n            self._last_substeps = 0\n            return 0\n\n        n = self.world._high_water\n        if n == 0:\n            self._last_substeps = 0\n            return 0\n\n        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n        sim_steps = max(0, min(\n            self.max_substeps,\n            round(self.speed * wall_dt / self.dt),\n        ))\n\n        for _ in range(sim_steps):\n            self._sim_step(n)\n\n        self._last_substeps = sim_steps\n        return sim_steps\n\n    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n\n        Parameters\n        ----------\n        cuda_pos : CudaGLBuffer\n            Position VBO wrapper (must be context-managed externally).\n        cuda_col : CudaGLBuffer\n            Color VBO wrapper (must be context-managed externally).\n        \"\"\"\n        n = self.world._high_water\n        if n == 0:\n            return\n\n        # Position: world pos (float4) -> VBO pos (float4)\n        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n            (cuda_pos.nbytes // 16, 4), np.float32,\n        )\n        pos_arr[:n] = self.world.position[:n]\n\n        # Color: world color (float4) -> VBO color (float4)\n        col_arr = cuda_col.device_pointer_as_cupy_array(\n            (cuda_col.nbytes // 16, 4), np.float32,\n        )\n        col_arr[:n] = self.world.color[:n]\n\n    @property\n    def paused(self) -> bool:\n        return self._paused\n\n    def toggle_pause(self) -> None:\n        self._paused = not self._paused\n\n    def adjust_speed(self, delta: float) -> None:\n        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n        self.speed = max(0.1, min(10.0, self.speed + delta))\n\n    @property\n    def last_substeps(self) -> int:\n        return self._last_substeps\n","numLines":274,"startLine":1,"totalLines":274}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ConjApALy2q9w2FfmjS8Ju","type":"tool_result","content":"     1→\"\"\"World state management for Falling Sand 3D.\n     2→\n     3→Manages CuPy arrays for all per-particle SoA data. Supports configurable\n     4→max_particles at startup, spawning particles in sphere/cube shapes, and\n     5→tracking num_active via counter.\n     6→\n     7→All arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\n     8→DEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→from typing import Tuple\n    14→\n    15→import cupy as cp\n    16→import numpy as np\n    17→\n    18→from materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n    19→\n    20→# packed_info bitfield macros (mirrors common.cuh)\n    21→_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n    22→\n    23→# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\n    24→DEFAULT_SPACING = 0.02\n    25→\n    26→# Default temperatures for hot materials (Kelvin)\n    27→_DEFAULT_TEMPS = {\n    28→    7: 1500.0,   # LAVA\n    29→    14: 1200.0,  # FIRE\n    30→    12: 373.0,   # STEAM\n    31→    13: 500.0,   # SMOKE\n    32→}\n    33→\n    34→# Ambient temperature\n    35→T_AMBIENT = 293.0\n    36→\n    37→\n    38→class World:\n    39→    \"\"\"Manages all per-particle SoA arrays on GPU.\n    40→\n    41→    Parameters\n    42→    ----------\n    43→    max_particles : int\n    44→        Maximum number of particles to allocate for (default 500000).\n    45→    \"\"\"\n    46→\n    47→    def __init__(self, max_particles: int = 500_000) -> None:\n    48→        self.max_particles: int = max_particles\n    49→        self._high_water: int = 0  # one past last allocated slot\n    50→        self._allocate()\n    51→\n    52→    def _allocate(self) -> None:\n    53→        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n    54→        n = self.max_particles\n    55→        # float4 arrays (stored as (n, 4) float32)\n    56→        self.position = cp.zeros((n, 4), dtype=cp.float32)\n    57→        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n    58→        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n    59→        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    60→        self.color = cp.zeros((n, 4), dtype=cp.float32)\n    61→        # float arrays\n    62→        self.density = cp.zeros(n, dtype=cp.float32)\n    63→        self.mass = cp.zeros(n, dtype=cp.float32)\n    64→        self.temperature = cp.zeros(n, dtype=cp.float32)\n    65→        self.health = cp.zeros(n, dtype=cp.float32)\n    66→        self.lifetime = cp.zeros(n, dtype=cp.float32)\n    67→        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n    68→        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n    69→        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    70→        # uint32 arrays\n    71→        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n    72→        # uint8 arrays\n    73→        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    74→\n    75→        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n    76→        # These are the double-buffer targets: after sort+reorder, physics\n    77→        # kernels (Step1/Step2) read from these.  Integrate writes back to\n    78→        # the unsorted arrays above via sort_indexes.\n    79→        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n    80→        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n    81→        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n    82→        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    83→        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n    84→        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n    85→        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n    86→        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n    87→        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n    88→        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n    89→        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n    90→        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n    91→        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    92→        # Sort index arrays (hash + original index, plus sorted versions)\n    93→        self.hashes = cp.zeros(n, dtype=cp.uint32)\n    94→        self.indices = cp.zeros(n, dtype=cp.uint32)\n    95→        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n    96→        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n    97→\n    98→    def resize(self, new_max: int) -> None:\n    99→        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n   100→        self.max_particles = new_max\n   101→        self._high_water = 0\n   102→        self._allocate()\n   103→\n   104→    @property\n   105→    def num_active(self) -> int:\n   106→        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n   107→        if self._high_water == 0:\n   108→            return 0\n   109→        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n   110→\n   111→    def spawn_sphere(\n   112→        self,\n   113→        center: Tuple[float, float, float],\n   114→        radius: float,\n   115→        material_id: int,\n   116→        count: int,\n   117→    ) -> int:\n   118→        \"\"\"Spawn particles with random positions inside a sphere.\n   119→\n   120→        Returns the number of particles actually spawned (may be less than\n   121→        count if max_particles is reached).\n   122→        \"\"\"\n   123→        if material_id not in MATERIALS:\n   124→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   125→\n   126→        available = self.max_particles - self._high_water\n   127→        actual = min(count, available)\n   128→        if actual <= 0:\n   129→            return 0\n   130→\n   131→        mat = MATERIALS[material_id]\n   132→        start = self._high_water\n   133→\n   134→        # Generate random positions in unit sphere using rejection sampling on GPU\n   135→        # Over-generate by ~2x to account for rejection, then take first `actual`\n   136→        needed = actual\n   137→        positions_list = []\n   138→        remaining = needed\n   139→        while remaining > 0:\n   140→            batch = int(remaining * 2.0) + 128\n   141→            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n   142→            r_sq = cp.sum(pts * pts, axis=1)\n   143→            inside = pts[r_sq <= 1.0]\n   144→            take = min(len(inside), remaining)\n   145→            if take > 0:\n   146→                positions_list.append(inside[:take])\n   147→                remaining -= take\n   148→\n   149→        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n   150→        # Scale to desired radius and translate to center\n   151→        cx, cy, cz = center\n   152→        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n   153→        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n   154→        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n   155→\n   156→        sl = slice(start, start + actual)\n   157→        self.position[sl, 0] = sphere_pts[:, 0]\n   158→        self.position[sl, 1] = sphere_pts[:, 1]\n   159→        self.position[sl, 2] = sphere_pts[:, 2]\n   160→        self.position[sl, 3] = 0.0\n   161→\n   162→        self.velocity[sl] = 0.0\n   163→        self.veleval[sl] = 0.0\n   164→        self.sph_force[sl] = 0.0\n   165→\n   166→        # mass = rho0 * spacing^3\n   167→        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n   168→        self.mass[sl] = particle_mass\n   169→\n   170→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   171→        self.packed_info[sl] = cp.uint32(packed)\n   172→\n   173→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   174→        self.temperature[sl] = temp\n   175→        self.health[sl] = 1.0\n   176→        self.lifetime[sl] = 0.0\n   177→        self.shear_rate[sl] = 0.0\n   178→        self.exposure_heat[sl] = 0.0\n   179→        self.exposure_corrode[sl] = 0.0\n   180→\n   181→        self.color[sl, 0] = mat.color_r\n   182→        self.color[sl, 1] = mat.color_g\n   183→        self.color[sl, 2] = mat.color_b\n   184→        self.color[sl, 3] = 1.0\n   185→\n   186→        self.density[sl] = mat.rest_density\n   187→        self.sleep_counter[sl] = 0\n   188→\n   189→        self._high_water += actual\n   190→        return actual\n   191→\n   192→    def spawn_cube(\n   193→        self,\n   194→        min_corner: Tuple[float, float, float],\n   195→        max_corner: Tuple[float, float, float],\n   196→        material_id: int,\n   197→        spacing: float = DEFAULT_SPACING,\n   198→    ) -> int:\n   199→        \"\"\"Spawn particles on a regular grid within a cube.\n   200→\n   201→        Returns the number of particles actually spawned.\n   202→        \"\"\"\n   203→        if material_id not in MATERIALS:\n   204→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   205→\n   206→        # Build grid positions on CPU (small overhead, predictable count)\n   207→        x0, y0, z0 = min_corner\n   208→        x1, y1, z1 = max_corner\n   209→        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n   210→        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n   211→        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n   212→\n   213→        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n   214→            return 0\n   215→\n   216→        total = len(xs) * len(ys) * len(zs)\n   217→        available = self.max_particles - self._high_water\n   218→        actual = min(total, available)\n   219→        if actual <= 0:\n   220→            return 0\n   221→\n   222→        # Generate meshgrid positions\n   223→        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n   224→        positions = np.column_stack([\n   225→            gx.ravel()[:actual],\n   226→            gy.ravel()[:actual],\n   227→            gz.ravel()[:actual],\n   228→        ]).astype(np.float32)\n   229→\n   230→        actual = len(positions)\n   231→        if actual == 0:\n   232→            return 0\n   233→\n   234→        mat = MATERIALS[material_id]\n   235→        start = self._high_water\n   236→        sl = slice(start, start + actual)\n   237→\n   238→        d_positions = cp.asarray(positions)\n   239→        self.position[sl, 0] = d_positions[:, 0]\n   240→        self.position[sl, 1] = d_positions[:, 1]\n   241→        self.position[sl, 2] = d_positions[:, 2]\n   242→        self.position[sl, 3] = 0.0\n   243→\n   244→        self.velocity[sl] = 0.0\n   245→        self.veleval[sl] = 0.0\n   246→        self.sph_force[sl] = 0.0\n   247→\n   248→        particle_mass = mat.rest_density * (spacing ** 3)\n   249→        self.mass[sl] = particle_mass\n   250→\n   251→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   252→        self.packed_info[sl] = cp.uint32(packed)\n   253→\n   254→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   255→        self.temperature[sl] = temp\n   256→        self.health[sl] = 1.0\n   257→        self.lifetime[sl] = 0.0\n   258→        self.shear_rate[sl] = 0.0\n   259→        self.exposure_heat[sl] = 0.0\n   260→        self.exposure_corrode[sl] = 0.0\n   261→\n   262→        self.color[sl, 0] = mat.color_r\n   263→        self.color[sl, 1] = mat.color_g\n   264→        self.color[sl, 2] = mat.color_b\n   265→        self.color[sl, 3] = 1.0\n   266→\n   267→        self.density[sl] = mat.rest_density\n   268→        self.sleep_counter[sl] = 0\n   269→\n   270→        self._high_water += actual\n   271→        return actual\n   272→\n   273→    def kill_in_sphere(\n   274→        self,\n   275→        center: Tuple[float, float, float],\n   276→        radius: float,\n   277→    ) -> int:\n   278→        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n   279→\n   280→        Returns the number of particles killed.\n   281→        \"\"\"\n   282→        if self._high_water == 0:\n   283→            return 0\n   284→\n   285→        n = self._high_water\n   286→        cx, cy, cz = center\n   287→        dx = self.position[:n, 0] - cx\n   288→        dy = self.position[:n, 1] - cy\n   289→        dz = self.position[:n, 2] - cz\n   290→        dist_sq = dx * dx + dy * dy + dz * dz\n   291→\n   292→        mask = dist_sq <= (radius * radius)\n   293→        # Only kill non-DEAD particles\n   294→        mask = mask & (self.packed_info[:n] != 0)\n   295→        killed = int(cp.sum(mask))\n   296→\n   297→        if killed > 0:\n   298→            self.packed_info[:n][mask] = cp.uint32(0)\n   299→\n   300→        return killed\n   301→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f40960f-027e-4191-b9d0-267c1a3715c8","uuid":"d0d61a12-40aa-4977-b45d-b007ba6f93ff","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/world.py","content":"\"\"\"World state management for Falling Sand 3D.\n\nManages CuPy arrays for all per-particle SoA data. Supports configurable\nmax_particles at startup, spawning particles in sphere/cube shapes, and\ntracking num_active via counter.\n\nAll arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\nDEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Tuple\n\nimport cupy as cp\nimport numpy as np\n\nfrom materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n\n# packed_info bitfield macros (mirrors common.cuh)\n_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n\n# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\nDEFAULT_SPACING = 0.02\n\n# Default temperatures for hot materials (Kelvin)\n_DEFAULT_TEMPS = {\n    7: 1500.0,   # LAVA\n    14: 1200.0,  # FIRE\n    12: 373.0,   # STEAM\n    13: 500.0,   # SMOKE\n}\n\n# Ambient temperature\nT_AMBIENT = 293.0\n\n\nclass World:\n    \"\"\"Manages all per-particle SoA arrays on GPU.\n\n    Parameters\n    ----------\n    max_particles : int\n        Maximum number of particles to allocate for (default 500000).\n    \"\"\"\n\n    def __init__(self, max_particles: int = 500_000) -> None:\n        self.max_particles: int = max_particles\n        self._high_water: int = 0  # one past last allocated slot\n        self._allocate()\n\n    def _allocate(self) -> None:\n        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n        n = self.max_particles\n        # float4 arrays (stored as (n, 4) float32)\n        self.position = cp.zeros((n, 4), dtype=cp.float32)\n        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n        self.color = cp.zeros((n, 4), dtype=cp.float32)\n        # float arrays\n        self.density = cp.zeros(n, dtype=cp.float32)\n        self.mass = cp.zeros(n, dtype=cp.float32)\n        self.temperature = cp.zeros(n, dtype=cp.float32)\n        self.health = cp.zeros(n, dtype=cp.float32)\n        self.lifetime = cp.zeros(n, dtype=cp.float32)\n        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n        # uint32 arrays\n        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n        # uint8 arrays\n        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n\n        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n        # These are the double-buffer targets: after sort+reorder, physics\n        # kernels (Step1/Step2) read from these.  Integrate writes back to\n        # the unsorted arrays above via sort_indexes.\n        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n        # Sort index arrays (hash + original index, plus sorted versions)\n        self.hashes = cp.zeros(n, dtype=cp.uint32)\n        self.indices = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n\n    def resize(self, new_max: int) -> None:\n        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n        self.max_particles = new_max\n        self._high_water = 0\n        self._allocate()\n\n    @property\n    def num_active(self) -> int:\n        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n        if self._high_water == 0:\n            return 0\n        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n\n    def spawn_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n        material_id: int,\n        count: int,\n    ) -> int:\n        \"\"\"Spawn particles with random positions inside a sphere.\n\n        Returns the number of particles actually spawned (may be less than\n        count if max_particles is reached).\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        available = self.max_particles - self._high_water\n        actual = min(count, available)\n        if actual <= 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n\n        # Generate random positions in unit sphere using rejection sampling on GPU\n        # Over-generate by ~2x to account for rejection, then take first `actual`\n        needed = actual\n        positions_list = []\n        remaining = needed\n        while remaining > 0:\n            batch = int(remaining * 2.0) + 128\n            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n            r_sq = cp.sum(pts * pts, axis=1)\n            inside = pts[r_sq <= 1.0]\n            take = min(len(inside), remaining)\n            if take > 0:\n                positions_list.append(inside[:take])\n                remaining -= take\n\n        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n        # Scale to desired radius and translate to center\n        cx, cy, cz = center\n        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n\n        sl = slice(start, start + actual)\n        self.position[sl, 0] = sphere_pts[:, 0]\n        self.position[sl, 1] = sphere_pts[:, 1]\n        self.position[sl, 2] = sphere_pts[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        # mass = rho0 * spacing^3\n        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def spawn_cube(\n        self,\n        min_corner: Tuple[float, float, float],\n        max_corner: Tuple[float, float, float],\n        material_id: int,\n        spacing: float = DEFAULT_SPACING,\n    ) -> int:\n        \"\"\"Spawn particles on a regular grid within a cube.\n\n        Returns the number of particles actually spawned.\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        # Build grid positions on CPU (small overhead, predictable count)\n        x0, y0, z0 = min_corner\n        x1, y1, z1 = max_corner\n        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n\n        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n            return 0\n\n        total = len(xs) * len(ys) * len(zs)\n        available = self.max_particles - self._high_water\n        actual = min(total, available)\n        if actual <= 0:\n            return 0\n\n        # Generate meshgrid positions\n        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n        positions = np.column_stack([\n            gx.ravel()[:actual],\n            gy.ravel()[:actual],\n            gz.ravel()[:actual],\n        ]).astype(np.float32)\n\n        actual = len(positions)\n        if actual == 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n        sl = slice(start, start + actual)\n\n        d_positions = cp.asarray(positions)\n        self.position[sl, 0] = d_positions[:, 0]\n        self.position[sl, 1] = d_positions[:, 1]\n        self.position[sl, 2] = d_positions[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        particle_mass = mat.rest_density * (spacing ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def kill_in_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n    ) -> int:\n        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n\n        Returns the number of particles killed.\n        \"\"\"\n        if self._high_water == 0:\n            return 0\n\n        n = self._high_water\n        cx, cy, cz = center\n        dx = self.position[:n, 0] - cx\n        dy = self.position[:n, 1] - cy\n        dz = self.position[:n, 2] - cz\n        dist_sq = dx * dx + dy * dy + dz * dz\n\n        mask = dist_sq <= (radius * radius)\n        # Only kill non-DEAD particles\n        mask = mask & (self.packed_info[:n] != 0)\n        killed = int(cp.sum(mask))\n\n        if killed > 0:\n            self.packed_info[:n][mask] = cp.uint32(0)\n\n        return killed\n","numLines":301,"startLine":1,"totalLines":301}}}

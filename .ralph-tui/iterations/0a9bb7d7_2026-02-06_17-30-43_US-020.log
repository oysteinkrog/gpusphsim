cupy.float32)"," ","     # density_in can be None (first frame) -- pass null pointer","     density_in_ptr = density_in if density_in is not None else cupy.ndarray(0, dtype=cupy.float32)"]},{"oldStart":297,"oldLines":11,"newStart":306,"newLines":13,"lines":["             mass,","             density_in_ptr,","             packed_info,","+            temperature_in,","             cell_start,","             cell_end,","             density_out,","             shear_rate_out,","+            dTdt_out,","         ),","     )"," ","-    return density_out, shear_rate_out","+    return density_out, shear_rate_out, dTdt_out"]}],"userModified":false,"replaceAll":false}}

{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013ssCTtN8sp7GvrtKdpq9iJ","type":"tool_result","content":"     1→\"\"\"World state management for Falling Sand 3D.\n     2→\n     3→Manages CuPy arrays for all per-particle SoA data. Supports configurable\n     4→max_particles at startup, spawning particles in sphere/cube shapes, and\n     5→tracking num_active via counter.\n     6→\n     7→All arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\n     8→DEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→from typing import Tuple\n    14→\n    15→import cupy as cp\n    16→import numpy as np\n    17→\n    18→from materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n    19→\n    20→# packed_info bitfield macros (mirrors common.cuh)\n    21→_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n    22→\n    23→# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\n    24→DEFAULT_SPACING = 0.02\n    25→\n    26→# Default temperatures for hot materials (Kelvin)\n    27→_DEFAULT_TEMPS = {\n    28→    7: 1500.0,   # LAVA\n    29→    14: 1200.0,  # FIRE\n    30→    12: 373.0,   # STEAM\n    31→    13: 500.0,   # SMOKE\n    32→}\n    33→\n    34→# Ambient temperature\n    35→T_AMBIENT = 293.0\n    36→\n    37→\n    38→class World:\n    39→    \"\"\"Manages all per-particle SoA arrays on GPU.\n    40→\n    41→    Parameters\n    42→    ----------\n    43→    max_particles : int\n    44→        Maximum number of particles to allocate for (default 500000).\n    45→    \"\"\"\n    46→\n    47→    def __init__(self, max_particles: int = 500_000) -> None:\n    48→        self.max_particles: int = max_particles\n    49→        self._high_water: int = 0  # one past last allocated slot\n    50→        self._allocate()\n    51→\n    52→    def _allocate(self) -> None:\n    53→        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n    54→        n = self.max_particles\n    55→        # float4 arrays (stored as (n, 4) float32)\n    56→        self.position = cp.zeros((n, 4), dtype=cp.float32)\n    57→        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n    58→        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n    59→        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    60→        self.color = cp.zeros((n, 4), dtype=cp.float32)\n    61→        # float arrays\n    62→        self.density = cp.zeros(n, dtype=cp.float32)\n    63→        self.mass = cp.zeros(n, dtype=cp.float32)\n    64→        self.temperature = cp.zeros(n, dtype=cp.float32)\n    65→        self.health = cp.zeros(n, dtype=cp.float32)\n    66→        self.lifetime = cp.zeros(n, dtype=cp.float32)\n    67→        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n    68→        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n    69→        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    70→        # uint32 arrays\n    71→        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n    72→        # uint8 arrays\n    73→        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    74→\n    75→        # --- Sorted temporary buffers (pre-allocated, reused every frame) ---\n    76→        # These are the double-buffer targets: after sort+reorder, physics\n    77→        # kernels (Step1/Step2) read from these.  Integrate writes back to\n    78→        # the unsorted arrays above via sort_indexes.\n    79→        self.sorted_position = cp.zeros((n, 4), dtype=cp.float32)\n    80→        self.sorted_velocity = cp.zeros((n, 4), dtype=cp.float32)\n    81→        self.sorted_veleval = cp.zeros((n, 4), dtype=cp.float32)\n    82→        self.sorted_sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    83→        self.sorted_color = cp.zeros((n, 4), dtype=cp.float32)\n    84→        self.sorted_density = cp.zeros(n, dtype=cp.float32)\n    85→        self.sorted_mass = cp.zeros(n, dtype=cp.float32)\n    86→        self.sorted_temperature = cp.zeros(n, dtype=cp.float32)\n    87→        self.sorted_health = cp.zeros(n, dtype=cp.float32)\n    88→        self.sorted_lifetime = cp.zeros(n, dtype=cp.float32)\n    89→        self.sorted_shear_rate = cp.zeros(n, dtype=cp.float32)\n    90→        self.sorted_packed_info = cp.zeros(n, dtype=cp.uint32)\n    91→        self.sorted_sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    92→        # Sort index arrays (hash + original index, plus sorted versions)\n    93→        self.hashes = cp.zeros(n, dtype=cp.uint32)\n    94→        self.indices = cp.zeros(n, dtype=cp.uint32)\n    95→        self.sorted_hashes = cp.zeros(n, dtype=cp.uint32)\n    96→        self.sorted_indices = cp.zeros(n, dtype=cp.uint32)\n    97→\n    98→    def resize(self, new_max: int) -> None:\n    99→        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n   100→        self.max_particles = new_max\n   101→        self._high_water = 0\n   102→        self._allocate()\n   103→\n   104→    @property\n   105→    def num_active(self) -> int:\n   106→        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n   107→        if self._high_water == 0:\n   108→            return 0\n   109→        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n   110→\n   111→    def spawn_sphere(\n   112→        self,\n   113→        center: Tuple[float, float, float],\n   114→        radius: float,\n   115→        material_id: int,\n   116→        count: int,\n   117→    ) -> int:\n   118→        \"\"\"Spawn particles with random positions inside a sphere.\n   119→\n   120→        Returns the number of particles actually spawned (may be less than\n   121→        count if max_particles is reached).\n   122→        \"\"\"\n   123→        if material_id not in MATERIALS:\n   124→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   125→\n   126→        available = self.max_particles - self._high_water\n   127→        actual = min(count, available)\n   128→        if actual <= 0:\n   129→            return 0\n   130→\n   131→        mat = MATERIALS[material_id]\n   132→        start = self._high_water\n   133→\n   134→        # Generate random positions in unit sphere using rejection sampling on GPU\n   135→        # Over-generate by ~2x to account for rejection, then take first `actual`\n   136→        needed = actual\n   137→        positions_list = []\n   138→        remaining = needed\n   139→        while remaining > 0:\n   140→            batch = int(remaining * 2.0) + 128\n   141→            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n   142→            r_sq = cp.sum(pts * pts, axis=1)\n   143→            inside = pts[r_sq <= 1.0]\n   144→            take = min(len(inside), remaining)\n   145→            if take > 0:\n   146→                positions_list.append(inside[:take])\n   147→                remaining -= take\n   148→\n   149→        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n   150→        # Scale to desired radius and translate to center\n   151→        cx, cy, cz = center\n   152→        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n   153→        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n   154→        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n   155→\n   156→        sl = slice(start, start + actual)\n   157→        self.position[sl, 0] = sphere_pts[:, 0]\n   158→        self.position[sl, 1] = sphere_pts[:, 1]\n   159→        self.position[sl, 2] = sphere_pts[:, 2]\n   160→        self.position[sl, 3] = 0.0\n   161→\n   162→        self.velocity[sl] = 0.0\n   163→        self.veleval[sl] = 0.0\n   164→        self.sph_force[sl] = 0.0\n   165→\n   166→        # mass = rho0 * spacing^3\n   167→        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n   168→        self.mass[sl] = particle_mass\n   169→\n   170→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   171→        self.packed_info[sl] = cp.uint32(packed)\n   172→\n   173→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   174→        self.temperature[sl] = temp\n   175→        self.health[sl] = 1.0\n   176→        self.lifetime[sl] = 0.0\n   177→        self.shear_rate[sl] = 0.0\n   178→        self.exposure_heat[sl] = 0.0\n   179→        self.exposure_corrode[sl] = 0.0\n   180→\n   181→        self.color[sl, 0] = mat.color_r\n   182→        self.color[sl, 1] = mat.color_g\n   183→        self.color[sl, 2] = mat.color_b\n   184→        self.color[sl, 3] = 1.0\n   185→\n   186→        self.density[sl] = mat.rest_density\n   187→        self.sleep_counter[sl] = 0\n   188→\n   189→        self._high_water += actual\n   190→        return actual\n   191→\n   192→    def spawn_cube(\n   193→        self,\n   194→        min_corner: Tuple[float, float, float],\n   195→        max_corner: Tuple[float, float, float],\n   196→        material_id: int,\n   197→        spacing: float = DEFAULT_SPACING,\n   198→    ) -> int:\n   199→        \"\"\"Spawn particles on a regular grid within a cube.\n   200→\n   201→        Returns the number of particles actually spawned.\n   202→        \"\"\"\n   203→        if material_id not in MATERIALS:\n   204→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   205→\n   206→        # Build grid positions on CPU (small overhead, predictable count)\n   207→        x0, y0, z0 = min_corner\n   208→        x1, y1, z1 = max_corner\n   209→        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n   210→        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n   211→        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n   212→\n   213→        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n   214→            return 0\n   215→\n   216→        total = len(xs) * len(ys) * len(zs)\n   217→        available = self.max_particles - self._high_water\n   218→        actual = min(total, available)\n   219→        if actual <= 0:\n   220→            return 0\n   221→\n   222→        # Generate meshgrid positions\n   223→        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n   224→        positions = np.column_stack([\n   225→            gx.ravel()[:actual],\n   226→            gy.ravel()[:actual],\n   227→            gz.ravel()[:actual],\n   228→        ]).astype(np.float32)\n   229→\n   230→        actual = len(positions)\n   231→        if actual == 0:\n   232→            return 0\n   233→\n   234→        mat = MATERIALS[material_id]\n   235→        start = self._high_water\n   236→        sl = slice(start, start + actual)\n   237→\n   238→        d_positions = cp.asarray(positions)\n   239→        self.position[sl, 0] = d_positions[:, 0]\n   240→        self.position[sl, 1] = d_positions[:, 1]\n   241→        self.position[sl, 2] = d_positions[:, 2]\n   242→        self.position[sl, 3] = 0.0\n   243→\n   244→        self.velocity[sl] = 0.0\n   245→        self.veleval[sl] = 0.0\n   246→        self.sph_force[sl] = 0.0\n   247→\n   248→        particle_mass = mat.rest_density * (spacing ** 3)\n   249→        self.mass[sl] = particle_mass\n   250→\n   251→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   252→        self.packed_info[sl] = cp.uint32(packed)\n   253→\n   254→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   255→        self.temperature[sl] = temp\n   256→        self.health[sl] = 1.0\n   257→        self.lifetime[sl] = 0.0\n   258→        self.shear_rate[sl] = 0.0\n   259→        self.exposure_heat[sl] = 0.0\n   260→        self.exposure_corrode[sl] = 0.0\n   261→\n   262→        self.color[sl, 0] = mat.color_r\n   263→        self.color[sl, 1] = mat.color_g\n   264→        self.color[sl, 2] = mat.color_b\n   265→        self.color[sl, 3] = 1.0\n   266→\n   267→        self.density[sl] = mat.rest_density\n   268→        self.sleep_counter[sl] = 0\n   269→\n   270→        self._high_water += actual\n   271→        return actual\n   272→\n   273→    def kill_in_sphere(\n   274→        self,\n   275→        center: Tuple[float, float, float],\n   276→        radius: float,\n   277→    ) -> int:\n   278→        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n   279→\n   280→        Returns the number of particles killed.\n   281→        \"\"\"\n   282→        if self._high_water == 0:\n   283→            return 0\n   284→\n   285→        n = self._high_water\n   286→        cx, cy, cz = center\n   287→        dx = self.position[:n, 0] - cx\n   288→        dy = self.position[:n, 1] - cy\n   289→        dz = self.position[:n, 2] - cz\n   290→        dist_sq = dx * dx + dy * dy + dz * dz\n   291→\n   292→        mask = dist_sq <= (radius * radius)\n   293→        # Only kill non-DEAD particles\n   294→        mask = mask & (self.packed_info[:n] != 0)\n   295→        killed = int(cp.sum(mask))\n   296→\n   297→        if killed > 0:\n   298→            self.packed_info[:n][mask] = cp.uint32(0)\n   299→\n   300→        return killed\n   301→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01XEZUxfjZFQQcTVtqsUcHHn","session_id":"e6e8b27e-e279-4052-ba7d-ce90d33ff805","uuid":"ab5bbe5a-e49d-42dc-952c-377458820eb0"}

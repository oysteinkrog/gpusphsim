{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Gpzty2fsP3kRf4ZCvuQXz","type":"tool_result","content":"     1→\"\"\"Integration test for step1.py -- K_Step1 density + strain-rate kernel.\n     2→\n     3→Acceptance criteria (density, US-011):\n     4→  - K_Step1 iterates 3x3x3 neighbor cells using cell_start/cell_end\n     5→  - density_sum += m_j * (h_sq - r_sq)^3 with PER-PARTICLE mass\n     6→  - Final density = max(1.0, poly6_coeff * density_sum)\n     7→  - Smoothing length uses squared distance (r_sq < h_sq)\n     8→  - Neighbor position loaded via __ldg() (read-only cache)\n     9→  - Self-contribution included (j==i NOT skipped)\n    10→  - Test: uniform field at rest density -> rho ~= rho0 (within 10%)\n    11→  - Test: single isolated particle -> rho = mass * poly6_coeff * h^6\n    12→  - Block size = 128, runs without errors for 500K particles\n    13→\n    14→Acceptance criteria (strain-rate, US-015):\n    15→  - Step1 accumulates 6 symmetric D components for GRANULAR only\n    16→  - D tensor uses spiky gradient (NOT poly6 gradient), m_j/rho_j weighting\n    17→  - PostCalc: gamma_dot = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n    18→  - gamma_dot written to sorted shear_rate array\n    19→  - Non-GRANULAR particles get shear_rate = 0\n    20→  - Test: stationary sand -> gamma_dot ~ 0\n    21→  - Test: sand in shear flow -> gamma_dot > 0\n    22→\n    23→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    24→\"\"\"\n    25→\n    26→from __future__ import annotations\n    27→\n    28→import math\n    29→import os\n    30→import sys\n    31→\n    32→sys.path.insert(0, os.path.dirname(__file__))\n    33→\n    34→import cupy\n    35→import numpy as np\n    36→\n    37→from hash_sort import (\n    38→    NUM_CELLS,\n    39→    build_grid_params,\n    40→    calc_hash,\n    41→    sort_by_hash,\n    42→    upload_grid_params as upload_hash_grid_params,\n    43→)\n    44→from build_grid import (\n    45→    build_data_struct,\n    46→    upload_grid_params as upload_build_grid_params,\n    47→)\n    48→from step1 import (\n    49→    BLOCK_SIZE,\n    50→    build_precalc_params,\n    51→    build_sim_params,\n    52→    compute_step1,\n    53→    get_module,\n    54→    upload_grid_params as upload_step1_grid_params,\n    55→    upload_precalc_params,\n    56→    upload_sim_params,\n    57→)\n    58→\n    59→# Simulation constants matching the acceptance criteria\n    60→H = 0.04                # smoothing length\n    61→H_SQ = H * H\n    62→SPACING = 0.02          # particle spacing\n    63→RHO0 = 1000.0           # rest density of water\n    64→MASS = RHO0 * SPACING**3  # 0.008 kg\n    65→POLY6_COEFF = 315.0 / (64.0 * math.pi * H**9)\n    66→\n    67→# packed_info constants\n    68→# MAKE_PACKED(mat, beh) = (mat & 0xFF) | ((beh & 0x3) << 8)\n    69→FLUID = 0\n    70→GRANULAR = 1\n    71→PACKED_WATER = 5 | (FLUID << 8)     # material 5, FLUID\n    72→PACKED_SAND  = 2 | (GRANULAR << 8)  # material 2, GRANULAR\n    73→\n    74→\n    75→def _upload_all_params() -> None:\n    76→    \"\"\"Upload grid, sim, and precalc params to all kernel modules.\"\"\"\n    77→    gp = build_grid_params()\n    78→    upload_hash_grid_params(gp)\n    79→    upload_build_grid_params(gp)\n    80→    upload_step1_grid_params(gp)\n    81→\n    82→    sp = build_sim_params(\n    83→        smoothing_length=H,\n    84→        particle_mass=MASS,\n    85→        particle_spacing=SPACING,\n    86→    )\n    87→    upload_sim_params(sp)\n    88→\n    89→    pp = build_precalc_params(smoothing_length=H)\n    90→    upload_precalc_params(pp)\n    91→\n    92→\n    93→def _run_full_pipeline(\n    94→    positions_np: np.ndarray,\n    95→    mass_np: np.ndarray,\n    96→    velocity_np: np.ndarray | None = None,\n    97→    packed_info_np: np.ndarray | None = None,\n    98→    density_in_np: np.ndarray | None = None,\n    99→) -> tuple:\n   100→    \"\"\"Run hash -> sort -> build -> step1 and return results.\n   101→\n   102→    Parameters\n   103→    ----------\n   104→    positions_np : (N, 4) float32\n   105→    mass_np : (N,) float32\n   106→    velocity_np : (N, 4) float32, optional (default: zeros)\n   107→    packed_info_np : (N,) uint32, optional (default: PACKED_WATER)\n   108→    density_in_np : (N,) float32, optional (default: None -> kernel uses fallback)\n   109→\n   110→    Returns\n   111→    -------\n   112→    density_cpu : (N,) float32 -- density in sorted order\n   113→    shear_rate_cpu : (N,) float32 -- gamma_dot in sorted order\n   114→    sorted_positions_cpu : (N, 4) float32\n   115→    sorted_mass_cpu : (N,) float32\n   116→    \"\"\"\n   117→    n = positions_np.shape[0]\n   118→\n   119→    if velocity_np is None:\n   120→        velocity_np = np.zeros((n, 4), dtype=np.float32)\n   121→    if packed_info_np is None:\n   122→        packed_info_np = np.full(n, PACKED_WATER, dtype=np.uint32)\n   123→\n   124→    pos_gpu = cupy.asarray(positions_np)\n   125→    mass_gpu = cupy.asarray(mass_np)\n   126→    vel_gpu = cupy.asarray(velocity_np)\n   127→    pi_gpu = cupy.asarray(packed_info_np)\n   128→    density_in_gpu = cupy.asarray(density_in_np) if density_in_np is not None else None\n   129→\n   130→    hashes, indices = calc_hash(pos_gpu)\n   131→    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n   132→\n   133→    # Reorder all arrays to sorted order\n   134→    sorted_pos = pos_gpu[sorted_indices]\n   135→    sorted_mass = mass_gpu[sorted_indices]\n   136→    sorted_vel = vel_gpu[sorted_indices]\n   137→    sorted_pi = pi_gpu[sorted_indices]\n   138→    sorted_density_in = density_in_gpu[sorted_indices] if density_in_gpu is not None else None\n   139→\n   140→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   141→\n   142→    density, shear_rate = compute_step1(\n   143→        sorted_pos, sorted_vel, sorted_mass,\n   144→        sorted_density_in, sorted_pi,\n   145→        cell_start, cell_end,\n   146→    )\n   147→    cupy.cuda.Device().synchronize()\n   148→\n   149→    return (\n   150→        cupy.asnumpy(density),\n   151→        cupy.asnumpy(shear_rate),\n   152→        cupy.asnumpy(sorted_pos),\n   153→        cupy.asnumpy(sorted_mass),\n   154→    )\n   155→\n   156→\n   157→# ===================================================================\n   158→# Density tests (unchanged acceptance criteria from US-011)\n   159→# ===================================================================\n   160→\n   161→def test_compilation() -> None:\n   162→    \"\"\"Verify CuPy RawModule compiles step1.cu.\"\"\"\n   163→    print(\"--- Compilation check ---\")\n   164→\n   165→    module = get_module()\n   166→    assert module is not None\n   167→    print(\"[OK] CuPy RawModule compiled step1.cu (includes common.cuh)\")\n   168→\n   169→    kernel = module.get_function(\"K_Step1\")  # type: ignore[union-attr]\n   170→    assert kernel is not None\n   171→    print(\"[OK] K_Step1 kernel function found\")\n   172→\n   173→    # Verify all constant memory symbols accessible\n   174→    for sym in [\"c_grid\", \"c_sim\", \"c_precalc\"]:\n   175→        d_ptr = module.get_global(sym)  # type: ignore[union-attr]\n   176→        assert int(d_ptr) != 0, f\"{sym} symbol not found\"\n   177→    print(\"[OK] c_grid, c_sim, c_precalc constant memory symbols found\")\n   178→\n   179→\n   180→def test_block_size() -> None:\n   181→    \"\"\"Verify block size is 128.\"\"\"\n   182→    print(\"\\n--- Block size check ---\")\n   183→    assert BLOCK_SIZE == 128, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 128\"\n   184→    print(\"[OK] BLOCK_SIZE = 128\")\n   185→\n   186→\n   187→def test_struct_sizes() -> None:\n   188→    \"\"\"Verify SimParams and PrecalcParams dtypes match CUDA struct sizes.\"\"\"\n   189→    print(\"\\n--- Struct size check ---\")\n   190→\n   191→    sp = build_sim_params()\n   192→    pp = build_precalc_params()\n   193→\n   194→    # SimParams: 64 bytes (from US-005 test)\n   195→    assert sp.nbytes == 64, f\"SimParams: {sp.nbytes} != 64 bytes\"\n   196→    print(f\"[OK] SimParams: {sp.nbytes} bytes\")\n   197→\n   198→    # PrecalcParams: 20 bytes\n   199→    assert pp.nbytes == 20, f\"PrecalcParams: {pp.nbytes} != 20 bytes\"\n   200→    print(f\"[OK] PrecalcParams: {pp.nbytes} bytes\")\n   201→\n   202→\n   203→def test_precalc_coefficients() -> None:\n   204→    \"\"\"Verify poly6_coeff matches expected value for h=0.04.\"\"\"\n   205→    print(\"\\n--- Precalc coefficient check ---\")\n   206→\n   207→    pp = build_precalc_params(smoothing_length=H)\n   208→    poly6 = pp[0][\"poly6_coeff\"]\n   209→\n   210→    expected = np.float32(315.0 / (64.0 * math.pi * H**9))\n   211→    rel_err = abs(float(poly6) - float(expected)) / abs(float(expected))\n   212→\n   213→    print(f\"  poly6_coeff = {poly6:.6e} (expected {expected:.6e})\")\n   214→    assert rel_err < 1e-5, f\"poly6_coeff relative error {rel_err:.2e} > 1e-5\"\n   215→    print(\"[OK] poly6_coeff matches 315/(64*pi*h^9)\")\n   216→\n   217→\n   218→def test_single_isolated_particle() -> None:\n   219→    \"\"\"Single isolated particle: rho = mass * poly6_coeff * h^6.\n   220→\n   221→    Self-contribution: r_sq = 0, so (h^2 - 0)^3 = h^6.\n   222→    density = poly6_coeff * mass * h^6.\n   223→    \"\"\"\n   224→    print(\"\\n--- Single isolated particle test ---\")\n   225→    _upload_all_params()\n   226→\n   227→    # Place particle at center of grid\n   228→    positions = np.zeros((1, 4), dtype=np.float32)\n   229→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   230→\n   231→    mass_arr = np.array([MASS], dtype=np.float32)\n   232→\n   233→    density, shear_rate, _, _ = _run_full_pipeline(positions, mass_arr)\n   234→\n   235→    expected = POLY6_COEFF * MASS * H_SQ**3  # poly6_coeff * mass * h^6\n   236→    actual = density[0]\n   237→\n   238→    rel_err = abs(actual - expected) / abs(expected)\n   239→    print(f\"  Expected density: {expected:.6f}\")\n   240→    print(f\"  Actual density:   {actual:.6f}\")\n   241→    print(f\"  Relative error:   {rel_err:.6e}\")\n   242→\n   243→    assert rel_err < 1e-4, (\n   244→        f\"Single particle density mismatch: {actual:.6f} vs {expected:.6f} \"\n   245→        f\"(rel err {rel_err:.6e})\"\n   246→    )\n   247→\n   248→    # Non-GRANULAR (default WATER/FLUID) -> shear_rate should be 0\n   249→    assert shear_rate[0] == 0.0, f\"FLUID particle shear_rate = {shear_rate[0]}, expected 0\"\n   250→\n   251→    print(\"[OK] Single isolated particle density matches mass * poly6_coeff * h^6\")\n   252→    print(\"[OK] FLUID particle shear_rate = 0\")\n   253→\n   254→\n   255→def test_two_particles_within_h() -> None:\n   256→    \"\"\"Two particles within h should have higher density than one alone.\"\"\"\n   257→    print(\"\\n--- Two particles within smoothing length test ---\")\n   258→    _upload_all_params()\n   259→\n   260→    sep = H * 0.5  # half the smoothing length\n   261→    positions = np.zeros((2, 4), dtype=np.float32)\n   262→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   263→    positions[1] = [sep, 0.0, 0.0, 1.0]\n   264→\n   265→    mass_arr = np.full(2, MASS, dtype=np.float32)\n   266→\n   267→    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   268→\n   269→    # Self-contribution only\n   270→    single_rho = POLY6_COEFF * MASS * H_SQ**3\n   271→\n   272→    # Both particles should have density > single particle\n   273→    assert density[0] > single_rho * 0.99, (\n   274→        f\"Particle 0 density {density[0]:.4f} not > single {single_rho:.4f}\"\n   275→    )\n   276→    assert density[1] > single_rho * 0.99, (\n   277→        f\"Particle 1 density {density[1]:.4f} not > single {single_rho:.4f}\"\n   278→    )\n   279→\n   280→    # By symmetry, densities should be approximately equal\n   281→    rel_diff = abs(density[0] - density[1]) / max(density[0], density[1])\n   282→    assert rel_diff < 1e-4, (\n   283→        f\"Asymmetric densities: {density[0]:.6f} vs {density[1]:.6f}\"\n   284→    )\n   285→\n   286→    print(f\"  Single particle density: {single_rho:.6f}\")\n   287→    print(f\"  Particle 0 density:      {density[0]:.6f}\")\n   288→    print(f\"  Particle 1 density:      {density[1]:.6f}\")\n   289→    print(\"[OK] Two particles within h produce symmetric density > single particle\")\n   290→\n   291→\n   292→def test_two_particles_beyond_h() -> None:\n   293→    \"\"\"Two particles separated by more than h should not see each other.\"\"\"\n   294→    print(\"\\n--- Two particles beyond smoothing length test ---\")\n   295→    _upload_all_params()\n   296→\n   297→    sep = H * 1.5  # beyond smoothing length\n   298→    positions = np.zeros((2, 4), dtype=np.float32)\n   299→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   300→    positions[1] = [sep, 0.0, 0.0, 1.0]\n   301→\n   302→    mass_arr = np.full(2, MASS, dtype=np.float32)\n   303→\n   304→    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   305→\n   306→    single_rho = POLY6_COEFF * MASS * H_SQ**3\n   307→\n   308→    # Both should have same density as single particle (only self-contribution)\n   309→    for i in range(2):\n   310→        rel_err = abs(density[i] - single_rho) / single_rho\n   311→        assert rel_err < 1e-4, (\n   312→            f\"Particle {i} density {density[i]:.6f} != single {single_rho:.6f} \"\n   313→            f\"(rel err {rel_err:.2e})\"\n   314→        )\n   315→\n   316→    print(f\"  Particle 0 density: {density[0]:.6f}\")\n   317→    print(f\"  Particle 1 density: {density[1]:.6f}\")\n   318→    print(f\"  Expected (self-only): {single_rho:.6f}\")\n   319→    print(\"[OK] Particles beyond h have self-contribution-only density\")\n   320→\n   321→\n   322→def test_per_particle_mass() -> None:\n   323→    \"\"\"Two particles with different masses produce different densities.\"\"\"\n   324→    print(\"\\n--- Per-particle mass test ---\")\n   325→    _upload_all_params()\n   326→\n   327→    sep = H * 0.3  # within smoothing length\n   328→    positions = np.zeros((2, 4), dtype=np.float32)\n   329→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   330→    positions[1] = [sep, 0.0, 0.0, 1.0]\n   331→\n   332→    # Particle 0 has 2x mass\n   333→    mass_arr = np.array([MASS * 2.0, MASS], dtype=np.float32)\n   334→\n   335→    density, _, _, sorted_mass = _run_full_pipeline(positions, mass_arr)\n   336→\n   337→    # Particle with larger mass should generally produce higher self-density\n   338→    # But both particles contribute to each other, and mass affects contribution\n   339→    # The key thing: densities differ due to different masses\n   340→    assert density[0] != density[1], (\n   341→        f\"Expected different densities but got {density[0]} == {density[1]}\"\n   342→    )\n   343→\n   344→    print(f\"  Mass[0]={sorted_mass[0]:.6f}, density[0]={density[0]:.6f}\")\n   345→    print(f\"  Mass[1]={sorted_mass[1]:.6f}, density[1]={density[1]:.6f}\")\n   346→    print(\"[OK] Per-particle mass produces different densities\")\n   347→\n   348→\n   349→def test_density_clamp_minimum() -> None:\n   350→    \"\"\"Density is clamped to minimum 1.0.\"\"\"\n   351→    print(\"\\n--- Density clamp test ---\")\n   352→    _upload_all_params()\n   353→\n   354→    # Use extremely small mass so poly6_coeff * mass * h^6 < 1.0\n   355→    tiny_mass = 1e-20  # absurdly small\n   356→    positions = np.zeros((1, 4), dtype=np.float32)\n   357→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   358→\n   359→    mass_arr = np.array([tiny_mass], dtype=np.float32)\n   360→\n   361→    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   362→\n   363→    assert density[0] >= 1.0, (\n   364→        f\"Density {density[0]} < 1.0 (clamp failed)\"\n   365→    )\n   366→    print(f\"  Density with tiny mass: {density[0]:.6f}\")\n   367→    print(\"[OK] Density clamped to >= 1.0\")\n   368→\n   369→\n   370→def test_uniform_field_rest_density() -> None:\n   371→    \"\"\"Uniform particle field at rest density produces rho ~= rho0 (within 10%).\n   372→\n   373→    Sets up a regular grid of particles with spacing = 0.02 in a small cube,\n   374→    with mass = rho0 * spacing^3. Interior particles should have density\n   375→    close to rho0.\n   376→    \"\"\"\n   377→    print(\"\\n--- Uniform field rest density test ---\")\n   378→    _upload_all_params()\n   379→\n   380→    # Create a regular grid of particles\n   381→    spacing = SPACING\n   382→    # Use a region large enough for interior particles to have full neighborhood\n   383→    extent = 0.2  # -0.1 to +0.1 in each axis\n   384→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   385→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   386→    n = xx.size\n   387→\n   388→    positions = np.zeros((n, 4), dtype=np.float32)\n   389→    positions[:, 0] = xx.ravel()\n   390→    positions[:, 1] = yy.ravel()\n   391→    positions[:, 2] = zz.ravel()\n   392→    positions[:, 3] = 1.0\n   393→\n   394→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   395→\n   396→    density, _, sorted_pos, _ = _run_full_pipeline(positions, mass_arr)\n   397→\n   398→    # Filter to interior particles (at least 2h from edge to avoid boundary effects)\n   399→    margin = 2.0 * H  # 0.08\n   400→    interior = (\n   401→        (sorted_pos[:, 0] > -extent + margin)\n   402→        & (sorted_pos[:, 0] < extent - margin)\n   403→        & (sorted_pos[:, 1] > -extent + margin)\n   404→        & (sorted_pos[:, 1] < extent - margin)\n   405→        & (sorted_pos[:, 2] > -extent + margin)\n   406→        & (sorted_pos[:, 2] < extent - margin)\n   407→    )\n   408→    num_interior = int(np.sum(interior))\n   409→\n   410→    if num_interior == 0:\n   411→        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n   412→        print(\"  Skipping rest density check, using overall stats instead\")\n   413→        mean_rho = float(np.mean(density))\n   414→        print(f\"  Mean density (all): {mean_rho:.2f}\")\n   415→        return\n   416→\n   417→    interior_density = density[interior]\n   418→    mean_rho = float(np.mean(interior_density))\n   419→    min_rho = float(np.min(interior_density))\n   420→    max_rho = float(np.max(interior_density))\n   421→\n   422→    rel_err = abs(mean_rho - RHO0) / RHO0\n   423→\n   424→    print(f\"  Total particles: {n}\")\n   425→    print(f\"  Interior particles: {num_interior}\")\n   426→    print(f\"  Mean interior density: {mean_rho:.2f} (expected ~{RHO0:.0f})\")\n   427→    print(f\"  Min/Max interior density: {min_rho:.2f} / {max_rho:.2f}\")\n   428→    print(f\"  Relative error: {rel_err:.4f}\")\n   429→\n   430→    assert rel_err < 0.10, (\n   431→        f\"Mean interior density {mean_rho:.2f} differs from rho0={RHO0:.0f} \"\n   432→        f\"by {rel_err*100:.1f}% (> 10%)\"\n   433→    )\n   434→    print(\"[OK] Uniform field interior density within 10% of rho0\")\n   435→\n   436→\n   437→def test_self_contribution_included() -> None:\n   438→    \"\"\"Verify self-contribution is included by checking r_sq=0 case.\"\"\"\n   439→    print(\"\\n--- Self-contribution included test ---\")\n   440→    _upload_all_params()\n   441→\n   442→    # Single particle should have nonzero density (from self-contribution)\n   443→    positions = np.zeros((1, 4), dtype=np.float32)\n   444→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   445→    mass_arr = np.array([MASS], dtype=np.float32)\n   446→\n   447→    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   448→\n   449→    # Without self-contribution, density would be 0 -> clamped to 1.0\n   450→    # With self-contribution, density = poly6_coeff * mass * h^6 which is >> 1.0\n   451→    expected_self = POLY6_COEFF * MASS * H_SQ**3\n   452→    assert density[0] > 1.0, (\n   453→        f\"Density {density[0]} == 1.0 means self-contribution missing\"\n   454→    )\n   455→    assert density[0] > expected_self * 0.99, (\n   456→        f\"Density {density[0]:.4f} too low vs expected self-only {expected_self:.4f}\"\n   457→    )\n   458→\n   459→    print(f\"  Density: {density[0]:.6f} (expected self-only: {expected_self:.6f})\")\n   460→    print(\"[OK] Self-contribution is included in density computation\")\n   461→\n   462→\n   463→# ===================================================================\n   464→# Strain-rate tensor tests (US-015)\n   465→# ===================================================================\n   466→\n   467→def test_stationary_sand_zero_gamma_dot() -> None:\n   468→    \"\"\"Stationary GRANULAR particles produce gamma_dot approximately 0.\n   469→\n   470→    All particles at rest (velocity=0), so the velocity gradient tensor D\n   471→    should be zero everywhere, and gamma_dot = sqrt(2*D:D) = 0.\n   472→    \"\"\"\n   473→    print(\"\\n--- Stationary sand zero gamma_dot test ---\")\n   474→    _upload_all_params()\n   475→\n   476→    # Regular grid of GRANULAR particles, all at rest\n   477→    spacing = SPACING\n   478→    extent = 0.1\n   479→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   480→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   481→    n = xx.size\n   482→\n   483→    positions = np.zeros((n, 4), dtype=np.float32)\n   484→    positions[:, 0] = xx.ravel()\n   485→    positions[:, 1] = yy.ravel()\n   486→    positions[:, 2] = zz.ravel()\n   487→    positions[:, 3] = 1.0\n   488→\n   489→    velocities = np.zeros((n, 4), dtype=np.float32)  # all at rest\n   490→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   491→    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n   492→    # Provide density_in for m_j/rho_j weighting\n   493→    density_in = np.full(n, RHO0, dtype=np.float32)\n   494→\n   495→    density, shear_rate, sorted_pos, _ = _run_full_pipeline(\n   496→        positions, mass_arr, velocities, packed_info, density_in,\n   497→    )\n   498→\n   499→    # All shear_rates should be approximately 0 (within numerical tolerance)\n   500→    max_gamma_dot = float(np.max(np.abs(shear_rate)))\n   501→    mean_gamma_dot = float(np.mean(np.abs(shear_rate)))\n   502→\n   503→    print(f\"  {n} GRANULAR particles at rest\")\n   504→    print(f\"  Max |gamma_dot|:  {max_gamma_dot:.6e}\")\n   505→    print(f\"  Mean |gamma_dot|: {mean_gamma_dot:.6e}\")\n   506→\n   507→    assert max_gamma_dot < 1e-3, (\n   508→        f\"Stationary particles have gamma_dot = {max_gamma_dot:.6e}, expected ~0\"\n   509→    )\n   510→    print(\"[OK] Stationary sand particles produce gamma_dot ~ 0\")\n   511→\n   512→\n   513→def test_shear_flow_nonzero_gamma_dot() -> None:\n   514→    \"\"\"Sand particles in shear flow produce gamma_dot > 0.\n   515→\n   516→    Sets up a simple shear flow: v_x = shear_rate * y (linear shear in x-y plane).\n   517→    The analytical strain rate D_xy = 0.5 * dv_x/dy = 0.5 * shear_rate_applied.\n   518→    gamma_dot = sqrt(2 * 2 * D_xy^2) = sqrt(4 * 0.25 * SR^2) = |SR|.\n   519→    \"\"\"\n   520→    print(\"\\n--- Shear flow nonzero gamma_dot test ---\")\n   521→    _upload_all_params()\n   522→\n   523→    # Regular grid of GRANULAR particles with linear shear velocity\n   524→    spacing = SPACING\n   525→    extent = 0.1\n   526→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   527→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   528→    n = xx.size\n   529→\n   530→    positions = np.zeros((n, 4), dtype=np.float32)\n   531→    positions[:, 0] = xx.ravel()\n   532→    positions[:, 1] = yy.ravel()\n   533→    positions[:, 2] = zz.ravel()\n   534→    positions[:, 3] = 1.0\n   535→\n   536→    # Shear flow: v_x = SR * y, v_y = 0, v_z = 0\n   537→    applied_shear_rate = 10.0  # s^-1\n   538→    velocities = np.zeros((n, 4), dtype=np.float32)\n   539→    velocities[:, 0] = applied_shear_rate * positions[:, 1]  # v_x = SR * y\n   540→\n   541→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   542→    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n   543→    density_in = np.full(n, RHO0, dtype=np.float32)\n   544→\n   545→    density, shear_rate, sorted_pos, _ = _run_full_pipeline(\n   546→        positions, mass_arr, velocities, packed_info, density_in,\n   547→    )\n   548→\n   549→    # Interior particles should have gamma_dot > 0\n   550→    margin = 2.0 * H\n   551→    interior = (\n   552→        (sorted_pos[:, 0] > -extent + margin)\n   553→        & (sorted_pos[:, 0] < extent - margin)\n   554→        & (sorted_pos[:, 1] > -extent + margin)\n   555→        & (sorted_pos[:, 1] < extent - margin)\n   556→        & (sorted_pos[:, 2] > -extent + margin)\n   557→        & (sorted_pos[:, 2] < extent - margin)\n   558→    )\n   559→    num_interior = int(np.sum(interior))\n   560→\n   561→    if num_interior == 0:\n   562→        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n   563→        print(\"  Using all particles for shear rate check\")\n   564→        interior_shear = shear_rate\n   565→    else:\n   566→        interior_shear = shear_rate[interior]\n   567→\n   568→    mean_gamma_dot = float(np.mean(interior_shear))\n   569→    max_gamma_dot = float(np.max(interior_shear))\n   570→    min_gamma_dot = float(np.min(interior_shear))\n   571→\n   572→    print(f\"  {n} GRANULAR particles in shear flow (SR={applied_shear_rate})\")\n   573→    print(f\"  Interior particles: {num_interior}\")\n   574→    print(f\"  Mean gamma_dot: {mean_gamma_dot:.4f}\")\n   575→    print(f\"  Range: [{min_gamma_dot:.4f}, {max_gamma_dot:.4f}]\")\n   576→    print(f\"  Expected (analytical): ~{applied_shear_rate:.1f}\")\n   577→\n   578→    # gamma_dot should be significantly > 0\n   579→    assert mean_gamma_dot > 1.0, (\n   580→        f\"Mean gamma_dot = {mean_gamma_dot:.4f} too low for SR={applied_shear_rate}\"\n   581→    )\n   582→\n   583→    # gamma_dot should be in the right ballpark (within factor of 5 of analytical)\n   584→    # SPH approximation won't be exact due to kernel support, discretization, boundary effects\n   585→    assert mean_gamma_dot < applied_shear_rate * 5.0, (\n   586→        f\"Mean gamma_dot = {mean_gamma_dot:.4f} way too high for SR={applied_shear_rate}\"\n   587→    )\n   588→\n   589→    print(\"[OK] Sand particles in shear flow produce gamma_dot > 0\")\n   590→\n   591→\n   592→def test_non_granular_zero_shear_rate() -> None:\n   593→    \"\"\"Non-GRANULAR particles get shear_rate = 0 even with velocity gradients.\"\"\"\n   594→    print(\"\\n--- Non-GRANULAR zero shear_rate test ---\")\n   595→    _upload_all_params()\n   596→\n   597→    n = 100\n   598→    rng = np.random.default_rng(123)\n   599→\n   600→    positions = np.zeros((n, 4), dtype=np.float32)\n   601→    positions[:, :3] = rng.uniform(-0.1, 0.1, size=(n, 3)).astype(np.float32)\n   602→    positions[:, 3] = 1.0\n   603→\n   604→    # Give particles random velocities (nonzero velocity gradient)\n   605→    velocities = np.zeros((n, 4), dtype=np.float32)\n   606→    velocities[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n   607→\n   608→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   609→    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)  # FLUID, not GRANULAR\n   610→\n   611→    density, shear_rate, _, _ = _run_full_pipeline(\n   612→        positions, mass_arr, velocities, packed_info,\n   613→    )\n   614→\n   615→    # All shear_rates should be exactly 0 for FLUID particles\n   616→    assert np.all(shear_rate == 0.0), (\n   617→        f\"FLUID particles have nonzero shear_rate: max={np.max(np.abs(shear_rate)):.6e}\"\n   618→    )\n   619→\n   620→    print(f\"  {n} FLUID particles with random velocities\")\n   621→    print(f\"  All shear_rate = 0 (confirmed)\")\n   622→    print(\"[OK] Non-GRANULAR particles get shear_rate = 0\")\n   623→\n   624→\n   625→def test_500k_no_errors() -> None:\n   626→    \"\"\"Kernel runs without errors for 500K particles (mixed FLUID and GRANULAR).\"\"\"\n   627→    print(\"\\n--- 500K particle stress test ---\")\n   628→    _upload_all_params()\n   629→\n   630→    rng = np.random.default_rng(42)\n   631→    n = 500_000\n   632→\n   633→    positions = np.zeros((n, 4), dtype=np.float32)\n   634→    positions[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n   635→    positions[:, 3] = 1.0\n   636→\n   637→    velocities = np.zeros((n, 4), dtype=np.float32)\n   638→    velocities[:, :3] = rng.uniform(-0.5, 0.5, size=(n, 3)).astype(np.float32)\n   639→\n   640→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   641→\n   642→    # Mix of FLUID and GRANULAR particles (50/50)\n   643→    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)\n   644→    packed_info[n // 2:] = PACKED_SAND\n   645→\n   646→    density_in = np.full(n, RHO0, dtype=np.float32)\n   647→\n   648→    density, shear_rate, _, _ = _run_full_pipeline(\n   649→        positions, mass_arr, velocities, packed_info, density_in,\n   650→    )\n   651→\n   652→    # Basic sanity checks\n   653→    assert density.shape == (n,), f\"density shape {density.shape} != ({n},)\"\n   654→    assert shear_rate.shape == (n,), f\"shear_rate shape {shear_rate.shape} != ({n},)\"\n   655→    assert np.all(density >= 1.0), \"Some densities < 1.0 (clamp failed)\"\n   656→    assert np.all(np.isfinite(density)), \"NaN or Inf in densities\"\n   657→    assert np.all(np.isfinite(shear_rate)), \"NaN or Inf in shear_rates\"\n   658→    assert np.all(shear_rate >= 0.0), \"Negative shear_rate values found\"\n   659→\n   660→    mean_rho = float(np.mean(density))\n   661→    min_rho = float(np.min(density))\n   662→    max_rho = float(np.max(density))\n   663→    mean_sr = float(np.mean(shear_rate))\n   664→    max_sr = float(np.max(shear_rate))\n   665→\n   666→    print(f\"  500K particles processed (250K FLUID + 250K GRANULAR)\")\n   667→    print(f\"  Density range: [{min_rho:.2f}, {max_rho:.2f}], mean: {mean_rho:.2f}\")\n   668→    print(f\"  Shear rate: mean={mean_sr:.4f}, max={max_sr:.4f}\")\n   669→    print(\"[OK] 500K particles: no CUDA errors, all values finite\")\n   670→\n   671→\n   672→def main() -> None:\n   673→    test_compilation()\n   674→    test_block_size()\n   675→    test_struct_sizes()\n   676→    test_precalc_coefficients()\n   677→    test_single_isolated_particle()\n   678→    test_two_particles_within_h()\n   679→    test_two_particles_beyond_h()\n   680→    test_per_particle_mass()\n   681→    test_density_clamp_minimum()\n   682→    test_uniform_field_rest_density()\n   683→    test_self_contribution_included()\n   684→    test_stationary_sand_zero_gamma_dot()\n   685→    test_shear_flow_nonzero_gamma_dot()\n   686→    test_non_granular_zero_shear_rate()\n   687→    test_500k_no_errors()\n   688→    print(\"\\n=== ALL CHECKS PASSED ===\")\n   689→\n   690→\n   691→if __name__ == \"__main__\":\n   692→    main()\n   693→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"e6e8b27e-e279-4052-ba7d-ce90d33ff805","uuid":"8c3a7dff-1324-4e8f-8b9b-18f99c7a0713","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_step1.py","content":"\"\"\"Integration test for step1.py -- K_Step1 density + strain-rate kernel.\n\nAcceptance criteria (density, US-011):\n  - K_Step1 iterates 3x3x3 neighbor cells using cell_start/cell_end\n  - density_sum += m_j * (h_sq - r_sq)^3 with PER-PARTICLE mass\n  - Final density = max(1.0, poly6_coeff * density_sum)\n  - Smoothing length uses squared distance (r_sq < h_sq)\n  - Neighbor position loaded via __ldg() (read-only cache)\n  - Self-contribution included (j==i NOT skipped)\n  - Test: uniform field at rest density -> rho ~= rho0 (within 10%)\n  - Test: single isolated particle -> rho = mass * poly6_coeff * h^6\n  - Block size = 128, runs without errors for 500K particles\n\nAcceptance criteria (strain-rate, US-015):\n  - Step1 accumulates 6 symmetric D components for GRANULAR only\n  - D tensor uses spiky gradient (NOT poly6 gradient), m_j/rho_j weighting\n  - PostCalc: gamma_dot = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n  - gamma_dot written to sorted shear_rate array\n  - Non-GRANULAR particles get shear_rate = 0\n  - Test: stationary sand -> gamma_dot ~ 0\n  - Test: sand in shear flow -> gamma_dot > 0\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport os\nimport sys\n\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom hash_sort import (\n    NUM_CELLS,\n    build_grid_params,\n    calc_hash,\n    sort_by_hash,\n    upload_grid_params as upload_hash_grid_params,\n)\nfrom build_grid import (\n    build_data_struct,\n    upload_grid_params as upload_build_grid_params,\n)\nfrom step1 import (\n    BLOCK_SIZE,\n    build_precalc_params,\n    build_sim_params,\n    compute_step1,\n    get_module,\n    upload_grid_params as upload_step1_grid_params,\n    upload_precalc_params,\n    upload_sim_params,\n)\n\n# Simulation constants matching the acceptance criteria\nH = 0.04                # smoothing length\nH_SQ = H * H\nSPACING = 0.02          # particle spacing\nRHO0 = 1000.0           # rest density of water\nMASS = RHO0 * SPACING**3  # 0.008 kg\nPOLY6_COEFF = 315.0 / (64.0 * math.pi * H**9)\n\n# packed_info constants\n# MAKE_PACKED(mat, beh) = (mat & 0xFF) | ((beh & 0x3) << 8)\nFLUID = 0\nGRANULAR = 1\nPACKED_WATER = 5 | (FLUID << 8)     # material 5, FLUID\nPACKED_SAND  = 2 | (GRANULAR << 8)  # material 2, GRANULAR\n\n\ndef _upload_all_params() -> None:\n    \"\"\"Upload grid, sim, and precalc params to all kernel modules.\"\"\"\n    gp = build_grid_params()\n    upload_hash_grid_params(gp)\n    upload_build_grid_params(gp)\n    upload_step1_grid_params(gp)\n\n    sp = build_sim_params(\n        smoothing_length=H,\n        particle_mass=MASS,\n        particle_spacing=SPACING,\n    )\n    upload_sim_params(sp)\n\n    pp = build_precalc_params(smoothing_length=H)\n    upload_precalc_params(pp)\n\n\ndef _run_full_pipeline(\n    positions_np: np.ndarray,\n    mass_np: np.ndarray,\n    velocity_np: np.ndarray | None = None,\n    packed_info_np: np.ndarray | None = None,\n    density_in_np: np.ndarray | None = None,\n) -> tuple:\n    \"\"\"Run hash -> sort -> build -> step1 and return results.\n\n    Parameters\n    ----------\n    positions_np : (N, 4) float32\n    mass_np : (N,) float32\n    velocity_np : (N, 4) float32, optional (default: zeros)\n    packed_info_np : (N,) uint32, optional (default: PACKED_WATER)\n    density_in_np : (N,) float32, optional (default: None -> kernel uses fallback)\n\n    Returns\n    -------\n    density_cpu : (N,) float32 -- density in sorted order\n    shear_rate_cpu : (N,) float32 -- gamma_dot in sorted order\n    sorted_positions_cpu : (N, 4) float32\n    sorted_mass_cpu : (N,) float32\n    \"\"\"\n    n = positions_np.shape[0]\n\n    if velocity_np is None:\n        velocity_np = np.zeros((n, 4), dtype=np.float32)\n    if packed_info_np is None:\n        packed_info_np = np.full(n, PACKED_WATER, dtype=np.uint32)\n\n    pos_gpu = cupy.asarray(positions_np)\n    mass_gpu = cupy.asarray(mass_np)\n    vel_gpu = cupy.asarray(velocity_np)\n    pi_gpu = cupy.asarray(packed_info_np)\n    density_in_gpu = cupy.asarray(density_in_np) if density_in_np is not None else None\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n\n    # Reorder all arrays to sorted order\n    sorted_pos = pos_gpu[sorted_indices]\n    sorted_mass = mass_gpu[sorted_indices]\n    sorted_vel = vel_gpu[sorted_indices]\n    sorted_pi = pi_gpu[sorted_indices]\n    sorted_density_in = density_in_gpu[sorted_indices] if density_in_gpu is not None else None\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n\n    density, shear_rate = compute_step1(\n        sorted_pos, sorted_vel, sorted_mass,\n        sorted_density_in, sorted_pi,\n        cell_start, cell_end,\n    )\n    cupy.cuda.Device().synchronize()\n\n    return (\n        cupy.asnumpy(density),\n        cupy.asnumpy(shear_rate),\n        cupy.asnumpy(sorted_pos),\n        cupy.asnumpy(sorted_mass),\n    )\n\n\n# ===================================================================\n# Density tests (unchanged acceptance criteria from US-011)\n# ===================================================================\n\ndef test_compilation() -> None:\n    \"\"\"Verify CuPy RawModule compiles step1.cu.\"\"\"\n    print(\"--- Compilation check ---\")\n\n    module = get_module()\n    assert module is not None\n    print(\"[OK] CuPy RawModule compiled step1.cu (includes common.cuh)\")\n\n    kernel = module.get_function(\"K_Step1\")  # type: ignore[union-attr]\n    assert kernel is not None\n    print(\"[OK] K_Step1 kernel function found\")\n\n    # Verify all constant memory symbols accessible\n    for sym in [\"c_grid\", \"c_sim\", \"c_precalc\"]:\n        d_ptr = module.get_global(sym)  # type: ignore[union-attr]\n        assert int(d_ptr) != 0, f\"{sym} symbol not found\"\n    print(\"[OK] c_grid, c_sim, c_precalc constant memory symbols found\")\n\n\ndef test_block_size() -> None:\n    \"\"\"Verify block size is 128.\"\"\"\n    print(\"\\n--- Block size check ---\")\n    assert BLOCK_SIZE == 128, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 128\"\n    print(\"[OK] BLOCK_SIZE = 128\")\n\n\ndef test_struct_sizes() -> None:\n    \"\"\"Verify SimParams and PrecalcParams dtypes match CUDA struct sizes.\"\"\"\n    print(\"\\n--- Struct size check ---\")\n\n    sp = build_sim_params()\n    pp = build_precalc_params()\n\n    # SimParams: 64 bytes (from US-005 test)\n    assert sp.nbytes == 64, f\"SimParams: {sp.nbytes} != 64 bytes\"\n    print(f\"[OK] SimParams: {sp.nbytes} bytes\")\n\n    # PrecalcParams: 20 bytes\n    assert pp.nbytes == 20, f\"PrecalcParams: {pp.nbytes} != 20 bytes\"\n    print(f\"[OK] PrecalcParams: {pp.nbytes} bytes\")\n\n\ndef test_precalc_coefficients() -> None:\n    \"\"\"Verify poly6_coeff matches expected value for h=0.04.\"\"\"\n    print(\"\\n--- Precalc coefficient check ---\")\n\n    pp = build_precalc_params(smoothing_length=H)\n    poly6 = pp[0][\"poly6_coeff\"]\n\n    expected = np.float32(315.0 / (64.0 * math.pi * H**9))\n    rel_err = abs(float(poly6) - float(expected)) / abs(float(expected))\n\n    print(f\"  poly6_coeff = {poly6:.6e} (expected {expected:.6e})\")\n    assert rel_err < 1e-5, f\"poly6_coeff relative error {rel_err:.2e} > 1e-5\"\n    print(\"[OK] poly6_coeff matches 315/(64*pi*h^9)\")\n\n\ndef test_single_isolated_particle() -> None:\n    \"\"\"Single isolated particle: rho = mass * poly6_coeff * h^6.\n\n    Self-contribution: r_sq = 0, so (h^2 - 0)^3 = h^6.\n    density = poly6_coeff * mass * h^6.\n    \"\"\"\n    print(\"\\n--- Single isolated particle test ---\")\n    _upload_all_params()\n\n    # Place particle at center of grid\n    positions = np.zeros((1, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n\n    mass_arr = np.array([MASS], dtype=np.float32)\n\n    density, shear_rate, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    expected = POLY6_COEFF * MASS * H_SQ**3  # poly6_coeff * mass * h^6\n    actual = density[0]\n\n    rel_err = abs(actual - expected) / abs(expected)\n    print(f\"  Expected density: {expected:.6f}\")\n    print(f\"  Actual density:   {actual:.6f}\")\n    print(f\"  Relative error:   {rel_err:.6e}\")\n\n    assert rel_err < 1e-4, (\n        f\"Single particle density mismatch: {actual:.6f} vs {expected:.6f} \"\n        f\"(rel err {rel_err:.6e})\"\n    )\n\n    # Non-GRANULAR (default WATER/FLUID) -> shear_rate should be 0\n    assert shear_rate[0] == 0.0, f\"FLUID particle shear_rate = {shear_rate[0]}, expected 0\"\n\n    print(\"[OK] Single isolated particle density matches mass * poly6_coeff * h^6\")\n    print(\"[OK] FLUID particle shear_rate = 0\")\n\n\ndef test_two_particles_within_h() -> None:\n    \"\"\"Two particles within h should have higher density than one alone.\"\"\"\n    print(\"\\n--- Two particles within smoothing length test ---\")\n    _upload_all_params()\n\n    sep = H * 0.5  # half the smoothing length\n    positions = np.zeros((2, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    positions[1] = [sep, 0.0, 0.0, 1.0]\n\n    mass_arr = np.full(2, MASS, dtype=np.float32)\n\n    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    # Self-contribution only\n    single_rho = POLY6_COEFF * MASS * H_SQ**3\n\n    # Both particles should have density > single particle\n    assert density[0] > single_rho * 0.99, (\n        f\"Particle 0 density {density[0]:.4f} not > single {single_rho:.4f}\"\n    )\n    assert density[1] > single_rho * 0.99, (\n        f\"Particle 1 density {density[1]:.4f} not > single {single_rho:.4f}\"\n    )\n\n    # By symmetry, densities should be approximately equal\n    rel_diff = abs(density[0] - density[1]) / max(density[0], density[1])\n    assert rel_diff < 1e-4, (\n        f\"Asymmetric densities: {density[0]:.6f} vs {density[1]:.6f}\"\n    )\n\n    print(f\"  Single particle density: {single_rho:.6f}\")\n    print(f\"  Particle 0 density:      {density[0]:.6f}\")\n    print(f\"  Particle 1 density:      {density[1]:.6f}\")\n    print(\"[OK] Two particles within h produce symmetric density > single particle\")\n\n\ndef test_two_particles_beyond_h() -> None:\n    \"\"\"Two particles separated by more than h should not see each other.\"\"\"\n    print(\"\\n--- Two particles beyond smoothing length test ---\")\n    _upload_all_params()\n\n    sep = H * 1.5  # beyond smoothing length\n    positions = np.zeros((2, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    positions[1] = [sep, 0.0, 0.0, 1.0]\n\n    mass_arr = np.full(2, MASS, dtype=np.float32)\n\n    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    single_rho = POLY6_COEFF * MASS * H_SQ**3\n\n    # Both should have same density as single particle (only self-contribution)\n    for i in range(2):\n        rel_err = abs(density[i] - single_rho) / single_rho\n        assert rel_err < 1e-4, (\n            f\"Particle {i} density {density[i]:.6f} != single {single_rho:.6f} \"\n            f\"(rel err {rel_err:.2e})\"\n        )\n\n    print(f\"  Particle 0 density: {density[0]:.6f}\")\n    print(f\"  Particle 1 density: {density[1]:.6f}\")\n    print(f\"  Expected (self-only): {single_rho:.6f}\")\n    print(\"[OK] Particles beyond h have self-contribution-only density\")\n\n\ndef test_per_particle_mass() -> None:\n    \"\"\"Two particles with different masses produce different densities.\"\"\"\n    print(\"\\n--- Per-particle mass test ---\")\n    _upload_all_params()\n\n    sep = H * 0.3  # within smoothing length\n    positions = np.zeros((2, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    positions[1] = [sep, 0.0, 0.0, 1.0]\n\n    # Particle 0 has 2x mass\n    mass_arr = np.array([MASS * 2.0, MASS], dtype=np.float32)\n\n    density, _, _, sorted_mass = _run_full_pipeline(positions, mass_arr)\n\n    # Particle with larger mass should generally produce higher self-density\n    # But both particles contribute to each other, and mass affects contribution\n    # The key thing: densities differ due to different masses\n    assert density[0] != density[1], (\n        f\"Expected different densities but got {density[0]} == {density[1]}\"\n    )\n\n    print(f\"  Mass[0]={sorted_mass[0]:.6f}, density[0]={density[0]:.6f}\")\n    print(f\"  Mass[1]={sorted_mass[1]:.6f}, density[1]={density[1]:.6f}\")\n    print(\"[OK] Per-particle mass produces different densities\")\n\n\ndef test_density_clamp_minimum() -> None:\n    \"\"\"Density is clamped to minimum 1.0.\"\"\"\n    print(\"\\n--- Density clamp test ---\")\n    _upload_all_params()\n\n    # Use extremely small mass so poly6_coeff * mass * h^6 < 1.0\n    tiny_mass = 1e-20  # absurdly small\n    positions = np.zeros((1, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n\n    mass_arr = np.array([tiny_mass], dtype=np.float32)\n\n    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    assert density[0] >= 1.0, (\n        f\"Density {density[0]} < 1.0 (clamp failed)\"\n    )\n    print(f\"  Density with tiny mass: {density[0]:.6f}\")\n    print(\"[OK] Density clamped to >= 1.0\")\n\n\ndef test_uniform_field_rest_density() -> None:\n    \"\"\"Uniform particle field at rest density produces rho ~= rho0 (within 10%).\n\n    Sets up a regular grid of particles with spacing = 0.02 in a small cube,\n    with mass = rho0 * spacing^3. Interior particles should have density\n    close to rho0.\n    \"\"\"\n    print(\"\\n--- Uniform field rest density test ---\")\n    _upload_all_params()\n\n    # Create a regular grid of particles\n    spacing = SPACING\n    # Use a region large enough for interior particles to have full neighborhood\n    extent = 0.2  # -0.1 to +0.1 in each axis\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n\n    density, _, sorted_pos, _ = _run_full_pipeline(positions, mass_arr)\n\n    # Filter to interior particles (at least 2h from edge to avoid boundary effects)\n    margin = 2.0 * H  # 0.08\n    interior = (\n        (sorted_pos[:, 0] > -extent + margin)\n        & (sorted_pos[:, 0] < extent - margin)\n        & (sorted_pos[:, 1] > -extent + margin)\n        & (sorted_pos[:, 1] < extent - margin)\n        & (sorted_pos[:, 2] > -extent + margin)\n        & (sorted_pos[:, 2] < extent - margin)\n    )\n    num_interior = int(np.sum(interior))\n\n    if num_interior == 0:\n        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n        print(\"  Skipping rest density check, using overall stats instead\")\n        mean_rho = float(np.mean(density))\n        print(f\"  Mean density (all): {mean_rho:.2f}\")\n        return\n\n    interior_density = density[interior]\n    mean_rho = float(np.mean(interior_density))\n    min_rho = float(np.min(interior_density))\n    max_rho = float(np.max(interior_density))\n\n    rel_err = abs(mean_rho - RHO0) / RHO0\n\n    print(f\"  Total particles: {n}\")\n    print(f\"  Interior particles: {num_interior}\")\n    print(f\"  Mean interior density: {mean_rho:.2f} (expected ~{RHO0:.0f})\")\n    print(f\"  Min/Max interior density: {min_rho:.2f} / {max_rho:.2f}\")\n    print(f\"  Relative error: {rel_err:.4f}\")\n\n    assert rel_err < 0.10, (\n        f\"Mean interior density {mean_rho:.2f} differs from rho0={RHO0:.0f} \"\n        f\"by {rel_err*100:.1f}% (> 10%)\"\n    )\n    print(\"[OK] Uniform field interior density within 10% of rho0\")\n\n\ndef test_self_contribution_included() -> None:\n    \"\"\"Verify self-contribution is included by checking r_sq=0 case.\"\"\"\n    print(\"\\n--- Self-contribution included test ---\")\n    _upload_all_params()\n\n    # Single particle should have nonzero density (from self-contribution)\n    positions = np.zeros((1, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    mass_arr = np.array([MASS], dtype=np.float32)\n\n    density, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    # Without self-contribution, density would be 0 -> clamped to 1.0\n    # With self-contribution, density = poly6_coeff * mass * h^6 which is >> 1.0\n    expected_self = POLY6_COEFF * MASS * H_SQ**3\n    assert density[0] > 1.0, (\n        f\"Density {density[0]} == 1.0 means self-contribution missing\"\n    )\n    assert density[0] > expected_self * 0.99, (\n        f\"Density {density[0]:.4f} too low vs expected self-only {expected_self:.4f}\"\n    )\n\n    print(f\"  Density: {density[0]:.6f} (expected self-only: {expected_self:.6f})\")\n    print(\"[OK] Self-contribution is included in density computation\")\n\n\n# ===================================================================\n# Strain-rate tensor tests (US-015)\n# ===================================================================\n\ndef test_stationary_sand_zero_gamma_dot() -> None:\n    \"\"\"Stationary GRANULAR particles produce gamma_dot approximately 0.\n\n    All particles at rest (velocity=0), so the velocity gradient tensor D\n    should be zero everywhere, and gamma_dot = sqrt(2*D:D) = 0.\n    \"\"\"\n    print(\"\\n--- Stationary sand zero gamma_dot test ---\")\n    _upload_all_params()\n\n    # Regular grid of GRANULAR particles, all at rest\n    spacing = SPACING\n    extent = 0.1\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    velocities = np.zeros((n, 4), dtype=np.float32)  # all at rest\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n    # Provide density_in for m_j/rho_j weighting\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    density, shear_rate, sorted_pos, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info, density_in,\n    )\n\n    # All shear_rates should be approximately 0 (within numerical tolerance)\n    max_gamma_dot = float(np.max(np.abs(shear_rate)))\n    mean_gamma_dot = float(np.mean(np.abs(shear_rate)))\n\n    print(f\"  {n} GRANULAR particles at rest\")\n    print(f\"  Max |gamma_dot|:  {max_gamma_dot:.6e}\")\n    print(f\"  Mean |gamma_dot|: {mean_gamma_dot:.6e}\")\n\n    assert max_gamma_dot < 1e-3, (\n        f\"Stationary particles have gamma_dot = {max_gamma_dot:.6e}, expected ~0\"\n    )\n    print(\"[OK] Stationary sand particles produce gamma_dot ~ 0\")\n\n\ndef test_shear_flow_nonzero_gamma_dot() -> None:\n    \"\"\"Sand particles in shear flow produce gamma_dot > 0.\n\n    Sets up a simple shear flow: v_x = shear_rate * y (linear shear in x-y plane).\n    The analytical strain rate D_xy = 0.5 * dv_x/dy = 0.5 * shear_rate_applied.\n    gamma_dot = sqrt(2 * 2 * D_xy^2) = sqrt(4 * 0.25 * SR^2) = |SR|.\n    \"\"\"\n    print(\"\\n--- Shear flow nonzero gamma_dot test ---\")\n    _upload_all_params()\n\n    # Regular grid of GRANULAR particles with linear shear velocity\n    spacing = SPACING\n    extent = 0.1\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    # Shear flow: v_x = SR * y, v_y = 0, v_z = 0\n    applied_shear_rate = 10.0  # s^-1\n    velocities = np.zeros((n, 4), dtype=np.float32)\n    velocities[:, 0] = applied_shear_rate * positions[:, 1]  # v_x = SR * y\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    density, shear_rate, sorted_pos, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info, density_in,\n    )\n\n    # Interior particles should have gamma_dot > 0\n    margin = 2.0 * H\n    interior = (\n        (sorted_pos[:, 0] > -extent + margin)\n        & (sorted_pos[:, 0] < extent - margin)\n        & (sorted_pos[:, 1] > -extent + margin)\n        & (sorted_pos[:, 1] < extent - margin)\n        & (sorted_pos[:, 2] > -extent + margin)\n        & (sorted_pos[:, 2] < extent - margin)\n    )\n    num_interior = int(np.sum(interior))\n\n    if num_interior == 0:\n        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n        print(\"  Using all particles for shear rate check\")\n        interior_shear = shear_rate\n    else:\n        interior_shear = shear_rate[interior]\n\n    mean_gamma_dot = float(np.mean(interior_shear))\n    max_gamma_dot = float(np.max(interior_shear))\n    min_gamma_dot = float(np.min(interior_shear))\n\n    print(f\"  {n} GRANULAR particles in shear flow (SR={applied_shear_rate})\")\n    print(f\"  Interior particles: {num_interior}\")\n    print(f\"  Mean gamma_dot: {mean_gamma_dot:.4f}\")\n    print(f\"  Range: [{min_gamma_dot:.4f}, {max_gamma_dot:.4f}]\")\n    print(f\"  Expected (analytical): ~{applied_shear_rate:.1f}\")\n\n    # gamma_dot should be significantly > 0\n    assert mean_gamma_dot > 1.0, (\n        f\"Mean gamma_dot = {mean_gamma_dot:.4f} too low for SR={applied_shear_rate}\"\n    )\n\n    # gamma_dot should be in the right ballpark (within factor of 5 of analytical)\n    # SPH approximation won't be exact due to kernel support, discretization, boundary effects\n    assert mean_gamma_dot < applied_shear_rate * 5.0, (\n        f\"Mean gamma_dot = {mean_gamma_dot:.4f} way too high for SR={applied_shear_rate}\"\n    )\n\n    print(\"[OK] Sand particles in shear flow produce gamma_dot > 0\")\n\n\ndef test_non_granular_zero_shear_rate() -> None:\n    \"\"\"Non-GRANULAR particles get shear_rate = 0 even with velocity gradients.\"\"\"\n    print(\"\\n--- Non-GRANULAR zero shear_rate test ---\")\n    _upload_all_params()\n\n    n = 100\n    rng = np.random.default_rng(123)\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, :3] = rng.uniform(-0.1, 0.1, size=(n, 3)).astype(np.float32)\n    positions[:, 3] = 1.0\n\n    # Give particles random velocities (nonzero velocity gradient)\n    velocities = np.zeros((n, 4), dtype=np.float32)\n    velocities[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)  # FLUID, not GRANULAR\n\n    density, shear_rate, _, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info,\n    )\n\n    # All shear_rates should be exactly 0 for FLUID particles\n    assert np.all(shear_rate == 0.0), (\n        f\"FLUID particles have nonzero shear_rate: max={np.max(np.abs(shear_rate)):.6e}\"\n    )\n\n    print(f\"  {n} FLUID particles with random velocities\")\n    print(f\"  All shear_rate = 0 (confirmed)\")\n    print(\"[OK] Non-GRANULAR particles get shear_rate = 0\")\n\n\ndef test_500k_no_errors() -> None:\n    \"\"\"Kernel runs without errors for 500K particles (mixed FLUID and GRANULAR).\"\"\"\n    print(\"\\n--- 500K particle stress test ---\")\n    _upload_all_params()\n\n    rng = np.random.default_rng(42)\n    n = 500_000\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n    positions[:, 3] = 1.0\n\n    velocities = np.zeros((n, 4), dtype=np.float32)\n    velocities[:, :3] = rng.uniform(-0.5, 0.5, size=(n, 3)).astype(np.float32)\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n\n    # Mix of FLUID and GRANULAR particles (50/50)\n    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)\n    packed_info[n // 2:] = PACKED_SAND\n\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    density, shear_rate, _, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info, density_in,\n    )\n\n    # Basic sanity checks\n    assert density.shape == (n,), f\"density shape {density.shape} != ({n},)\"\n    assert shear_rate.shape == (n,), f\"shear_rate shape {shear_rate.shape} != ({n},)\"\n    assert np.all(density >= 1.0), \"Some densities < 1.0 (clamp failed)\"\n    assert np.all(np.isfinite(density)), \"NaN or Inf in densities\"\n    assert np.all(np.isfinite(shear_rate)), \"NaN or Inf in shear_rates\"\n    assert np.all(shear_rate >= 0.0), \"Negative shear_rate values found\"\n\n    mean_rho = float(np.mean(density))\n    min_rho = float(np.min(density))\n    max_rho = float(np.max(density))\n    mean_sr = float(np.mean(shear_rate))\n    max_sr = float(np.max(shear_rate))\n\n    print(f\"  500K particles processed (250K FLUID + 250K GRANULAR)\")\n    print(f\"  Density range: [{min_rho:.2f}, {max_rho:.2f}], mean: {mean_rho:.2f}\")\n    print(f\"  Shear rate: mean={mean_sr:.4f}, max={max_sr:.4f}\")\n    print(\"[OK] 500K particles: no CUDA errors, all values finite\")\n\n\ndef main() -> None:\n    test_compilation()\n    test_block_size()\n    test_struct_sizes()\n    test_precalc_coefficients()\n    test_single_isolated_particle()\n    test_two_particles_within_h()\n    test_two_particles_beyond_h()\n    test_per_particle_mass()\n    test_density_clamp_minimum()\n    test_uniform_field_rest_density()\n    test_self_contribution_included()\n    test_stationary_sand_zero_gamma_dot()\n    test_shear_flow_nonzero_gamma_dot()\n    test_non_granular_zero_shear_rate()\n    test_500k_no_errors()\n    print(\"\\n=== ALL CHECKS PASSED ===\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":693,"startLine":1,"totalLines":693}}}

{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BJ9mfRNN4iJEK4HjtsH6xx","type":"tool_result","content":"     1→\"\"\"Material property table and interaction matrix for multi-material SPH.\n     2→\n     3→Defines 16 materials (IDs 0-15) as Python dataclasses, a 32x32 interaction\n     4→matrix, and an upload_to_gpu() function that copies both tables to CUDA\n     5→constant memory via CuPy RawModule symbol lookup.\n     6→\n     7→Constant-memory symbols\n     8→-----------------------\n     9→- ``c_materials``   : MaterialProps[32]\n    10→- ``c_interactions`` : Interaction[32][32]\n    11→\n    12→The C struct layout is defined in KERNEL_SOURCE below and must stay in sync\n    13→with any CUDA kernels that read these constants.\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import dataclasses\n    19→from typing import Dict, List, Optional, Tuple\n    20→\n    21→import numpy as np\n    22→\n    23→# ---------------------------------------------------------------------------\n    24→# CUDA kernel source -- struct definitions + constant memory declarations\n    25→# ---------------------------------------------------------------------------\n    26→\n    27→KERNEL_SOURCE = r\"\"\"\n    28→// ---- struct definitions (must match numpy dtypes in materials.py) --------\n    29→\n    30→struct MaterialProps {\n    31→    int   id;               // material ID (0-31)\n    32→    float rest_density;     // kg/m^3\n    33→    float viscosity;        // Pa*s\n    34→    float gas_stiffness;    // pressure response\n    35→    float surface_tension;  // surface tension coefficient\n    36→    float thermal_conductivity;  // W/(m*K)\n    37→    float specific_heat;    // J/(kg*K)\n    38→    float melting_point;    // Kelvin\n    39→    float boiling_point;    // Kelvin\n    40→    float ignition_point;   // Kelvin (0 = non-flammable)\n    41→    float friction_static;  // static friction coefficient\n    42→    float friction_kinetic; // kinetic friction coefficient\n    43→    float restitution;      // coefficient of restitution (bounciness)\n    44→    int   is_solid;         // 1 = solid, 0 = fluid/gas\n    45→    int   is_flammable;     // 1 = can burn\n    46→    int   _pad;             // padding to 16-int boundary (64 bytes)\n    47→};\n    48→\n    49→struct Interaction {\n    50→    float reaction_rate;    // reaction speed (0 = no reaction)\n    51→    float heat_exchange;    // heat transfer coefficient between pair\n    52→};\n    53→\n    54→__constant__ MaterialProps c_materials[32];\n    55→__constant__ Interaction   c_interactions[32][32];\n    56→\n    57→// Trivial test kernel: read a material field and an interaction field.\n    58→extern \"C\" __global__\n    59→void test_read_materials(float* out) {\n    60→    // out[0] = c_materials[5].rest_density   (water -> 1000.0)\n    61→    // out[1] = c_interactions[8][10].reaction_rate  (acid-metal -> 0.3)\n    62→    out[0] = c_materials[5].rest_density;\n    63→    out[1] = c_interactions[8][10].reaction_rate;\n    64→}\n    65→\"\"\"\n    66→\n    67→# ---------------------------------------------------------------------------\n    68→# Numpy structured dtypes matching the C structs exactly\n    69→# ---------------------------------------------------------------------------\n    70→\n    71→MATERIAL_PROPS_DTYPE = np.dtype(\n    72→    [\n    73→        (\"id\", np.int32),\n    74→        (\"rest_density\", np.float32),\n    75→        (\"viscosity\", np.float32),\n    76→        (\"gas_stiffness\", np.float32),\n    77→        (\"surface_tension\", np.float32),\n    78→        (\"thermal_conductivity\", np.float32),\n    79→        (\"specific_heat\", np.float32),\n    80→        (\"melting_point\", np.float32),\n    81→        (\"boiling_point\", np.float32),\n    82→        (\"ignition_point\", np.float32),\n    83→        (\"friction_static\", np.float32),\n    84→        (\"friction_kinetic\", np.float32),\n    85→        (\"restitution\", np.float32),\n    86→        (\"is_solid\", np.int32),\n    87→        (\"is_flammable\", np.int32),\n    88→        (\"_pad\", np.int32),\n    89→    ],\n    90→    align=True,\n    91→)\n    92→\n    93→INTERACTION_DTYPE = np.dtype(\n    94→    [\n    95→        (\"reaction_rate\", np.float32),\n    96→        (\"heat_exchange\", np.float32),\n    97→    ],\n    98→    align=True,\n    99→)\n   100→\n   101→# Compile-time size checks (must match sizeof(MaterialProps) and sizeof(Interaction))\n   102→assert MATERIAL_PROPS_DTYPE.itemsize == 64, (\n   103→    f\"MaterialProps size mismatch: {MATERIAL_PROPS_DTYPE.itemsize} != 64\"\n   104→)\n   105→assert INTERACTION_DTYPE.itemsize == 8, (\n   106→    f\"Interaction size mismatch: {INTERACTION_DTYPE.itemsize} != 8\"\n   107→)\n   108→\n   109→MAX_MATERIALS = 32  # slots in constant memory (IDs 0-31)\n   110→NUM_DEFINED = 16  # IDs 0-15 are defined; 16-31 reserved (zeroed)\n   111→\n   112→# ---------------------------------------------------------------------------\n   113→# MaterialDef dataclass\n   114→# ---------------------------------------------------------------------------\n   115→\n   116→\n   117→@dataclasses.dataclass\n   118→class MaterialDef:\n   119→    \"\"\"Python-side definition of a single material.\n   120→\n   121→    Field names and semantics match the ``MaterialProps`` C struct.\n   122→    \"\"\"\n   123→\n   124→    id: int\n   125→    name: str  # human-readable label (not uploaded to GPU)\n   126→    rest_density: float  # kg/m^3\n   127→    viscosity: float  # Pa*s\n   128→    gas_stiffness: float\n   129→    surface_tension: float\n   130→    thermal_conductivity: float  # W/(m*K)\n   131→    specific_heat: float  # J/(kg*K)\n   132→    melting_point: float  # Kelvin\n   133→    boiling_point: float  # Kelvin\n   134→    ignition_point: float  # Kelvin; 0 = non-flammable\n   135→    friction_static: float\n   136→    friction_kinetic: float\n   137→    restitution: float  # bounciness 0..1\n   138→    is_solid: bool\n   139→    is_flammable: bool\n   140→\n   141→    def to_numpy(self) -> np.void:\n   142→        \"\"\"Pack into a single numpy structured-array element.\"\"\"\n   143→        return np.array(\n   144→            (\n   145→                self.id,\n   146→                self.rest_density,\n   147→                self.viscosity,\n   148→                self.gas_stiffness,\n   149→                self.surface_tension,\n   150→                self.thermal_conductivity,\n   151→                self.specific_heat,\n   152→                self.melting_point,\n   153→                self.boiling_point,\n   154→                self.ignition_point,\n   155→                self.friction_static,\n   156→                self.friction_kinetic,\n   157→                self.restitution,\n   158→                int(self.is_solid),\n   159→                int(self.is_flammable),\n   160→                0,  # _pad\n   161→            ),\n   162→            dtype=MATERIAL_PROPS_DTYPE,\n   163→        )\n   164→\n   165→\n   166→# ---------------------------------------------------------------------------\n   167→# Material ID constants\n   168→# ---------------------------------------------------------------------------\n   169→\n   170→DEAD = 0\n   171→STONE = 1\n   172→SAND = 2\n   173→DIRT = 3\n   174→GRAVEL = 4\n   175→WATER = 5\n   176→OIL = 6\n   177→LAVA = 7\n   178→ACID = 8\n   179→WOOD = 9\n   180→METAL = 10\n   181→ICE = 11\n   182→STEAM = 12\n   183→SMOKE = 13\n   184→FIRE = 14\n   185→GUNPOWDER = 15\n   186→\n   187→# ---------------------------------------------------------------------------\n   188→# Material definitions (16 entries, IDs 0-15)\n   189→#\n   190→# Property values are chosen for a falling-sand / multi-material SPH game:\n   191→#   - rest_density in kg/m^3 (approximate real-world values)\n   192→#   - viscosity in Pa*s (scaled for game feel)\n   193→#   - gas_stiffness controls pressure response\n   194→#   - temperatures in Kelvin\n   195→# ---------------------------------------------------------------------------\n   196→\n   197→MATERIALS: Dict[int, MaterialDef] = {\n   198→    DEAD: MaterialDef(\n   199→        id=DEAD, name=\"DEAD\",\n   200→        rest_density=0.0, viscosity=0.0, gas_stiffness=0.0,\n   201→        surface_tension=0.0, thermal_conductivity=0.0,\n   202→        specific_heat=0.0, melting_point=0.0, boiling_point=0.0,\n   203→        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n   204→        restitution=0.0, is_solid=False, is_flammable=False,\n   205→    ),\n   206→    STONE: MaterialDef(\n   207→        id=STONE, name=\"STONE\",\n   208→        rest_density=2600.0, viscosity=0.0, gas_stiffness=0.0,\n   209→        surface_tension=0.0, thermal_conductivity=2.0,\n   210→        specific_heat=800.0, melting_point=1500.0, boiling_point=3000.0,\n   211→        ignition_point=0.0, friction_static=0.7, friction_kinetic=0.5,\n   212→        restitution=0.2, is_solid=True, is_flammable=False,\n   213→    ),\n   214→    SAND: MaterialDef(\n   215→        id=SAND, name=\"SAND\",\n   216→        rest_density=1600.0, viscosity=0.0, gas_stiffness=0.0,\n   217→        surface_tension=0.0, thermal_conductivity=0.3,\n   218→        specific_heat=830.0, melting_point=1700.0, boiling_point=2500.0,\n   219→        ignition_point=0.0, friction_static=0.6, friction_kinetic=0.4,\n   220→        restitution=0.1, is_solid=True, is_flammable=False,\n   221→    ),\n   222→    DIRT: MaterialDef(\n   223→        id=DIRT, name=\"DIRT\",\n   224→        rest_density=1500.0, viscosity=0.0, gas_stiffness=0.0,\n   225→        surface_tension=0.0, thermal_conductivity=0.25,\n   226→        specific_heat=900.0, melting_point=1400.0, boiling_point=2200.0,\n   227→        ignition_point=0.0, friction_static=0.5, friction_kinetic=0.35,\n   228→        restitution=0.05, is_solid=True, is_flammable=False,\n   229→    ),\n   230→    GRAVEL: MaterialDef(\n   231→        id=GRAVEL, name=\"GRAVEL\",\n   232→        rest_density=1800.0, viscosity=0.0, gas_stiffness=0.0,\n   233→        surface_tension=0.0, thermal_conductivity=0.5,\n   234→        specific_heat=840.0, melting_point=1500.0, boiling_point=2800.0,\n   235→        ignition_point=0.0, friction_static=0.65, friction_kinetic=0.45,\n   236→        restitution=0.15, is_solid=True, is_flammable=False,\n   237→    ),\n   238→    WATER: MaterialDef(\n   239→        id=WATER, name=\"WATER\",\n   240→        rest_density=1000.0, viscosity=1.0, gas_stiffness=1.5,\n   241→        surface_tension=0.072, thermal_conductivity=0.6,\n   242→        specific_heat=4186.0, melting_point=273.0, boiling_point=373.0,\n   243→        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n   244→        restitution=0.0, is_solid=False, is_flammable=False,\n   245→    ),\n   246→    OIL: MaterialDef(\n   247→        id=OIL, name=\"OIL\",\n   248→        rest_density=800.0, viscosity=5.0, gas_stiffness=1.2,\n   249→        surface_tension=0.03, thermal_conductivity=0.15,\n   250→        specific_heat=2000.0, melting_point=250.0, boiling_point=570.0,\n   251→        ignition_point=480.0, friction_static=0.0, friction_kinetic=0.0,\n   252→        restitution=0.0, is_solid=False, is_flammable=True,\n   253→    ),\n   254→    LAVA: MaterialDef(\n   255→        id=LAVA, name=\"LAVA\",\n   256→        rest_density=2500.0, viscosity=100.0, gas_stiffness=1.0,\n   257→        surface_tension=0.4, thermal_conductivity=1.5,\n   258→        specific_heat=1000.0, melting_point=1000.0, boiling_point=2500.0,\n   259→        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n   260→        restitution=0.0, is_solid=False, is_flammable=False,\n   261→    ),\n   262→    ACID: MaterialDef(\n   263→        id=ACID, name=\"ACID\",\n   264→        rest_density=1200.0, viscosity=1.5, gas_stiffness=1.4,\n   265→        surface_tension=0.05, thermal_conductivity=0.5,\n   266→        specific_heat=2500.0, melting_point=250.0, boiling_point=380.0,\n   267→        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n   268→        restitution=0.0, is_solid=False, is_flammable=False,\n   269→    ),\n   270→    WOOD: MaterialDef(\n   271→        id=WOOD, name=\"WOOD\",\n   272→        rest_density=600.0, viscosity=0.0, gas_stiffness=0.0,\n   273→        surface_tension=0.0, thermal_conductivity=0.15,\n   274→        specific_heat=1700.0, melting_point=0.0, boiling_point=0.0,\n   275→        ignition_point=570.0, friction_static=0.5, friction_kinetic=0.3,\n   276→        restitution=0.3, is_solid=True, is_flammable=True,\n   277→    ),\n   278→    METAL: MaterialDef(\n   279→        id=METAL, name=\"METAL\",\n   280→        rest_density=7800.0, viscosity=0.0, gas_stiffness=0.0,\n   281→        surface_tension=0.0, thermal_conductivity=50.0,\n   282→        specific_heat=450.0, melting_point=1800.0, boiling_point=3300.0,\n   283→        ignition_point=0.0, friction_static=0.6, friction_kinetic=0.4,\n   284→        restitution=0.4, is_solid=True, is_flammable=False,\n   285→    ),\n   286→    ICE: MaterialDef(\n   287→        id=ICE, name=\"ICE\",\n   288→        rest_density=917.0, viscosity=0.0, gas_stiffness=0.0,\n   289→        surface_tension=0.0, thermal_conductivity=2.2,\n   290→        specific_heat=2090.0, melting_point=273.0, boiling_point=373.0,\n   291→        ignition_point=0.0, friction_static=0.1, friction_kinetic=0.03,\n   292→        restitution=0.3, is_solid=True, is_flammable=False,\n   293→    ),\n   294→    STEAM: MaterialDef(\n   295→        id=STEAM, name=\"STEAM\",\n   296→        rest_density=0.6, viscosity=0.01, gas_stiffness=3.0,\n   297→        surface_tension=0.0, thermal_conductivity=0.025,\n   298→        specific_heat=2010.0, melting_point=0.0, boiling_point=0.0,\n   299→        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n   300→        restitution=0.0, is_solid=False, is_flammable=False,\n   301→    ),\n   302→    SMOKE: MaterialDef(\n   303→        id=SMOKE, name=\"SMOKE\",\n   304→        rest_density=0.3, viscosity=0.01, gas_stiffness=2.5,\n   305→        surface_tension=0.0, thermal_conductivity=0.02,\n   306→        specific_heat=1000.0, melting_point=0.0, boiling_point=0.0,\n   307→        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n   308→        restitution=0.0, is_solid=False, is_flammable=False,\n   309→    ),\n   310→    FIRE: MaterialDef(\n   311→        id=FIRE, name=\"FIRE\",\n   312→        rest_density=0.2, viscosity=0.01, gas_stiffness=4.0,\n   313→        surface_tension=0.0, thermal_conductivity=0.05,\n   314→        specific_heat=1000.0, melting_point=0.0, boiling_point=0.0,\n   315→        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n   316→        restitution=0.0, is_solid=False, is_flammable=False,\n   317→    ),\n   318→    GUNPOWDER: MaterialDef(\n   319→        id=GUNPOWDER, name=\"GUNPOWDER\",\n   320→        rest_density=1700.0, viscosity=0.0, gas_stiffness=0.0,\n   321→        surface_tension=0.0, thermal_conductivity=0.2,\n   322→        specific_heat=800.0, melting_point=0.0, boiling_point=0.0,\n   323→        ignition_point=480.0, friction_static=0.5, friction_kinetic=0.35,\n   324→        restitution=0.1, is_solid=True, is_flammable=True,\n   325→    ),\n   326→}\n   327→\n   328→assert len(MATERIALS) == NUM_DEFINED\n   329→\n   330→# ---------------------------------------------------------------------------\n   331→# 32x32 Interaction matrix\n   332→#\n   333→# Each (i, j) pair stores reaction_rate and heat_exchange.\n   334→# Only non-trivial pairs are listed; everything else defaults to zero.\n   335→#\n   336→# Key interactions:\n   337→#   water + lava   -> steam (high heat exchange)\n   338→#   acid  + metal  -> reaction_rate 0.3\n   339→#   acid  + stone  -> slow corrosion\n   340→#   acid  + wood   -> slow corrosion\n   341→#   fire  + wood   -> burning\n   342→#   fire  + oil    -> fast burning\n   343→#   fire  + gunpowder -> explosion\n   344→#   lava  + ice    -> steam + stone\n   345→#   lava  + wood   -> burning\n   346→#   lava  + water  -> steam + stone\n   347→#   water + ice    -> melting\n   348→# ---------------------------------------------------------------------------\n   349→\n   350→# (mat_a, mat_b): (reaction_rate, heat_exchange)\n   351→# Symmetric: both (a,b) and (b,a) are set.\n   352→_INTERACTION_PAIRS: List[Tuple[int, int, float, float]] = [\n   353→    # water interactions\n   354→    (WATER, LAVA,   0.5,  5.0),    # water + lava -> steam, cools lava\n   355→    (WATER, ICE,    0.1,  2.0),    # water near ice -> freezing/melting\n   356→    (WATER, FIRE,   0.8,  3.0),    # water extinguishes fire\n   357→    (WATER, ACID,   0.05, 0.5),    # water dilutes acid slowly\n   358→    # lava interactions\n   359→    (LAVA, ICE,     0.6,  6.0),    # lava melts ice rapidly\n   360→    (LAVA, WOOD,    0.7,  4.0),    # lava ignites wood\n   361→    (LAVA, METAL,   0.05, 3.0),    # lava heats metal\n   362→    (LAVA, STONE,   0.0,  2.0),    # lava heats stone (no reaction, just heat)\n   363→    (LAVA, OIL,     0.8,  5.0),    # lava ignites oil\n   364→    (LAVA, GUNPOWDER, 0.9, 5.0),  # lava detonates gunpowder\n   365→    # acid interactions\n   366→    (ACID, STONE,   0.15, 0.3),    # acid slowly corrodes stone\n   367→    (ACID, METAL,   0.3,  0.5),    # acid corrodes metal\n   368→    (ACID, WOOD,    0.2,  0.2),    # acid corrodes wood\n   369→    (ACID, DIRT,    0.1,  0.1),    # acid dissolves dirt\n   370→    (ACID, ICE,     0.2,  1.0),    # acid melts ice\n   371→    # fire interactions\n   372→    (FIRE, WOOD,    0.6,  2.0),    # fire burns wood\n   373→    (FIRE, OIL,     0.8,  3.0),    # fire burns oil quickly\n   374→    (FIRE, GUNPOWDER, 0.9, 4.0),  # fire detonates gunpowder\n   375→    (FIRE, ICE,     0.3,  2.5),    # fire melts ice\n   376→    (FIRE, SMOKE,   0.0,  0.5),    # fire produces smoke (heat only)\n   377→    # oil interactions\n   378→    (OIL, WATER,    0.0,  0.3),    # oil floats on water (no reaction, low heat)\n   379→    # ice + steam\n   380→    (ICE, STEAM,    0.2,  1.5),    # steam melts ice\n   381→    # metal + fire\n   382→    (FIRE, METAL,   0.0,  2.0),    # fire heats metal (no reaction, heat only)\n   383→    # stone + fire\n   384→    (FIRE, STONE,   0.0,  0.5),    # fire heats stone slowly\n   385→]\n   386→\n   387→\n   388→def build_interaction_matrix() -> np.ndarray:\n   389→    \"\"\"Build the 32x32 interaction matrix as a numpy structured array.\n   390→\n   391→    Returns a (32, 32) array of Interaction structs.  Interactions are\n   392→    symmetric: setting (a, b) also sets (b, a).\n   393→    \"\"\"\n   394→    matrix = np.zeros((MAX_MATERIALS, MAX_MATERIALS), dtype=INTERACTION_DTYPE)\n   395→    for a, b, rate, heat in _INTERACTION_PAIRS:\n   396→        matrix[a][b][\"reaction_rate\"] = rate\n   397→        matrix[a][b][\"heat_exchange\"] = heat\n   398→        matrix[b][a][\"reaction_rate\"] = rate\n   399→        matrix[b][a][\"heat_exchange\"] = heat\n   400→    return matrix\n   401→\n   402→\n   403→def build_material_array() -> np.ndarray:\n   404→    \"\"\"Build the MaterialProps[32] array as a numpy structured array.\n   405→\n   406→    IDs 0-15 come from MATERIALS; IDs 16-31 are zeroed (reserved).\n   407→    \"\"\"\n   408→    arr = np.zeros(MAX_MATERIALS, dtype=MATERIAL_PROPS_DTYPE)\n   409→    for mat_id, mat_def in MATERIALS.items():\n   410→        arr[mat_id] = mat_def.to_numpy()\n   411→    return arr\n   412→\n   413→\n   414→# ---------------------------------------------------------------------------\n   415→# GPU upload via CuPy RawModule\n   416→# ---------------------------------------------------------------------------\n   417→\n   418→# Cached CuPy RawModule (compiled on first use)\n   419→_module: Optional[object] = None\n   420→\n   421→\n   422→def _ensure_ptx_if_needed() -> None:\n   423→    \"\"\"Force PTX compilation when the GPU arch exceeds NVRTC's max sm target.\n   424→\n   425→    CuPy's NVRTC backend generates sm_NN cubin by default, but if the GPU\n   426→    compute capability is newer than what the bundled NVRTC supports (e.g.\n   427→    sm_120 Blackwell with CUDA 12.5 NVRTC that maxes at sm_90), the cubin\n   428→    won't load.  Forcing PTX (compute_NN) produces forward-compatible code\n   429→    that the driver JIT-compiles at load time.\n   430→    \"\"\"\n   431→    from cupy.cuda import compiler as _compiler  # type: ignore[import-untyped]\n   432→    from cupy.cuda import device as _device  # type: ignore[import-untyped]\n   433→\n   434→    gpu_cc = _device.Device().compute_capability\n   435→    nvrtc_max = _compiler._get_max_compute_capability()\n   436→    if int(gpu_cc) > int(nvrtc_max):\n   437→        _compiler._use_ptx = True\n   438→        # Clear memoized arch-option cache so the new flag takes effect\n   439→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n   440→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n   441→        if hasattr(_compiler._get_arch, \"_cache\"):\n   442→            _compiler._get_arch._cache = {}\n   443→\n   444→\n   445→def _get_module() -> \"object\":\n   446→    \"\"\"Compile (or return cached) CuPy RawModule from KERNEL_SOURCE.\"\"\"\n   447→    global _module\n   448→    if _module is None:\n   449→        import cupy  # type: ignore[import-untyped]\n   450→\n   451→        _ensure_ptx_if_needed()\n   452→        _module = cupy.RawModule(code=KERNEL_SOURCE, options=(\"--std=c++11\",))\n   453→    return _module\n   454→\n   455→\n   456→def upload_to_gpu() -> None:\n   457→    \"\"\"Copy MaterialProps[32] and Interaction[32][32] to CUDA constant memory.\n   458→\n   459→    Uses ``module.get_global('c_materials')`` / ``module.get_global('c_interactions')``\n   460→    to obtain device pointers, then ``cupy.cuda.runtime.memcpy`` with\n   461→    ``cudaMemcpyHostToDevice`` to upload the numpy arrays.\n   462→    \"\"\"\n   463→    import cupy  # type: ignore[import-untyped]\n   464→\n   465→    cudaMemcpyHostToDevice = 1  # enum value from cuda.h\n   466→\n   467→    module = _get_module()\n   468→\n   469→    # Build host arrays\n   470→    h_materials = build_material_array()\n   471→    h_interactions = build_interaction_matrix()\n   472→\n   473→    # Get device pointers to constant memory symbols\n   474→    d_materials_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n   475→    d_interactions_ptr = module.get_global(\"c_interactions\")  # type: ignore[union-attr]\n   476→\n   477→    # Upload MaterialProps[32]\n   478→    cupy.cuda.runtime.memcpy(\n   479→        int(d_materials_ptr),\n   480→        h_materials.ctypes.data,\n   481→        h_materials.nbytes,\n   482→        cudaMemcpyHostToDevice,\n   483→    )\n   484→\n   485→    # Upload Interaction[32][32]\n   486→    cupy.cuda.runtime.memcpy(\n   487→        int(d_interactions_ptr),\n   488→        h_interactions.ctypes.data,\n   489→        h_interactions.nbytes,\n   490→        cudaMemcpyHostToDevice,\n   491→    )\n   492→\n   493→\n   494→def get_module() -> \"object\":\n   495→    \"\"\"Return the compiled CuPy RawModule (public accessor for tests).\"\"\"\n   496→    return _get_module()\n   497→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"33641597-223f-410d-ab04-2c5d25a1c0a7","uuid":"2bbf8129-b4e7-4481-99df-c76a8b93d0a0","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/materials.py","content":"\"\"\"Material property table and interaction matrix for multi-material SPH.\n\nDefines 16 materials (IDs 0-15) as Python dataclasses, a 32x32 interaction\nmatrix, and an upload_to_gpu() function that copies both tables to CUDA\nconstant memory via CuPy RawModule symbol lookup.\n\nConstant-memory symbols\n-----------------------\n- ``c_materials``   : MaterialProps[32]\n- ``c_interactions`` : Interaction[32][32]\n\nThe C struct layout is defined in KERNEL_SOURCE below and must stay in sync\nwith any CUDA kernels that read these constants.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport dataclasses\nfrom typing import Dict, List, Optional, Tuple\n\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# CUDA kernel source -- struct definitions + constant memory declarations\n# ---------------------------------------------------------------------------\n\nKERNEL_SOURCE = r\"\"\"\n// ---- struct definitions (must match numpy dtypes in materials.py) --------\n\nstruct MaterialProps {\n    int   id;               // material ID (0-31)\n    float rest_density;     // kg/m^3\n    float viscosity;        // Pa*s\n    float gas_stiffness;    // pressure response\n    float surface_tension;  // surface tension coefficient\n    float thermal_conductivity;  // W/(m*K)\n    float specific_heat;    // J/(kg*K)\n    float melting_point;    // Kelvin\n    float boiling_point;    // Kelvin\n    float ignition_point;   // Kelvin (0 = non-flammable)\n    float friction_static;  // static friction coefficient\n    float friction_kinetic; // kinetic friction coefficient\n    float restitution;      // coefficient of restitution (bounciness)\n    int   is_solid;         // 1 = solid, 0 = fluid/gas\n    int   is_flammable;     // 1 = can burn\n    int   _pad;             // padding to 16-int boundary (64 bytes)\n};\n\nstruct Interaction {\n    float reaction_rate;    // reaction speed (0 = no reaction)\n    float heat_exchange;    // heat transfer coefficient between pair\n};\n\n__constant__ MaterialProps c_materials[32];\n__constant__ Interaction   c_interactions[32][32];\n\n// Trivial test kernel: read a material field and an interaction field.\nextern \"C\" __global__\nvoid test_read_materials(float* out) {\n    // out[0] = c_materials[5].rest_density   (water -> 1000.0)\n    // out[1] = c_interactions[8][10].reaction_rate  (acid-metal -> 0.3)\n    out[0] = c_materials[5].rest_density;\n    out[1] = c_interactions[8][10].reaction_rate;\n}\n\"\"\"\n\n# ---------------------------------------------------------------------------\n# Numpy structured dtypes matching the C structs exactly\n# ---------------------------------------------------------------------------\n\nMATERIAL_PROPS_DTYPE = np.dtype(\n    [\n        (\"id\", np.int32),\n        (\"rest_density\", np.float32),\n        (\"viscosity\", np.float32),\n        (\"gas_stiffness\", np.float32),\n        (\"surface_tension\", np.float32),\n        (\"thermal_conductivity\", np.float32),\n        (\"specific_heat\", np.float32),\n        (\"melting_point\", np.float32),\n        (\"boiling_point\", np.float32),\n        (\"ignition_point\", np.float32),\n        (\"friction_static\", np.float32),\n        (\"friction_kinetic\", np.float32),\n        (\"restitution\", np.float32),\n        (\"is_solid\", np.int32),\n        (\"is_flammable\", np.int32),\n        (\"_pad\", np.int32),\n    ],\n    align=True,\n)\n\nINTERACTION_DTYPE = np.dtype(\n    [\n        (\"reaction_rate\", np.float32),\n        (\"heat_exchange\", np.float32),\n    ],\n    align=True,\n)\n\n# Compile-time size checks (must match sizeof(MaterialProps) and sizeof(Interaction))\nassert MATERIAL_PROPS_DTYPE.itemsize == 64, (\n    f\"MaterialProps size mismatch: {MATERIAL_PROPS_DTYPE.itemsize} != 64\"\n)\nassert INTERACTION_DTYPE.itemsize == 8, (\n    f\"Interaction size mismatch: {INTERACTION_DTYPE.itemsize} != 8\"\n)\n\nMAX_MATERIALS = 32  # slots in constant memory (IDs 0-31)\nNUM_DEFINED = 16  # IDs 0-15 are defined; 16-31 reserved (zeroed)\n\n# ---------------------------------------------------------------------------\n# MaterialDef dataclass\n# ---------------------------------------------------------------------------\n\n\n@dataclasses.dataclass\nclass MaterialDef:\n    \"\"\"Python-side definition of a single material.\n\n    Field names and semantics match the ``MaterialProps`` C struct.\n    \"\"\"\n\n    id: int\n    name: str  # human-readable label (not uploaded to GPU)\n    rest_density: float  # kg/m^3\n    viscosity: float  # Pa*s\n    gas_stiffness: float\n    surface_tension: float\n    thermal_conductivity: float  # W/(m*K)\n    specific_heat: float  # J/(kg*K)\n    melting_point: float  # Kelvin\n    boiling_point: float  # Kelvin\n    ignition_point: float  # Kelvin; 0 = non-flammable\n    friction_static: float\n    friction_kinetic: float\n    restitution: float  # bounciness 0..1\n    is_solid: bool\n    is_flammable: bool\n\n    def to_numpy(self) -> np.void:\n        \"\"\"Pack into a single numpy structured-array element.\"\"\"\n        return np.array(\n            (\n                self.id,\n                self.rest_density,\n                self.viscosity,\n                self.gas_stiffness,\n                self.surface_tension,\n                self.thermal_conductivity,\n                self.specific_heat,\n                self.melting_point,\n                self.boiling_point,\n                self.ignition_point,\n                self.friction_static,\n                self.friction_kinetic,\n                self.restitution,\n                int(self.is_solid),\n                int(self.is_flammable),\n                0,  # _pad\n            ),\n            dtype=MATERIAL_PROPS_DTYPE,\n        )\n\n\n# ---------------------------------------------------------------------------\n# Material ID constants\n# ---------------------------------------------------------------------------\n\nDEAD = 0\nSTONE = 1\nSAND = 2\nDIRT = 3\nGRAVEL = 4\nWATER = 5\nOIL = 6\nLAVA = 7\nACID = 8\nWOOD = 9\nMETAL = 10\nICE = 11\nSTEAM = 12\nSMOKE = 13\nFIRE = 14\nGUNPOWDER = 15\n\n# ---------------------------------------------------------------------------\n# Material definitions (16 entries, IDs 0-15)\n#\n# Property values are chosen for a falling-sand / multi-material SPH game:\n#   - rest_density in kg/m^3 (approximate real-world values)\n#   - viscosity in Pa*s (scaled for game feel)\n#   - gas_stiffness controls pressure response\n#   - temperatures in Kelvin\n# ---------------------------------------------------------------------------\n\nMATERIALS: Dict[int, MaterialDef] = {\n    DEAD: MaterialDef(\n        id=DEAD, name=\"DEAD\",\n        rest_density=0.0, viscosity=0.0, gas_stiffness=0.0,\n        surface_tension=0.0, thermal_conductivity=0.0,\n        specific_heat=0.0, melting_point=0.0, boiling_point=0.0,\n        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n        restitution=0.0, is_solid=False, is_flammable=False,\n    ),\n    STONE: MaterialDef(\n        id=STONE, name=\"STONE\",\n        rest_density=2600.0, viscosity=0.0, gas_stiffness=0.0,\n        surface_tension=0.0, thermal_conductivity=2.0,\n        specific_heat=800.0, melting_point=1500.0, boiling_point=3000.0,\n        ignition_point=0.0, friction_static=0.7, friction_kinetic=0.5,\n        restitution=0.2, is_solid=True, is_flammable=False,\n    ),\n    SAND: MaterialDef(\n        id=SAND, name=\"SAND\",\n        rest_density=1600.0, viscosity=0.0, gas_stiffness=0.0,\n        surface_tension=0.0, thermal_conductivity=0.3,\n        specific_heat=830.0, melting_point=1700.0, boiling_point=2500.0,\n        ignition_point=0.0, friction_static=0.6, friction_kinetic=0.4,\n        restitution=0.1, is_solid=True, is_flammable=False,\n    ),\n    DIRT: MaterialDef(\n        id=DIRT, name=\"DIRT\",\n        rest_density=1500.0, viscosity=0.0, gas_stiffness=0.0,\n        surface_tension=0.0, thermal_conductivity=0.25,\n        specific_heat=900.0, melting_point=1400.0, boiling_point=2200.0,\n        ignition_point=0.0, friction_static=0.5, friction_kinetic=0.35,\n        restitution=0.05, is_solid=True, is_flammable=False,\n    ),\n    GRAVEL: MaterialDef(\n        id=GRAVEL, name=\"GRAVEL\",\n        rest_density=1800.0, viscosity=0.0, gas_stiffness=0.0,\n        surface_tension=0.0, thermal_conductivity=0.5,\n        specific_heat=840.0, melting_point=1500.0, boiling_point=2800.0,\n        ignition_point=0.0, friction_static=0.65, friction_kinetic=0.45,\n        restitution=0.15, is_solid=True, is_flammable=False,\n    ),\n    WATER: MaterialDef(\n        id=WATER, name=\"WATER\",\n        rest_density=1000.0, viscosity=1.0, gas_stiffness=1.5,\n        surface_tension=0.072, thermal_conductivity=0.6,\n        specific_heat=4186.0, melting_point=273.0, boiling_point=373.0,\n        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n        restitution=0.0, is_solid=False, is_flammable=False,\n    ),\n    OIL: MaterialDef(\n        id=OIL, name=\"OIL\",\n        rest_density=800.0, viscosity=5.0, gas_stiffness=1.2,\n        surface_tension=0.03, thermal_conductivity=0.15,\n        specific_heat=2000.0, melting_point=250.0, boiling_point=570.0,\n        ignition_point=480.0, friction_static=0.0, friction_kinetic=0.0,\n        restitution=0.0, is_solid=False, is_flammable=True,\n    ),\n    LAVA: MaterialDef(\n        id=LAVA, name=\"LAVA\",\n        rest_density=2500.0, viscosity=100.0, gas_stiffness=1.0,\n        surface_tension=0.4, thermal_conductivity=1.5,\n        specific_heat=1000.0, melting_point=1000.0, boiling_point=2500.0,\n        ignition_point=0.0, friction_static=0.0, friction_kinetic=0.0,\n        restitution=0.0, is_solid=False, is_flammable=False,\n    ),\n    ACID: MaterialDef(\n        id=ACID, name=\"ACID\",\n        rest_density=1200.0, viscosity=1.5, gas_stiffness=1.4,\n        surface_tension=0.05, thermal_conductivity=0.5,\n        specific_heat=2500.0, melting_point=250.0, boiling_
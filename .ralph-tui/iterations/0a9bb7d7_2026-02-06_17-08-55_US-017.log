{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016KkWpvXGzCePM65PbCxag8","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter\n     5→and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n     9→  2. Run sim_steps simulation substeps\n    10→  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import time\n    16→from typing import Optional\n    17→\n    18→import cupy as cp\n    19→import numpy as np\n    20→\n    21→from world import World\n    22→from materials import (\n    23→    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n    24→)\n    25→\n    26→import hash_sort\n    27→import fused_reorder\n    28→import build_grid\n    29→import step1\n    30→import step2\n    31→import integrate\n    32→\n    33→\n    34→class Simulation:\n    35→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    36→\n    37→    Parameters\n    38→    ----------\n    39→    world : World\n    40→        Particle state manager.\n    41→    dt : float\n    42→        Fixed simulation timestep (seconds).\n    43→    speed : float\n    44→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    45→    max_substeps : int\n    46→        Maximum substeps per render frame to prevent spiral-of-death.\n    47→    \"\"\"\n    48→\n    49→    def __init__(\n    50→        self,\n    51→        world: World,\n    52→        dt: float = 0.001,\n    53→        speed: float = 1.0,\n    54→        max_substeps: int = 20,\n    55→    ) -> None:\n    56→        self.world = world\n    57→        self.dt = dt\n    58→        self.speed = speed\n    59→        self.max_substeps = max_substeps\n    60→        self._paused = False\n    61→        self._prev_speed = speed\n    62→        self._last_frame_time: Optional[float] = None\n    63→        self._last_substeps = 0\n    64→        self.sim_time = 0.0\n    65→\n    66→        # Grid cell tables (pre-allocated, reused every frame)\n    67→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    68→\n    69→        # Compile all kernel modules and upload constant memory\n    70→        self._upload_constants()\n    71→\n    72→    def _upload_constants(self) -> None:\n    73→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n    74→        # Build shared param structs\n    75→        grid_params = hash_sort.build_grid_params()\n    76→        sim_params = step1.build_sim_params(\n    77→            smoothing_length=0.04,\n    78→            particle_mass=0.008,\n    79→            particle_spacing=0.02,\n    80→            gravity=(0.0, -9.8, 0.0),\n    81→            dt=self.dt,\n    82→            restitution=0.3,\n    83→            wall_friction=0.5,\n    84→            world_min=(-1.0, -1.0, -1.0),\n    85→            world_max=(1.0, 1.0, 1.0),\n    86→        )\n    87→        precalc_params = step1.build_precalc_params(\n    88→            smoothing_length=0.04,\n    89→            viscosity=1.0,\n    90→        )\n    91→        granular_params = step2.build_granular_params()\n    92→        materials_data = build_material_array()\n    93→        interactions_data = build_interaction_matrix()\n    94→\n    95→        # --- hash_sort module: c_grid ---\n    96→        hash_sort.upload_grid_params(grid_params)\n    97→\n    98→        # --- fused_reorder module: no constant memory needed ---\n    99→        fused_reorder.get_module()  # just compile\n   100→\n   101→        # --- build_grid module: c_grid ---\n   102→        build_grid.upload_grid_params(grid_params)\n   103→\n   104→        # --- step1 module: c_grid, c_sim, c_precalc ---\n   105→        step1.upload_grid_params(grid_params)\n   106→        step1.upload_sim_params(sim_params)\n   107→        step1.upload_precalc_params(precalc_params)\n   108→\n   109→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   110→        step2.upload_grid_params(grid_params)\n   111→        step2.upload_sim_params(sim_params)\n   112→        step2.upload_precalc_params(precalc_params)\n   113→        step2.upload_materials(materials_data)\n   114→        step2.upload_granular_params(granular_params)\n   115→\n   116→        # --- integrate module: c_sim, c_materials ---\n   117→        integrate.upload_sim_params(sim_params)\n   118→        integrate.upload_materials(materials_data)\n   119→\n   120→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   121→        upload_to_gpu()\n   122→\n   123→    def _sim_step(self, n: int) -> None:\n   124→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   125→        w = self.world\n   126→\n   127→        # 1. Hash particle positions\n   128→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   129→\n   130→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   131→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   132→            hashes, indices,\n   133→            sorted_hashes_out=w.sorted_hashes,\n   134→            sorted_indices_out=w.sorted_indices,\n   135→        )\n   136→\n   137→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   138→        fused_reorder.fused_reorder(\n   139→            n, sorted_indices,\n   140→            w.position, w.velocity, w.veleval,\n   141→            w.mass, w.packed_info, w.temperature,\n   142→            w.health, w.lifetime, w.color,\n   143→            w.sleep_counter, w.shear_rate,\n   144→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   145→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   146→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   147→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   148→        )\n   149→\n   150→        # 4. Build grid data structure (cell_start / cell_end tables)\n   151→        build_grid.build_data_struct(\n   152→            sorted_hashes[:n], self._cell_start, self._cell_end\n   153→        )\n   154→\n   155→        # 5. Step1: density summation + strain-rate tensor\n   156→        step1.compute_step1(\n   157→            w.sorted_position[:n],\n   158→            w.sorted_velocity[:n],\n   159→            w.sorted_mass[:n],\n   160→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   161→            w.sorted_packed_info[:n],\n   162→            self._cell_start,\n   163→            self._cell_end,\n   164→            density_out=w.sorted_density,\n   165→            shear_rate_out=w.sorted_shear_rate,\n   166→        )\n   167→        w._density_initialized = True\n   168→\n   169→        # 6. Step2: pressure + viscosity + XSPH forces\n   170→        step2.compute_step2(\n   171→            w.sorted_position[:n],\n   172→            w.sorted_velocity[:n],\n   173→            w.sorted_density[:n],\n   174→            w.sorted_mass[:n],\n   175→            w.sorted_packed_info[:n],\n   176→            self._cell_start,\n   177→            self._cell_end,\n   178→            sph_force_out=w.sorted_sph_force,\n   179→            veleval_out=w.sorted_veleval,\n   180→        )\n   181→\n   182→        # 7. Integrate: symplectic Euler + SDF boundaries + color update\n   183→        #    Writes back to UNSORTED arrays via sort_indexes\n   184→        integrate.integrate(\n   185→            w.sorted_position[:n],\n   186→            w.sorted_velocity[:n],\n   187→            w.sorted_veleval[:n],\n   188→            w.sorted_sph_force[:n],\n   189→            w.sorted_mass[:n],\n   190→            w.sorted_packed_info[:n],\n   191→            w.sorted_temperature[:n],\n   192→            w.sorted_health[:n],\n   193→            sorted_indices[:n],\n   194→            position_out=w.position,\n   195→            velocity_out=w.velocity,\n   196→            color_out=w.color,\n   197→        )\n   198→\n   199→        self.sim_time += self.dt\n   200→\n   201→    def step_frame(self) -> int:\n   202→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   203→        now = time.perf_counter()\n   204→        if self._last_frame_time is None:\n   205→            self._last_frame_time = now\n   206→            return 0\n   207→\n   208→        wall_dt = now - self._last_frame_time\n   209→        self._last_frame_time = now\n   210→\n   211→        if self._paused or self.speed <= 0.0:\n   212→            self._last_substeps = 0\n   213→            return 0\n   214→\n   215→        n = self.world._high_water\n   216→        if n == 0:\n   217→            self._last_substeps = 0\n   218→            return 0\n   219→\n   220→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   221→        sim_steps = max(0, min(\n   222→            self.max_substeps,\n   223→            round(self.speed * wall_dt / self.dt),\n   224→        ))\n   225→\n   226→        for _ in range(sim_steps):\n   227→            self._sim_step(n)\n   228→\n   229→        self._last_substeps = sim_steps\n   230→        return sim_steps\n   231→\n   232→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   233→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   234→\n   235→        Parameters\n   236→        ----------\n   237→        cuda_pos : CudaGLBuffer\n   238→            Position VBO wrapper (must be context-managed externally).\n   239→        cuda_col : CudaGLBuffer\n   240→            Color VBO wrapper (must be context-managed externally).\n   241→        \"\"\"\n   242→        n = self.world._high_water\n   243→        if n == 0:\n   244→            return\n   245→\n   246→        # Position: world pos (float4) -> VBO pos (float4)\n   247→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   248→            (cuda_pos.nbytes // 16, 4), np.float32,\n   249→        )\n   250→        pos_arr[:n] = self.world.position[:n]\n   251→\n   252→        # Color: world color (float4) -> VBO color (float4)\n   253→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   254→            (cuda_col.nbytes // 16, 4), np.float32,\n   255→        )\n   256→        col_arr[:n] = self.world.color[:n]\n   257→\n   258→    @property\n   259→    def paused(self) -> bool:\n   260→        return self._paused\n   261→\n   262→    def toggle_pause(self) -> None:\n   263→        self._paused = not self._paused\n   264→\n   265→    def adjust_speed(self, delta: float) -> None:\n   266→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   267→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   268→\n   269→    @property\n   270→    def last_substeps(self) -> int:\n   271→        return self._last_substeps\n   272→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8366e700-f36a-49ec-85fd-f97c4934f324","uuid":"2249aa21-c950-45ed-8155-60f954c137df","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/simulation.py","content":"\"\"\"SPH simulation orchestrator.\n\nWires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\nStep2 -> Integrate.  Decouples simulation from rendering via a speed parameter\nand substep budget.\n\nEach render frame:\n  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n  2. Run sim_steps simulation substeps\n  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Optional\n\nimport cupy as cp\nimport numpy as np\n\nfrom world import World\nfrom materials import (\n    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n)\n\nimport hash_sort\nimport fused_reorder\nimport build_grid\nimport step1\nimport step2\nimport integrate\n\n\nclass Simulation:\n    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n\n    Parameters\n    ----------\n    world : World\n        Particle state manager.\n    dt : float\n        Fixed simulation timestep (seconds).\n    speed : float\n        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    max_substeps : int\n        Maximum substeps per render frame to prevent spiral-of-death.\n    \"\"\"\n\n    def __init__(\n        self,\n        world: World,\n        dt: float = 0.001,\n        speed: float = 1.0,\n        max_substeps: int = 20,\n    ) -> None:\n        self.world = world\n        self.dt = dt\n        self.speed = speed\n        self.max_substeps = max_substeps\n        self._paused = False\n        self._prev_speed = speed\n        self._last_frame_time: Optional[float] = None\n        self._last_substeps = 0\n        self.sim_time = 0.0\n\n        # Grid cell tables (pre-allocated, reused every frame)\n        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n\n        # Compile all kernel modules and upload constant memory\n        self._upload_constants()\n\n    def _upload_constants(self) -> None:\n        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n        # Build shared param structs\n        grid_params = hash_sort.build_grid_params()\n        sim_params = step1.build_sim_params(\n            smoothing_length=0.04,\n            particle_mass=0.008,\n            particle_spacing=0.02,\n            gravity=(0.0, -9.8, 0.0),\n            dt=self.dt,\n            restitution=0.3,\n            wall_friction=0.5,\n            world_min=(-1.0, -1.0, -1.0),\n            world_max=(1.0, 1.0, 1.0),\n        )\n        precalc_params = step1.build_precalc_params(\n            smoothing_length=0.04,\n            viscosity=1.0,\n        )\n        granular_params = step2.build_granular_params()\n        materials_data = build_material_array()\n        interactions_data = build_interaction_matrix()\n\n        # --- hash_sort module: c_grid ---\n        hash_sort.upload_grid_params(grid_params)\n\n        # --- fused_reorder module: no constant memory needed ---\n        fused_reorder.get_module()  # just compile\n\n        # --- build_grid module: c_grid ---\n        build_grid.upload_grid_params(grid_params)\n\n        # --- step1 module: c_grid, c_sim, c_precalc ---\n        step1.upload_grid_params(grid_params)\n        step1.upload_sim_params(sim_params)\n        step1.upload_precalc_params(precalc_params)\n\n        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n        step2.upload_grid_params(grid_params)\n        step2.upload_sim_params(sim_params)\n        step2.upload_precalc_params(precalc_params)\n        step2.upload_materials(materials_data)\n        step2.upload_granular_params(granular_params)\n\n        # --- integrate module: c_sim, c_materials ---\n        integrate.upload_sim_params(sim_params)\n        integrate.upload_materials(materials_data)\n\n        # --- materials module (its own internal module): c_materials, c_interactions ---\n        upload_to_gpu()\n\n    def _sim_step(self, n: int) -> None:\n        \"\"\"Run one simulation substep on n particles.\"\"\"\n        w = self.world\n\n        # 1. Hash particle positions\n        hashes, indices = hash_sort.calc_hash(w.position[:n])\n\n        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n            hashes, indices,\n            sorted_hashes_out=w.sorted_hashes,\n            sorted_indices_out=w.sorted_indices,\n        )\n\n        # 3. Fused reorder: gather all unsorted arrays into sorted order\n        fused_reorder.fused_reorder(\n            n, sorted_indices,\n            w.position, w.velocity, w.veleval,\n            w.mass, w.packed_info, w.temperature,\n            w.health, w.lifetime, w.color,\n            w.sleep_counter, w.shear_rate,\n            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n            w.sorted_sleep_counter, w.sorted_shear_rate,\n        )\n\n        # 4. Build grid data structure (cell_start / cell_end tables)\n        build_grid.build_data_struct(\n            sorted_hashes[:n], self._cell_start, self._cell_end\n        )\n\n        # 5. Step1: density summation + strain-rate tensor\n        step1.compute_step1(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_mass[:n],\n            w.sorted_density if hasattr(w, '_density_initialized') else None,\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            density_out=w.sorted_density,\n            shear_rate_out=w.sorted_shear_rate,\n        )\n        w._density_initialized = True\n\n        # 6. Step2: pressure + viscosity + XSPH forces\n        step2.compute_step2(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_density[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            sph_force_out=w.sorted_sph_force,\n            veleval_out=w.sorted_veleval,\n        )\n\n        # 7. Integrate: symplectic Euler + SDF boundaries + color update\n        #    Writes back to UNSORTED arrays via sort_indexes\n        integrate.integrate(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_sph_force[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            sorted_indices[:n],\n            position_out=w.position,\n            velocity_out=w.velocity,\n            color_out=w.color,\n        )\n\n        self.sim_time += self.dt\n\n    def step_frame(self) -> int:\n        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n        now = time.perf_counter()\n        if self._last_frame_time is None:\n            self._last_frame_time = now\n            return 0\n\n        wall_dt = now - self._last_frame_time\n        self._last_frame_time = now\n\n        if self._paused or self.speed <= 0.0:\n            self._last_substeps = 0\n            return 0\n\n        n = self.world._high_water\n        if n == 0:\n            self._last_substeps = 0\n            return 0\n\n        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n        sim_steps = max(0, min(\n            self.max_substeps,\n            round(self.speed * wall_dt / self.dt),\n        ))\n\n        for _ in range(sim_steps):\n            self._sim_step(n)\n\n        self._last_substeps = sim_steps\n        return sim_steps\n\n    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n\n        Parameters\n        ----------\n        cuda_pos : CudaGLBuffer\n            Position VBO wrapper (must be context-managed externally).\n        cuda_col : CudaGLBuffer\n            Color VBO wrapper (must be context-managed externally).\n        \"\"\"\n        n = self.world._high_water\n        if n == 0:\n            return\n\n        # Position: world pos (float4) -> VBO pos (float4)\n        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n            (cuda_pos.nbytes // 16, 4), np.float32,\n        )\n        pos_arr[:n] = self.world.position[:n]\n\n        # Color: world color (float4) -> VBO color (float4)\n        col_arr = cuda_col.device_pointer_as_cupy_array(\n            (cuda_col.nbytes // 16, 4), np.float32,\n        )\n        col_arr[:n] = self.world.color[:n]\n\n    @property\n    def paused(self) -> bool:\n        return self._paused\n\n    def toggle_pause(self) -> None:\n        self._paused = not self._paused\n\n    def adjust_speed(self, delta: float) -> None:\n        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n        self.speed = max(0.1, min(10.0, self.speed + delta))\n\n    @property\n    def last_substeps(self) -> int:\n        return self._last_substeps\n","numLines":272,"startLine":1,"totalLines":272}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GP6xyRpCgt8GLjLzvM2LWx","type":"tool_result","content":"     1→\"\"\"Integration test for integrate.py -- K_Integrate kernel.\n     2→\n     3→Acceptance criteria:\n     4→  - Symplectic Euler: vel_new = vel + dt * accel; pos_new uses XSPH for FLUID\n     5→  - Impulse SDF boundary: 6 planes of box (-1,-1,-1) to (1,1,1), restitution=0.3,\n     6→    Coulomb friction mu_wall=0.5\n     7→  - STATIC particles skipped (position unchanged)\n     8→  - GAS buoyancy: beta=0.01 * (T-293) * (0, 9.81, 0)\n     9→  - GAS drag: vel *= (1 - 2.0 * dt)\n    10→  - Velocity clamp at 50.0\n    11→  - Color from c_materials, tinted red for T>293K, faded by health\n    12→  - Writeback to UNSORTED arrays via sort_indexes\n    13→  - Bounce test: particle dropped from height bounces and loses energy\n    14→  - 10K water pool test: no NaN after 1000 steps\n    15→  - Block size = 256, 500K stress test\n    16→\n    17→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    18→\"\"\"\n    19→\n    20→from __future__ import annotations\n    21→\n    22→import math\n    23→import os\n    24→import sys\n    25→\n    26→sys.path.insert(0, os.path.dirname(__file__))\n    27→\n    28→import cupy\n    29→import numpy as np\n    30→\n    31→from step1 import (\n    32→    SIM_PARAMS_DTYPE,\n    33→    build_sim_params,\n    34→)\n    35→from materials import (\n    36→    FLUID,\n    37→    GRANULAR,\n    38→    GAS,\n    39→    STATIC,\n    40→    WATER,\n    41→    SAND,\n    42→    STEAM,\n    43→    STONE,\n    44→    build_material_array,\n    45→)\n    46→from integrate import (\n    47→    BLOCK_SIZE,\n    48→    get_module,\n    49→    integrate,\n    50→    upload_materials,\n    51→    upload_sim_params,\n    52→)\n    53→\n    54→# ---------------------------------------------------------------------------\n    55→# Constants\n    56→# ---------------------------------------------------------------------------\n    57→\n    58→H = 0.04\n    59→SPACING = 0.02\n    60→RHO0 = 1000.0\n    61→MASS = RHO0 * SPACING**3  # 0.008 kg\n    62→DT = 0.001\n    63→\n    64→# packed_info helpers\n    65→def MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    66→    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n    67→\n    68→def SET_SLEEPING(p: int) -> int:\n    69→    return p | 0x400\n    70→\n    71→# ---------------------------------------------------------------------------\n    72→# Helper: upload params for all tests\n    73→# ---------------------------------------------------------------------------\n    74→\n    75→def setup_params(dt=DT, restitution=0.3, wall_friction=0.5,\n    76→                 gravity=(0.0, -9.8, 0.0)):\n    77→    \"\"\"Upload SimParams and materials to integrate module's constant memory.\"\"\"\n    78→    sim_params = build_sim_params(\n    79→        smoothing_length=H,\n    80→        particle_mass=MASS,\n    81→        particle_spacing=SPACING,\n    82→        gravity=gravity,\n    83→        dt=dt,\n    84→        restitution=restitution,\n    85→        wall_friction=wall_friction,\n    86→        world_min=(-1.0, -1.0, -1.0),\n    87→        world_max=(1.0, 1.0, 1.0),\n    88→    )\n    89→    upload_sim_params(sim_params)\n    90→    materials = build_material_array()\n    91→    upload_materials(materials)\n    92→\n    93→\n    94→def make_simple_particles(n, mat_id, behavior, pos=None, vel=None,\n    95→                          temp=293.0, health=1.0):\n    96→    \"\"\"Create sorted particle arrays for n particles. sort_indexes = identity.\"\"\"\n    97→    if pos is None:\n    98→        pos = np.zeros((n, 4), dtype=np.float32)\n    99→        pos[:, 3] = 1.0\n   100→    else:\n   101→        pos = np.array(pos, dtype=np.float32).reshape(n, 4)\n   102→\n   103→    if vel is None:\n   104→        vel = np.zeros((n, 4), dtype=np.float32)\n   105→    else:\n   106→        vel = np.array(vel, dtype=np.float32).reshape(n, 4)\n   107→\n   108→    veleval = vel.copy()  # same as vel unless XSPH\n   109→    sph_force = np.zeros((n, 4), dtype=np.float32)\n   110→    mass = np.full(n, MASS, dtype=np.float32)\n   111→    packed_info = np.full(n, MAKE_PACKED(mat_id, behavior), dtype=np.uint32)\n   112→    temperature = np.full(n, temp, dtype=np.float32)\n   113→    hlth = np.full(n, health, dtype=np.float32)\n   114→    sort_idx = np.arange(n, dtype=np.uint32)\n   115→\n   116→    return {\n   117→        \"sorted_position\": cupy.asarray(pos),\n   118→        \"sorted_velocity\": cupy.asarray(vel),\n   119→        \"sorted_veleval\": cupy.asarray(veleval),\n   120→        \"sorted_sph_force\": cupy.asarray(sph_force),\n   121→        \"sorted_mass\": cupy.asarray(mass),\n   122→        \"sorted_packed_info\": cupy.asarray(packed_info),\n   123→        \"sorted_temperature\": cupy.asarray(temperature),\n   124→        \"sorted_health\": cupy.asarray(hlth),\n   125→        \"sort_indexes\": cupy.asarray(sort_idx),\n   126→    }\n   127→\n   128→\n   129→# ===========================================================================\n   130→# Tests\n   131→# ===========================================================================\n   132→\n   133→\n   134→def test_compilation():\n   135→    \"\"\"integrate.cu compiles without errors via CuPy RawModule.\"\"\"\n   136→    module = get_module()\n   137→    kernel = module.get_function(\"K_Integrate\")\n   138→    assert kernel is not None\n   139→    print(\"PASS: test_compilation\")\n   140→\n   141→\n   142→def test_block_size():\n   143→    \"\"\"Block size is 256 per acceptance criteria.\"\"\"\n   144→    assert BLOCK_SIZE == 256\n   145→    print(\"PASS: test_block_size\")\n   146→\n   147→\n   148→def test_static_skip():\n   149→    \"\"\"STATIC particles are skipped -- position and velocity unchanged.\"\"\"\n   150→    setup_params()\n   151→    n = 4\n   152→    pos = np.zeros((n, 4), dtype=np.float32)\n   153→    pos[:, 0] = [0.0, 0.1, 0.2, 0.3]\n   154→    pos[:, 1] = [0.5, 0.5, 0.5, 0.5]\n   155→    pos[:, 3] = 1.0\n   156→    vel = np.zeros((n, 4), dtype=np.float32)\n   157→    vel[:, 1] = [-1.0, -1.0, -1.0, -1.0]  # downward velocity\n   158→\n   159→    d = make_simple_particles(n, STONE, STATIC, pos=pos, vel=vel)\n   160→\n   161→    pos_out, vel_out, color_out = integrate(**d)\n   162→\n   163→    pos_h = pos_out.get()\n   164→    vel_h = vel_out.get()\n   165→\n   166→    # STATIC: position should be unchanged, velocity should be zero\n   167→    for i in range(n):\n   168→        assert abs(pos_h[i, 0] - pos[i, 0]) < 1e-6, f\"STATIC pos.x changed for particle {i}\"\n   169→        assert abs(pos_h[i, 1] - pos[i, 1]) < 1e-6, f\"STATIC pos.y changed for particle {i}\"\n   170→        assert abs(vel_h[i, 0]) < 1e-6, f\"STATIC vel.x non-zero for particle {i}\"\n   171→        assert abs(vel_h[i, 1]) < 1e-6, f\"STATIC vel.y non-zero for particle {i}\"\n   172→        assert abs(vel_h[i, 2]) < 1e-6, f\"STATIC vel.z non-zero for particle {i}\"\n   173→\n   174→    print(\"PASS: test_static_skip\")\n   175→\n   176→\n   177→def test_gravity_freefall():\n   178→    \"\"\"A particle in free fall (no SPH force) accelerates downward correctly.\"\"\"\n   179→    setup_params(gravity=(0.0, -9.8, 0.0))\n   180→    n = 1\n   181→    pos = np.array([[0.0, 0.5, 0.0, 1.0]], dtype=np.float32)\n   182→    vel = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   183→\n   184→    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n   185→    pos_out, vel_out, _ = integrate(**d)\n   186→\n   187→    vel_h = vel_out.get()\n   188→    pos_h = pos_out.get()\n   189→\n   190→    # After 1 step: vel_y = 0 + dt * (-9.8) = -0.0098\n   191→    expected_vy = -9.8 * DT\n   192→    assert abs(vel_h[0, 1] - expected_vy) < 1e-5, (\n   193→        f\"Expected vel_y={expected_vy}, got {vel_h[0, 1]}\"\n   194→    )\n   195→\n   196→    # Position: pos_y = 0.5 + dt * vel_new_y = 0.5 + 0.001 * (-0.0098) = 0.4999902\n   197→    expected_py = 0.5 + DT * expected_vy\n   198→    assert abs(pos_h[0, 1] - expected_py) < 1e-5, (\n   199→        f\"Expected pos_y={expected_py}, got {pos_h[0, 1]}\"\n   200→    )\n   201→\n   202→    print(\"PASS: test_gravity_freefall\")\n   203→\n   204→\n   205→def test_bounce_floor():\n   206→    \"\"\"Particle dropped from height bounces off floor boundary and loses energy.\"\"\"\n   207→    setup_params(restitution=0.3, wall_friction=0.5, gravity=(0.0, -9.8, 0.0))\n   208→\n   209→    n = 1\n   210→    # Place particle at bottom boundary with downward velocity\n   211→    # Position just above floor, velocity pushing through it\n   212→    pos = np.array([[0.0, -0.99, 0.0, 1.0]], dtype=np.float32)\n   213→    vel = np.array([[0.0, -5.0, 0.0, 0.0]], dtype=np.float32)\n   214→\n   215→    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n   216→    pos_out, vel_out, _ = integrate(**d)\n   217→\n   218→    vel_h = vel_out.get()\n   219→    pos_h = pos_out.get()\n   220→\n   221→    # After integration: vel_new_y = -5.0 + 0.001*(-9.8) = -5.0098\n   222→    # pos_new_y = -0.99 + 0.001 * (-5.0098) = -0.9950098  -> penetrates floor at -1.0?\n   223→    # No, -0.9950098 > -1.0 so no penetration yet.\n   224→    # Let's use a bigger timestep or position closer to boundary.\n   225→    # Better test: place particle so that after integration it penetrates.\n   226→\n   227→    # Re-test with position that definitely penetrates\n   228→    pos2 = np.array([[0.0, -0.995, 0.0, 1.0]], dtype=np.float32)\n   229→    vel2 = np.array([[0.0, -10.0, 0.0, 0.0]], dtype=np.float32)\n   230→    d2 = make_simple_particles(n, WATER, FLUID, pos=pos2, vel=vel2)\n   231→    pos_out2, vel_out2, _ = integrate(**d2)\n   232→\n   233→    vel_h2 = vel_out2.get()\n   234→    pos_h2 = pos_out2.get()\n   235→\n   236→    # vel_new_y = -10.0 + 0.001*(-9.8) = -10.0098\n   237→    # pos_new_y = -0.995 + 0.001*(-10.0098) = -1.0050098 -> penetrates!\n   238→    # After boundary: pos_y = -1.0, vel_y = 0.3 * 10.0098 = ~3.003\n   239→\n   240→    assert pos_h2[0, 1] >= -1.0 - 1e-5, (\n   241→        f\"Particle below floor: pos_y={pos_h2[0, 1]}\"\n   242→    )\n   243→    # Velocity should be positive (bounced up) and less than original magnitude\n   244→    assert vel_h2[0, 1] > 0.0, (\n   245→        f\"Expected positive bounce vel_y, got {vel_h2[0, 1]}\"\n   246→    )\n   247→    assert abs(vel_h2[0, 1]) < 10.1, (\n   248→        f\"Bounce vel_y too large (no energy loss): {vel_h2[0, 1]}\"\n   249→    )\n   250→    # With restitution=0.3, bounced vel_y should be about 3.0\n   251→    assert abs(vel_h2[0, 1] - 0.3 * 10.0098) < 0.1, (\n   252→        f\"Expected bounce vel_y ~{0.3*10.0098}, got {vel_h2[0, 1]}\"\n   253→    )\n   254→\n   255→    print(\"PASS: test_bounce_floor\")\n   256→\n   257→\n   258→def test_bounce_multi_step():\n   259→    \"\"\"Particle dropped from height loses energy over multiple bounces.\"\"\"\n   260→    setup_params(restitution=0.3, wall_friction=0.5, gravity=(0.0, -9.8, 0.0))\n   261→\n   262→    n = 1\n   263→    pos_np = np.array([[0.0, 0.5, 0.0, 1.0]], dtype=np.float32)\n   264→    vel_np = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   265→\n   266→    pos_gpu = cupy.asarray(pos_np)\n   267→    vel_gpu = cupy.asarray(vel_np)\n   268→\n   269→    # Run 2000 steps\n   270→    for step in range(2000):\n   271→        d = {\n   272→            \"sorted_position\": pos_gpu,\n   273→            \"sorted_velocity\": vel_gpu,\n   274→            \"sorted_veleval\": vel_gpu.copy(),\n   275→            \"sorted_sph_force\": cupy.zeros((n, 4), dtype=cupy.float32),\n   276→            \"sorted_mass\": cupy.full(n, MASS, dtype=cupy.float32),\n   277→            \"sorted_packed_info\": cupy.full(n, MAKE_PACKED(WATER, FLUID), dtype=cupy.uint32),\n   278→            \"sorted_temperature\": cupy.full(n, 293.0, dtype=cupy.float32),\n   279→            \"sorted_health\": cupy.full(n, 1.0, dtype=cupy.float32),\n   280→            \"sort_indexes\": cupy.arange(n, dtype=cupy.uint32),\n   281→            \"position_out\": pos_gpu,\n   282→            \"velocity_out\": vel_gpu,\n   283→            \"color_out\": cupy.zeros((n, 4), dtype=cupy.float32),\n   284→        }\n   285→        integrate(**d)\n   286→\n   287→    pos_h = pos_gpu.get()\n   288→    vel_h = vel_gpu.get()\n   289→\n   290→    # After many bounces, particle should have settled near bottom\n   291→    assert pos_h[0, 1] >= -1.0 - 1e-5, f\"Below floor: {pos_h[0, 1]}\"\n   292→    # Velocity should be small (energy dissipated through bounces)\n   293→    speed = math.sqrt(vel_h[0, 0]**2 + vel_h[0, 1]**2 + vel_h[0, 2]**2)\n   294→    assert speed < 2.0, f\"Too much residual speed after bouncing: {speed}\"\n   295→    # No NaN\n   296→    assert not np.any(np.isnan(pos_h)), \"NaN in position\"\n   297→    assert not np.any(np.isnan(vel_h)), \"NaN in velocity\"\n   298→\n   299→    print(\"PASS: test_bounce_multi_step\")\n   300→\n   301→\n   302→def test_gas_buoyancy():\n   303→    \"\"\"GAS particles with T > 293K get upward buoyancy force.\"\"\"\n   304→    setup_params(gravity=(0.0, -9.8, 0.0))\n   305→\n   306→    n = 1\n   307→    temp = 500.0  # hot gas\n   308→    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n   309→    vel = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   310→\n   311→    d = make_simple_particles(n, STEAM, GAS, pos=pos, vel=vel, temp=temp)\n   312→    _, vel_out, _ = integrate(**d)\n   313→\n   314→    vel_h = vel_out.get()\n   315→\n   316→    # Expected: accel_y = -9.8 + 0.01 * (500 - 293) * 9.81 = -9.8 + 20.306 = +10.506\n   317→    # vel_new_y = 0 + 0.001 * 10.506 = +0.010506\n   318→    # Then drag: vel_new_y *= (1 - 2.0 * 0.001) = 0.998 -> ~0.01049\n   319→    expected_buoyancy = 0.01 * (500.0 - 293.0) * 9.81\n   320→    expected_accel_y = -9.8 + expected_buoyancy\n   321→    expected_vel_y = DT * expected_accel_y * (1.0 - 2.0 * DT)\n   322→\n   323→    assert vel_h[0, 1] > 0, (\n   324→        f\"Expected positive vel_y for hot gas, got {vel_h[0, 1]}\"\n   325→    )\n   326→    assert abs(vel_h[0, 1] - expected_vel_y) < 1e-4, (\n   327→        f\"Expected vel_y ~{expected_vel_y}, got {vel_h[0, 1]}\"\n   328→    )\n   329→\n   330→    print(\"PASS: test_gas_buoyancy\")\n   331→\n   332→\n   333→def test_gas_drag():\n   334→    \"\"\"GAS drag reduces velocity by (1 - c_drag * dt) factor.\"\"\"\n   335→    setup_params(gravity=(0.0, 0.0, 0.0))  # no gravity for clean test\n   336→\n   337→    n = 1\n   338→    vel = np.array([[10.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   339→    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n   340→\n   341→    d = make_simple_particles(n, STEAM, GAS, pos=pos, vel=vel, temp=293.0)\n   342→    _, vel_out, _ = integrate(**d)\n   343→\n   344→    vel_h = vel_out.get()\n   345→\n   346→    # No SPH force, no gravity, no buoyancy (T=293K):\n   347→    # vel_new = 10.0, then drag: vel *= (1 - 2.0*0.001) = 0.998\n   348→    expected_vx = 10.0 * (1.0 - 2.0 * DT)\n   349→    assert abs(vel_h[0, 0] - expected_vx) < 1e-4, (\n   350→        f\"Expected vx={expected_vx}, got {vel_h[0, 0]}\"\n   351→    )\n   352→\n   353→    print(\"PASS: test_gas_drag\")\n   354→\n   355→\n   356→def test_velocity_clamp():\n   357→    \"\"\"Velocity magnitude is clamped to 50.0.\"\"\"\n   358→    setup_params(gravity=(0.0, 0.0, 0.0))\n   359→\n   360→    n = 1\n   361→    # Give particle huge SPH force that would produce vel > 50\n   362→    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n   363→    vel = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   364→    sph_force = np.array([[0.0, 1e6, 0.0, 0.0]], dtype=np.float32)\n   365→\n   366→    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n   367→    d[\"sorted_sph_force\"] = cupy.asarray(sph_force)\n   368→    _, vel_out, _ = integrate(**d)\n   369→\n   370→    vel_h = vel_out.get()\n   371→    speed = math.sqrt(vel_h[0, 0]**2 + vel_h[0, 1]**2 + vel_h[0, 2]**2)\n   372→\n   373→    assert speed <= 50.0 + 0.1, (\n   374→        f\"Velocity not clamped: speed={speed}\"\n   375→    )\n   376→    assert speed > 49.0, (\n   377→        f\"Velocity too low after clamp: speed={speed}\"\n   378→    )\n   379→\n   380→    print(\"PASS: test_velocity_clamp\")\n   381→\n   382→\n   383→def test_color_computation():\n   384→    \"\"\"Color is computed from material base color, temperature, and health.\"\"\"\n   385→    setup_params()\n   386→\n   387→    # Test 1: room temp, full health -> base material color\n   388→    n = 1\n   389→    d = make_simple_particles(n, WATER, FLUID, temp=293.0, health=1.0)\n   390→    d[\"sorted_position\"] = cupy.array([[0.0, 0.0, 0.0, 1.0]], dtype=cupy.float32)\n   391→    _, _, color_out = integrate(**d)\n   392→    color_h = color_out.get()\n   393→\n   394→    # Water color: (0.2, 0.5, 0.9)\n   395→    assert abs(color_h[0, 0] - 0.2) < 0.02, f\"Water R={color_h[0, 0]}, expected 0.2\"\n   396→    assert abs(color_h[0, 1] - 0.5) < 0.02, f\"Water G={color_h[0, 1]}, expected 0.5\"\n   397→    assert abs(color_h[0, 2] - 0.9) < 0.02, f\"Water B={color_h[0, 2]}, expected 0.9\"\n   398→    assert abs(color_h[0, 3] - 1.0) < 0.01, f\"Alpha={color_h[0, 3]}, expected 1.0\"\n   399→\n   400→    # Test 2: hot particle -> red tint\n   401→    d2 = make_simple_particles(n, WATER, FLUID, temp=1293.0, health=1.0)\n   402→    d2[\"sorted_position\"] = cupy.array([[0.0, 0.0, 0.0, 1.0]], dtype=cupy.float32)\n   403→    _, _, color_out2 = integrate(**d2)\n   404→    color_h2 = color_out2.get()\n   405→\n   406→    # Should be more red than base water\n   407→    assert color_h2[0, 0] > color_h[0, 0], \"Hot particle not redder\"\n   408→    assert color_h2[0, 2] < color_h[0, 2], \"Hot particle blue not reduced\"\n   409→\n   410→    # Test 3: low health -> faded color\n   411→    d3 = make_simple_particles(n, WATER, FLUID, temp=293.0, health=0.5)\n   412→    d3[\"sorted_position\"] = cupy.array([[0.0, 0.0, 0.0, 1.0]], dtype=cupy.float32)\n   413→    _, _, color_out3 = integrate(**d3)\n   414→    color_h3 = color_out3.get()\n   415→\n   416→    # Should be ~half brightness\n   417→    assert abs(color_h3[0, 0] - 0.1) < 0.02, f\"Health fade R={color_h3[0, 0]}\"\n   418→    assert abs(color_h3[0, 1] - 0.25) < 0.02, f\"Health fade G={color_h3[0, 1]}\"\n   419→\n   420→    print(\"PASS: test_color_computation\")\n   421→\n   422→\n   423→def test_sort_indexes_writeback():\n   424→    \"\"\"Results are written to UNSORTED arrays using sort_indexes mapping.\"\"\"\n   425→    setup_params(gravity=(0.0, -9.8, 0.0))\n   426→\n   427→    n = 4\n   428→    # Sorted order: 0,1,2,3 maps to unsorted: 3,1,0,2\n   429→    sort_idx = np.array([3, 1, 0, 2], dtype=np.uint32)\n   430→\n   431→    pos = np.zeros((n, 4), dtype=np.float32)\n   432→    pos[:, 0] = [0.0, 0.1, 0.2, 0.3]\n   433→    pos[:, 1] = 0.5\n   434→    pos[:, 3] = 1.0\n   435→    vel = np.zeros((n, 4), dtype=np.float32)\n   436→\n   437→    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n   438→    d[\"sort_indexes\"] = cupy.asarray(sort_idx)\n   439→\n   440→    out_pos = cupy.zeros((n, 4), dtype=cupy.float32)\n   441→    out_vel = cupy.zeros((n, 4), dtype=cupy.float32)\n   442→    out_col = cupy.zeros((n, 4), dtype=cupy.float32)\n   443→\n   444→    integrate(**d, position_out=out_pos, velocity_out=out_vel, color_out=out_col)\n   445→\n   446→    pos_h = out_pos.get()\n   447→\n   448→    # Sorted particle 0 (x=0.0) -> unsorted slot 3\n   449→    assert abs(pos_h[3, 0] - 0.0) < 1e-4, f\"Sort writeback failed: slot 3 x={pos_h[3, 0]}\"\n   450→    # Sorted particle 1 (x=0.1) -> unsorted slot 1\n   451→    assert abs(pos_h[1, 0] - 0.1) < 1e-4, f\"Sort writeback failed: slot 1 x={pos_h[1, 0]}\"\n   452→    # Sorted particle 2 (x=0.2) -> unsorted slot 0\n   453→    assert abs(pos_h[0, 0] - 0.2) < 1e-4, f\"Sort writeback failed: slot 0 x={pos_h[0, 0]}\"\n   454→    # Sorted particle 3 (x=0.3) -> unsorted slot 2\n   455→    assert abs(pos_h[2, 0] - 0.3) < 1e-4, f\"Sort writeback failed: slot 2 x={pos_h[2, 0]}\"\n   456→\n   457→    print(\"PASS: test_sort_indexes_writeback\")\n   458→\n   459→\n   460→def test_boundary_all_walls():\n   461→    \"\"\"Particles are contained by all 6 walls of the box.\"\"\"\n   462→    setup_params(gravity=(0.0, 0.0, 0.0), restitution=0.3, wall_friction=0.5)\n   463→\n   464→    n = 6\n   465→    # Each particle aimed at a different wall\n   466→    pos = np.array([\n   467→        [-0.999, 0.0, 0.0, 1.0],  # -> -X wall\n   468→        [ 0.999, 0.0, 0.0, 1.0],  # -> +X wall\n   469→        [0.0, -0.999, 0.0, 1.0],  # -> -Y wall\n   470→        [0.0,  0.999, 0.0, 1.0],  # -> +Y wall\n   471→        [0.0, 0.0, -0.999, 1.0],  # -> -Z wall\n   472→        [0.0, 0.0,  0.999, 1.0],  # -> +Z wall\n   473→    ], dtype=np.float32)\n   474→\n   475→    vel = np.array([\n   476→        [-20.0, 0.0, 0.0, 0.0],\n   477→        [ 20.0, 0.0, 0.0, 0.0],\n   478→        [0.0, -20.0, 0.0, 0.0],\n   479→        [0.0,  20.0, 0.0, 0.0],\n   480→        [0.0, 0.0, -20.0, 0.0],\n   481→        [0.0, 0.0,  20.0, 0.0],\n   482→    ], dtype=np.float32)\n   483→\n   484→    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n   485→    pos_out, vel_out, _ = integrate(**d)\n   486→\n   487→    pos_h = pos_out.get()\n   488→    vel_h = vel_out.get()\n   489→\n   490→    for i in range(n):\n   491→        assert pos_h[i, 0] >= -1.0 - 1e-5, f\"Particle {i} escaped -X: {pos_h[i, 0]}\"\n   492→        assert pos_h[i, 0] <=  1.0 + 1e-5, f\"Particle {i} escaped +X: {pos_h[i, 0]}\"\n   493→        assert pos_h[i, 1] >= -1.0 - 1e-5, f\"Particle {i} escaped -Y: {pos_h[i, 1]}\"\n   494→        assert pos_h[i, 1] <=  1.0 + 1e-5, f\"Particle {i} escaped +Y: {pos_h[i, 1]}\"\n   495→        assert pos_h[i, 2] >= -1.0 - 1e-5, f\"Particle {i} escaped -Z: {pos_h[i, 2]}\"\n   496→        assert pos_h[i, 2] <=  1.0 + 1e-5, f\"Particle {i} escaped +Z: {pos_h[i, 2]}\"\n   497→\n   498→    # Verify velocity reflection happened (direction reversed)\n   499→    assert vel_h[0, 0] > 0, f\"Particle 0 should have bounced +X, got vx={vel_h[0, 0]}\"\n   500→    assert vel_h[1, 0] < 0, f\"Particle 1 should have bounced -X, got vx={vel_h[1, 0]}\"\n   501→    assert vel_h[2, 1] > 0, f\"Particle 2 should have bounced +Y, got vy={vel_h[2, 1]}\"\n   502→    assert vel_h[3, 1] < 0, f\"Particle 3 should have bounced -Y, got vy={vel_h[3, 1]}\"\n   503→    assert vel_h[4, 2] > 0, f\"Particle 4 should have bounced +Z, got vz={vel_h[4, 2]}\"\n   504→    assert vel_h[5, 2] < 0, f\"Particle 5 should have bounced -Z, got vz={vel_h[5, 2]}\"\n   505→\n   506→    print(\"PASS: test_boundary_all_walls\")\n   507→\n   508→\n   509→def test_coulomb_friction():\n   510→    \"\"\"Wall collision applies Coulomb friction to tangential velocity.\"\"\"\n   511→    setup_params(gravity=(0.0, 0.0, 0.0), restitution=0.3, wall_friction=0.5)\n   512→\n   513→    n = 1\n   514→    # Particle hitting floor with both normal and tangential velocity\n   515→    pos = np.array([[0.5, -0.999, 0.0, 1.0]], dtype=np.float32)\n   516→    vel = np.array([[5.0, -10.0, 0.0, 0.0]], dtype=np.float32)\n   517→\n   518→    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n   519→    _, vel_out, _ = integrate(**d)\n   520→\n   521→    vel_h = vel_out.get()\n   522→\n   523→    # Normal: vy reflected with restitution -> ~0.3 * 10.0 = 3.0 upward\n   524→    assert vel_h[0, 1] > 0, f\"Expected upward bounce, got vy={vel_h[0, 1]}\"\n   525→\n   526→    # Tangential: vx should be reduced by friction\n   527→    # friction_impulse = mu_wall * |vn| = 0.5 * 10.0 = 5.0\n   528→    # reduction = min(5.0 / |vt|, 1.0) = min(5.0/5.0, 1.0) = 1.0\n   529→    # vx = 5.0 * (1 - 1.0) = 0.0\n   530→    assert abs(vel_h[0, 0]) < 0.5, (\n   531→        f\"Expected vx ~0 after friction, got {vel_h[0, 0]}\"\n   532→    )\n   533→\n   534→    print(\"PASS: test_coulomb_friction\")\n   535→\n   536→\n   537→def test_xsph_position_update():\n   538→    \"\"\"FLUID particles use XSPH-corrected velocity for position advection.\"\"\"\n   539→    setup_params(gravity=(0.0, 0.0, 0.0))\n   540→\n   541→    n = 1\n   542→    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n   543→    vel = np.array([[1.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   544→    # veleval has XSPH correction: vel + eps*xsph_sum\n   545→    veleval = np.array([[1.5, 0.0, 0.0, 0.0]], dtype=np.float32)  # xsph added 0.5\n   546→\n   547→    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n   548→    d[\"sorted_veleval\"] = cupy.asarray(veleval)\n   549→    pos_out, vel_out, _ = integrate(**d)\n   550→\n   551→    pos_h = pos_out.get()\n   552→    vel_h = vel_out.get()\n   553→\n   554→    # vel_new = 1.0 (no force)\n   555→    # xsph_correction = veleval - vel = 0.5\n   556→    # pos_new = 0 + dt * (vel_new + xsph_correction) = 0 + 0.001 * 1.5 = 0.0015\n   557→    expected_px = DT * (1.0 + 0.5)\n   558→    assert abs(pos_h[0, 0] - expected_px) < 1e-5, (\n   559→        f\"Expected pos_x={expected_px}, got {pos_h[0, 0]}\"\n   560→    )\n   561→\n   562→    # Non-FLUID should NOT use XSPH\n   563→    d2 = make_simple_particles(n, SAND, GRANULAR, pos=pos, vel=vel)\n   564→    d2[\"sorted_veleval\"] = cupy.asarray(veleval)\n   565→    pos_out2, _, _ = integrate(**d2)\n   566→    pos_h2 = pos_out2.get()\n   567→\n   568→    expected_px2 = DT * 1.0  # no XSPH\n   569→    assert abs(pos_h2[0, 0] - expected_px2) < 1e-5, (\n   570→        f\"GRANULAR should not use XSPH: expected {expected_px2}, got {pos_h2[0, 0]}\"\n   571→    )\n   572→\n   573→    print(\"PASS: test_xsph_position_update\")\n   574→\n   575→\n   576→def test_water_pool_no_nan():\n   577→    \"\"\"10K water particles in box settle without NaN after 1000 steps.\n   578→\n   579→    This is a simplified test without the full neighbor pipeline --\n   580→    we just check that integration alone doesn't produce NaN with\n   581→    typical SPH-like forces.\n   582→    \"\"\"\n   583→    setup_params(gravity=(0.0, -9.8, 0.0))\n   584→\n   585→    n = 10000\n   586→    rng = np.random.RandomState(42)\n   587→\n   588→    # Particles in a cube near the top, falling\n   589→    pos = np.zeros((n, 4), dtype=np.float32)\n   590→    pos[:, 0] = rng.uniform(-0.5, 0.5, n)\n   591→    pos[:, 1] = rng.uniform(0.0, 0.8, n)\n   592→    pos[:, 2] = rng.uniform(-0.5, 0.5, n)\n   593→    pos[:, 3] = 1.0\n   594→\n   595→    vel = np.zeros((n, 4), dtype=np.float32)\n   596→\n   597→    pos_gpu = cupy.asarray(pos)\n   598→    vel_gpu = cupy.asarray(vel)\n   599→    veleval_gpu = vel_gpu.copy()\n   600→    force_gpu = cupy.zeros((n, 4), dtype=cupy.float32)\n   601→    mass_gpu = cupy.full(n, MASS, dtype=cupy.float32)\n   602→    pi_gpu = cupy.full(n, MAKE_PACKED(WATER, FLUID), dtype=cupy.uint32)\n   603→    temp_gpu = cupy.full(n, 293.0, dtype=cupy.float32)\n   604→    health_gpu = cupy.full(n, 1.0, dtype=cupy.float32)\n   605→    sort_idx = cupy.arange(n, dtype=cupy.uint32)\n   606→    color_gpu = cupy.zeros((n, 4), dtype=cupy.float32)\n   607→\n   608→    for step in range(1000):\n   609→        # Apply small random SPH-like forces for realism\n   610→        if step % 10 == 0:\n   611→            force_gpu[:, :3] = cupy.random.uniform(-0.1, 0.1, (n, 3), dtype=cupy.float32)\n   612→\n   613→        integrate(\n   614→            sorted_position=pos_gpu,\n   615→            sorted_velocity=vel_gpu,\n   616→            sorted_veleval=veleval_gpu,\n   617→            sorted_sph_force=force_gpu,\n   618→            sorted_mass=mass_gpu,\n   619→            sorted_packed_info=pi_gpu,\n   620→            sorted_temperature=temp_gpu,\n   621→            sorted_health=health_gpu,\n   622→            sort_indexes=sort_idx,\n   623→            position_out=pos_gpu,\n   624→            velocity_out=vel_gpu,\n   625→            color_out=color_gpu,\n   626→        )\n   627→        veleval_gpu[:] = vel_gpu\n   628→\n   629→    pos_h = pos_gpu.get()\n   630→    vel_h = vel_gpu.get()\n   631→\n   632→    assert not np.any(np.isnan(pos_h)), \"NaN found in positions after 1000 steps\"\n   633→    assert not np.any(np.isnan(vel_h)), \"NaN found in velocities after 1000 steps\"\n   634→\n   635→    # All particles should be within boundaries\n   636→    assert np.all(pos_h[:, 0] >= -1.0 - 1e-4), \"Particles escaped -X\"\n   637→    assert np.all(pos_h[:, 0] <=  1.0 + 1e-4), \"Particles escaped +X\"\n   638→    assert np.all(pos_h[:, 1] >= -1.0 - 1e-4), \"Particles escaped -Y\"\n   639→    assert np.all(pos_h[:, 1] <=  1.0 + 1e-4), \"Particles escaped +Y\"\n   640→    assert np.all(pos_h[:, 2] >= -1.0 - 1e-4), \"Particles escaped -Z\"\n   641→    assert np.all(pos_h[:, 2] <=  1.0 + 1e-4), \"Particles escaped +Z\"\n   642→\n   643→    # Most particles should have settled near the bottom\n   644→    mean_y = np.mean(pos_h[:, 1])\n   645→    assert mean_y < 0.0, f\"Mean Y should be negative (settled), got {mean_y}\"\n   646→\n   647→    print(\"PASS: test_water_pool_no_nan\")\n   648→\n   649→\n   650→def test_500k_stress():\n   651→    \"\"\"500K particles run through integrate without errors.\"\"\"\n   652→    setup_params()\n   653→\n   654→    n = 500_000\n   655→    rng = np.random.RandomState(123)\n   656→\n   657→    pos = np.zeros((n, 4), dtype=np.float32)\n   658→    pos[:, :3] = rng.uniform(-0.9, 0.9, (n, 3))\n   659→    pos[:, 3] = 1.0\n   660→    vel = np.zeros((n, 4), dtype=np.float32)\n   661→    vel[:, :3] = rng.uniform(-1.0, 1.0, (n, 3))\n   662→\n   663→    # Mix of behaviors\n   664→    packed = np.zeros(n, dtype=np.uint32)\n   665→    packed[:200000] = MAKE_PACKED(WATER, FLUID)\n   666→    packed[200000:400000] = MAKE_PACKED(SAND, GRANULAR)\n   667→    packed[400000:480000] = MAKE_PACKED(STEAM, GAS)\n   668→    packed[480000:] = MAKE_PACKED(STONE, STATIC)\n   669→\n   670→    d = {\n   671→        \"sorted_position\": cupy.asarray(pos),\n   672→        \"sorted_velocity\": cupy.asarray(vel),\n   673→        \"sorted_veleval\": cupy.asarray(vel),\n   674→        \"sorted_sph_force\": cupy.zeros((n, 4), dtype=cupy.float32),\n   675→        \"sorted_mass\": cupy.full(n, MASS, dtype=cupy.float32),\n   676→        \"sorted_packed_info\": cupy.asarray(packed),\n   677→        \"sorted_temperature\": cupy.full(n, 293.0, dtype=cupy.float32),\n   678→        \"sorted_health\": cupy.full(n, 1.0, dtype=cupy.float32),\n   679→        \"sort_indexes\": cupy.arange(n, dtype=cupy.uint32),\n   680→    }\n   681→\n   682→    pos_out, vel_out, color_out = integrate(**d)\n   683→\n   684→    # Synchronize to catch any CUDA errors\n   685→    cupy.cuda.Device().synchronize()\n   686→\n   687→    pos_h = pos_out.get()\n   688→    vel_h = vel_out.get()\n   689→    color_h = color_out.get()\n   690→\n   691→    assert not np.any(np.isnan(pos_h)), \"NaN in positions (500K)\"\n   692→    assert not np.any(np.isnan(vel_h)), \"NaN in velocities (500K)\"\n   693→    assert not np.any(np.isnan(color_h)), \"NaN in colors (500K)\"\n   694→\n   695→    # All particles should be within boundaries\n   696→    assert np.all(pos_h[:, 0] >= -1.0 - 1e-4), \"500K: particles escaped -X\"\n   697→    assert np.all(pos_h[:, 0] <=  1.0 + 1e-4), \"500K: particles escaped +X\"\n   698→    assert np.all(pos_h[:, 1] >= -1.0 - 1e-4), \"500K: particles escaped -Y\"\n   699→    assert np.all(pos_h[:, 1] <=  1.0 + 1e-4), \"500K: particles escaped +Y\"\n   700→\n   701→    # STATIC particles should keep their original positions\n   702→    static_pos_orig = pos[480000:, :3]\n   703→    static_pos_new = pos_h[480000:, :3]\n   704→    assert np.allclose(static_pos_orig, static_pos_new, atol=1e-5), (\n   705→        \"STATIC particle positions changed!\"\n   706→    )\n   707→\n   708→    print(\"PASS: test_500k_stress\")\n   709→\n   710→\n   711→# ===========================================================================\n   712→# Main\n   713→# ===========================================================================\n   714→\n   715→if __name__ == \"__main__\":\n   716→    tests = [\n   717→        test_compilation,\n   718→        test_block_size,\n   719→        test_static_skip,\n   720→        test_gravity_freefall,\n   721→        test_bounce_floor,\n   722→        test_bounce_multi_step,\n   723→        test_gas_buoyancy,\n   724→        test_gas_drag,\n   725→        test_velocity_clamp,\n   726→        test_color_computation,\n   727→        test_sort_indexes_writeback,\n   728→        test_boundary_all_walls,\n   729→        test_coulomb_friction,\n   730→        test_xsph_position_update,\n   731→        test_water_pool_no_nan,\n   732→        test_500k_stress,\n   733→    ]\n   734→\n   735→    passed = 0\n   736→    failed = 0\n   737→    for test in tests:\n   738→        try:\n   739→            test()\n   740→            passed += 1\n   741→        except Exception as e:\n   742→            print(f\"FAIL: {test.__name__}: {e}\")\n   743→            import traceback\n   744→            traceback.print_exc()\n   745→            failed += 1\n   746→\n   747→    print(f\"\\n{'='*60}\")\n   748→    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)}\")\n   749→    if failed > 0:\n   750→        sys.exit(1)\n   751→    print(\"All tests passed!\")\n   752→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8366e700-f36a-49ec-85fd-f97c4934f324","uuid":"b6fba16b-dc5f-472b-a6ef-0f8dabef5d84","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_integrate.py","content":"\"\"\"Integration test for integrate.py -- K_Integrate kernel.\n\nAcceptance criteria:\n  - Symplectic Euler: vel_new = vel + dt * accel; pos_new uses XSPH for FLUID\n  - Impulse SDF boundary: 6 planes of box (-1,-1,-1) to (1,1,1), restitution=0.3,\n    Coulomb friction mu_wall=0.5\n  - STATIC particles skipped (position unchanged)\n  - GAS buoyancy: beta=0.01 * (T-293) * (0, 9.81, 0)\n  - GAS drag: vel *= (1 - 2.0 * dt)\n  - Velocity clamp at 50.0\n  - Color from c_materials, tinted red for T>293K, faded by health\n  - Writeback to UNSORTED arrays via sort_indexes\n  - Bounce test: particle dropped from height bounces and loses energy\n  - 10K water pool test: no NaN after 1000 steps\n  - Block size = 256, 500K stress test\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport os\nimport sys\n\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom step1 import (\n    SIM_PARAMS_DTYPE,\n    build_sim_params,\n)\nfrom materials import (\n    FLUID,\n    GRANULAR,\n    GAS,\n    STATIC,\n    WATER,\n    SAND,\n    STEAM,\n    STONE,\n    build_material_array,\n)\nfrom integrate import (\n    BLOCK_SIZE,\n    get_module,\n    integrate,\n    upload_materials,\n    upload_sim_params,\n)\n\n# ---------------------------------------------------------------------------\n# Constants\n# ---------------------------------------------------------------------------\n\nH = 0.04\nSPACING = 0.02\nRHO0 = 1000.0\nMASS = RHO0 * SPACING**3  # 0.008 kg\nDT = 0.001\n\n# packed_info helpers\ndef MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n\ndef SET_SLEEPING(p: int) -> int:\n    return p | 0x400\n\n# ---------------------------------------------------------------------------\n# Helper: upload params for all tests\n# ---------------------------------------------------------------------------\n\ndef setup_params(dt=DT, restitution=0.3, wall_friction=0.5,\n                 gravity=(0.0, -9.8, 0.0)):\n    \"\"\"Upload SimParams and materials to integrate module's constant memory.\"\"\"\n    sim_params = build_sim_params(\n        smoothing_length=H,\n        particle_mass=MASS,\n        particle_spacing=SPACING,\n        gravity=gravity,\n        dt=dt,\n        restitution=restitution,\n        wall_friction=wall_friction,\n        world_min=(-1.0, -1.0, -1.0),\n        world_max=(1.0, 1.0, 1.0),\n    )\n    upload_sim_params(sim_params)\n    materials = build_material_array()\n    upload_materials(materials)\n\n\ndef make_simple_particles(n, mat_id, behavior, pos=None, vel=None,\n                          temp=293.0, health=1.0):\n    \"\"\"Create sorted particle arrays for n particles. sort_indexes = identity.\"\"\"\n    if pos is None:\n        pos = np.zeros((n, 4), dtype=np.float32)\n        pos[:, 3] = 1.0\n    else:\n        pos = np.array(pos, dtype=np.float32).reshape(n, 4)\n\n    if vel is None:\n        vel = np.zeros((n, 4), dtype=np.float32)\n    else:\n        vel = np.array(vel, dtype=np.float32).reshape(n, 4)\n\n    veleval = vel.copy()  # same as vel unless XSPH\n    sph_force = np.zeros((n, 4), dtype=np.float32)\n    mass = np.full(n, MASS, dtype=np.float32)\n    packed_info = np.full(n, MAKE_PACKED(mat_id, behavior), dtype=np.uint32)\n    temperature = np.full(n, temp, dtype=np.float32)\n    hlth = np.full(n, health, dtype=np.float32)\n    sort_idx = np.arange(n, dtype=np.uint32)\n\n    return {\n        \"sorted_position\": cupy.asarray(pos),\n        \"sorted_velocity\": cupy.asarray(vel),\n        \"sorted_veleval\": cupy.asarray(veleval),\n        \"sorted_sph_force\": cupy.asarray(sph_force),\n        \"sorted_mass\": cupy.asarray(mass),\n        \"sorted_packed_info\": cupy.asarray(packed_info),\n        \"sorted_temperature\": cupy.asarray(temperature),\n        \"sorted_health\": cupy.asarray(hlth),\n        \"sort_indexes\": cupy.asarray(sort_idx),\n    }\n\n\n# ===========================================================================\n# Tests\n# ===========================================================================\n\n\ndef test_compilation():\n    \"\"\"integrate.cu compiles without errors via CuPy RawModule.\"\"\"\n    module = get_module()\n    kernel = module.get_function(\"K_Integrate\")\n    assert kernel is not None\n    print(\"PASS: test_compilation\")\n\n\ndef test_block_size():\n    \"\"\"Block size is 256 per acceptance criteria.\"\"\"\n    assert BLOCK_SIZE == 256\n    print(\"PASS: test_block_size\")\n\n\ndef test_static_skip():\n    \"\"\"STATIC particles are skipped -- position and velocity unchanged.\"\"\"\n    setup_params()\n    n = 4\n    pos = np.zeros((n, 4), dtype=np.float32)\n    pos[:, 0] = [0.0, 0.1, 0.2, 0.3]\n    pos[:, 1] = [0.5, 0.5, 0.5, 0.5]\n    pos[:, 3] = 1.0\n    vel = np.zeros((n, 4), dtype=np.float32)\n    vel[:, 1] = [-1.0, -1.0, -1.0, -1.0]  # downward velocity\n\n    d = make_simple_particles(n, STONE, STATIC, pos=pos, vel=vel)\n\n    pos_out, vel_out, color_out = integrate(**d)\n\n    pos_h = pos_out.get()\n    vel_h = vel_out.get()\n\n    # STATIC: position should be unchanged, velocity should be zero\n    for i in range(n):\n        assert abs(pos_h[i, 0] - pos[i, 0]) < 1e-6, f\"STATIC pos.x changed for particle {i}\"\n        assert abs(pos_h[i, 1] - pos[i, 1]) < 1e-6, f\"STATIC pos.y changed for particle {i}\"\n        assert abs(vel_h[i, 0]) < 1e-6, f\"STATIC vel.x non-zero for particle {i}\"\n        assert abs(vel_h[i, 1]) < 1e-6, f\"STATIC vel.y non-zero for particle {i}\"\n        assert abs(vel_h[i, 2]) < 1e-6, f\"STATIC vel.z non-zero for particle {i}\"\n\n    print(\"PASS: test_static_skip\")\n\n\ndef test_gravity_freefall():\n    \"\"\"A particle in free fall (no SPH force) accelerates downward correctly.\"\"\"\n    setup_params(gravity=(0.0, -9.8, 0.0))\n    n = 1\n    pos = np.array([[0.0, 0.5, 0.0, 1.0]], dtype=np.float32)\n    vel = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n\n    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n    pos_out, vel_out, _ = integrate(**d)\n\n    vel_h = vel_out.get()\n    pos_h = pos_out.get()\n\n    # After 1 step: vel_y = 0 + dt * (-9.8) = -0.0098\n    expected_vy = -9.8 * DT\n    assert abs(vel_h[0, 1] - expected_vy) < 1e-5, (\n        f\"Expected vel_y={expected_vy}, got {vel_h[0, 1]}\"\n    )\n\n    # Position: pos_y = 0.5 + dt * vel_new_y = 0.5 + 0.001 * (-0.0098) = 0.4999902\n    expected_py = 0.5 + DT * expected_vy\n    assert abs(pos_h[0, 1] - expected_py) < 1e-5, (\n        f\"Expected pos_y={expected_py}, got {pos_h[0, 1]}\"\n    )\n\n    print(\"PASS: test_gravity_freefall\")\n\n\ndef test_bounce_floor():\n    \"\"\"Particle dropped from height bounces off floor boundary and loses energy.\"\"\"\n    setup_params(restitution=0.3, wall_friction=0.5, gravity=(0.0, -9.8, 0.0))\n\n    n = 1\n    # Place particle at bottom boundary with downward velocity\n    # Position just above floor, velocity pushing through it\n    pos = np.array([[0.0, -0.99, 0.0, 1.0]], dtype=np.float32)\n    vel = np.array([[0.0, -5.0, 0.0, 0.0]], dtype=np.float32)\n\n    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n    pos_out, vel_out, _ = integrate(**d)\n\n    vel_h = vel_out.get()\n    pos_h = pos_out.get()\n\n    # After integration: vel_new_y = -5.0 + 0.001*(-9.8) = -5.0098\n    # pos_new_y = -0.99 + 0.001 * (-5.0098) = -0.9950098  -> penetrates floor at -1.0?\n    # No, -0.9950098 > -1.0 so no penetration yet.\n    # Let's use a bigger timestep or position closer to boundary.\n    # Better test: place particle so that after integration it penetrates.\n\n    # Re-test with position that definitely penetrates\n    pos2 = np.array([[0.0, -0.995, 0.0, 1.0]], dtype=np.float32)\n    vel2 = np.array([[0.0, -10.0, 0.0, 0.0]], dtype=np.float32)\n    d2 = make_simple_particles(n, WATER, FLUID, pos=pos2, vel=vel2)\n    pos_out2, vel_out2, _ = integrate(**d2)\n\n    vel_h2 = vel_out2.get()\n    pos_h2 = pos_out2.get()\n\n    # vel_new_y = -10.0 + 0.001*(-9.8) = -10.0098\n    # pos_new_y = -0.995 + 0.001*(-10.0098) = -1.0050098 -> penetrates!\n    # After boundary: pos_y = -1.0, vel_y = 0.3 * 10.0098 = ~3.003\n\n    assert pos_h2[0, 1] >= -1.0 - 1e-5, (\n        f\"Particle below floor: pos_y={pos_h2[0, 1]}\"\n    )\n    # Velocity should be positive (bounced up) and less than original magnitude\n    assert vel_h2[0, 1] > 0.0, (\n        f\"Expected positive bounce vel_y, got {vel_h2[0, 1]}\"\n    )\n    assert abs(vel_h2[0, 1]) < 10.1, (\n        f\"Bounce vel_y too large (no energy loss): {vel_h2[0, 1]}\"\n    )\n    # With restitution=0.3, bounced vel_y should be about 3.0\n    assert abs(vel_h2[0, 1] - 0.3 * 10.0098) < 0.1, (\n        f\"Expected bounce vel_y ~{0.3*10.0098}, got {vel_h2[0, 1]}\"\n    )\n\n    print(\"PASS: test_bounce_floor\")\n\n\ndef test_bounce_multi_step():\n    \"\"\"Particle dropped from height loses energy over multiple bounces.\"\"\"\n    setup_params(restitution=0.3, wall_friction=0.5, gravity=(0.0, -9.8, 0.0))\n\n    n = 1\n    pos_np = np.array([[0.0, 0.5, 0.0, 1.0]], dtype=np.float32)\n    vel_np = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n\n    pos_gpu = cupy.asarray(pos_np)\n    vel_gpu = cupy.asarray(vel_np)\n\n    # Run 2000 steps\n    for step in range(2000):\n        d = {\n            \"sorted_position\": pos_gpu,\n            \"sorted_velocity\": vel_gpu,\n            \"sorted_veleval\": vel_gpu.copy(),\n            \"sorted_sph_force\": cupy.zeros((n, 4), dtype=cupy.float32),\n            \"sorted_mass\": cupy.full(n, MASS, dtype=cupy.float32),\n            \"sorted_packed_info\": cupy.full(n, MAKE_PACKED(WATER, FLUID), dtype=cupy.uint32),\n            \"sorted_temperature\": cupy.full(n, 293.0, dtype=cupy.float32),\n            \"sorted_health\": cupy.full(n, 1.0, dtype=cupy.float32),\n            \"sort_indexes\": cupy.arange(n, dtype=cupy.uint32),\n            \"position_out\": pos_gpu,\n            \"velocity_out\": vel_gpu,\n            \"color_out\": cupy.zeros((n, 4), dtype=cupy.float32),\n        }\n        integrate(**d)\n\n    pos_h = pos_gpu.get()\n    vel_h = vel_gpu.get()\n\n    # After many bounces, particle should have settled near bottom\n    assert pos_h[0, 1] >= -1.0 - 1e-5, f\"Below floor: {pos_h[0, 1]}\"\n    # Velocity should be small (energy dissipated through bounces)\n    speed = math.sqrt(vel_h[0, 0]**2 + vel_h[0, 1]**2 + vel_h[0, 2]**2)\n    assert speed < 2.0, f\"Too much residual speed after bouncing: {speed}\"\n    # No NaN\n    assert not np.any(np.isnan(pos_h)), \"NaN in position\"\n    assert not np.any(np.isnan(vel_h)), \"NaN in velocity\"\n\n    print(\"PASS: test_bounce_multi_step\")\n\n\ndef test_gas_buoyancy():\n    \"\"\"GAS particles with T > 293K get upward buoyancy force.\"\"\"\n    setup_params(gravity=(0.0, -9.8, 0.0))\n\n    n = 1\n    temp = 500.0  # hot gas\n    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n    vel = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n\n    d = make_simple_particles(n, STEAM, GAS, pos=pos, vel=vel, temp=temp)\n    _, vel_out, _ = integrate(**d)\n\n    vel_h = vel_out.get()\n\n    # Expected: accel_y = -9.8 + 0.01 * (500 - 293) * 9.81 = -9.8 + 20.306 = +10.506\n    # vel_new_y = 0 + 0.001 * 10.506 = +0.010506\n    # Then drag: vel_new_y *= (1 - 2.0 * 0.001) = 0.998 -> ~0.01049\n    expected_buoyancy = 0.01 * (500.0 - 293.0) * 9.81\n    expected_accel_y = -9.8 + expected_buoyancy\n    expected_vel_y = DT * expected_accel_y * (1.0 - 2.0 * DT)\n\n    assert vel_h[0, 1] > 0, (\n        f\"Expected positive vel_y for hot gas, got {vel_h[0, 1]}\"\n    )\n    assert abs(vel_h[0, 1] - expected_vel_y) < 1e-4, (\n        f\"Expected vel_y ~{expected_vel_y}, got {vel_h[0, 1]}\"\n    )\n\n    print(\"PASS: test_gas_buoyancy\")\n\n\ndef test_gas_drag():\n    \"\"\"GAS drag reduces velocity by (1 - c_drag * dt) factor.\"\"\"\n    setup_params(gravity=(0.0, 0.0, 0.0))  # no gravity for clean test\n\n    n = 1\n    vel = np.array([[10.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n\n    d = make_simple_particles(n, STEAM, GAS, pos=pos, vel=vel, temp=293.0)\n    _, vel_out, _ = integrate(**d)\n\n    vel_h = vel_out.get()\n\n    # No SPH force, no gravity, no buoyancy (T=293K):\n    # vel_new = 10.0, then drag: vel *= (1 - 2.0*0.001) = 0.998\n    expected_vx = 10.0 * (1.0 - 2.0 * DT)\n    assert abs(vel_h[0, 0] - expected_vx) < 1e-4, (\n        f\"Expected vx={expected_vx}, got {vel_h[0, 0]}\"\n    )\n\n    print(\"PASS: test_gas_drag\")\n\n\ndef test_velocity_clamp():\n    \"\"\"Velocity magnitude is clamped to 50.0.\"\"\"\n    setup_params(gravity=(0.0, 0.0, 0.0))\n\n    n = 1\n    # Give particle huge SPH force that would produce vel > 50\n    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n    vel = np.array([[0.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n    sph_force = np.array([[0.0, 1e6, 0.0, 0.0]], dtype=np.float32)\n\n    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n    d[\"sorted_sph_force\"] = cupy.asarray(sph_force)\n    _, vel_out, _ = integrate(**d)\n\n    vel_h = vel_out.get()\n    speed = math.sqrt(vel_h[0, 0]**2 + vel_h[0, 1]**2 + vel_h[0, 2]**2)\n\n    assert speed <= 50.0 + 0.1, (\n        f\"Velocity not clamped: speed={speed}\"\n    )\n    assert speed > 49.0, (\n        f\"Velocity too low after clamp: speed={speed}\"\n    )\n\n    print(\"PASS: test_velocity_clamp\")\n\n\ndef test_color_computation():\n    \"\"\"Color is computed from material base color, temperature, and health.\"\"\"\n    setup_params()\n\n    # Test 1: room temp, full health -> base material color\n    n = 1\n    d = make_simple_particles(n, WATER, FLUID, temp=293.0, health=1.0)\n    d[\"sorted_position\"] = cupy.array([[0.0, 0.0, 0.0, 1.0]], dtype=cupy.float32)\n    _, _, color_out = integrate(**d)\n    color_h = color_out.get()\n\n    # Water color: (0.2, 0.5, 0.9)\n    assert abs(color_h[0, 0] - 0.2) < 0.02, f\"Water R={color_h[0, 0]}, expected 0.2\"\n    assert abs(color_h[0, 1] - 0.5) < 0.02, f\"Water G={color_h[0, 1]}, expected 0.5\"\n    assert abs(color_h[0, 2] - 0.9) < 0.02, f\"Water B={color_h[0, 2]}, expected 0.9\"\n    assert abs(color_h[0, 3] - 1.0) < 0.01, f\"Alpha={color_h[0, 3]}, expected 1.0\"\n\n    # Test 2: hot particle -> red tint\n    d2 = make_simple_particles(n, WATER, FLUID, temp=1293.0, health=1.0)\n    d2[\"sorted_position\"] = cupy.array([[0.0, 0.0, 0.0, 1.0]], dtype=cupy.float32)\n    _, _, color_out2 = integrate(**d2)\n    color_h2 = color_out2.get()\n\n    # Should be more red than base water\n    assert color_h2[0, 0] > color_h[0, 0], \"Hot particle not redder\"\n    assert color_h2[0, 2] < color_h[0, 2], \"Hot particle blue not reduced\"\n\n    # Test 3: low health -> faded color\n    d3 = make_simple_particles(n, WATER, FLUID, temp=293.0, health=0.5)\n    d3[\"sorted_position\"] = cupy.array([[0.0, 0.0, 0.0, 1.0]], dtype=cupy.float32)\n    _, _, color_out3 = integrate(**d3)\n    color_h3 = color_out3.get()\n\n    # Should be ~half brightness\n    assert abs(color_h3[0, 0] - 0.1) < 0.02, f\"Health fade R={color_h3[0, 0]}\"\n    assert abs(color_h3[0, 1] - 0.25) < 0.02, f\"Health fade G={color_h3[0, 1]}\"\n\n    print(\"PASS: test_color_computation\")\n\n\ndef test_sort_indexes_writeback():\n    \"\"\"Results are written to UNSORTED arrays using sort_indexes mapping.\"\"\"\n    setup_params(gravity=(0.0, -9.8, 0.0))\n\n    n = 4\n    # Sorted order: 0,1,2,3 maps to unsorted: 3,1,0,2\n    sort_idx = np.array([3, 1, 0, 2], dtype=np.uint32)\n\n    pos = np.zeros((n, 4), dtype=np.float32)\n    pos[:, 0] = [0.0, 0.1, 0.2, 0.3]\n    pos[:, 1] = 0.5\n    pos[:, 3] = 1.0\n    vel = np.zeros((n, 4), dtype=np.float32)\n\n    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n    d[\"sort_indexes\"] = cupy.asarray(sort_idx)\n\n    out_pos = cupy.zeros((n, 4), dtype=cupy.float32)\n    out_vel = cupy.zeros((n, 4), dtype=cupy.float32)\n    out_col = cupy.zeros((n, 4), dtype=cupy.float32)\n\n    integrate(**d, position_out=out_pos, velocity_out=out_vel, color_out=out_col)\n\n    pos_h = out_pos.get()\n\n    # Sorted particle 0 (x=0.0) -> unsorted slot 3\n    assert abs(pos_h[3, 0] - 0.0) < 1e-4, f\"Sort writeback failed: slot 3 x={pos_h[3, 0]}\"\n    # Sorted particle 1 (x=0.1) -> unsorted slot 1\n    assert abs(pos_h[1, 0] - 0.1) < 1e-4, f\"Sort writeback failed: slot 1 x={pos_h[1, 0]}\"\n    # Sorted particle 2 (x=0.2) -> unsorted slot 0\n    assert abs(pos_h[0, 0] - 0.2) < 1e-4, f\"Sort writeback failed: slot 0 x={pos_h[0, 0]}\"\n    # Sorted particle 3 (x=0.3) -> unsorted slot 2\n    assert abs(pos_h[2, 0] - 0.3) < 1e-4, f\"Sort writeback failed: slot 2 x={pos_h[2, 0]}\"\n\n    print(\"PASS: test_sort_indexes_writeback\")\n\n\ndef test_boundary_all_walls():\n    \"\"\"Particles are contained by all 6 walls of the box.\"\"\"\n    setup_params(gravity=(0.0, 0.0, 0.0), restitution=0.3, wall_friction=0.5)\n\n    n = 6\n    # Each particle aimed at a different wall\n    pos = np.array([\n        [-0.999, 0.0, 0.0, 1.0],  # -> -X wall\n        [ 0.999, 0.0, 0.0, 1.0],  # -> +X wall\n        [0.0, -0.999, 0.0, 1.0],  # -> -Y wall\n        [0.0,  0.999, 0.0, 1.0],  # -> +Y wall\n        [0.0, 0.0, -0.999, 1.0],  # -> -Z wall\n        [0.0, 0.0,  0.999, 1.0],  # -> +Z wall\n    ], dtype=np.float32)\n\n    vel = np.array([\n        [-20.0, 0.0, 0.0, 0.0],\n        [ 20.0, 0.0, 0.0, 0.0],\n        [0.0, -20.0, 0.0, 0.0],\n        [0.0,  20.0, 0.0, 0.0],\n        [0.0, 0.0, -20.0, 0.0],\n        [0.0, 0.0,  20.0, 0.0],\n    ], dtype=np.float32)\n\n    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n    pos_out, vel_out, _ = integrate(**d)\n\n    pos_h = pos_out.get()\n    vel_h = vel_out.get()\n\n    for i in range(n):\n        assert pos_h[i, 0] >= -1.0 - 1e-5, f\"Particle {i} escaped -X: {pos_h[i, 0]}\"\n        assert pos_h[i, 0] <=  1.0 + 1e-5, f\"Particle {i} escaped +X: {pos_h[i, 0]}\"\n        assert pos_h[i, 1] >= -1.0 - 1e-5, f\"Particle {i} escaped -Y: {pos_h[i, 1]}\"\n        assert pos_h[i, 1] <=  1.0 + 1e-5, f\"Particle {i} escaped +Y: {pos_h[i, 1]}\"\n        assert pos_h[i, 2] >= -1.0 - 1e-5, f\"Particle {i} escaped -Z: {pos_h[i, 2]}\"\n        assert pos_h[i, 2] <=  1.0 + 1e-5, f\"Particle {i} escaped +Z: {pos_h[i, 2]}\"\n\n    # Verify velocity reflection happened (direction reversed)\n    assert vel_h[0, 0] > 0, f\"Particle 0 should have bounced +X, got vx={vel_h[0, 0]}\"\n    assert vel_h[1, 0] < 0, f\"Particle 1 should have bounced -X, got vx={vel_h[1, 0]}\"\n    assert vel_h[2, 1] > 0, f\"Particle 2 should have bounced +Y, got vy={vel_h[2, 1]}\"\n    assert vel_h[3, 1] < 0, f\"Particle 3 should have bounced -Y, got vy={vel_h[3, 1]}\"\n    assert vel_h[4, 2] > 0, f\"Particle 4 should have bounced +Z, got vz={vel_h[4, 2]}\"\n    assert vel_h[5, 2] < 0, f\"Particle 5 should have bounced -Z, got vz={vel_h[5, 2]}\"\n\n    print(\"PASS: test_boundary_all_walls\")\n\n\ndef test_coulomb_friction():\n    \"\"\"Wall collision applies Coulomb friction to tangential velocity.\"\"\"\n    setup_params(gravity=(0.0, 0.0, 0.0), restitution=0.3, wall_friction=0.5)\n\n    n = 1\n    # Particle hitting floor with both normal and tangential velocity\n    pos = np.array([[0.5, -0.999, 0.0, 1.0]], dtype=np.float32)\n    vel = np.array([[5.0, -10.0, 0.0, 0.0]], dtype=np.float32)\n\n    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n    _, vel_out, _ = integrate(**d)\n\n    vel_h = vel_out.get()\n\n    # Normal: vy reflected with restitution -> ~0.3 * 10.0 = 3.0 upward\n    assert vel_h[0, 1] > 0, f\"Expected upward bounce, got vy={vel_h[0, 1]}\"\n\n    # Tangential: vx should be reduced by friction\n    # friction_impulse = mu_wall * |vn| = 0.5 * 10.0 = 5.0\n    # reduction = min(5.0 / |vt|, 1.0) = min(5.0/5.0, 1.0) = 1.0\n    # vx = 5.0 * (1 - 1.0) = 0.0\n    assert abs(vel_h[0, 0]) < 0.5, (\n        f\"Expected vx ~0 after friction, got {vel_h[0, 0]}\"\n    )\n\n    print(\"PASS: test_coulomb_friction\")\n\n\ndef test_xsph_position_update():\n    \"\"\"FLUID particles use XSPH-corrected velocity for position advection.\"\"\"\n    setup_params(gravity=(0.0, 0.0, 0.0))\n\n    n = 1\n    pos = np.array([[0.0, 0.0, 0.0, 1.0]], dtype=np.float32)\n    vel = np.array([[1.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n    # veleval has XSPH correction: vel + eps*xsph_sum\n    veleval = np.array([[1.5, 0.0, 0.0, 0.0]], dtype=np.float32)  # xsph added 0.5\n\n    d = make_simple_particles(n, WATER, FLUID, pos=pos, vel=vel)\n    d[\"sorted_veleval\"] = cupy.asarray(veleval)\n    pos_out, vel_out, _ = integrate(**d)\n\n    pos_h = pos_out.get()\n    vel_h = vel_out.get()\n\n    # vel_new = 1.0 (no force)\n    # xsph_correction = veleval - vel = 0.5\n    # pos_new = 0 + dt * (vel_new + xsph_correction) = 0 + 0.001 * 1.5 = 0.0015\n    expected_px = DT * (1.0 + 0.5)\n    assert abs(pos_h[0, 0] - expected_px) < 1e-5, (\n        f\"Expected pos_x={expected_px}, got {pos_h[0, 0]}\"\n    )\n\n    # Non-FLUID should NOT use XSPH\n    d2 = make_simple_particles(n, SAND, GRANULAR, pos=pos, vel=vel)\n    d2[\"sorted_veleval\"] = cupy.asarray(veleval)\n    pos_out2, _, _ = integrate(**d2)\n    pos_h2 = pos_out2.get()\n\n    expected_px2 = DT * 1.0  # no XSPH\n    assert abs(pos_h2[0, 0] - expected_px2) < 1e-5, (\n        f\"GRANULAR should not use XSPH: expected {expected_px2}, got {pos_h2[0, 0]}\"\n    )\n\n    print(\"PASS: test_xsph_position_update\")\n\n\ndef test_water_pool_no_nan():\n    \"\"\"10K water particles in box settle without NaN after 1000 steps.\n\n    This is a simplified test without the full neighbor pipeline --\n    we just check that integration alone doesn't produce NaN with\n    typical SPH-like forces.\n    \"\"\"\n    setup_params(gravity=(0.0, -9.8, 0.0))\n\n    n = 10000\n    rng = np.random.RandomState(42)\n\n    # Particles in a cube near the top, falling\n    pos = np.zeros((n, 4), dtype=np.float32)\n    pos[:, 0] = rng.uniform(-0.5, 0.5, n)\n    pos[:, 1] = rng.uniform(0.0, 0.8, n)\n    pos[:, 2] = rng.uniform(-0.5, 0.5, n)\n    pos[:, 3] = 1.0\n\n    vel = np.zeros((n, 4), dtype=np.float32)\n\n    pos_gpu = cupy.asarray(pos)\n    vel_gpu = cupy.asarray(vel)\n    veleval_gpu = vel_gpu.copy()\n    force_gpu = cupy.zeros((n, 4), dtype=cupy.float32)\n    mass_gpu = cupy.full(n, MASS, dtype=cupy.float32)\n    pi_gpu = cupy.full(n, MAKE_PACKED(WATER, FLUID), dtype=cupy.uint32)\n    temp_gpu = cupy.full(n, 293.0, dtype=cupy.float32)\n    health_gpu = cupy.full(n, 1.0, dtype=cupy.float32)\n    sort_idx = cupy.arange(n, dtype=cupy.uint32)\n    color_gpu = cupy.zeros((n, 4), dtype=cupy.float32)\n\n    for step in range(1000):\n        # Apply small random SPH-like forces for realism\n        if step % 10 == 0:\n            force_gpu[:, :3] = cupy.random.uniform(-0.1, 0.1, (n, 3), dtype=cupy.float32)\n\n        integrate(\n            sorted_position=pos_gpu,\n            sorted_velocity=vel_gpu,\n            sorted_veleval=veleval_gpu,\n            sorted_sph_force=force_gpu,\n            sorted_mass=mass_gpu,\n            sorted_packed_info=pi_gpu,\n            sorted_temperature=temp_gpu,\n            sorted_health=health_gpu,\n            sort_indexes=sort_idx,\n            position_out=pos_gpu,\n            velocity_out=vel_gpu,\n            color_out=color_gpu,\n        )\n        veleval_gpu[:] = vel_gpu\n\n    pos_h = pos_gpu.get()\n    vel_h = vel_gpu.get()\n\n    assert not np.any(np.isnan(pos_h)), \"NaN found in positions after 1000 steps\"\n    assert not np.any(np.isnan(vel_h)), \"NaN found in velocities after 1000 steps\"\n\n    # All particles should be within boundaries\n    assert np.all(pos_h[:, 0] >= -1.0 - 1e-4), \"Particles escaped -X\"\n    assert np.all(pos_h[:, 0] <=  1.0 + 1e-4), \"Particles escaped +X\"\n    assert np.all(pos_h[:, 1] >= -1.0 - 1e-4), \"Particles escaped -Y\"\n    assert np.all(pos_h[:, 1] <=  1.0 + 1e-4), \"Particles escaped +Y\"\n    assert np.all(pos_h[:, 2] >= -1.0 - 1e-4), \"Particles escaped -Z\"\n    assert np.all(pos_h[:, 2] <=  1.0 + 1e-4), \"Particles escaped +Z\"\n\n    # Most particles should have settled near the bottom\n    mean_y = np.mean(pos_h[:, 1])\n    assert mean_y < 0.0, f\"Mean Y should be negative (settled), got {mean_y}\"\n\n    print(\"PASS: test_water_pool_no_nan\")\n\n\ndef test_500k_stress():\n    \"\"\"500K particles run through integrate without errors.\"\"\"\n    setup_params()\n\n    n = 500_000\n    rng = np.random.RandomState(123)\n\n    pos = np.zeros((n, 4), dtype=np.float32)\n    pos[:, :3] = rng.uniform(-0.9, 0.9, (n, 3))\n    pos[:, 3] = 1.0\n    vel = np.zeros((n, 4), dtype=np.float32)\n    vel[:, :3] = rng.uniform(-1.0, 1.0, (n, 3))\n\n    # Mix of behaviors\n    packed = np.zeros(n, dtype=np.uint32)\n    packed[:200000] = MAKE_PACKED(WATER, FLUID)\n    packed[200000:400000] = MAKE_PACKED(SAND, GRANULAR)\n    packed[400000:480000] = MAKE_PACKED(STEAM, GAS)\n    packed[480000:] = MAKE_PACKED(STONE, STATIC)\n\n    d = {\n        \"sorted_position\": cupy.asarray(pos),\n        \"sorted_velocity\": cupy.asarray(vel),\n        \"sorted_veleval\": cupy.asarray(vel),\n        \"sorted_sph_force\": cupy.zeros((n, 4), dtype=cupy.float32),\n        \"sorted_mass\": cupy.full(n, MASS, dtype=cupy.float32),\n        \"sorted_packed_info\": cupy.asarray(packed),\n        \"sorted_temperature\": cupy.full(n, 293.0, dtype=cupy.float32),\n        \"sorted_health\": cupy.full(n, 1.0, dtype=cupy.float32),\n        \"sort_indexes\": cupy.arange(n, dtype=cupy.uint32),\n    }\n\n    pos_out, vel_out, color_out = integrate(**d)\n\n    # Synchronize to catch any CUDA errors\n    cupy.cuda.Device().synchronize()\n\n    pos_h = pos_out.get()\n    vel_h = vel_out.get()\n    color_h = color_out.get()\n\n    assert not np.any(np.isnan(pos_h)), \"NaN in positions (500K)\"\n    assert not np.any(np.isnan(vel_h)), \"NaN in velocities (500K)\"\n    assert not np.any(np.isnan(color_h)), \"NaN in colors (500K)\"\n\n    # All particles should be within boundaries\n    assert np.all(pos_h[:, 0] >= -1.0 - 1e-4), \"500K: particles escaped -X\"\n    assert np.all(pos_h[:, 0] <=  1.0 + 1e-4), \"500K: particles escaped +X\"\n    assert np.all(pos_h[:, 1] >= -1.0 - 1e-4), \"500K: particles escaped -Y\"\n    assert np.all(pos_h[:, 1] <=  1.0 + 1e-4), \"500K: particles escaped +Y\"\n\n    # STATIC particles should keep their original positions\n    static_pos_orig = pos[480000:, :3]\n    static_pos_new = pos_h[480000:, :3]\n    assert np.allclose(static_pos_orig, static_pos_new, atol=1e-5), (\n        \"STATIC particle positions changed!\"\n    )\n\n    print(\"PASS: test_500k_stress\")\n\n\n# ===========================================================================\n# Main\n# ===========================================================================\n\nif __name__ == \"__main__\":\n    tests = [\n        test_compilation,\n        test_block_size,\n        test_static_skip,\n        test_gravity_freefall,\n        test_bounce_floor,\n        test_bounce_multi_step,\n        test_gas_buoyancy,\n        test_gas_drag,\n        test_velocity_clamp,\n        test_color_computation,\n        test_sort_indexes_writeback,\n        test_boundary_all_walls,\n        test_coulomb_friction,\n        test_xsph_position_update,\n        test_water_pool_no_nan,\n        test_500k_stress,\n    ]\n\n    passed = 0\n    failed = 0\n    for test in tests:\n        try:\n            test()\n            passed += 1\n        except Exception as e:\n            print(f\"FAIL: {test.__name__}: {e}\")\n            import traceback\n            traceback.print_exc()\n            failed += 1\n\n    print(f\"\\n{'='*60}\")\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)}\")\n    if failed > 0:\n        sys.exit(1)\n    print(\"All tests passed!\")\n","numLines":752,"startLine":1,"totalLines":752}}}

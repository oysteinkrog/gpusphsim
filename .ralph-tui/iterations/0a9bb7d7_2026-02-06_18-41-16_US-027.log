{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q4Yj3Un9qgprJ6oBMe8N7m","type":"tool_result","content":"     1→\"\"\"Material property table and interaction matrix for multi-material SPH.\n     2→\n     3→Defines 16 materials (IDs 0-15) as Python dataclasses, a 32x32 interaction\n     4→matrix, and an upload_to_gpu() function that copies both tables to CUDA\n     5→constant memory via CuPy RawModule symbol lookup.\n     6→\n     7→Struct layout matches fallingsand3d/physics/kernels/common.cuh exactly.\n     8→\n     9→Constant-memory symbols\n    10→-----------------------\n    11→- ``c_materials``   : MaterialProps[32]\n    12→- ``c_interactions`` : Interaction[32][32]\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import dataclasses\n    18→import os\n    19→from typing import Dict, List, Optional, Tuple\n    20→\n    21→import numpy as np\n    22→\n    23→# ---------------------------------------------------------------------------\n    24→# Numpy structured dtypes matching the C structs in common.cuh\n    25→# ---------------------------------------------------------------------------\n    26→\n    27→MATERIAL_PROPS_DTYPE = np.dtype(\n    28→    [\n    29→        (\"rest_density\", np.float32),\n    30→        (\"eos_stiffness\", np.float32),\n    31→        (\"eos_gamma\", np.float32),\n    32→        (\"base_viscosity\", np.float32),\n    33→        (\"friction_coeff\", np.float32),\n    34→        (\"cohesion\", np.float32),\n    35→        (\"buoyancy_extra\", np.float32),\n    36→        (\"thermal_conductivity\", np.float32),\n    37→        (\"heat_capacity\", np.float32),\n    38→        (\"temp_melt\", np.float32),\n    39→        (\"temp_boil\", np.float32),\n    40→        (\"temp_ignite\", np.float32),\n    41→        (\"behavior_class\", np.int32),\n    42→        (\"color_r\", np.float32),\n    43→        (\"color_g\", np.float32),\n    44→        (\"color_b\", np.float32),\n    45→    ],\n    46→    align=True,\n    47→)\n    48→\n    49→INTERACTION_DTYPE = np.dtype(\n    50→    [\n    51→        (\"reaction_rate\", np.float32),\n    52→        (\"heat_exchange\", np.float32),\n    53→    ],\n    54→    align=True,\n    55→)\n    56→\n    57→# Compile-time size checks (must match sizeof(MaterialProps) and sizeof(Interaction))\n    58→assert MATERIAL_PROPS_DTYPE.itemsize == 64, (\n    59→    f\"MaterialProps size mismatch: {MATERIAL_PROPS_DTYPE.itemsize} != 64\"\n    60→)\n    61→assert INTERACTION_DTYPE.itemsize == 8, (\n    62→    f\"Interaction size mismatch: {INTERACTION_DTYPE.itemsize} != 8\"\n    63→)\n    64→\n    65→MAX_MATERIALS = 32  # slots in constant memory (IDs 0-31)\n    66→NUM_DEFINED = 16  # IDs 0-15 are defined; 16-31 reserved (zeroed)\n    67→\n    68→# ---------------------------------------------------------------------------\n    69→# BehaviorClass enum (mirrors common.cuh)\n    70→# ---------------------------------------------------------------------------\n    71→\n    72→FLUID = 0\n    73→GRANULAR = 1\n    74→GAS = 2\n    75→STATIC = 3\n    76→\n    77→# ---------------------------------------------------------------------------\n    78→# MaterialDef dataclass\n    79→# ---------------------------------------------------------------------------\n    80→\n    81→\n    82→@dataclasses.dataclass\n    83→class MaterialDef:\n    84→    \"\"\"Python-side definition of a single material.\n    85→\n    86→    Field names and semantics match the ``MaterialProps`` C struct in common.cuh.\n    87→    \"\"\"\n    88→\n    89→    id: int\n    90→    name: str  # human-readable label (not uploaded to GPU)\n    91→    rest_density: float  # kg/m^3\n    92→    eos_stiffness: float  # Tait EOS k\n    93→    eos_gamma: float  # Tait EOS exponent (7 for liquid, 1 for gas)\n    94→    base_viscosity: float  # Pa*s\n    95→    friction_coeff: float  # mu_s for granular friction\n    96→    cohesion: float  # cohesion coefficient\n    97→    buoyancy_extra: float  # extra buoyancy factor for gas\n    98→    thermal_conductivity: float  # W/(m*K)\n    99→    heat_capacity: float  # J/(kg*K)\n   100→    temp_melt: float  # Kelvin\n   101→    temp_boil: float  # Kelvin\n   102→    temp_ignite: float  # Kelvin (0 = non-flammable)\n   103→    behavior_class: int  # BehaviorClass enum value\n   104→    color_r: float  # default material color R [0,1]\n   105→    color_g: float  # default material color G [0,1]\n   106→    color_b: float  # default material color B [0,1]\n   107→\n   108→    def to_numpy(self) -> np.void:\n   109→        \"\"\"Pack into a single numpy structured-array element.\"\"\"\n   110→        return np.array(\n   111→            (\n   112→                self.rest_density,\n   113→                self.eos_stiffness,\n   114→                self.eos_gamma,\n   115→                self.base_viscosity,\n   116→                self.friction_coeff,\n   117→                self.cohesion,\n   118→                self.buoyancy_extra,\n   119→                self.thermal_conductivity,\n   120→                self.heat_capacity,\n   121→                self.temp_melt,\n   122→                self.temp_boil,\n   123→                self.temp_ignite,\n   124→                self.behavior_class,\n   125→                self.color_r,\n   126→                self.color_g,\n   127→                self.color_b,\n   128→            ),\n   129→            dtype=MATERIAL_PROPS_DTYPE,\n   130→        )\n   131→\n   132→\n   133→# ---------------------------------------------------------------------------\n   134→# Material ID constants\n   135→# ---------------------------------------------------------------------------\n   136→\n   137→DEAD = 0\n   138→STONE = 1\n   139→SAND = 2\n   140→DIRT = 3\n   141→GRAVEL = 4\n   142→WATER = 5\n   143→OIL = 6\n   144→LAVA = 7\n   145→ACID = 8\n   146→WOOD = 9\n   147→METAL = 10\n   148→ICE = 11\n   149→STEAM = 12\n   150→SMOKE = 13\n   151→FIRE = 14\n   152→GUNPOWDER = 15\n   153→\n   154→# ---------------------------------------------------------------------------\n   155→# Material definitions (16 entries, IDs 0-15)\n   156→#\n   157→# Property values chosen for a falling-sand / multi-material SPH game:\n   158→#   - rest_density in kg/m^3 (approximate real-world)\n   159→#   - eos_stiffness: Tait EOS pressure coefficient (game-tuned)\n   160→#   - eos_gamma: 7 for FLUID/GRANULAR, 1 for GAS, 0 for STATIC/DEAD\n   161→#   - base_viscosity in Pa*s (scaled for game feel)\n   162→#   - temperatures in Kelvin\n   163→# ---------------------------------------------------------------------------\n   164→\n   165→MATERIALS: Dict[int, MaterialDef] = {\n   166→    DEAD: MaterialDef(\n   167→        id=DEAD, name=\"DEAD\",\n   168→        rest_density=0.0, eos_stiffness=0.0, eos_gamma=0.0,\n   169→        base_viscosity=0.0, friction_coeff=0.0, cohesion=0.0,\n   170→        buoyancy_extra=0.0, thermal_conductivity=0.0, heat_capacity=0.0,\n   171→        temp_melt=0.0, temp_boil=0.0, temp_ignite=0.0,\n   172→        behavior_class=STATIC,\n   173→        color_r=0.0, color_g=0.0, color_b=0.0,\n   174→    ),\n   175→    STONE: MaterialDef(\n   176→        id=STONE, name=\"STONE\",\n   177→        rest_density=2600.0, eos_stiffness=50.0, eos_gamma=7.0,\n   178→        base_viscosity=0.0, friction_coeff=0.7, cohesion=0.5,\n   179→        buoyancy_extra=0.0, thermal_conductivity=2.0, heat_capacity=800.0,\n   180→        temp_melt=1500.0, temp_boil=3000.0, temp_ignite=0.0,\n   181→        behavior_class=STATIC,\n   182→        color_r=0.5, color_g=0.5, color_b=0.5,\n   183→    ),\n   184→    SAND: MaterialDef(\n   185→        id=SAND, name=\"SAND\",\n   186→        rest_density=1600.0, eos_stiffness=20.0, eos_gamma=7.0,\n   187→        base_viscosity=0.5, friction_coeff=0.6, cohesion=0.0,\n   188→        buoyancy_extra=0.0, thermal_conductivity=0.3, heat_capacity=830.0,\n   189→        temp_melt=1700.0, temp_boil=2500.0, temp_ignite=0.0,\n   19
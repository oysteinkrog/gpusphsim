{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019q7PExNuCrXAbc9zrQ5Y3X","type":"tool_result","content":"     1→\"\"\"Grid hashing kernel for spatial partitioning of SPH particles.\n     2→\n     3→Compiles physics/kernels/hash_sort.cu via CuPy RawModule and provides\n     4→functions to upload GridParams to ``__constant__ GridParams c_grid`` and\n     5→launch the ``K_CalcHash`` kernel.\n     6→\n     7→Grid sizing (from acceptance criteria)\n     8→--------------------------------------\n     9→- grid_min = (-1, -1, -1), grid_max = (1, 1, 1)\n    10→- cell_size = h = 0.04\n    11→- grid_res  = 50 per axis\n    12→- grid_delta = (25, 25, 25)   (= grid_res / grid_size = 50/2)\n    13→- num_cells  = 125000          (= 50^3)\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import os\n    19→from typing import Optional, Tuple\n    20→\n    21→import cupy  # type: ignore[import-untyped]\n    22→import numpy as np\n    23→\n    24→# ---------------------------------------------------------------------------\n    25→# Grid constants\n    26→# ---------------------------------------------------------------------------\n    27→\n    28→GRID_MIN = np.array([-1.0, -1.0, -1.0], dtype=np.float32)\n    29→GRID_MAX = np.array([1.0, 1.0, 1.0], dtype=np.float32)\n    30→CELL_SIZE = np.float32(0.04)\n    31→GRID_RES = np.array([50, 50, 50], dtype=np.int32)\n    32→GRID_DELTA = np.array([25.0, 25.0, 25.0], dtype=np.float32)  # grid_res / grid_size\n    33→NUM_CELLS = 125_000  # 50 * 50 * 50\n    34→\n    35→# ---------------------------------------------------------------------------\n    36→# Numpy dtype matching ``struct GridParams`` in common.cuh\n    37→#\n    38→# CUDA float3 is 12 bytes (3 x float32, no trailing padding).\n    39→# Five float3 fields = 60 bytes total.\n    40→# ---------------------------------------------------------------------------\n    41→\n    42→GRID_PARAMS_DTYPE = np.dtype(\n    43→    [\n    44→        (\"grid_size\", np.float32, (3,)),\n    45→        (\"grid_min\", np.float32, (3,)),\n    46→        (\"grid_max\", np.float32, (3,)),\n    47→        (\"grid_res\", np.float32, (3,)),\n    48→        (\"grid_delta\", np.float32, (3,)),\n    49→    ],\n    50→    align=False,  # CUDA float3 has no trailing pad, so no alignment\n    51→)\n    52→\n    53→\n    54→def build_grid_params() -> np.ndarray:\n    55→    \"\"\"Build a single GridParams struct as a numpy structured array.\"\"\"\n    56→    params = np.zeros(1, dtype=GRID_PARAMS_DTYPE)\n    57→    grid_size = GRID_MAX - GRID_MIN\n    58→    params[0][\"grid_size\"] = grid_size\n    59→    params[0][\"grid_min\"] = GRID_MIN\n    60→    params[0][\"grid_max\"] = GRID_MAX\n    61→    params[0][\"grid_res\"] = GRID_RES.astype(np.float32)\n    62→    params[0][\"grid_delta\"] = GRID_DELTA\n    63→    return params\n    64→\n    65→\n    66→# ---------------------------------------------------------------------------\n    67→# CuPy RawModule compilation\n    68→# ---------------------------------------------------------------------------\n    69→\n    70→_module: Optional[object] = None\n    71→\n    72→\n    73→def _ensure_ptx_if_needed() -> None:\n    74→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    75→    from cupy.cuda import compiler as _compiler  # type: ignore[import-untyped]\n    76→    from cupy.cuda import device as _device  # type: ignore[import-untyped]\n    77→\n    78→    gpu_cc = _device.Device().compute_capability\n    79→    nvrtc_max = _compiler._get_max_compute_capability()\n    80→    if int(gpu_cc) > int(nvrtc_max):\n    81→        _compiler._use_ptx = True\n    82→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    83→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    84→        if hasattr(_compiler._get_arch, \"_cache\"):\n    85→            _compiler._get_arch._cache = {}\n    86→\n    87→\n    88→def _get_module() -> \"object\":\n    89→    \"\"\"Compile (or return cached) CuPy RawModule from hash_sort.cu.\"\"\"\n    90→    global _module\n    91→    if _module is not None:\n    92→        return _module\n    93→\n    94→    _ensure_ptx_if_needed()\n    95→\n    96→    # Read the .cu source from disk\n    97→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    98→    cu_path = os.path.join(kernel_dir, \"hash_sort.cu\")\n    99→    with open(cu_path) as f:\n   100→        source = f.read()\n   101→\n   102→    _module = cupy.RawModule(\n   103→        code=source,\n   104→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n   105→    )\n   106→    return _module\n   107→\n   108→\n   109→def get_module() -> \"object\":\n   110→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n   111→    return _get_module()\n   112→\n   113→\n   114→# ---------------------------------------------------------------------------\n   115→# Constant memory upload\n   116→# ---------------------------------------------------------------------------\n   117→\n   118→\n   119→def upload_grid_params(params: Optional[np.ndarray] = None) -> None:\n   120→    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\n   121→\n   122→    Parameters\n   123→    ----------\n   124→    params : numpy structured array, optional\n   125→        A single GridParams element.  If *None*, uses ``build_grid_params()``.\n   126→    \"\"\"\n   127→    if params is None:\n   128→        params = build_grid_params()\n   129→\n   130→    module = _get_module()\n   131→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n   132→\n   133→    cupy.cuda.runtime.memcpy(\n   134→        int(d_ptr),\n   135→        params.ctypes.data,\n   136→        params.nbytes,\n   137→        1,  # cudaMemcpyHostToDevice\n   138→    )\n   139→\n   140→\n   141→# ----------------------------------------------------
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K1NcwbBpUivBA6tqxWutAF","type":"tool_result","content":"     1→\"\"\"Integration test for hash_sort.py -- K_CalcHash grid hashing kernel.\n     2→\n     3→Acceptance criteria:\n     4→  - K_CalcHash computes grid cell: cell = int3((pos - grid_min) * grid_delta),\n     5→    clamped to [0, grid_res-1]\n     6→  - Hash = cell.z * grid_res.y * grid_res.x + cell.y * grid_res.x + cell.x\n     7→  - Grid parameters read from __constant__ GridParams c_grid\n     8→  - Grid sizing: grid_min=(-1,-1,-1), grid_max=(1,1,1), cell_size=h=0.04,\n     9→    grid_res=50, grid_delta=(25,25,25), num_cells=125000\n    10→  - CuPy RawModule compiles hash_sort.cu including common.cuh without errors\n    11→  - Test: 100K particles uniformly distributed in unit cube -> valid hashes [0, num_cells-1]\n    12→  - Test: particles at/outside grid boundaries -> clamped hashes (no OOB)\n    13→  - Kernel runs without errors for 500K particles\n    14→\n    15→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    16→\"\"\"\n    17→\n    18→from __future__ import annotations\n    19→\n    20→import cupy  # type: ignore[import-untyped]\n    21→import numpy as np\n    22→\n    23→from hash_sort import (\n    24→    CELL_SIZE,\n    25→    GRID_DELTA,\n    26→    GRID_MAX,\n    27→    GRID_MIN,\n    28→    GRID_PARAMS_DTYPE,\n    29→    GRID_RES,\n    30→    NUM_CELLS,\n    31→    build_grid_params,\n    32→    calc_hash,\n    33→    get_module,\n    34→    upload_grid_params,\n    35→)\n    36→\n    37→\n    38→def _host_hash(pos: np.ndarray) -> np.ndarray:\n    39→    \"\"\"Reference CPU implementation of the hash for validation.\"\"\"\n    40→    grid_min = GRID_MIN\n    41→    grid_delta = GRID_DELTA\n    42→    grid_res = GRID_RES.astype(np.float32)\n    43→\n    44→    # calcGridCell: int3((pos - grid_min) * grid_delta)\n    45→    cell = np.floor((pos[:, :3] - grid_min) * grid_delta).astype(np.int32)\n    46→\n    47→    # clamp to [0, grid_res - 1]\n    48→    cell = np.clip(cell, 0, GRID_RES - 1)\n    49→\n    50→    # linear hash: z * ry * rx + y * rx + x\n    51→    rx = int(grid_res[0])\n    52→    ry = int(grid_res[1])\n    53→    h = cell[:, 2] * ry * rx + cell[:, 1] * rx + cell[:, 0]\n    54→    return h.astype(np.uint32)\n    55→\n    56→\n    57→def test_grid_constants() -> None:\n    58→    \"\"\"Verify grid sizing matches acceptance criteria.\"\"\"\n    59→    print(\"--- Grid constant checks ---\")\n    60→\n    61→    np.testing.assert_array_almost_equal(GRID_MIN, [-1.0, -1.0, -1.0])\n    62→    np.testing.assert_array_almost_equal(GRID_MAX, [1.0, 1.0, 1.0])\n    63→    assert abs(float(CELL_SIZE) - 0.04) < 1e-7\n    64→    np.testing.assert_array_equal(GRID_RES, [50, 50, 50])\n    65→    np.testing.assert_array_almost_equal(GRID_DELTA, [25.0, 25.0, 25.0])\n    66→    assert NUM_CELLS == 125_000\n    67→    print(\"[OK] Grid constants: grid_min=(-1,-1,-1) grid_max=(1,1,1) \"\n    68→          \"cell_size=0.04 grid_res=50 grid_delta=25 num_cells=125000\")\n    69→\n    70→\n    71→def test_grid_params_struct() -> None:\n    72→    \"\"\"Verify GridParams numpy dtype layout.\"\"\"\n    73→    print(\"\\n--- GridParams struct checks ---\")\n    74→\n    75→    # 5 float3 fields = 5 * 12 = 60 bytes\n    76→    assert GRID_PARAMS_DTYPE.itemsize == 60, (\n    77→        f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 60\"\n    78→    )\n    79→    print(f\"[OK] sizeof(GridParams) = {GRID_PARAMS_DTYPE.itemsize} bytes\")\n    80→\n    81→    params = build_grid_params()\n    82→    np.testing.assert_array_almost_equal(params[0][\"grid_size\"], [2.0, 2.0, 2.0])\n    83→    np.testing.assert_array_almost_equal(params[0][\"grid_min\"], [-1.0, -1.0, -1.0])\n    84→    np.testing.assert_array_almost_equal(params[0][\"grid_max\"], [1.0, 1.0, 1.0])\n    85→    np.testing.assert_array_almost_equal(params[0][\"grid_res\"], [50.0, 50.0, 50.0])\n    86→    np.testing.assert_array_almost_equal(params[0][\"grid_delta\"], [25.0, 25.0, 25.0])\n    87→    print(\"[OK] GridParams fields populated correctly\")\n    88→\n    89→\n    90→def test_compilation() -> None:\n    91→    \"\"\"Verify CuPy RawModule compiles hash_sort.cu including common.cuh.\"\"\"\n    92→    print(\"\\n--- Compilation check ---\")\n    93→\n    94→    module = get_module()\n    95→    assert module is not None\n    96→    print(\"[OK] CuPy RawModule compiled hash_sort.cu (includes common.cuh)\")\n    97→\n    98→    # Verify kernel function is accessible\n    99→    kernel = module.get_function(\"K_CalcHash\")  # type: ignore[union-attr]\n   100→    assert kernel is not None\n   101→    print(\"[OK] K_CalcHash kernel function found\")\n   102→\n   103→    # Verify constant memory symbol is accessible\n   104→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n   105→    assert int(d_ptr) != 0\n   106→    print(\"[OK] c_grid constant memory symbol found\")\n   107→\n   108→\n   109→def test_100k_uniform_unit_cube() -> None:\n   110→    \"\"\"100K particles uniformly distributed in unit cube -> valid hashes.\"\"\"\n   111→    print(\"\\n--- 100K uniform unit-cube test ---\")\n   112→\n   113→    upload_grid_params()\n   114→\n   115→    rng = np.random.default_rng(42)\n   116→    # Unit cube [0, 1]^3 is entirely inside grid [-1, 1]^3\n   117→    pos_np = np.zeros((100_000, 4), dtype=np.float32)\n   118→    pos_np[:, :3] = rng.uniform(0.0, 1.0, size=(100_000, 3)).astype(np.float32)\n   119→    pos_gpu = cupy.asarray(pos_np)\n   120→\n   121→    hashes, indices = calc_hash(pos_gpu)\n   122→    cupy.cuda.Device().synchronize()\n   123→\n   124→    h_hashes = cupy.asnumpy(hashes)\n   125→    h_indices = cupy.asnumpy(indices)\n   126→\n   127→    # All hashes in [0, NUM_CELLS - 1]\n   128→    assert h_hashes.min() >= 0, f\"Min hash = {h_hashes.min()}, expected >= 0\"\n   129→    assert h_hashes.max() < NUM_CELLS, (\n   130→        f\"Max hash = {h_hashes.max()}, expected < {NUM_CELLS}\"\n   131→    )\n   132→    print(f\"[OK] All 100K hashes in [0, {NUM_CELLS - 1}]: \"\n   133→          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n   134→\n   135→    # Indices should be identity permutation\n   136→    np.testing.assert_array_equal(h_indices, np.arange(100_000, dtype=np.uint32))\n   137→    print(\"[OK] Indices are identity [0..99999]\")\n   138→\n   139→    # Cross-check against CPU reference\n   140→    ref = _host_hash(pos_np)\n   141→    np.testing.assert_array_equal(h_hashes, ref)\n   142→    print(\"[OK] GPU hashes match CPU reference for all 100K particles\")\n   143→\n   144→\n   145→def test_boundary_clamping() -> None:\n   146→    \"\"\"Particles at or outside grid boundaries produce clamped hashes.\"\"\"\n   147→    print(\"\\n--- Boundary clamping test ---\")\n   148→\n   149→    upload_grid_params()\n   150→\n   151→    # Test positions: inside, on boundary, and outside\n   152→    test_positions = np.array([\n   153→        # Inside (center of grid)\n   154→        [0.0, 0.0, 0.0, 0.0],\n   155→        # At grid_min exactly\n   156→        [-1.0, -1.0, -1.0, 0.0],\n   157→        # At grid_max exactly (should clamp to res-1)\n   158→        [1.0, 1.0, 1.0, 0.0],\n   159→        # Far outside negative\n   160→        [-10.0, -10.0, -10.0, 0.0],\n   161→        # Far outside positive\n   162→        [10.0, 10.0, 10.0, 0.0],\n   163→        # Mixed: some axes inside, some outside\n   164→        [0.5, -5.0, 3.0, 0.0],\n   165→        # Just inside near grid_max\n   166→        [0.99, 0.99, 0.99, 0.0],\n   167→    ], dtype=np.float32)\n   168→\n   169→    pos_gpu = cupy.asarray(test_positions)\n   170→    hashes, indices = calc_hash(pos_gpu)\n   171→    cupy.cuda.Device().synchronize()\n   172→\n   173→    h_hashes = cupy.asnumpy(hashes)\n   174→\n   175→    # All hashes must be in valid range\n   176→    for i, h in enumerate(h_hashes):\n   177→        assert 0 <= h < NUM_CELLS, (\n   178→            f\"Particle {i} at {test_positions[i, :3]}: hash={h}, \"\n   179→            f\"expected in [0, {NUM_CELLS - 1}]\"\n   180→        )\n   181→    print(f\"[OK] All {len(test_positions)} boundary test particles have valid hashes\")\n   182→\n   183→    # Verify specific expected values:\n   184→    # Particle at grid_min (-1,-1,-1): cell = (0,0,0), hash = 0\n   185→    assert h_hashes[1] == 0, f\"grid_min hash = {h_hashes[1]}, expected 0\"\n   186→    print(\"[OK] Particle at grid_min -> hash = 0\")\n   187→\n   188→    # Particle far outside negative: should clamp to (0,0,0), hash = 0\n   189→    assert h_hashes[3] == 0, f\"far-negative hash = {h_hashes[3]}, expected 0\"\n   190→    print(\"[OK] Particle far outside negative -> hash = 0 (clamped)\")\n   191→\n   192→    # Particle far outside positive: should clamp to (49,49,49)\n   193→    max_hash = 49 * 50 * 50 + 49 * 50 + 49  # = 124999\n   194→    assert h_hashes[4] == max_hash, (\n   195→        f\"far-positive hash = {h_hashes[4]}, expected {max_hash}\"\n   196→    )\n   197→    print(f\"[OK] Particle far outside positive -> hash = {max_hash} (clamped to max)\")\n   198→\n   199→    # Particle at grid_max (1,1,1): cell unclamped = (50,50,50), clamped to (49,49,49)\n   200→    assert h_hashes[2] == max_hash, (\n   201→        f\"grid_max hash = {h_hashes[2]}, expected {max_hash}\"\n   202→    )\n   203→    print(f\"[OK] Particle at grid_max -> hash = {max_hash} (clamped)\")\n   204→\n   205→    # Cross-check all against CPU reference\n   206→    ref = _host_hash(test_positions)\n   207→    np.testing.assert_array_equal(h_hashes, ref)\n   208→    print(\"[OK] Boundary hashes match CPU reference\")\n   209→\n   210→\n   211→def test_500k_no_errors() -> None:\n   212→    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n   213→    print(\"\\n--- 500K particle stress test ---\")\n   214→\n   215→    upload_grid_params()\n   216→\n   217→    rng = np.random.default_rng(123)\n   218→    # Distribute across entire grid range [-1, 1]^3\n   219→    pos_np = np.zeros((500_000, 4), dtype=np.float32)\n   220→    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(500_000, 3)).astype(np.float32)\n   221→    pos_gpu = cupy.asarray(pos_np)\n   222→\n   223→    hashes, indices = calc_hash(pos_gpu)\n   224→    cupy.cuda.Device().synchronize()\n   225→\n   226→    h_hashes = cupy.asnumpy(hashes)\n   227→\n   228→    # All valid\n   229→    assert h_hashes.min() >= 0\n   230→    assert h_hashes.max() < NUM_CELLS\n   231→    print(f\"[OK] 500K particles hashed without errors: \"\n   232→          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n   233→\n   234→    # Spot-check against CPU reference (first 1000)\n   235→    ref = _host_hash(pos_np[:1000])\n   236→    np.testing.assert_array_equal(h_hashes[:1000], ref)\n   237→    print(\"[OK] First 1000 hashes match CPU reference\")\n   238→\n   239→\n   240→def test_known_position() -> None:\n   241→    \"\"\"Verify hash for a particle with a known grid cell.\"\"\"\n   242→    print(\"\\n--- Known position test ---\")\n   243→\n   244→    upload_grid_params()\n   245→\n   246→    # Position (0.02, 0.02, 0.02):\n   247→    #   cell = int3((0.02 - (-1)) * 25, (0.02 - (-1)) * 25, (0.02 - (-1)) * 25)\n   248→    #        = int3(25.5, 25.5, 25.5) = (25, 25, 25)\n   249→    #   hash = 25 * 50 * 50 + 25 * 50 + 25 = 62500 + 1250 + 25 = 63775\n   250→    pos = np.array([[0.02, 0.02, 0.02, 0.0]], dtype=np.float32)\n   251→    pos_gpu = cupy.asarray(pos)\n   252→\n   253→    hashes, _ = calc_hash(pos_gpu)\n   254→    cupy.cuda.Device().synchronize()\n   255→\n   256→    h = int(cupy.asnumpy(hashes)[0])\n   257→    expected = 25 * 50 * 50 + 25 * 50 + 25  # 63775\n   258→    assert h == expected, f\"hash = {h}, expected {expected}\"\n   259→    print(f\"[OK] Position (0.02, 0.02, 0.02) -> cell (25,25,25) -> hash = {h}\")\n   260→\n   261→\n   262→def main() -> None:\n   263→    test_grid_constants()\n   264→    test_grid_params_struct()\n   265→    test_compilation()\n   266→    test_known_position()\n   267→    test_100k_uniform_unit_cube()\n   268→    test_boundary_clamping()\n   269→    test_500k_no_errors()\n   270→    print(\"\\n=== ALL CHECKS PASSED ===\")\n   271→\n   272→\n   273→if __name__ == \"__main__\":\n   274→    main()\n   275→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"d82bc328-318f-4f77-9b79-06e2a6de0f28","uuid":"53d16976-9890-4496-99b4-8c74dc441159","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/test_hash_sort.py","content":"\"\"\"Integration test for hash_sort.py -- K_CalcHash grid hashing kernel.\n\nAcceptance criteria:\n  - K_CalcHash computes grid cell: cell = int3((pos - grid_min) * grid_delta),\n    clamped to [0, grid_res-1]\n  - Hash = cell.z * grid_res.y * grid_res.x + cell.y * grid_res.x + cell.x\n  - Grid parameters read from __constant__ GridParams c_grid\n  - Grid sizing: grid_min=(-1,-1,-1), grid_max=(1,1,1), cell_size=h=0.04,\n    grid_res=50, grid_delta=(25,25,25), num_cells=125000\n  - CuPy RawModule compiles hash_sort.cu including common.cuh without errors\n  - Test: 100K particles uniformly distributed in unit cube -> valid hashes [0, num_cells-1]\n  - Test: particles at/outside grid boundaries -> clamped hashes (no OOB)\n  - Kernel runs without errors for 500K particles\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport cupy  # type: ignore[import-untyped]\nimport numpy as np\n\nfrom hash_sort import (\n    CELL_SIZE,\n    GRID_DELTA,\n    GRID_MAX,\n    GRID_MIN,\n    GRID_PARAMS_DTYPE,\n    GRID_RES,\n    NUM_CELLS,\n    build_grid_params,\n    calc_hash,\n    get_module,\n    upload_grid_params,\n)\n\n\ndef _host_hash(pos: np.ndarray) -> np.ndarray:\n    \"\"\"Reference CPU implementation of the hash for validation.\"\"\"\n    grid_min = GRID_MIN\n    grid_delta = GRID_DELTA\n    grid_res = GRID_RES.astype(np.float32)\n\n    # calcGridCell: int3((pos - grid_min) * grid_delta)\n    cell = np.floor((pos[:, :3] - grid_min) * grid_delta).astype(np.int32)\n\n    # clamp to [0, grid_res - 1]\n    cell = np.clip(cell, 0, GRID_RES - 1)\n\n    # linear hash: z * ry * rx + y * rx + x\n    rx = int(grid_res[0])\n    ry = int(grid_res[1])\n    h = cell[:, 2] * ry * rx + cell[:, 1] * rx + cell[:, 0]\n    return h.astype(np.uint32)\n\n\ndef test_grid_constants() -> None:\n    \"\"\"Verify grid sizing matches acceptance criteria.\"\"\"\n    print(\"--- Grid constant checks ---\")\n\n    np.testing.assert_array_almost_equal(GRID_MIN, [-1.0, -1.0, -1.0])\n    np.testing.assert_array_almost_equal(GRID_MAX, [1.0, 1.0, 1.0])\n    assert abs(float(CELL_SIZE) - 0.04) < 1e-7\n    np.testing.assert_array_equal(GRID_RES, [50, 50, 50])\n    np.testing.assert_array_almost_equal(GRID_DELTA, [25.0, 25.0, 25.0])\n    assert NUM_CELLS == 125_000\n    print(\"[OK] Grid constants: grid_min=(-1,-1,-1) grid_max=(1,1,1) \"\n          \"cell_size=0.04 grid_res=50 grid_delta=25 num_cells=125000\")\n\n\ndef test_grid_params_struct() -> None:\n    \"\"\"Verify GridParams numpy dtype layout.\"\"\"\n    print(\"\\n--- GridParams struct checks ---\")\n\n    # 5 float3 fields = 5 * 12 = 60 bytes\n    assert GRID_PARAMS_DTYPE.itemsize == 60, (\n        f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 60\"\n    )\n    print(f\"[OK] sizeof(GridParams) = {GRID_PARAMS_DTYPE.itemsize} bytes\")\n\n    params = build_grid_params()\n    np.testing.assert_array_almost_equal(params[0][\"grid_size\"], [2.0, 2.0, 2.0])\n    np.testing.assert_array_almost_equal(params[0][\"grid_min\"], [-1.0, -1.0, -1.0])\n    np.testing.assert_array_almost_equal(params[0][\"grid_max\"], [1.0, 1.0, 1.0])\n    np.testing.assert_array_almost_equal(params[0][\"grid_res\"], [50.0, 50.0, 50.0])\n    np.testing.assert_array_almost_equal(params[0][\"grid_delta\"], [25.0, 25.0, 25.0])\n    print(\"[OK] GridParams fields populated correctly\")\n\n\ndef test_compilation() -> None:\n    \"\"\"Verify CuPy RawModule compiles hash_sort.cu including common.cuh.\"\"\"\n    print(\"\\n--- Compilation check ---\")\n\n    module = get_module()\n    assert module is not None\n    print(\"[OK] CuPy RawModule compiled hash_sort.cu (includes common.cuh)\")\n\n    # Verify kernel function is accessible\n    kernel = module.get_function(\"K_CalcHash\")  # type: ignore[union-attr]\n    assert kernel is not None\n    print(\"[OK] K_CalcHash kernel function found\")\n\n    # Verify constant memory symbol is accessible\n    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n    assert int(d_ptr) != 0\n    print(\"[OK] c_grid constant memory symbol found\")\n\n\ndef test_100k_uniform_unit_cube() -> None:\n    \"\"\"100K particles uniformly distributed in unit cube -> valid hashes.\"\"\"\n    print(\"\\n--- 100K uniform unit-cube test ---\")\n\n    upload_grid_params()\n\n    rng = np.random.default_rng(42)\n    # Unit cube [0, 1]^3 is entirely inside grid [-1, 1]^3\n    pos_np = np.zeros((100_000, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(0.0, 1.0, size=(100_000, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h_hashes = cupy.asnumpy(hashes)\n    h_indices = cupy.asnumpy(indices)\n\n    # All hashes in [0, NUM_CELLS - 1]\n    assert h_hashes.min() >= 0, f\"Min hash = {h_hashes.min()}, expected >= 0\"\n    assert h_hashes.max() < NUM_CELLS, (\n        f\"Max hash = {h_hashes.max()}, expected < {NUM_CELLS}\"\n    )\n    print(f\"[OK] All 100K hashes in [0, {NUM_CELLS - 1}]: \"\n          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n\n    # Indices should be identity permutation\n    np.testing.assert_array_equal(h_indices, np.arange(100_000, dtype=np.uint32))\n    print(\"[OK] Indices are identity [0..99999]\")\n\n    # Cross-check against CPU reference\n    ref = _host_hash(pos_np)\n    np.testing.assert_array_equal(h_hashes, ref)\n    print(\"[OK] GPU hashes match CPU reference for all 100K particles\")\n\n\ndef test_boundary_clamping() -> None:\n    \"\"\"Particles at or outside grid boundaries produce clamped hashes.\"\"\"\n    print(\"\\n--- Boundary clamping test ---\")\n\n    upload_grid_params()\n\n    # Test positions: inside, on boundary, and outside\n    test_positions = np.array([\n        # Inside (center of grid)\n        [0.0, 0.0, 0.0, 0.0],\n        # At grid_min exactly\n        [-1.0, -1.0, -1.0, 0.0],\n        # At grid_max exactly (should clamp to res-1)\n        [1.0, 1.0, 1.0, 0.0],\n        # Far outside negative\n        [-10.0, -10.0, -10.0, 0.0],\n        # Far outside positive\n        [10.0, 10.0, 10.0, 0.0],\n        # Mixed: some axes inside, some outside\n        [0.5, -5.0, 3.0, 0.0],\n        # Just inside near grid_max\n        [0.99, 0.99, 0.99, 0.0],\n    ], dtype=np.float32)\n\n    pos_gpu = cupy.asarray(test_positions)\n    hashes, indices = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h_hashes = cupy.asnumpy(hashes)\n\n    # All hashes must be in valid range\n    for i, h in enumerate(h_hashes):\n        assert 0 <= h < NUM_CELLS, (\n            f\"Particle {i} at {test_positions[i, :3]}: hash={h}, \"\n            f\"expected in [0, {NUM_CELLS - 1}]\"\n        )\n    print(f\"[OK] All {len(test_positions)} boundary test particles have valid hashes\")\n\n    # Verify specific expected values:\n    # Particle at grid_min (-1,-1,-1): cell = (0,0,0), hash = 0\n    assert h_hashes[1] == 0, f\"grid_min hash = {h_hashes[1]}, expected 0\"\n    print(\"[OK] Particle at grid_min -> hash = 0\")\n\n    # Particle far outside negative: should clamp to (0,0,0), hash = 0\n    assert h_hashes[3] == 0, f\"far-negative hash = {h_hashes[3]}, expected 0\"\n    print(\"[OK] Particle far outside negative -> hash = 0 (clamped)\")\n\n    # Particle far outside positive: should clamp to (49,49,49)\n    max_hash = 49 * 50 * 50 + 49 * 50 + 49  # = 124999\n    assert h_hashes[4] == max_hash, (\n        f\"far-positive hash = {h_hashes[4]}, expected {max_hash}\"\n    )\n    print(f\"[OK] Particle far outside positive -> hash = {max_hash} (clamped to max)\")\n\n    # Particle at grid_max (1,1,1): cell unclamped = (50,50,50), clamped to (49,49,49)\n    assert h_hashes[2] == max_hash, (\n        f\"grid_max hash = {h_hashes[2]}, expected {max_hash}\"\n    )\n    print(f\"[OK] Particle at grid_max -> hash = {max_hash} (clamped)\")\n\n    # Cross-check all against CPU reference\n    ref = _host_hash(test_positions)\n    np.testing.assert_array_equal(h_hashes, ref)\n    print(\"[OK] Boundary hashes match CPU reference\")\n\n\ndef test_500k_no_errors() -> None:\n    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n    print(\"\\n--- 500K particle stress test ---\")\n\n    upload_grid_params()\n\n    rng = np.random.default_rng(123)\n    # Distribute across entire grid range [-1, 1]^3\n    pos_np = np.zeros((500_000, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(500_000, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h_hashes = cupy.asnumpy(hashes)\n\n    # All valid\n    assert h_hashes.min() >= 0\n    assert h_hashes.max() < NUM_CELLS\n    print(f\"[OK] 500K particles hashed without errors: \"\n          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n\n    # Spot-check against CPU reference (first 1000)\n    ref = _host_hash(pos_np[:1000])\n    np.testing.assert_array_equal(h_hashes[:1000], ref)\n    print(\"[OK] First 1000 hashes match CPU reference\")\n\n\ndef test_known_position() -> None:\n    \"\"\"Verify hash for a particle with a known grid cell.\"\"\"\n    print(\"\\n--- Known position test ---\")\n\n    upload_grid_params()\n\n    # Position (0.02, 0.02, 0.02):\n    #   cell = int3((0.02 - (-1)) * 25, (0.02 - (-1)) * 25, (0.02 - (-1)) * 25)\n    #        = int3(25.5, 25.5, 25.5) = (25, 25, 25)\n    #   hash = 25 * 50 * 50 + 25 * 50 + 25 = 62500 + 1250 + 25 = 63775\n    pos = np.array([[0.02, 0.02, 0.02, 0.0]], dtype=np.float32)\n    pos_gpu = cupy.asarray(pos)\n\n    hashes, _ = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h = int(cupy.asnumpy(hashes)[0])\n    expected = 25 * 50 * 50 + 25 * 50 + 25  # 63775\n    assert h == expected, f\"hash = {h}, expected {expected}\"\n    print(f\"[OK] Position (0.02, 0.02, 0.02) -> cell (25,25,25) -> hash = {h}\")\n\n\ndef main() -> None:\n    test_grid_constants()\n    test_grid_params_struct()\n    test_compilation()\n    test_known_position()\n    test_100k_uniform_unit_cube()\n    test_boundary_clamping()\n    test_500k_no_errors()\n    print(\"\\n=== ALL CHECKS PASSED ===\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":275,"startLine":1,"totalLines":275}}}

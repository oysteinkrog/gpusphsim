{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gh9mjigptgiJz74QqnexVz","type":"tool_result","content":"     1→\"\"\"Grid hashing kernel for spatial partitioning of SPH particles.\n     2→\n     3→Compiles physics/kernels/hash_sort.cu via CuPy RawModule and provides\n     4→functions to upload GridParams to ``__constant__ GridParams c_grid`` and\n     5→launch the ``K_CalcHash`` kernel.\n     6→\n     7→Grid sizing (from acceptance criteria)\n     8→--------------------------------------\n     9→- grid_min = (-1, -1, -1), grid_max = (1, 1, 1)\n    10→- cell_size = h = 0.04\n    11→- grid_res  = 50 per axis\n    12→- grid_delta = (25, 25, 25)   (= grid_res / grid_size = 50/2)\n    13→- num_cells  = 125000          (= 50^3)\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import os\n    19→from typing import Optional, Tuple\n    20→\n    21→import cupy\n    22→import numpy as np\n    23→\n    24→# ---------------------------------------------------------------------------\n    25→# Grid constants\n    26→# ---------------------------------------------------------------------------\n    27→\n    28→GRID_MIN = np.array([-1.0, -1.0, -1.0], dtype=np.float32)\n    29→GRID_MAX = np.array([1.0, 1.0, 1.0], dtype=np.float32)\n    30→CELL_SIZE = np.float32(0.04)\n    31→GRID_RES = np.array([50, 50, 50], dtype=np.int32)\n    32→GRID_DELTA = np.array([25.0, 25.0, 25.0], dtype=np.float32)  # grid_res / grid_size\n    33→NUM_CELLS = 125_000  # 50 * 50 * 50\n    34→\n    35→# ---------------------------------------------------------------------------\n    36→# Numpy dtype matching ``struct GridParams`` in common.cuh\n    37→#\n    38→# struct GridParams {\n    39→#     float3 grid_min;    // 12 bytes\n    40→#     float3 grid_max;    // 12 bytes\n    41→#     int3   grid_res;    // 12 bytes\n    42→#     float3 grid_delta;  // 12 bytes\n    43→#     int    num_cells;   //  4 bytes\n    44→# };                      // Total: 52 bytes\n    45→#\n    46→# CUDA float3/int3 are 12 bytes with no trailing pad. align=False required.\n    47→# ---------------------------------------------------------------------------\n    48→\n    49→GRID_PARAMS_DTYPE = np.dtype(\n    50→    [\n    51→        (\"grid_min\", np.float32, (3,)),\n    52→        (\"grid_max\", np.float32, (3,)),\n    53→        (\"grid_res\", np.int32, (3,)),\n    54→        (\"grid_delta\", np.float32, (3,)),\n    55→        (\"num_cells\", np.int32),\n    56→    ],\n    57→    align=False,\n    58→)\n    59→\n    60→assert GRID_PARAMS_DTYPE.itemsize == 52, (\n    61→    f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 52\"\n    62→)\n    63→\n    64→\n    65→def build_grid_params() -> np.ndarray:\n    66→    \"\"\"Build a single GridParams struct as a numpy structured array.\"\"\"\n    67→    params = np.zeros(1, dtype=GRID_PARAMS_DTYPE)\n    68→    params[0][\"grid_min\"] = GRID_MIN\n    69→    params[0][\"grid_max\"] = GRID_MAX\n    70→    params[0][\"grid_res\"] = GRID_RES\n    71→    params[0][\"grid_delta\"] = GRID_DELTA\n    72→    params[0][\"num_cells\"] = NUM_CELLS\n    73→    return params\n    74→\n    75→\n    76→# ---------------------------------------------------------------------------\n    77→# CuPy RawModule compilation\n    78→# ---------------------------------------------------------------------------\n    79→\n    80→_module: Optional[object] = None\n    81→\n    82→\n    83→def _ensure_ptx_if_needed() -> None:\n    84→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    85→    from cupy.cuda import compiler as _compiler\n    86→    from cupy.cuda import device as _device\n    87→\n    88→    gpu_cc = _device.Device().compute_capability\n    89→    nvrtc_max = _compiler._get_max_compute_capability()\n    90→    if int(gpu_cc) > int(nvrtc_max):\n    91→        _compiler._use_ptx = True\n    92→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    93→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    94→        if hasattr(_compiler._get_arch, \"_cache\"):\n    95→            _compiler._get_arch._cache = {}\n    96→\n    97→\n    98→def _get_module() -> \"object\":\n    99→    \"\"\"Compile (or return cached) CuPy RawModule from hash_sort.cu.\"\"\"\n   100→    global _module\n   101→    if _module is not None:\n   102→        return _module\n   103→\n   104→    _ensure_ptx_if_needed()\n   105→\n   106→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   107→    cu_path = os.path.join(kernel_dir, \"hash_sort.cu\")\n   108→    with open(cu_path) as f:\n   109→        source = f.read()\n   110→\n   111→    _module = cupy.RawModule(\n   112→        code=source,\n   113→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n   114→    )\n   115→    return _module\n   116→\n   117→\n   118→def get_module() -> \"object\":\n   119→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n   120→    return _get_module()\n   121→\n   122→\n   123→# ---------------------------------------------------------------------------\n   124→# Constant memory upload\n   125→# ---------------------------------------------------------------------------\n   126→\n   127→\n   128→def upload_grid_params(params: Optional[np.ndarray] = None) -> None:\n   129→    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\n   130→\n   131→    Parameters\n   132→    ----------\n   133→    params : numpy structured array, optional\n   134→        A single GridParams element.  If *None*, uses ``build_grid_params()``.\n   135→    \"\"\"\n   136→    if params is None:\n   137→        params = build_grid_params()\n   138→\n   139→    module = _get_module()\n   140→    d_ptr = module.get_global(\"c_grid\")\n   141→\n   142→    cupy.cuda.runtime.memcpy(\n   143→        int(d_ptr),\n   144→        params.ctypes.data,\n   145→        params.nbytes,\n   146→        1,  # cudaMemcpyHostToDevice\n   147→    )\n   148→\n   149→\n   150→# ---------------------------------------------------------------------------\n   151→# Kernel launch\n   152→# ---------------------------------------------------------------------------\n   153→\n   154→BLOCK_SIZE = 256\n   155→\n   156→\n   157→def calc_hash(\n   158→    positions: cupy.ndarray,\n   159→) -> Tuple[cupy.ndarray, cupy.ndarray]:\n   160→    \"\"\"Launch K_CalcHash and return (hashes, indices) arrays.\n   161→\n   162→    Parameters\n   163→    ----------\n   164→    positions : cupy.ndarray\n   165→        (N, 4) float32 array of particle positions (x, y, z, w).\n   166→\n   167→    Returns\n   168→    -------\n   169→    hashes : cupy.ndarray, shape (N,), dtype uint32\n   170→    indices : cupy.ndarray, shape (N,), dtype uint32\n   171→    \"\"\"\n   172→    n = positions.shape[0]\n   173→    hashes = cupy.empty(n, dtype=cupy.uint32)\n   174→    indices = cupy.empty(n, dtype=cupy.uint32)\n   175→\n   176→    module = _get_module()\n   177→    kernel = module.get_function(\"K_CalcHash\")\n   178→\n   179→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   180→    block = (BLOCK_SIZE,)\n   181→\n   182→    kernel(grid, block, (np.uint32(n), positions, hashes, indices))\n   183→\n   184→    return hashes, indices\n   185→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"4f34ec55-60dd-4138-9f3f-3caa2dc4a5d0","uuid":"649e5752-5cbb-49e7-bca3-ade88127dd88","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/hash_sort.py","content":"\"\"\"Grid hashing kernel for spatial partitioning of SPH particles.\n\nCompiles physics/kernels/hash_sort.cu via CuPy RawModule and provides\nfunctions to upload GridParams to ``__constant__ GridParams c_grid`` and\nlaunch the ``K_CalcHash`` kernel.\n\nGrid sizing (from acceptance criteria)\n--------------------------------------\n- grid_min = (-1, -1, -1), grid_max = (1, 1, 1)\n- cell_size = h = 0.04\n- grid_res  = 50 per axis\n- grid_delta = (25, 25, 25)   (= grid_res / grid_size = 50/2)\n- num_cells  = 125000          (= 50^3)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom typing import Optional, Tuple\n\nimport cupy\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# Grid constants\n# ---------------------------------------------------------------------------\n\nGRID_MIN = np.array([-1.0, -1.0, -1.0], dtype=np.float32)\nGRID_MAX = np.array([1.0, 1.0, 1.0], dtype=np.float32)\nCELL_SIZE = np.float32(0.04)\nGRID_RES = np.array([50, 50, 50], dtype=np.int32)\nGRID_DELTA = np.array([25.0, 25.0, 25.0], dtype=np.float32)  # grid_res / grid_size\nNUM_CELLS = 125_000  # 50 * 50 * 50\n\n# ---------------------------------------------------------------------------\n# Numpy dtype matching ``struct GridParams`` in common.cuh\n#\n# struct GridParams {\n#     float3 grid_min;    // 12 bytes\n#     float3 grid_max;    // 12 bytes\n#     int3   grid_res;    // 12 bytes\n#     float3 grid_delta;  // 12 bytes\n#     int    num_cells;   //  4 bytes\n# };                      // Total: 52 bytes\n#\n# CUDA float3/int3 are 12 bytes with no trailing pad. align=False required.\n# ---------------------------------------------------------------------------\n\nGRID_PARAMS_DTYPE = np.dtype(\n    [\n        (\"grid_min\", np.float32, (3,)),\n        (\"grid_max\", np.float32, (3,)),\n        (\"grid_res\", np.int32, (3,)),\n        (\"grid_delta\", np.float32, (3,)),\n        (\"num_cells\", np.int32),\n    ],\n    align=False,\n)\n\nassert GRID_PARAMS_DTYPE.itemsize == 52, (\n    f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 52\"\n)\n\n\ndef build_grid_params() -> np.ndarray:\n    \"\"\"Build a single GridParams struct as a numpy structured array.\"\"\"\n    params = np.zeros(1, dtype=GRID_PARAMS_DTYPE)\n    params[0][\"grid_min\"] = GRID_MIN\n    params[0][\"grid_max\"] = GRID_MAX\n    params[0][\"grid_res\"] = GRID_RES\n    params[0][\"grid_delta\"] = GRID_DELTA\n    params[0][\"num_cells\"] = NUM_CELLS\n    return params\n\n\n# ---------------------------------------------------------------------------\n# CuPy RawModule compilation\n# ---------------------------------------------------------------------------\n\n_module: Optional[object] = None\n\n\ndef _ensure_ptx_if_needed() -> None:\n    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    from cupy.cuda import compiler as _compiler\n    from cupy.cuda import device as _device\n\n    gpu_cc = _device.Device().compute_capability\n    nvrtc_max = _compiler._get_max_compute_capability()\n    if int(gpu_cc) > int(nvrtc_max):\n        _compiler._use_ptx = True\n        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n        if hasattr(_compiler._get_arch, \"_cache\"):\n            _compiler._get_arch._cache = {}\n\n\ndef _get_module() -> \"object\":\n    \"\"\"Compile (or return cached) CuPy RawModule from hash_sort.cu.\"\"\"\n    global _module\n    if _module is not None:\n        return _module\n\n    _ensure_ptx_if_needed()\n\n    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    cu_path = os.path.join(kernel_dir, \"hash_sort.cu\")\n    with open(cu_path) as f:\n        source = f.read()\n\n    _module = cupy.RawModule(\n        code=source,\n        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    )\n    return _module\n\n\ndef get_module() -> \"object\":\n    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    return _get_module()\n\n\n# ---------------------------------------------------------------------------\n# Constant memory upload\n# ---------------------------------------------------------------------------\n\n\ndef upload_grid_params(params: Optional[np.ndarray] = None) -> None:\n    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\n\n    Parameters\n    ----------\n    params : numpy structured array, optional\n        A single GridParams element.  If *None*, uses ``build_grid_params()``.\n    \"\"\"\n    if params is None:\n        params = build_grid_params()\n\n    module = _get_module()\n    d_ptr = module.get_global(\"c_grid\")\n\n    cupy.cuda.runtime.memcpy(\n        int(d_ptr),\n        params.ctypes.data,\n        params.nbytes,\n        1,  # cudaMemcpyHostToDevice\n    )\n\n\n# ---------------------------------------------------------------------------\n# Kernel launch\n# ---------------------------------------------------------------------------\n\nBLOCK_SIZE = 256\n\n\ndef calc_hash(\n    positions: cupy.ndarray,\n) -> Tuple[cupy.ndarray, cupy.ndarray]:\n    \"\"\"Launch K_CalcHash and return (hashes, indices) arrays.\n\n    Parameters\n    ----------\n    positions : cupy.ndarray\n        (N, 4) float32 array of particle positions (x, y, z, w).\n\n    Returns\n    -------\n    hashes : cupy.ndarray, shape (N,), dtype uint32\n    indices : cupy.ndarray, shape (N,), dtype uint32\n    \"\"\"\n    n = positions.shape[0]\n    hashes = cupy.empty(n, dtype=cupy.uint32)\n    indices = cupy.empty(n, dtype=cupy.uint32)\n\n    module = _get_module()\n    kernel = module.get_function(\"K_CalcHash\")\n\n    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n    block = (BLOCK_SIZE,)\n\n    kernel(grid, block, (np.uint32(n), positions, hashes, indices))\n\n    return hashes, indices\n","numLines":185,"startLine":1,"totalLines":185}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MN92JjtXFsWVqWWXsdmFUJ","type":"tool_result","content":"     1→\"\"\"World state management for Falling Sand 3D.\n     2→\n     3→Manages CuPy arrays for all per-particle SoA data. Supports configurable\n     4→max_particles at startup, spawning particles in sphere/cube shapes, and\n     5→tracking num_active via counter.\n     6→\n     7→All arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\n     8→DEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→from typing import Tuple\n    14→\n    15→import cupy as cp\n    16→import numpy as np\n    17→\n    18→from materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n    19→\n    20→# packed_info bitfield macros (mirrors common.cuh)\n    21→_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n    22→\n    23→# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\n    24→DEFAULT_SPACING = 0.02\n    25→\n    26→# Default temperatures for hot materials (Kelvin)\n    27→_DEFAULT_TEMPS = {\n    28→    7: 1500.0,   # LAVA\n    29→    14: 1200.0,  # FIRE\n    30→    12: 373.0,   # STEAM\n    31→    13: 500.0,   # SMOKE\n    32→}\n    33→\n    34→# Ambient temperature\n    35→T_AMBIENT = 293.0\n    36→\n    37→\n    38→class World:\n    39→    \"\"\"Manages all per-particle SoA arrays on GPU.\n    40→\n    41→    Parameters\n    42→    ----------\n    43→    max_particles : int\n    44→        Maximum number of particles to allocate for (default 500000).\n    45→    \"\"\"\n    46→\n    47→    def __init__(self, max_particles: int = 500_000) -> None:\n    48→        self.max_particles: int = max_particles\n    49→        self._high_water: int = 0  # one past last allocated slot\n    50→        self._allocate()\n    51→\n    52→    def _allocate(self) -> None:\n    53→        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n    54→        n = self.max_particles\n    55→        # float4 arrays (stored as (n, 4) float32)\n    56→        self.position = cp.zeros((n, 4), dtype=cp.float32)\n    57→        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n    58→        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n    59→        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n    60→        self.color = cp.zeros((n, 4), dtype=cp.float32)\n    61→        # float arrays\n    62→        self.density = cp.zeros(n, dtype=cp.float32)\n    63→        self.mass = cp.zeros(n, dtype=cp.float32)\n    64→        self.temperature = cp.zeros(n, dtype=cp.float32)\n    65→        self.health = cp.zeros(n, dtype=cp.float32)\n    66→        self.lifetime = cp.zeros(n, dtype=cp.float32)\n    67→        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n    68→        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n    69→        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n    70→        # uint32 arrays\n    71→        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n    72→        # uint8 arrays\n    73→        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n    74→\n    75→    def resize(self, new_max: int) -> None:\n    76→        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n    77→        self.max_particles = new_max\n    78→        self._high_water = 0\n    79→        self._allocate()\n    80→\n    81→    @property\n    82→    def num_active(self) -> int:\n    83→        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n    84→        if self._high_water == 0:\n    85→            return 0\n    86→        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n    87→\n    88→    def spawn_sphere(\n    89→        self,\n    90→        center: Tuple[float, float, float],\n    91→        radius: float,\n    92→        material_id: int,\n    93→        count: int,\n    94→    ) -> int:\n    95→        \"\"\"Spawn particles with random positions inside a sphere.\n    96→\n    97→        Returns the number of particles actually spawned (may be less than\n    98→        count if max_particles is reached).\n    99→        \"\"\"\n   100→        if material_id not in MATERIALS:\n   101→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   102→\n   103→        available = self.max_particles - self._high_water\n   104→        actual = min(count, available)\n   105→        if actual <= 0:\n   106→            return 0\n   107→\n   108→        mat = MATERIALS[material_id]\n   109→        start = self._high_water\n   110→\n   111→        # Generate random positions in unit sphere using rejection sampling on GPU\n   112→        # Over-generate by ~2x to account for rejection, then take first `actual`\n   113→        needed = actual\n   114→        positions_list = []\n   115→        remaining = needed\n   116→        while remaining > 0:\n   117→            batch = int(remaining * 2.0) + 128\n   118→            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n   119→            r_sq = cp.sum(pts * pts, axis=1)\n   120→            inside = pts[r_sq <= 1.0]\n   121→            take = min(len(inside), remaining)\n   122→            if take > 0:\n   123→                positions_list.append(inside[:take])\n   124→                remaining -= take\n   125→\n   126→        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n   127→        # Scale to desired radius and translate to center\n   128→        cx, cy, cz = center\n   129→        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n   130→        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n   131→        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n   132→\n   133→        sl = slice(start, start + actual)\n   134→        self.position[sl, 0] = sphere_pts[:, 0]\n   135→        self.position[sl, 1] = sphere_pts[:, 1]\n   136→        self.position[sl, 2] = sphere_pts[:, 2]\n   137→        self.position[sl, 3] = 0.0\n   138→\n   139→        self.velocity[sl] = 0.0\n   140→        self.veleval[sl] = 0.0\n   141→        self.sph_force[sl] = 0.0\n   142→\n   143→        # mass = rho0 * spacing^3\n   144→        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n   145→        self.mass[sl] = particle_mass\n   146→\n   147→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   148→        self.packed_info[sl] = cp.uint32(packed)\n   149→\n   150→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   151→        self.temperature[sl] = temp\n   152→        self.health[sl] = 1.0\n   153→        self.lifetime[sl] = 0.0\n   154→        self.shear_rate[sl] = 0.0\n   155→        self.exposure_heat[sl] = 0.0\n   156→        self.exposure_corrode[sl] = 0.0\n   157→\n   158→        self.color[sl, 0] = mat.color_r\n   159→        self.color[sl, 1] = mat.color_g\n   160→        self.color[sl, 2] = mat.color_b\n   161→        self.color[sl, 3] = 1.0\n   162→\n   163→        self.density[sl] = mat.rest_density\n   164→        self.sleep_counter[sl] = 0\n   165→\n   166→        self._high_water += actual\n   167→        return actual\n   168→\n   169→    def spawn_cube(\n   170→        self,\n   171→        min_corner: Tuple[float, float, float],\n   172→        max_corner: Tuple[float, float, float],\n   173→        material_id: int,\n   174→        spacing: float = DEFAULT_SPACING,\n   175→    ) -> int:\n   176→        \"\"\"Spawn particles on a regular grid within a cube.\n   177→\n   178→        Returns the number of particles actually spawned.\n   179→        \"\"\"\n   180→        if material_id not in MATERIALS:\n   181→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   182→\n   183→        # Build grid positions on CPU (small overhead, predictable count)\n   184→        x0, y0, z0 = min_corner\n   185→        x1, y1, z1 = max_corner\n   186→        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n   187→        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n   188→        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n   189→\n   190→        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n   191→            return 0\n   192→\n   193→        total = len(xs) * len(ys) * len(zs)\n   194→        available = self.max_particles - self._high_water\n   195→        actual = min(total, available)\n   196→        if actual <= 0:\n   197→            return 0\n   198→\n   199→        # Generate meshgrid positions\n   200→        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n   201→        positions = np.column_stack([\n   202→            gx.ravel()[:actual],\n   203→            gy.ravel()[:actual],\n   204→            gz.ravel()[:actual],\n   205→        ]).astype(np.float32)\n   206→\n   207→        actual = len(positions)\n   208→        if actual == 0:\n   209→            return 0\n   210→\n   211→        mat = MATERIALS[material_id]\n   212→        start = self._high_water\n   213→        sl = slice(start, start + actual)\n   214→\n   215→        d_positions = cp.asarray(positions)\n   216→        self.position[sl, 0] = d_positions[:, 0]\n   217→        self.position[sl, 1] = d_positions[:, 1]\n   218→        self.position[sl, 2] = d_positions[:, 2]\n   219→        self.position[sl, 3] = 0.0\n   220→\n   221→        self.velocity[sl] = 0.0\n   222→        self.veleval[sl] = 0.0\n   223→        self.sph_force[sl] = 0.0\n   224→\n   225→        particle_mass = mat.rest_density * (spacing ** 3)\n   226→        self.mass[sl] = particle_mass\n   227→\n   228→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   229→        self.packed_info[sl] = cp.uint32(packed)\n   230→\n   231→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   232→        self.temperature[sl] = temp\n   233→        self.health[sl] = 1.0\n   234→        self.lifetime[sl] = 0.0\n   235→        self.shear_rate[sl] = 0.0\n   236→        self.exposure_heat[sl] = 0.0\n   237→        self.exposure_corrode[sl] = 0.0\n   238→\n   239→        self.color[sl, 0] = mat.color_r\n   240→        self.color[sl, 1] = mat.color_g\n   241→        self.color[sl, 2] = mat.color_b\n   242→        self.color[sl, 3] = 1.0\n   243→\n   244→        self.density[sl] = mat.rest_density\n   245→        self.sleep_counter[sl] = 0\n   246→\n   247→        self._high_water += actual\n   248→        return actual\n   249→\n   250→    def kill_in_sphere(\n   251→        self,\n   252→        center: Tuple[float, float, float],\n   253→        radius: float,\n   254→    ) -> int:\n   255→        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n   256→\n   257→        Returns the number of particles killed.\n   258→        \"\"\"\n   259→        if self._high_water == 0:\n   260→            return 0\n   261→\n   262→        n = self._high_water\n   263→        cx, cy, cz = center\n   264→        dx = self.position[:n, 0] - cx\n   265→        dy = self.position[:n, 1] - cy\n   266→        dz = self.position[:n, 2] - cz\n   267→        dist_sq = dx * dx + dy * dy + dz * dz\n   268→\n   269→        mask = dist_sq <= (radius * radius)\n   270→        # Only kill non-DEAD particles\n   271→        mask = mask & (self.packed_info[:n] != 0)\n   272→        killed = int(cp.sum(mask))\n   273→\n   274→        if killed > 0:\n   275→            self.packed_info[:n][mask] = cp.uint32(0)\n   276→\n   277→        return killed\n   278→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"4f34ec55-60dd-4138-9f3f-3caa2dc4a5d0","uuid":"bfa33c0e-fbd5-4f79-b300-0f56183a46e7","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/world.py","content":"\"\"\"World state management for Falling Sand 3D.\n\nManages CuPy arrays for all per-particle SoA data. Supports configurable\nmax_particles at startup, spawning particles in sphere/cube shapes, and\ntracking num_active via counter.\n\nAll arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\nDEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Tuple\n\nimport cupy as cp\nimport numpy as np\n\nfrom materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n\n# packed_info bitfield macros (mirrors common.cuh)\n_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n\n# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\nDEFAULT_SPACING = 0.02\n\n# Default temperatures for hot materials (Kelvin)\n_DEFAULT_TEMPS = {\n    7: 1500.0,   # LAVA\n    14: 1200.0,  # FIRE\n    12: 373.0,   # STEAM\n    13: 500.0,   # SMOKE\n}\n\n# Ambient temperature\nT_AMBIENT = 293.0\n\n\nclass World:\n    \"\"\"Manages all per-particle SoA arrays on GPU.\n\n    Parameters\n    ----------\n    max_particles : int\n        Maximum number of particles to allocate for (default 500000).\n    \"\"\"\n\n    def __init__(self, max_particles: int = 500_000) -> None:\n        self.max_particles: int = max_particles\n        self._high_water: int = 0  # one past last allocated slot\n        self._allocate()\n\n    def _allocate(self) -> None:\n        \"\"\"Allocate all SoA arrays as CuPy arrays of max_particles size.\"\"\"\n        n = self.max_particles\n        # float4 arrays (stored as (n, 4) float32)\n        self.position = cp.zeros((n, 4), dtype=cp.float32)\n        self.velocity = cp.zeros((n, 4), dtype=cp.float32)\n        self.veleval = cp.zeros((n, 4), dtype=cp.float32)\n        self.sph_force = cp.zeros((n, 4), dtype=cp.float32)\n        self.color = cp.zeros((n, 4), dtype=cp.float32)\n        # float arrays\n        self.density = cp.zeros(n, dtype=cp.float32)\n        self.mass = cp.zeros(n, dtype=cp.float32)\n        self.temperature = cp.zeros(n, dtype=cp.float32)\n        self.health = cp.zeros(n, dtype=cp.float32)\n        self.lifetime = cp.zeros(n, dtype=cp.float32)\n        self.shear_rate = cp.zeros(n, dtype=cp.float32)\n        self.exposure_heat = cp.zeros(n, dtype=cp.float32)\n        self.exposure_corrode = cp.zeros(n, dtype=cp.float32)\n        # uint32 arrays\n        self.packed_info = cp.zeros(n, dtype=cp.uint32)\n        # uint8 arrays\n        self.sleep_counter = cp.zeros(n, dtype=cp.uint8)\n\n    def resize(self, new_max: int) -> None:\n        \"\"\"Reallocate all arrays for a new max_particles. Kills all particles.\"\"\"\n        self.max_particles = new_max\n        self._high_water = 0\n        self._allocate()\n\n    @property\n    def num_active(self) -> int:\n        \"\"\"Count of non-DEAD particles (packed_info != 0).\"\"\"\n        if self._high_water == 0:\n            return 0\n        return int(cp.count_nonzero(self.packed_info[:self._high_water]))\n\n    def spawn_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n        material_id: int,\n        count: int,\n    ) -> int:\n        \"\"\"Spawn particles with random positions inside a sphere.\n\n        Returns the number of particles actually spawned (may be less than\n        count if max_particles is reached).\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        available = self.max_particles - self._high_water\n        actual = min(count, available)\n        if actual <= 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n\n        # Generate random positions in unit sphere using rejection sampling on GPU\n        # Over-generate by ~2x to account for rejection, then take first `actual`\n        needed = actual\n        positions_list = []\n        remaining = needed\n        while remaining > 0:\n            batch = int(remaining * 2.0) + 128\n            pts = cp.random.uniform(-1.0, 1.0, (batch, 3)).astype(cp.float32)\n            r_sq = cp.sum(pts * pts, axis=1)\n            inside = pts[r_sq <= 1.0]\n            take = min(len(inside), remaining)\n            if take > 0:\n                positions_list.append(inside[:take])\n                remaining -= take\n\n        sphere_pts = cp.concatenate(positions_list, axis=0)[:actual]\n        # Scale to desired radius and translate to center\n        cx, cy, cz = center\n        sphere_pts[:, 0] = sphere_pts[:, 0] * radius + cx\n        sphere_pts[:, 1] = sphere_pts[:, 1] * radius + cy\n        sphere_pts[:, 2] = sphere_pts[:, 2] * radius + cz\n\n        sl = slice(start, start + actual)\n        self.position[sl, 0] = sphere_pts[:, 0]\n        self.position[sl, 1] = sphere_pts[:, 1]\n        self.position[sl, 2] = sphere_pts[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        # mass = rho0 * spacing^3\n        particle_mass = mat.rest_density * (DEFAULT_SPACING ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def spawn_cube(\n        self,\n        min_corner: Tuple[float, float, float],\n        max_corner: Tuple[float, float, float],\n        material_id: int,\n        spacing: float = DEFAULT_SPACING,\n    ) -> int:\n        \"\"\"Spawn particles on a regular grid within a cube.\n\n        Returns the number of particles actually spawned.\n        \"\"\"\n        if material_id not in MATERIALS:\n            raise ValueError(f\"Unknown material_id: {material_id}\")\n\n        # Build grid positions on CPU (small overhead, predictable count)\n        x0, y0, z0 = min_corner\n        x1, y1, z1 = max_corner\n        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n\n        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n            return 0\n\n        total = len(xs) * len(ys) * len(zs)\n        available = self.max_particles - self._high_water\n        actual = min(total, available)\n        if actual <= 0:\n            return 0\n\n        # Generate meshgrid positions\n        gx, gy, gz = np.meshgrid(xs, ys, zs, indexing='ij')\n        positions = np.column_stack([\n            gx.ravel()[:actual],\n            gy.ravel()[:actual],\n            gz.ravel()[:actual],\n        ]).astype(np.float32)\n\n        actual = len(positions)\n        if actual == 0:\n            return 0\n\n        mat = MATERIALS[material_id]\n        start = self._high_water\n        sl = slice(start, start + actual)\n\n        d_positions = cp.asarray(positions)\n        self.position[sl, 0] = d_positions[:, 0]\n        self.position[sl, 1] = d_positions[:, 1]\n        self.position[sl, 2] = d_positions[:, 2]\n        self.position[sl, 3] = 0.0\n\n        self.velocity[sl] = 0.0\n        self.veleval[sl] = 0.0\n        self.sph_force[sl] = 0.0\n\n        particle_mass = mat.rest_density * (spacing ** 3)\n        self.mass[sl] = particle_mass\n\n        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n        self.packed_info[sl] = cp.uint32(packed)\n\n        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n        self.temperature[sl] = temp\n        self.health[sl] = 1.0\n        self.lifetime[sl] = 0.0\n        self.shear_rate[sl] = 0.0\n        self.exposure_heat[sl] = 0.0\n        self.exposure_corrode[sl] = 0.0\n\n        self.color[sl, 0] = mat.color_r\n        self.color[sl, 1] = mat.color_g\n        self.color[sl, 2] = mat.color_b\n        self.color[sl, 3] = 1.0\n\n        self.density[sl] = mat.rest_density\n        self.sleep_counter[sl] = 0\n\n        self._high_water += actual\n        return actual\n\n    def kill_in_sphere(\n        self,\n        center: Tuple[float, float, float],\n        radius: float,\n    ) -> int:\n        \"\"\"Mark particles within a sphere as DEAD (packed_info=0).\n\n        Returns the number of particles killed.\n        \"\"\"\n        if self._high_water == 0:\n            return 0\n\n        n = self._high_water\n        cx, cy, cz = center\n        dx = self.position[:n, 0] - cx\n        dy = self.position[:n, 1] - cy\n        dz = self.position[:n, 2] - cz\n        dist_sq = dx * dx + dy * dy + dz * dz\n\n        mask = dist_sq <= (radius * radius)\n        # Only kill non-DEAD particles\n        mask = mask & (self.packed_info[:n] != 0)\n        killed = int(cp.sum(mask))\n\n        if killed > 0:\n            self.packed_info[:n][mask] = cp.uint32(0)\n\n        return killed\n","numLines":278,"startLine":1,"totalLines":278}}}

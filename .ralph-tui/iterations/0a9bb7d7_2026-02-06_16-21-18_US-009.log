{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CjPFLsxMS5qEb5oCGoTs51","type":"tool_result","content":"     1→/*\n     2→ * hash_sort.cu -- K_CalcHash kernel for spatial grid hashing.\n     3→ *\n     4→ * Ported from SPHSimLib/K_UniformGrid_Utils.inl calcGridCell + calcGridHash\n     5→ * (linear, NOT Morton). Each thread computes the grid cell for one particle\n     6→ * and writes a hash key + original index.\n     7→ *\n     8→ * GridParams read from __constant__ c_grid declared in common.cuh.\n     9→ */\n    10→\n    11→#include \"common.cuh\"\n    12→\n    13→// Compute grid cell coordinates from a world-space position.\n    14→// Ported from SPHSimLib/K_UniformGrid_Utils.inl::calcGridCell.\n    15→__device__ inline int3 calcGridCell(float3 p) {\n    16→    return make_int3(\n    17→        (int)((p.x - c_grid.grid_min.x) * c_grid.grid_delta.x),\n    18→        (int)((p.y - c_grid.grid_min.y) * c_grid.grid_delta.y),\n    19→        (int)((p.z - c_grid.grid_min.z) * c_grid.grid_delta.z)\n    20→    );\n    21→}\n    22→\n    23→// Clamp grid cell to valid range [0, grid_res-1].\n    24→__device__ inline int3 clampCell(int3 cell) {\n    25→    cell.x = max(0, min(cell.x, c_grid.grid_res.x - 1));\n    26→    cell.y = max(0, min(cell.y, c_grid.grid_res.y - 1));\n    27→    cell.z = max(0, min(cell.z, c_grid.grid_res.z - 1));\n    28→    return cell;\n    29→}\n    30→\n    31→// Linear hash: z * res_y * res_x + y * res_x + x\n    32→// Ported from SPHSimLib/K_UniformGrid_Utils.inl::calcGridHash (non-Morton).\n    33→__device__ inline uint calcGridHash(int3 cell) {\n    34→    return (uint)(cell.z * c_grid.grid_res.y * c_grid.grid_res.x\n    35→                + cell.y * c_grid.grid_res.x\n    36→                + cell.x);\n    37→}\n    38→\n    39→// K_CalcHash: each thread computes the grid hash for one particle.\n    40→// Positions are float4 (x,y,z,w) where w is unused.\n    41→extern \"C\" __global__\n    42→void K_CalcHash(uint numParticles,\n    43→                const float4* __restrict__ positions,\n    44→                uint* __restrict__ hashes,\n    45→                uint* __restrict__ indices) {\n    46→    uint idx = blockIdx.x * blockDim.x + threadIdx.x;\n    47→    if (idx >= numParticles) return;\n    48→\n    49→    float4 p4 = positions[idx];\n    50→    float3 p = make_float3(p4.x, p4.y, p4.z);\n    51→\n    52→    int3 cell = calcGridCell(p);\n    53→    cell = clampCell(cell);\n    54→    uint hash = calcGridHash(cell);\n    55→\n    56→    hashes[idx] = hash;\n    57→    indices[idx] = idx;\n    58→}\n    59→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01A8Hw16a6pwLWKH19vVg9CD","session_id":"4f34ec55-60dd-4138-9f3f-3caa2dc4a5d0","uuid":"64ab38b2-9421-4697-ac82-f1c2b191b5c3"}

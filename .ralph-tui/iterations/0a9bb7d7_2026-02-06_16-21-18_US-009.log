{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012S7ub2Xus5Nt8t4SKcxyg1","type":"tool_result","content":"     1→\"\"\"Integration test for hash_sort.py -- K_CalcHash grid hashing kernel.\n     2→\n     3→Acceptance criteria:\n     4→  - K_CalcHash computes grid cell: cell = int3((pos - grid_min) * grid_delta),\n     5→    clamped to [0, grid_res-1]\n     6→  - Hash = cell.z * grid_res.y * grid_res.x + cell.y * grid_res.x + cell.x\n     7→  - Grid parameters read from __constant__ GridParams c_grid\n     8→  - Grid sizing: grid_min=(-1,-1,-1), grid_max=(1,1,1), cell_size=h=0.04,\n     9→    grid_res=50, grid_delta=(25,25,25), num_cells=125000\n    10→  - CuPy RawModule compiles hash_sort.cu including common.cuh without errors\n    11→  - Test: 100K particles uniformly distributed in unit cube -> valid hashes [0, num_cells-1]\n    12→  - Test: particles at/outside grid boundaries -> clamped hashes (no OOB)\n    13→  - Kernel runs without errors for 500K particles\n    14→\n    15→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    16→\"\"\"\n    17→\n    18→from __future__ import annotations\n    19→\n    20→import sys\n    21→import os\n    22→\n    23→# Ensure fallingsand3d directory is on the path\n    24→sys.path.insert(0, os.path.dirname(__file__))\n    25→\n    26→import cupy\n    27→import numpy as np\n    28→\n    29→from hash_sort import (\n    30→    CELL_SIZE,\n    31→    GRID_DELTA,\n    32→    GRID_MAX,\n    33→    GRID_MIN,\n    34→    GRID_PARAMS_DTYPE,\n    35→    GRID_RES,\n    36→    NUM_CELLS,\n    37→    build_grid_params,\n    38→    calc_hash,\n    39→    get_module,\n    40→    upload_grid_params,\n    41→)\n    42→\n    43→\n    44→def _host_hash(pos: np.ndarray) -> np.ndarray:\n    45→    \"\"\"Reference CPU implementation of the hash for validation.\"\"\"\n    46→    grid_min = GRID_MIN\n    47→    grid_delta = GRID_DELTA\n    48→    grid_res = GRID_RES\n    49→\n    50→    # calcGridCell: int3((pos - grid_min) * grid_delta)\n    51→    # CUDA (int) cast truncates toward zero, matching np.trunc for positive values.\n    52→    # Since (pos - grid_min) * grid_delta is non-negative after clamping, floor\n    53→    # and trunc give the same result for values in [0, grid_res).\n    54→    cell = np.floor((pos[:, :3] - grid_min) * grid_delta).astype(np.int32)\n    55→\n    56→    # clamp to [0, grid_res - 1]\n    57→    cell = np.clip(cell, 0, grid_res - 1)\n    58→\n    59→    # linear hash: z * ry * rx + y * rx + x\n    60→    rx = int(grid_res[0])\n    61→    ry = int(grid_res[1])\n    62→    h = cell[:, 2] * ry * rx + cell[:, 1] * rx + cell[:, 0]\n    63→    return h.astype(np.uint32)\n    64→\n    65→\n    66→def test_grid_constants() -> None:\n    67→    \"\"\"Verify grid sizing matches acceptance criteria.\"\"\"\n    68→    print(\"--- Grid constant checks ---\")\n    69→\n    70→    np.testing.assert_array_almost_equal(GRID_MIN, [-1.0, -1.0, -1.0])\n    71→    np.testing.assert_array_almost_equal(GRID_MAX, [1.0, 1.0, 1.0])\n    72→    assert abs(float(CELL_SIZE) - 0.04) < 1e-7\n    73→    np.testing.assert_array_equal(GRID_RES, [50, 50, 50])\n    74→    np.testing.assert_array_almost_equal(GRID_DELTA, [25.0, 25.0, 25.0])\n    75→    assert NUM_CELLS == 125_000\n    76→    print(\"[OK] Grid constants: grid_min=(-1,-1,-1) grid_max=(1,1,1) \"\n    77→          \"cell_size=0.04 grid_res=50 grid_delta=25 num_cells=125000\")\n    78→\n    79→\n    80→def test_grid_params_struct() -> None:\n    81→    \"\"\"Verify GridParams numpy dtype layout matches common.cuh struct.\"\"\"\n    82→    print(\"\\n--- GridParams struct checks ---\")\n    83→\n    84→    # float3 grid_min (12) + float3 grid_max (12) + int3 grid_res (12)\n    85→    # + float3 grid_delta (12) + int num_cells (4) = 52 bytes\n    86→    assert GRID_PARAMS_DTYPE.itemsize == 52, (\n    87→        f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 52\"\n    88→    )\n    89→    print(f\"[OK] sizeof(GridParams) = {GRID_PARAMS_DTYPE.itemsize} bytes\")\n    90→\n    91→    params = build_grid_params()\n    92→    np.testing.assert_array_almost_equal(params[0][\"grid_min\"], [-1.0, -1.0, -1.0])\n    93→    np.testing.assert_array_almost_equal(params[0][\"grid_max\"], [1.0, 1.0, 1.0])\n    94→    np.testing.assert_array_equal(params[0][\"grid_res\"], [50, 50, 50])\n    95→    np.testing.assert_array_almost_equal(params[0][\"grid_delta\"], [25.0, 25.0, 25.0])\n    96→    assert params[0][\"num_cells\"] == 125_000\n    97→    print(\"[OK] GridParams fields populated correctly\")\n    98→\n    99→\n   100→def test_compilation() -> None:\n   101→    \"\"\"Verify CuPy RawModule compiles hash_sort.cu including common.cuh.\"\"\"\n   102→    print(\"\\n--- Compilation check ---\")\n   103→\n   104→    module = get_module()\n   105→    assert module is not None\n   106→    print(\"[OK] CuPy RawModule compiled hash_sort.cu (includes common.cuh)\")\n   107→\n   108→    # Verify kernel function is accessible\n   109→    kernel = module.get_function(\"K_CalcHash\")\n   110→    assert kernel is not None\n   111→    print(\"[OK] K_CalcHash kernel function found\")\n   112→\n   113→    # Verify constant memory symbol is accessible\n   114→    d_ptr = module.get_global(\"c_grid\")\n   115→    assert int(d_ptr) != 0\n   116→    print(\"[OK] c_grid constant memory symbol found\")\n   117→\n   118→\n   119→def test_known_position() -> None:\n   120→    \"\"\"Verify hash for a particle with a known grid cell.\"\"\"\n   121→    print(\"\\n--- Known position test ---\")\n   122→\n   123→    upload_grid_params()\n   124→\n   125→    # Position (0.02, 0.02, 0.02):\n   126→    #   cell = int3((0.02 - (-1)) * 25, (0.02 - (-1)) * 25, (0.02 - (-1)) * 25)\n   127→    #        = int3(25.5, 25.5, 25.5) = (25, 25, 25)\n   128→    #   hash = 25 * 50 * 50 + 25 * 50 + 25 = 62500 + 1250 + 25 = 63775\n   129→    pos = np.array([[0.02, 0.02, 0.02, 0.0]], dtype=np.float32)\n   130→    pos_gpu = cupy.asarray(pos)\n   131→\n   132→    hashes, _ = calc_hash(pos_gpu)\n   133→    cupy.cuda.Device().synchronize()\n   134→\n   135→    h = int(cupy.asnumpy(hashes)[0])\n   136→    expected = 25 * 50 * 50 + 25 * 50 + 25  # 63775\n   137→    assert h == expected, f\"hash = {h}, expected {expected}\"\n   138→    print(f\"[OK] Position (0.02, 0.02, 0.02) -> cell (25,25,25) -> hash = {h}\")\n   139→\n   140→\n   141→def test_100k_uniform_unit_cube() -> None:\n   142→    \"\"\"100K particles uniformly distributed in unit cube -> valid hashes.\"\"\"\n   143→    print(\"\\n--- 100K uniform unit-cube test ---\")\n   144→\n   145→    upload_grid_params()\n   146→\n   147→    rng = np.random.default_rng(42)\n   148→    # Unit cube [0, 1]^3 is entirely inside grid [-1, 1]^3\n   149→    pos_np = np.zeros((100_000, 4), dtype=np.float32)\n   150→    pos_np[:, :3] = rng.uniform(0.0, 1.0, size=(100_000, 3)).astype(np.float32)\n   151→    pos_gpu = cupy.asarray(pos_np)\n   152→\n   153→    hashes, indices = calc_hash(pos_gpu)\n   154→    cupy.cuda.Device().synchronize()\n   155→\n   156→    h_hashes = cupy.asnumpy(hashes)\n   157→    h_indices = cupy.asnumpy(indices)\n   158→\n   159→    # All hashes in [0, NUM_CELLS - 1]\n   160→    assert h_hashes.min() >= 0, f\"Min hash = {h_hashes.min()}, expected >= 0\"\n   161→    assert h_hashes.max() < NUM_CELLS, (\n   162→        f\"Max hash = {h_hashes.max()}, expected < {NUM_CELLS}\"\n   163→    )\n   164→    print(f\"[OK] All 100K hashes in [0, {NUM_CELLS - 1}]: \"\n   165→          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n   166→\n   167→    # Indices should be identity permutation\n   168→    np.testing.assert_array_equal(h_indices, np.arange(100_000, dtype=np.uint32))\n   169→    print(\"[OK] Indices are identity [0..99999]\")\n   170→\n   171→    # Cross-check against CPU reference\n   172→    ref = _host_hash(pos_np)\n   173→    np.testing.assert_array_equal(h_hashes, ref)\n   174→    print(\"[OK] GPU hashes match CPU reference for all 100K particles\")\n   175→\n   176→\n   177→def test_boundary_clamping() -> None:\n   178→    \"\"\"Particles at or outside grid boundaries produce clamped hashes.\"\"\"\n   179→    print(\"\\n--- Boundary clamping test ---\")\n   180→\n   181→    upload_grid_params()\n   182→\n   183→    # Test positions: inside, on boundary, and outside\n   184→    test_positions = np.array([\n   185→        # Inside (center of grid)\n   186→        [0.0, 0.0, 0.0, 0.0],\n   187→        # At grid_min exactly\n   188→        [-1.0, -1.0, -1.0, 0.0],\n   189→        # At grid_max exactly (should clamp to res-1)\n   190→        [1.0, 1.0, 1.0, 0.0],\n   191→        # Far outside negative\n   192→        [-10.0, -10.0, -10.0, 0.0],\n   193→        # Far outside positive\n   194→        [10.0, 10.0, 10.0, 0.0],\n   195→        # Mixed: some axes inside, some outside\n   196→        [0.5, -5.0, 3.0, 0.0],\n   197→        # Just inside near grid_max\n   198→        [0.99, 0.99, 0.99, 0.0],\n   199→    ], dtype=np.float32)\n   200→\n   201→    pos_gpu = cupy.asarray(test_positions)\n   202→    hashes, indices = calc_hash(pos_gpu)\n   203→    cupy.cuda.Device().synchronize()\n   204→\n   205→    h_hashes = cupy.asnumpy(hashes)\n   206→\n   207→    # All hashes must be in valid range\n   208→    for i, h in enumerate(h_hashes):\n   209→        assert 0 <= h < NUM_CELLS, (\n   210→            f\"Particle {i} at {test_positions[i, :3]}: hash={h}, \"\n   211→            f\"expected in [0, {NUM_CELLS - 1}]\"\n   212→        )\n   213→    print(f\"[OK] All {len(test_positions)} boundary test particles have valid hashes\")\n   214→\n   215→    # Verify specific expected values:\n   216→    # Particle at grid_min (-1,-1,-1): cell = (0,0,0), hash = 0\n   217→    assert h_hashes[1] == 0, f\"grid_min hash = {h_hashes[1]}, expected 0\"\n   218→    print(\"[OK] Particle at grid_min -> hash = 0\")\n   219→\n   220→    # Particle far outside negative: should clamp to (0,0,0), hash = 0\n   221→    assert h_hashes[3] == 0, f\"far-negative hash = {h_hashes[3]}, expected 0\"\n   222→    print(\"[OK] Particle far outside negative -> hash = 0 (clamped)\")\n   223→\n   224→    # Particle far outside positive: should clamp to (49,49,49)\n   225→    max_hash = 49 * 50 * 50 + 49 * 50 + 49  # = 124999\n   226→    assert h_hashes[4] == max_hash, (\n   227→        f\"far-positive hash = {h_hashes[4]}, expected {max_hash}\"\n   228→    )\n   229→    print(f\"[OK] Particle far outside positive -> hash = {max_hash} (clamped to max)\")\n   230→\n   231→    # Particle at grid_max (1,1,1): cell unclamped = (50,50,50), clamped to (49,49,49)\n   232→    assert h_hashes[2] == max_hash, (\n   233→        f\"grid_max hash = {h_hashes[2]}, expected {max_hash}\"\n   234→    )\n   235→    print(f\"[OK] Particle at grid_max -> hash = {max_hash} (clamped)\")\n   236→\n   237→    # Cross-check all against CPU reference\n   238→    ref = _host_hash(test_positions)\n   239→    np.testing.assert_array_equal(h_hashes, ref)\n   240→    print(\"[OK] Boundary hashes match CPU reference\")\n   241→\n   242→\n   243→def test_500k_no_errors() -> None:\n   244→    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n   245→    print(\"\\n--- 500K particle stress test ---\")\n   246→\n   247→    upload_grid_params()\n   248→\n   249→    rng = np.random.default_rng(123)\n   250→    # Distribute across entire grid range [-1, 1]^3\n   251→    pos_np = np.zeros((500_000, 4), dtype=np.float32)\n   252→    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(500_000, 3)).astype(np.float32)\n   253→    pos_gpu = cupy.asarray(pos_np)\n   254→\n   255→    hashes, indices = calc_hash(pos_gpu)\n   256→    cupy.cuda.Device().synchronize()\n   257→\n   258→    h_hashes = cupy.asnumpy(hashes)\n   259→\n   260→    # All valid\n   261→    assert h_hashes.min() >= 0\n   262→    assert h_hashes.max() < NUM_CELLS\n   263→    print(f\"[OK] 500K particles hashed without errors: \"\n   264→          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n   265→\n   266→    # Spot-check against CPU reference (first 1000)\n   267→    ref = _host_hash(pos_np[:1000])\n   268→    np.testing.assert_array_equal(h_hashes[:1000], ref)\n   269→    print(\"[OK] First 1000 hashes match CPU reference\")\n   270→\n   271→\n   272→def main() -> None:\n   273→    test_grid_constants()\n   274→    test_grid_params_struct()\n   275→    test_compilation()\n   276→    test_known_position()\n   277→    test_100k_uniform_unit_cube()\n   278→    test_boundary_clamping()\n   279→    test_500k_no_errors()\n   280→    print(\"\\n=== ALL CHECKS PASSED ===\")\n   281→\n   282→\n   283→if __name__ == \"__main__\":\n   284→    main()\n   285→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"4f34ec55-60dd-4138-9f3f-3caa2dc4a5d0","uuid":"c0fa7b68-a8e4-4492-b54d-f3bdbcaa46ca","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_hash_sort.py","content":"\"\"\"Integration test for hash_sort.py -- K_CalcHash grid hashing kernel.\n\nAcceptance criteria:\n  - K_CalcHash computes grid cell: cell = int3((pos - grid_min) * grid_delta),\n    clamped to [0, grid_res-1]\n  - Hash = cell.z * grid_res.y * grid_res.x + cell.y * grid_res.x + cell.x\n  - Grid parameters read from __constant__ GridParams c_grid\n  - Grid sizing: grid_min=(-1,-1,-1), grid_max=(1,1,1), cell_size=h=0.04,\n    grid_res=50, grid_delta=(25,25,25), num_cells=125000\n  - CuPy RawModule compiles hash_sort.cu including common.cuh without errors\n  - Test: 100K particles uniformly distributed in unit cube -> valid hashes [0, num_cells-1]\n  - Test: particles at/outside grid boundaries -> clamped hashes (no OOB)\n  - Kernel runs without errors for 500K particles\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport sys\nimport os\n\n# Ensure fallingsand3d directory is on the path\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom hash_sort import (\n    CELL_SIZE,\n    GRID_DELTA,\n    GRID_MAX,\n    GRID_MIN,\n    GRID_PARAMS_DTYPE,\n    GRID_RES,\n    NUM_CELLS,\n    build_grid_params,\n    calc_hash,\n    get_module,\n    upload_grid_params,\n)\n\n\ndef _host_hash(pos: np.ndarray) -> np.ndarray:\n    \"\"\"Reference CPU implementation of the hash for validation.\"\"\"\n    grid_min = GRID_MIN\n    grid_delta = GRID_DELTA\n    grid_res = GRID_RES\n\n    # calcGridCell: int3((pos - grid_min) * grid_delta)\n    # CUDA (int) cast truncates toward zero, matching np.trunc for positive values.\n    # Since (pos - grid_min) * grid_delta is non-negative after clamping, floor\n    # and trunc give the same result for values in [0, grid_res).\n    cell = np.floor((pos[:, :3] - grid_min) * grid_delta).astype(np.int32)\n\n    # clamp to [0, grid_res - 1]\n    cell = np.clip(cell, 0, grid_res - 1)\n\n    # linear hash: z * ry * rx + y * rx + x\n    rx = int(grid_res[0])\n    ry = int(grid_res[1])\n    h = cell[:, 2] * ry * rx + cell[:, 1] * rx + cell[:, 0]\n    return h.astype(np.uint32)\n\n\ndef test_grid_constants() -> None:\n    \"\"\"Verify grid sizing matches acceptance criteria.\"\"\"\n    print(\"--- Grid constant checks ---\")\n\n    np.testing.assert_array_almost_equal(GRID_MIN, [-1.0, -1.0, -1.0])\n    np.testing.assert_array_almost_equal(GRID_MAX, [1.0, 1.0, 1.0])\n    assert abs(float(CELL_SIZE) - 0.04) < 1e-7\n    np.testing.assert_array_equal(GRID_RES, [50, 50, 50])\n    np.testing.assert_array_almost_equal(GRID_DELTA, [25.0, 25.0, 25.0])\n    assert NUM_CELLS == 125_000\n    print(\"[OK] Grid constants: grid_min=(-1,-1,-1) grid_max=(1,1,1) \"\n          \"cell_size=0.04 grid_res=50 grid_delta=25 num_cells=125000\")\n\n\ndef test_grid_params_struct() -> None:\n    \"\"\"Verify GridParams numpy dtype layout matches common.cuh struct.\"\"\"\n    print(\"\\n--- GridParams struct checks ---\")\n\n    # float3 grid_min (12) + float3 grid_max (12) + int3 grid_res (12)\n    # + float3 grid_delta (12) + int num_cells (4) = 52 bytes\n    assert GRID_PARAMS_DTYPE.itemsize == 52, (\n        f\"GridParams size mismatch: {GRID_PARAMS_DTYPE.itemsize} != 52\"\n    )\n    print(f\"[OK] sizeof(GridParams) = {GRID_PARAMS_DTYPE.itemsize} bytes\")\n\n    params = build_grid_params()\n    np.testing.assert_array_almost_equal(params[0][\"grid_min\"], [-1.0, -1.0, -1.0])\n    np.testing.assert_array_almost_equal(params[0][\"grid_max\"], [1.0, 1.0, 1.0])\n    np.testing.assert_array_equal(params[0][\"grid_res\"], [50, 50, 50])\n    np.testing.assert_array_almost_equal(params[0][\"grid_delta\"], [25.0, 25.0, 25.0])\n    assert params[0][\"num_cells\"] == 125_000\n    print(\"[OK] GridParams fields populated correctly\")\n\n\ndef test_compilation() -> None:\n    \"\"\"Verify CuPy RawModule compiles hash_sort.cu including common.cuh.\"\"\"\n    print(\"\\n--- Compilation check ---\")\n\n    module = get_module()\n    assert module is not None\n    print(\"[OK] CuPy RawModule compiled hash_sort.cu (includes common.cuh)\")\n\n    # Verify kernel function is accessible\n    kernel = module.get_function(\"K_CalcHash\")\n    assert kernel is not None\n    print(\"[OK] K_CalcHash kernel function found\")\n\n    # Verify constant memory symbol is accessible\n    d_ptr = module.get_global(\"c_grid\")\n    assert int(d_ptr) != 0\n    print(\"[OK] c_grid constant memory symbol found\")\n\n\ndef test_known_position() -> None:\n    \"\"\"Verify hash for a particle with a known grid cell.\"\"\"\n    print(\"\\n--- Known position test ---\")\n\n    upload_grid_params()\n\n    # Position (0.02, 0.02, 0.02):\n    #   cell = int3((0.02 - (-1)) * 25, (0.02 - (-1)) * 25, (0.02 - (-1)) * 25)\n    #        = int3(25.5, 25.5, 25.5) = (25, 25, 25)\n    #   hash = 25 * 50 * 50 + 25 * 50 + 25 = 62500 + 1250 + 25 = 63775\n    pos = np.array([[0.02, 0.02, 0.02, 0.0]], dtype=np.float32)\n    pos_gpu = cupy.asarray(pos)\n\n    hashes, _ = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h = int(cupy.asnumpy(hashes)[0])\n    expected = 25 * 50 * 50 + 25 * 50 + 25  # 63775\n    assert h == expected, f\"hash = {h}, expected {expected}\"\n    print(f\"[OK] Position (0.02, 0.02, 0.02) -> cell (25,25,25) -> hash = {h}\")\n\n\ndef test_100k_uniform_unit_cube() -> None:\n    \"\"\"100K particles uniformly distributed in unit cube -> valid hashes.\"\"\"\n    print(\"\\n--- 100K uniform unit-cube test ---\")\n\n    upload_grid_params()\n\n    rng = np.random.default_rng(42)\n    # Unit cube [0, 1]^3 is entirely inside grid [-1, 1]^3\n    pos_np = np.zeros((100_000, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(0.0, 1.0, size=(100_000, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h_hashes = cupy.asnumpy(hashes)\n    h_indices = cupy.asnumpy(indices)\n\n    # All hashes in [0, NUM_CELLS - 1]\n    assert h_hashes.min() >= 0, f\"Min hash = {h_hashes.min()}, expected >= 0\"\n    assert h_hashes.max() < NUM_CELLS, (\n        f\"Max hash = {h_hashes.max()}, expected < {NUM_CELLS}\"\n    )\n    print(f\"[OK] All 100K hashes in [0, {NUM_CELLS - 1}]: \"\n          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n\n    # Indices should be identity permutation\n    np.testing.assert_array_equal(h_indices, np.arange(100_000, dtype=np.uint32))\n    print(\"[OK] Indices are identity [0..99999]\")\n\n    # Cross-check against CPU reference\n    ref = _host_hash(pos_np)\n    np.testing.assert_array_equal(h_hashes, ref)\n    print(\"[OK] GPU hashes match CPU reference for all 100K particles\")\n\n\ndef test_boundary_clamping() -> None:\n    \"\"\"Particles at or outside grid boundaries produce clamped hashes.\"\"\"\n    print(\"\\n--- Boundary clamping test ---\")\n\n    upload_grid_params()\n\n    # Test positions: inside, on boundary, and outside\n    test_positions = np.array([\n        # Inside (center of grid)\n        [0.0, 0.0, 0.0, 0.0],\n        # At grid_min exactly\n        [-1.0, -1.0, -1.0, 0.0],\n        # At grid_max exactly (should clamp to res-1)\n        [1.0, 1.0, 1.0, 0.0],\n        # Far outside negative\n        [-10.0, -10.0, -10.0, 0.0],\n        # Far outside positive\n        [10.0, 10.0, 10.0, 0.0],\n        # Mixed: some axes inside, some outside\n        [0.5, -5.0, 3.0, 0.0],\n        # Just inside near grid_max\n        [0.99, 0.99, 0.99, 0.0],\n    ], dtype=np.float32)\n\n    pos_gpu = cupy.asarray(test_positions)\n    hashes, indices = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h_hashes = cupy.asnumpy(hashes)\n\n    # All hashes must be in valid range\n    for i, h in enumerate(h_hashes):\n        assert 0 <= h < NUM_CELLS, (\n            f\"Particle {i} at {test_positions[i, :3]}: hash={h}, \"\n            f\"expected in [0, {NUM_CELLS - 1}]\"\n        )\n    print(f\"[OK] All {len(test_positions)} boundary test particles have valid hashes\")\n\n    # Verify specific expected values:\n    # Particle at grid_min (-1,-1,-1): cell = (0,0,0), hash = 0\n    assert h_hashes[1] == 0, f\"grid_min hash = {h_hashes[1]}, expected 0\"\n    print(\"[OK] Particle at grid_min -> hash = 0\")\n\n    # Particle far outside negative: should clamp to (0,0,0), hash = 0\n    assert h_hashes[3] == 0, f\"far-negative hash = {h_hashes[3]}, expected 0\"\n    print(\"[OK] Particle far outside negative -> hash = 0 (clamped)\")\n\n    # Particle far outside positive: should clamp to (49,49,49)\n    max_hash = 49 * 50 * 50 + 49 * 50 + 49  # = 124999\n    assert h_hashes[4] == max_hash, (\n        f\"far-positive hash = {h_hashes[4]}, expected {max_hash}\"\n    )\n    print(f\"[OK] Particle far outside positive -> hash = {max_hash} (clamped to max)\")\n\n    # Particle at grid_max (1,1,1): cell unclamped = (50,50,50), clamped to (49,49,49)\n    assert h_hashes[2] == max_hash, (\n        f\"grid_max hash = {h_hashes[2]}, expected {max_hash}\"\n    )\n    print(f\"[OK] Particle at grid_max -> hash = {max_hash} (clamped)\")\n\n    # Cross-check all against CPU reference\n    ref = _host_hash(test_positions)\n    np.testing.assert_array_equal(h_hashes, ref)\n    print(\"[OK] Boundary hashes match CPU reference\")\n\n\ndef test_500k_no_errors() -> None:\n    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n    print(\"\\n--- 500K particle stress test ---\")\n\n    upload_grid_params()\n\n    rng = np.random.default_rng(123)\n    # Distribute across entire grid range [-1, 1]^3\n    pos_np = np.zeros((500_000, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(500_000, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    cupy.cuda.Device().synchronize()\n\n    h_hashes = cupy.asnumpy(hashes)\n\n    # All valid\n    assert h_hashes.min() >= 0\n    assert h_hashes.max() < NUM_CELLS\n    print(f\"[OK] 500K particles hashed without errors: \"\n          f\"min={h_hashes.min()}, max={h_hashes.max()}\")\n\n    # Spot-check against CPU reference (first 1000)\n    ref = _host_hash(pos_np[:1000])\n    np.testing.assert_array_equal(h_hashes[:1000], ref)\n    print(\"[OK] First 1000 hashes match CPU reference\")\n\n\ndef main() -> None:\n    test_grid_constants()\n    test_grid_params_struct()\n    test_compilation()\n    test_known_position()\n    test_100k_uniform_unit_cube()\n    test_boundary_clamping()\n    test_500k_no_errors()\n    print(\"\\n=== ALL CHECKS PASSED ===\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":285,"startLine":1,"totalLines":285}}}

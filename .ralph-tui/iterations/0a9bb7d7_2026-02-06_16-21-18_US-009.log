  position .. shear_rate : cupy.ndarray\n        Unsorted source arrays (indexed by original particle ID).\n    sorted_position .. sorted_shear_rate : cupy.ndarray\n        Pre-allocated sorted destination arrays (indexed by sorted slot).\n    \"\"\"\n    if num_particles == 0:\n        return\n\n    module = _get_module()\n    kernel = module.get_function(\"K_FusedReorder\")\n\n    grid = ((num_particles + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n    block = (BLOCK_SIZE,)\n\n    kernel(\n        grid,\n        block,\n        (\n            np.uint32(num_particles),\n            sorted_index,\n            # Unsorted inputs\n            position,\n            velocity,\n            veleval,\n            mass,\n            packed_info,\n            temperature,\n            health,\n            lifetime,\n            color,\n            sleep_counter,\n            shear_rate,\n            # Sorted outputs\n            sorted_position,\n            sorted_velocity,\n            sorted_veleval,\n            sorted_mass,\n            sorted_packed_info,\n            sorted_temperature,\n            sorted_health,\n            sorted_lifetime,\n            sorted_color,\n            sorted_sleep_counter,\n            sorted_shear_rate,\n        ),\n    )\n","structuredPatch":[],"originalFile":null}}

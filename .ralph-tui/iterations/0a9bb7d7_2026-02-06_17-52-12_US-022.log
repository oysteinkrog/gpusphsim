{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RqdazrkCsa8p3QQY9X6o27","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter\n     5→and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n     9→  2. Run sim_steps simulation substeps\n    10→  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import time\n    16→from typing import Optional\n    17→\n    18→import cupy as cp\n    19→import numpy as np\n    20→\n    21→from world import World\n    22→from materials import (\n    23→    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n    24→)\n    25→\n    26→import hash_sort\n    27→import fused_reorder\n    28→import build_grid\n    29→import step1\n    30→import step2\n    31→import integrate\n    32→import wake\n    33→\n    34→\n    35→class Simulation:\n    36→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    37→\n    38→    Parameters\n    39→    ----------\n    40→    world : World\n    41→        Particle state manager.\n    42→    dt : float\n    43→        Fixed simulation timestep (seconds).\n    44→    speed : float\n    45→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    46→    max_substeps : int\n    47→        Maximum substeps per render frame to prevent spiral-of-death.\n    48→    \"\"\"\n    49→\n    50→    def __init__(\n    51→        self,\n    52→        world: World,\n    53→        dt: float = 0.001,\n    54→        speed: float = 1.0,\n    55→        max_substeps: int = 20,\n    56→    ) -> None:\n    57→        self.world = world\n    58→        self.dt = dt\n    59→        self.speed = speed\n    60→        self.max_substeps = max_substeps\n    61→        self._paused = False\n    62→        self._prev_speed = speed\n    63→        self._last_frame_time: Optional[float] = None\n    64→        self._last_substeps = 0\n    65→        self.sim_time = 0.0\n    66→\n    67→        # Grid cell tables (pre-allocated, reused every frame)\n    68→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    69→\n    70→        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n    71→        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n    72→\n    73→        # Compile all kernel modules and upload constant memory\n    74→        self._upload_constants()\n    75→\n    76→    def _upload_constants(self) -> None:\n    77→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n    78→        # Build shared param structs\n    79→        grid_params = hash_sort.build_grid_params()\n    80→        sim_params = step1.build_sim_params(\n    81→            smoothing_length=0.04,\n    82→            particle_mass=0.008,\n    83→            particle_spacing=0.02,\n    84→            gravity=(0.0, -9.8, 0.0),\n    85→            dt=self.dt,\n    86→            restitution=0.3,\n    87→            wall_friction=0.5,\n    88→            world_min=(-1.0, -1.0, -1.0),\n    89→            world_max=(1.0, 1.0, 1.0),\n    90→        )\n    91→        precalc_params = step1.build_precalc_params(\n    92→            smoothing_length=0.04,\n    93→            viscosity=1.0,\n    94→        )\n    95→        granular_params = step2.build_granular_params()\n    96→        materials_data = build_material_array()\n    97→        interactions_data = build_interaction_matrix()\n    98→\n    99→        # --- hash_sort module: c_grid ---\n   100→        hash_sort.upload_grid_params(grid_params)\n   101→\n   102→        # --- fused_reorder module: no constant memory needed ---\n   103→        fused_reorder.get_module()  # just compile\n   104→\n   105→        # --- build_grid module: c_grid ---\n   106→        build_grid.upload_grid_params(grid_params)\n   107→\n   108→        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n   109→        step1.upload_grid_params(grid_params)\n   110→        step1.upload_sim_params(sim_params)\n   111→        step1.upload_precalc_params(precalc_params)\n   112→        step1.upload_materials(materials_data)\n   113→        step1.upload_interactions(interactions_data)\n   114→\n   115→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   116→        step2.upload_grid_params(grid_params)\n   117→        step2.upload_sim_params(sim_params)\n   118→        step2.upload_precalc_params(precalc_params)\n   119→        step2.upload_materials(materials_data)\n   120→        step2.upload_granular_params(granular_params)\n   121→\n   122→        # --- integrate module: c_sim, c_materials ---\n   123→        integrate.upload_sim_params(sim_params)\n   124→        integrate.upload_materials(materials_data)\n   125→\n   126→        # --- wake module: c_grid ---\n   127→        wake.upload_grid_params(grid_params)\n   128→\n   129→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   130→        upload_to_gpu()\n   131→\n   132→    def _sim_step(self, n: int) -> None:\n   133→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   134→        w = self.world\n   135→\n   136→        # 1. Hash particle positions\n   137→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   138→\n   139→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   140→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   141→            hashes, indices,\n   142→            sorted_hashes_out=w.sorted_hashes,\n   143→            sorted_indices_out=w.sorted_indices,\n   144→        )\n   145→\n   146→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   147→        fused_reorder.fused_reorder(\n   148→            n, sorted_indices,\n   149→            w.position, w.velocity, w.veleval,\n   150→            w.mass, w.packed_info, w.temperature,\n   151→            w.health, w.lifetime, w.color,\n   152→            w.sleep_counter, w.shear_rate,\n   153→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   154→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   155→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   156→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   157→        )\n   158→\n   159→        # 4. Build grid data structure (cell_start / cell_end tables)\n   160→        build_grid.build_data_struct(\n   161→            sorted_hashes[:n], self._cell_start, self._cell_end\n   162→        )\n   163→\n   164→        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n   165→        step1.compute_step1(\n   166→            w.sorted_position[:n],\n   167→            w.sorted_velocity[:n],\n   168→            w.sorted_mass[:n],\n   169→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   170→            w.sorted_packed_info[:n],\n   171→            w.sorted_temperature[:n],\n   172→            self._cell_start,\n   173→            self._cell_end,\n   174→            density_out=w.sorted_density,\n   175→            shear_rate_out=w.sorted_shear_rate,\n   176→            dTdt_out=w.sorted_dTdt,\n   177→            exposure_heat_out=w.sorted_exposure_heat,\n   178→            exposure_corrode_out=w.sorted_exposure_corrode,\n   179→        )\n   180→        w._density_initialized = True\n   181→\n   182→        # 6. Step2: pressure + viscosity + XSPH forces\n   183→        step2.compute_step2(\n   184→            w.sorted_position[:n],\n   185→            w.sorted_velocity[:n],\n   186→            w.sorted_density[:n],\n   187→            w.sorted_mass[:n],\n   188→            w.sorted_packed_info[:n],\n   189→            self._cell_start,\n   190→            self._cell_end,\n   191→            sph_force_out=w.sorted_sph_force,\n   192→            veleval_out=w.sorted_veleval,\n   193→        )\n   194→\n   195→        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n   196→        #    Writes back to UNSORTED arrays via sort_indexes\n   197→        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n   198→        integrate.integrate(\n   199→            w.sorted_position[:n],\n   200→            w.sorted_velocity[:n],\n   201→            w.sorted_veleval[:n],\n   202→            w.sorted_sph_force[:n],\n   203→            w.sorted_mass[:n],\n   204→            w.sorted_packed_info[:n],\n   205→            w.sorted_temperature[:n],\n   206→            w.sorted_health[:n],\n   207→            sorted_density=w.sorted_density[:n],\n   208→            sorted_shear_rate=w.sorted_shear_rate[:n],\n   209→            sorted_dTdt=w.sorted_dTdt[:n],\n   210→            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n   211→            sort_indexes=sorted_indices[:n],\n   212→            position_out=w.position,\n   213→            velocity_out=w.velocity,\n   214→            color_out=w.color,\n   215→            packed_info_out=w.packed_info,\n   216→            sleep_counter_out=w.sleep_counter,\n   217→            temperature_out=w.temperature,\n   218→        )\n   219→\n   220→        # 8. Wake propagation: mark cells near just-woke particles,\n   221→        #    wake sleeping neighbors, clear JUST_WOKE flags\n   222→        wake.run_wake_propagation(\n   223→            w.position[:n],\n   224→            w.packed_info[:n],\n   225→            w.sleep_counter[:n],\n   226→            self._cell_wake_flags,\n   227→            num_particles=n,\n   228→        )\n   229→\n   230→        self.sim_time += self.dt\n   231→\n   232→    def step_frame(self) -> int:\n   233→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   234→        now = time.perf_counter()\n   235→        if self._last_frame_time is None:\n   236→            self._last_frame_time = now\n   237→            return 0\n   238→\n   239→        wall_dt = now - self._last_frame_time\n   240→        self._last_frame_time = now\n   241→\n   242→        if self._paused or self.speed <= 0.0:\n   243→            self._last_substeps = 0\n   244→            return 0\n   245→\n   246→        n = self.world._high_water\n   247→        if n == 0:\n   248→            self._last_substeps = 0\n   249→            return 0\n   250→\n   251→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   252→        sim_steps = max(0, min(\n   253→            self.max_substeps,\n   254→            round(self.speed * wall_dt / self.dt),\n   255→        ))\n   256→\n   257→        for _ in range(sim_steps):\n   258→            self._sim_step(n)\n   259→\n   260→        self._last_substeps = sim_steps\n   261→        return sim_steps\n   262→\n   263→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   264→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   265→\n   266→        Parameters\n   267→        ----------\n   268→        cuda_pos : CudaGLBuffer\n   269→            Position VBO wrapper (must be context-managed externally).\n   270→        cuda_col : CudaGLBuffer\n   271→            Color VBO wrapper (must be context-managed externally).\n   272→        \"\"\"\n   273→        n = self.world._high_water\n   274→        if n == 0:\n   275→            return\n   276→\n   277→        # Position: world pos (float4) -> VBO pos (float4)\n   278→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   279→            (cuda_pos.nbytes // 16, 4), np.float32,\n   280→        )\n   281→        pos_arr[:n] = self.world.position[:n]\n   282→\n   283→        # Color: world color (float4) -> VBO color (float4)\n   284→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   285→            (cuda_col.nbytes // 16, 4), np.float32,\n   286→        )\n   287→        col_arr[:n] = self.world.color[:n]\n   288→\n   289→    @property\n   290→    def paused(self) -> bool:\n   291→        return self._paused\n   292→\n   293→    def toggle_pause(self) -> None:\n   294→        self._paused = not self._paused\n   295→\n   296→    def adjust_speed(self, delta: float) -> None:\n   297→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   298→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   299→\n   300→    @property\n   301→    def last_substeps(self) -> int:\n   302→        return self._last_substeps\n   303→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"ae171d41-74af-46d5-8681-c560fdb8377c","uuid":"ce7aecb7-d5f1-4dea-8870-64329778faf2","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/simulation.py","content":"\"\"\"SPH simulation orchestrator.\n\nWires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\nStep2 -> Integrate.  Decouples simulation from rendering via a speed parameter\nand substep budget.\n\nEach render frame:\n  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n  2. Run sim_steps simulation substeps\n  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Optional\n\nimport cupy as cp\nimport numpy as np\n\nfrom world import World\nfrom materials import (\n    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n)\n\nimport hash_sort\nimport fused_reorder\nimport build_grid\nimport step1\nimport step2\nimport integrate\nimport wake\n\n\nclass Simulation:\n    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n\n    Parameters\n    ----------\n    world : World\n        Particle state manager.\n    dt : float\n        Fixed simulation timestep (seconds).\n    speed : float\n        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    max_substeps : int\n        Maximum substeps per render frame to prevent spiral-of-death.\n    \"\"\"\n\n    def __init__(\n        self,\n        world: World,\n        dt: float = 0.001,\n        speed: float = 1.0,\n        max_substeps: int = 20,\n    ) -> None:\n        self.world = world\n        self.dt = dt\n        self.speed = speed\n        self.max_substeps = max_substeps\n        self._paused = False\n        self._prev_speed = speed\n        self._last_frame_time: Optional[float] = None\n        self._last_substeps = 0\n        self.sim_time = 0.0\n\n        # Grid cell tables (pre-allocated, reused every frame)\n        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n\n        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n\n        # Compile all kernel modules and upload constant memory\n        self._upload_constants()\n\n    def _upload_constants(self) -> None:\n        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n        # Build shared param structs\n        grid_params = hash_sort.build_grid_params()\n        sim_params = step1.build_sim_params(\n            smoothing_length=0.04,\n            particle_mass=0.008,\n            particle_spacing=0.02,\n            gravity=(0.0, -9.8, 0.0),\n            dt=self.dt,\n            restitution=0.3,\n            wall_friction=0.5,\n            world_min=(-1.0, -1.0, -1.0),\n            world_max=(1.0, 1.0, 1.0),\n        )\n        precalc_params = step1.build_precalc_params(\n            smoothing_length=0.04,\n            viscosity=1.0,\n        )\n        granular_params = step2.build_granular_params()\n        materials_data = build_material_array()\n        interactions_data = build_interaction_matrix()\n\n        # --- hash_sort module: c_grid ---\n        hash_sort.upload_grid_params(grid_params)\n\n        # --- fused_reorder module: no constant memory needed ---\n        fused_reorder.get_module()  # just compile\n\n        # --- build_grid module: c_grid ---\n        build_grid.upload_grid_params(grid_params)\n\n        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n        step1.upload_grid_params(grid_params)\n        step1.upload_sim_params(sim_params)\n        step1.upload_precalc_params(precalc_params)\n        step1.upload_materials(materials_data)\n        step1.upload_interactions(interactions_data)\n\n        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n        step2.upload_grid_params(grid_params)\n        step2.upload_sim_params(sim_params)\n        step2.upload_precalc_params(precalc_params)\n        step2.upload_materials(materials_data)\n        step2.upload_granular_params(granular_params)\n\n        # --- integrate module: c_sim, c_materials ---\n        integrate.upload_sim_params(sim_params)\n        integrate.upload_materials(materials_data)\n\n        # --- wake module: c_grid ---\n        wake.upload_grid_params(grid_params)\n\n        # --- materials module (its own internal module): c_materials, c_interactions ---\n        upload_to_gpu()\n\n    def _sim_step(self, n: int) -> None:\n        \"\"\"Run one simulation substep on n particles.\"\"\"\n        w = self.world\n\n        # 1. Hash particle positions\n        hashes, indices = hash_sort.calc_hash(w.position[:n])\n\n        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n            hashes, indices,\n            sorted_hashes_out=w.sorted_hashes,\n            sorted_indices_out=w.sorted_indices,\n        )\n\n        # 3. Fused reorder: gather all unsorted arrays into sorted order\n        fused_reorder.fused_reorder(\n            n, sorted_indices,\n            w.position, w.velocity, w.veleval,\n            w.mass, w.packed_info, w.temperature,\n            w.health, w.lifetime, w.color,\n            w.sleep_counter, w.shear_rate,\n            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n            w.sorted_sleep_counter, w.sorted_shear_rate,\n        )\n\n        # 4. Build grid data structure (cell_start / cell_end tables)\n        build_grid.build_data_struct(\n            sorted_hashes[:n], self._cell_start, self._cell_end\n        )\n\n        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n        step1.compute_step1(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_mass[:n],\n            w.sorted_density if hasattr(w, '_density_initialized') else None,\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            self._cell_start,\n            self._cell_end,\n            density_out=w.sorted_density,\n            shear_rate_out=w.sorted_shear_rate,\n            dTdt_out=w.sorted_dTdt,\n            exposure_heat_out=w.sorted_exposure_heat,\n            exposure_corrode_out=w.sorted_exposure_corrode,\n        )\n        w._density_initialized = True\n\n        # 6. Step2: pressure + viscosity + XSPH forces\n        step2.compute_step2(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_density[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            sph_force_out=w.sorted_sph_force,\n            veleval_out=w.sorted_veleval,\n        )\n\n        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n        #    Writes back to UNSORTED arrays via sort_indexes\n        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n        integrate.integrate(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_sph_force[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            sorted_density=w.sorted_density[:n],\n            sorted_shear_rate=w.sorted_shear_rate[:n],\n            sorted_dTdt=w.sorted_dTdt[:n],\n            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n            sort_indexes=sorted_indices[:n],\n            position_out=w.position,\n            velocity_out=w.velocity,\n            color_out=w.color,\n            packed_info_out=w.packed_info,\n            sleep_counter_out=w.sleep_counter,\n            temperature_out=w.temperature,\n        )\n\n        # 8. Wake propagation: mark cells near just-woke particles,\n        #    wake sleeping neighbors, clear JUST_WOKE flags\n        wake.run_wake_propagation(\n            w.position[:n],\n            w.packed_info[:n],\n            w.sleep_counter[:n],\n            self._cell_wake_flags,\n            num_particles=n,\n        )\n\n        self.sim_time += self.dt\n\n    def step_frame(self) -> int:\n        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n        now = time.perf_counter()\n        if self._last_frame_time is None:\n            self._last_frame_time = now\n            return 0\n\n        wall_dt = now - self._last_frame_time\n        self._last_frame_time = now\n\n        if self._paused or self.speed <= 0.0:\n            self._last_substeps = 0\n            return 0\n\n        n = self.world._high_water\n        if n == 0:\n            self._last_substeps = 0\n            return 0\n\n        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n        sim_steps = max(0, min(\n            self.max_substeps,\n            round(self.speed * wall_dt / self.dt),\n        ))\n\n        for _ in range(sim_steps):\n            self._sim_step(n)\n\n        self._last_substeps = sim_steps\n        return sim_steps\n\n    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n\n        Parameters\n        ----------\n        cuda_pos : CudaGLBuffer\n            Position VBO wrapper (must be context-managed externally).\n        cuda_col : CudaGLBuffer\n            Color VBO wrapper (must be context-managed externally).\n        \"\"\"\n        n = self.world._high_water\n        if n == 0:\n            return\n\n        # Position: world pos (float4) -> VBO pos (float4)\n        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n            (cuda_pos.nbytes // 16, 4), np.float32,\n        )\n        pos_arr[:n] = self.world.position[:n]\n\n        # Color: world color (float4) -> VBO color (float4)\n        col_arr = cuda_col.device_pointer_as_cupy_array(\n            (cuda_col.nbytes // 16, 4), np.float32,\n        )\n        col_arr[:n] = self.world.color[:n]\n\n    @property\n    def paused(self) -> bool:\n        return self._paused\n\n    def toggle_pause(self) -> None:\n        self._paused = not self._paused\n\n    def adjust_speed(self, delta: float) -> None:\n        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n        self.speed = max(0.1, min(10.0, self.speed + delta))\n\n    @property\n    def last_substeps(self) -> int:\n        return self._last_substeps\n","numLines":303,"startLine":1,"totalLines":303}}}

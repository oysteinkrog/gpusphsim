{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J6PVf9eaZ2zRT5rVH6RZxn","type":"tool_result","content":"The file /c/WORK/gpusphsim/fallingsand3d/ui.py has been updated. Here's the result of running `cat -n` on a snippet of the edited file:\n     1→\"\"\"ImGui-based user interface for Falling Sand 3D.\n     2→\n     3→Provides:\n     4→- Material picker panel (15 materials as colored buttons in 3x5 grid)\n     5→- Brush size slider\n     6→- Simulation controls (speed, accuracy, fixed_dt, max_particles)\n     7→- Status bar (particle count, FPS, dt, substeps, speed, paused)\n     8→- Left-click spawns selected material; Shift+click kills particles\n     9→- Keyboard shortcuts: 1-9 for material select, Space=pause, R=reset, +/- speed\n    10→\n    11→Uses imgui-bundle (imgui.backends.glfw_opengl3) integrated into the GLFW event loop.\n    12→\"\"\"\n    13→\n    14→from __future__ import annotations\n    15→\n    16→import math\n    17→from typing import Optional, Tuple\n    18→\n    19→import numpy as np\n    20→\n    21→from imgui_bundle import imgui\n    22→from imgui_bundle.python_backends.glfw_backend import GlfwRenderer\n    23→import glfw\n    24→\n    25→from materials import (\n    26→    MATERIALS, DEAD, STONE, SAND, DIRT, GRAVEL, WATER, OIL, LAVA, ACID,\n    27→    WOOD, METAL, ICE, STEAM, SMOKE, FIRE, GUNPOWDER,\n    28→)\n    29→\n    30→# Material IDs for the picker (exclude DEAD=0)\n    31→_PICKER_MATERIALS = [\n    32→    STONE, SAND, DIRT, GRAVEL, WATER,\n    33→    OIL, LAVA, ACID, WOOD, METAL,\n    34→    ICE, STEAM, SMOKE, FIRE, GUNPOWDER,\n    35→]\n    36→\n    37→# Quick-select mapping: keys 1-9 map to first 9 materials\n    38→_QUICK_SELECT = {\n    39→    glfw.KEY_1: STONE,\n    40→    glfw.KEY_2: SAND,\n    41→    glfw.KEY_3: DIRT,\n    42→    glfw.KEY_4: GRAVEL,\n    43→    glfw.KEY_5: WATER,\n    44→    glfw.KEY_6: OIL,\n    45→    glfw.KEY_7: LAVA,\n    46→    glfw.KEY_8: ACID,\n    47→    glfw.KEY_9: WOOD,\n    48→}\n    49→\n    50→# Max particles options\n    51→_MAX_PARTICLES_OPTIONS = [\n    52→    (100_000, \"100K\"),\n    53→    (250_000, \"250K\"),\n    54→    (500_000, \"500K\"),\n    55→    (1_000_000, \"1M\"),\n    56→]\n    57→\n    58→\n    59→def _unproject_mouse_ray(\n    60→    mx: float, my: float,\n    61→    viewport_w: int, viewport_h: int,\n    62→    view: np.ndarray, proj: np.ndarray,\n    63→) -> Tuple[np.ndarray, np.ndarray]:\n    64→    \"\"\"Unproject screen coordinates to a world-space ray.\n    65→\n    66→    Returns (ray_origin, ray_direction) both as float32[3].\n    67→    \"\"\"\n    68→    # Normalized device coords [-1, 1]\n    69→    ndc_x = (2.0 * mx / viewport_w) - 1.0\n    70→    ndc_y = 1.0 - (2.0 * my / viewport_h)  # flip Y\n    71→\n    72→    # Inverse view-projection\n    73→    vp = proj @ view\n    74→    try:\n    75→        inv_vp = np.linalg.inv(vp)\n    76→    except np.linalg.LinAlgError:\n    77→        return np.zeros(3, dtype=np.float32), np.array([0, 0, -1], dtype=np.float32)\n    78→\n    79→    # Near and far points in clip space\n    80→    near_clip = np.array([ndc_x, ndc_y, -1.0, 1.0], dtype=np.float32)\n    81→    far_clip = np.array([ndc_x, ndc_y, 1.0, 1.0], dtype=np.float32)\n    82→\n    83→    near_world = inv_vp @ near_clip\n    84→    far_world = inv_vp @ far_clip\n    85→\n    86→    # Perspective divide\n    87→    near_world = near_world[:3] / near_world[3]\n    88→    far_world = far_world[:3] / far_world[3]\n    89→\n    90→    direction = far_world - near_world\n    91→    length = np.linalg.norm(direction)\n    92→    if length > 1e-8:\n    93→        direction /= length\n    94→\n    95→    return near_world.astype(np.float32), direction.astype(np.float32)\n    96→\n    97→\n    98→def _ray_plane_intersect(\n    99→    ray_origin: np.ndarray,\n   100→    ray_dir: np.ndarray,\n   101→    plane_y: float = 0.0,\n   102→) -> Optional[np.ndarray]:\n   103→    \"\"\"Intersect ray with horizontal plane y=plane_y. Returns hit point or None.\"\"\"\n   104→    if abs(ray_dir[1]) < 1e-8:\n   105→        return None\n   106→    t = (plane_y - ray_origin[1]) / ray_dir[1]\n   107→    if t < 0:\n   108→        return None\n   109→    return (ray_origin + t * ray_dir).astype(np.float32)\n   110→\n   111→\n   112→class UI:\n   113→    \"\"\"ImGui user interface manager.\n   114→\n   115→    Parameters\n   116→    ----------\n   117→    window : GLFW window handle\n   118→        The GLFW window to attach ImGui to.\n   119→    \"\"\"\n   120→\n   121→    def __init__(self, window) -> None:\n   122→        self._window = window\n   123→        self._selected_material: int = WATER\n   124→        self._brush_radius: float = 0.1\n   125→        self._speed_log: float = 0.0  # log10(speed), maps to 0.1-10.0\n   126→        self._max_particles_idx: int = 0  # index into _MAX_PARTICLES_OPTIONS\n   127→\n   128→        # ImGui context + renderer\n   129→        imgui.create_context()\n   130→        self._imgui_renderer = GlfwRenderer(window, attach_callbacks=False)\n   131→\n   132→        # We manually forward events to imgui renderer\n   133→        # Store references to user callbacks so we can chain\n   134→        self._user_key_cb = None\n   135→        self._user_mouse_button_cb = None\n   136→        self._user_cursor_pos_cb = None\n   137→        self._user_scroll_cb = None\n   138→\n   139→        # Brush action state\n   140→        self._pending_spawn: Optional[Tuple[float, float]] = None\n   141→        self._pending_kill: Optional[Tuple[float, float]] = None\n   142→\n   143→        # Cached viewport size\n   144→        w, h = glfw.get_framebuffer_size(window)\n   145→        self._viewport_w = w\n   146→        self._viewport_h = h\n   147→\n   148→        # Track whether resize callback needs chaining\n   149→        self._user_framebuffer_cb = None\n   150→\n   151→    def set_callbacks(\n   152→        self,\n   153→        key_cb=None,\n   154→        mouse_button_cb=None,\n   155→        cursor_pos_cb=None,\n   156→        scroll_cb=None,\n   157→        framebuffer_cb=None,\n   158→    ) -> None:\n   159→        \"\"\"Store user callbacks and install combined GLFW callbacks.\"\"\"\n   160→        self._user_key_cb = key_cb\n   161→        self._user_mouse_button_cb = mouse_button_cb\n   162→        self._user_cursor_pos_cb = cursor_pos_cb\n   163→        self._user_scroll_cb = scroll_cb\n   164→        self._user_framebuffer_cb = framebuffer_cb\n   165→\n   166→        glfw.set_key_callback(self._window, self._on_key)\n   167→        glfw.set_mouse_button_callback(self._window, self._on_mouse_button)\n   168→        glfw.set_cursor_pos_callback(self._window, self._on_cursor_pos)\n   169→        glfw.set_scroll_callback(self._window, self._on_scroll)\n   170→        glfw.set_char_callback(self._window, self._on_char)\n   171→        glfw.set_framebuffer_size_callback(self._window, self._on_framebuffer_size)\n   172→\n   173→    def _on_key(self, window, key, scancode, action, mods):\n   174→        self._imgui_renderer.keyboard_callback(window, key, scancode, action, mods)\n   175→        io = imgui.get_io()\n   176→        if io.want_capture_keyboard:\n   177→            return\n   178→        if self._user_key_cb:\n   179→            self._user_key_cb(window, key, scancode, action, mods)\n   180→\n   181→    def _on_mouse_button(self, window, button, action, mods):\n   182→        self._imgui_renderer.mouse_button_callback(window, button, action, mods)\n   183→        io = imgui.get_io()\n   184→        if io.want_capture_mouse:\n   185→            return\n   186→\n   187→        # Left click = spawn, Shift+left click = kill\n   188→        if button == glfw.MOUSE_BUTTON_LEFT and action == glfw.PRESS:\n   189→            mx, my = glfw.get_cursor_pos(window)\n   190→            if mods & glfw.MOD_SHIFT:\n   191→                self._pending_kill = (mx, my)\n   192→            else:\n   193→                self._pending_spawn = (mx, my)\n   194→            return\n   195→\n   196→        if self._user_mouse_button_cb:\n   197→            self._user_mouse_button_cb(window, button, action, mods)\n   198→\n   199→    def _on_cursor_pos(self, window, xpos, ypos):\n   200→        self._imgui_renderer.mouse_callback(window, xpos, ypos)\n   201→        io = imgui.get_io()\n   202→        if io.want_capture_mouse:\n   203→            return\n   204→        if self._user_cursor_pos_cb:\n   205→            self._user_cursor_pos_cb(window, xpos, ypos)\n   206→\n   207→    def _on_scroll(self, window, xoffset, yoffset):\n   208→        self._imgui_renderer.scroll_callback(window, xoffset, yoffset)\n   209→        io = imgui.get_io()\n   210→        if io.want_capture_mouse:\n   211→            return\n   212→        if self._user_scroll_cb:\n   213→            self._user_scroll_cb(window, xoffset, yoffset)\n   214→\n   215→    def _on_char(self, window, char):\n   216→        self._imgui_renderer.char_callback(window, char)\n   217→\n   218→    def _on_framebuffer_size(self, window, width, height):\n   219→        self._viewport_w = width\n   220→        self._viewport_h = height\n   221→        if self._user_framebuffer_cb:\n   222→            self._user_framebuffer_cb(window, width, height)\n   223→\n   224→    @property\n   225→    def selected_material(self) -> int:\n   226→        return self._selected_material\n   227→\n   228→    @property\n   229→    def brush_radius(self) -> float:\n   230→        return self._brush_radius\n   231→\n   232→    @property\n   233→    def want_capture_mouse(self) -> bool:\n   234→        return imgui.get_io().want_capture_mouse\n   235→\n   236→    def process_brush_actions(self, world, camera) -> int:\n   237→        \"\"\"Process pending spawn/kill brush actions.\n   238→\n   239→        Returns number of particles spawned (negative = killed).\n   240→        \"\"\"\n   241→        delta = 0\n   242→        view = camera.view_matrix()\n   243→        proj = camera.projection_matrix()\n   244→\n   245→        if self._pending_spawn is not None:\n   246→            mx, my = self._pending_spawn\n   247→            self._pending_spawn = None\n   248→            origin, direction = _unproject_mouse_ray(\n   249→                mx, my, self._viewport_w, self._viewport_h, view, proj,\n   250→            )\n   251→            hit = _ray_plane_intersect(origin, direction, plane_y=0.0)\n   252→            if hit is not None:\n   253→                n = world.spawn_sphere(\n   254→                    center=(float(hit[0]), float(hit[1]), float(hit[2])),\n   255→                    radius=self._brush_radius,\n   256→                    material_id=self._selected_material,\n   257→                    count=int(500 * (self._brush_radius / 0.1) ** 3),\n   258→                )\n   259→                delta += n\n   260→\n   261→        if self._pending_kill is not None:\n   262→            mx, my = self._pending_kill\n   263→            self._pending_kill = None\n   264→            origin, direction = _unproject_mouse_ray(\n   265→                mx, my, self._viewport_w, self._viewport_h, view, proj,\n   266→            )\n   267→            hit = _ray_plane_intersect(origin, direction, plane_y=0.0)\n   268→            if hit is not None:\n   269→                killed = world.kill_in_sphere(\n   270→                    center=(float(hit[0]), float(hit[1]), float(hit[2])),\n   271→                    radius=self._brush_radius,\n   272→                )\n   273→                delta -= killed\n   274→\n   275→        return delta\n   276→\n   277→    def begin_frame(self) -> None:\n   278→        \"\"\"Start a new ImGui frame. Call after glfw.poll_events().\"\"\"\n   279→        self._imgui_renderer.process_inputs()\n   280→        imgui.new_frame()\n   281→\n   282→    def end_frame(self) -> None:\n   283→        \"\"\"Finalize and render ImGui. Call before glfw.swap_buffers().\"\"\"\n   284→        imgui.render()\n   285→        self._imgui_renderer.render(imgui.get_draw_data())\n   286→\n   287→    def draw(self, sim, world, fps: float) -> Optional[int]:\n   288→        \"\"\"Draw all UI panels. Returns new max_particles if changed, else None.\n   289→\n   290→        Parameters\n   291→        ----------\n   292→        sim : Simulation\n   293→            The simulation orchestrator (for speed, accuracy, dt, etc.)\n   294→        world : World\n   295→            The particle world (for particle count, max_particles)\n   296→        fps : float\n   297→            Current frames per second\n   298→        \"\"\"\n   299→        new_max = None\n   300→\n   301→        # --- Material Picker Panel ---\n   302→        imgui.set_next_window_pos(imgui.ImVec2(10, 10), imgui.Cond_.first_use_ever)\n   303→        imgui.set_next_window_size(imgui.ImVec2(220, 0), imgui.Cond_.first_use_ever)\n   304→\n   305→        if imgui.begin(\"Materials\", None, imgui.WindowFlags_.always_auto_resize)[0]:\n   306→            # 3x5 grid of material buttons\n   307→            btn_size = imgui.ImVec2(60, 30)\n   308→            for i, mat_id in enumerate(_PICKER_MATERIALS):\n   309→                mat = MATERIALS[mat_id]\n   310→                col = imgui.ImVec4(mat.color_r, mat.color_g, mat.color_b, 1.0)\n   311→\n   312→                # Highlight selected material\n   313→                is_selected = (mat_id == self._selected_material)\n   314→                if is_selected:\n   315→                    imgui.push_style_color(imgui.Col_.button, col)\n   316→                    imgui.push_style_color(\n   317→                        imgui.Col_.button_hovered,\n   318→                        imgui.ImVec4(\n   319→                            min(1.0, col.x + 0.2),\n   320→                            min(1.0, col.y + 0.2),\n   321→                            min(1.0, col.z + 0.2),\n   322→                            1.0,\n   323→                        ),\n   324→                    )\n   325→                    imgui.push_style_color(imgui.Col_.button_active, col)\n   326→                else:\n   327→                    # Dim version of color\n   328→                    dim = imgui.ImVec4(col.x * 0.6, col.y * 0.6, col.z * 0.6, 1.0)\n   329→                    imgui.push_style_color(imgui.Col_.button, dim)\n   330→                    imgui.push_style_color(\n   331→                        imgui.Col_.button_hovered, col,\n   332→                    )\n   333→                    imgui.push_style_color(\n   334→                        imgui.Col_.button_active, col,\n   335→                    )\n   336→\n   337→                # Short name for button label\n   338→                label = mat.name[:6]\n   339→                if imgui.button(f\"{label}##{mat_id}\", btn_size):\n   340→                    self._selected_material = mat_id\n   341→\n   342→                imgui.pop_style_color(3)\n   343→\n   344→                # 3 columns: same_line after 1st and 2nd in each row\n   345→                col_idx = i % 3\n   346→                if col_idx < 2 and i < len(_PICKER_MATERIALS) - 1:\n   347→                    imgui.same_line()\n   348→\n   349→            imgui.separator()\n   350→\n   351→            # Brush size slider\n   352→            changed, new_val = imgui.slider_float(\n   353→                \"Brush\", self._brush_radius, 0.02, 0.3, \"%.2f\",\n   354→            )\n   355→            if changed:\n   356→                self._brush_radius = new_val\n   357→\n   358→            imgui.text(f\"Selected: {MATERIALS[self._selected_material].name}\")\n   359→            imgui.text(\"LClick=Spawn  Shift+LClick=Kill\")\n   360→\n   361→        imgui.end()\n   362→\n   363→        # --- Simulation Controls Panel ---\n   364→        imgui.set_next_window_pos(imgui.ImVec2(10, 400), imgui.Cond_.first_use_ever)\n   365→        imgui.set_next_window_size(imgui.ImVec2(220, 0), imgui.Cond_.first_use_ever)\n   366→\n   367→        if imgui.begin(\"Simulation\", None, imgui.WindowFlags_.always_auto_resize)[0]:\n   368→            # Speed slider (log scale 0.1 to 10.0)\n   369→            # Map log10(speed) from log10(0.1)=-1 to log10(10)=1\n   370→            log_speed = math.log10(max(0.1, sim.speed))\n   371→            changed, new_log = imgui.slider_float(\n   372→                \"Speed\", log_speed, -1.0, 1.0, f\"{sim.speed:.2f}x\",\n   373→            )\n   374→            if changed:\n   375→                sim.speed = max(0.1, min(10.0, 10.0 ** new_log))\n   376→\n   377→            # Accuracy slider\n   378→            changed, new_acc = imgui.slider_float(\n   379→                \"Accuracy\", sim.accuracy, 0.1, 1.0, \"%.1f\",\n   380→            )\n   381→            if changed:\n   382→                sim.accuracy = max(0.1, min(1.0, new_acc))\n   383→\n   384→            # Fixed dt checkbox + value\n   385→            changed, new_fixed = imgui.checkbox(\"Fixed dt\", sim.fixed_dt)\n   386→            if changed:\n   387→                sim.toggle_fixed_dt()\n   388→\n   389→            if sim.fixed_dt:\n   390→                imgui.same_line()\n   391→                changed, new_fdt = imgui.input_float(\n   392→                    \"##fdt\", sim.fixed_dt_value * 1000.0, 0.1, 1.0, \"%.2f ms\",\n   393→                )\n   394→                if changed:\n   395→                    sim.fixed_dt_value = max(0.01, new_fdt) / 1000.0\n   396→                    sim._upload_dt(sim.fixed_dt_value)\n   397→\n   398→            # Max particles dropdown\n   399→            imgui.separator()\n   400→            # Find current index\n   401→            cur_max = world.max_particles\n   402→            cur_idx = 0\n   403→            for idx, (val, _) in enumerate(_MAX_PARTICLES_OPTIONS):\n   404→                if val == cur_max:\n   405→                    cur_idx = idx\n   406→                    break\n   407→\n   408→            labels = [label for _, label in _MAX_PARTICLES_OPTIONS]\n   409→            preview = labels[cur_idx]\n   410→            if imgui.begin_combo(\"Max particles\", preview)[0]:\n   411→                for idx, (val, label) in enumerate(_MAX_PARTICLES_OPTIONS):\n   412→                    is_sel = (idx == cur_idx)\n   413→                    clicked, _ = imgui.selectable(label, is_sel)\n   414→                    if clicked and val != cur_max:\n   415→                        new_max = val\n   416→                    if is_sel:\n   417→                        imgui.set_item_default_focus()\n   418→                imgui.end_combo()\n   419→\n   420→            # Pause button\n   421→            if imgui.button(\"Pause [Space]\" if not sim.paused else \"Resume [Space]\"):\n   422→                sim.toggle_pause()\n   423→\n   424→        imgui.end()\n   425→\n   426→        # --- Status Bar ---\n   427→        vp = imgui.get_main_viewport()\n   428→        status_h = 30.0\n   429→        imgui.set_next_window_pos(\n   430→            imgui.ImVec2(vp.pos.x, vp.pos.y + vp.size.y - status_h),\n   431→        )\n   432→        imgui.set_next_window_size(imgui.ImVec2(vp.size.x, status_h))\n   433→        flags = (\n   434→            imgui.WindowFlags_.no_decoration\n   435→            | imgui.WindowFlags_.no_move\n   436→            | imgui.WindowFlags_.no_saved_settings\n   437→            | imgui.WindowFlags_.no_focus_on_appearing\n   438→            | imgui.WindowFlags_.no_nav\n   439→            | imgui.WindowFlags_.no_inputs\n   440→        )\n   441→        imgui.set_next_window_bg_alpha(0.65)\n   442→\n   443→        if imgui.begin(\"##StatusBar\", None, flags)[0]:\n   444→            active = world._high_water\n   445→            max_p = world.max_particles\n   446→            dt_ms = sim.dt * 1000.0\n   447→            substeps = sim.last_substeps\n   448→            speed = sim.speed\n   449→            paused_str = \"PAUSED\" if sim.paused else \"\"\n   450→            dt_mode = \"FIXED\" if sim.fixed_dt else \"CFL\"\n   451→\n   452→            imgui.text(\n   453→                f\"  Particles: {active:,}/{max_p:,}  |  \"\n   454→                f\"FPS: {fps:.0f}  |  \"\n   455→                f\"dt: {dt_ms:.2f}ms ({dt_mode})  |  \"\n   456→                f\"substeps: {substeps}  |  \"\n   457→                f\"speed: {speed:.1f}x  \"\n   458→                f\"{paused_str}\"\n   459→            )\n   460→\n   461→        imgui.end()\n   462→\n   463→        return new_max\n   464→\n   465→    def handle_key_shortcuts(self, key: int, action: int, sim) -> bool:\n   466→        \"\"\"Handle keyboard shortcuts for material selection etc.\n   467→\n   468→        Returns True if the key was consumed.\n   469→        \"\"\"\n   470→        if action != glfw.PRESS:\n   471→            return False\n   472→\n   473→        # Quick material select: 1-9\n   474→        if key in _QUICK_SELECT:\n   475→            self._selected_material = _QUICK_SELECT[key]\n   476→            return True\n   477→\n   478→        return False\n   479→\n   480→    def shutdown(self) -> None:\n   481→        \"\"\"Clean up ImGui resources.\"\"\"\n   482→        self._imgui_renderer.shutdown()\n   483→        imgui.destroy_context()\n   484→"}]},"parent_tool_use_id":null,"session_id":"b723e047-a0d7-4deb-a7c3-8c0b4525f837","uuid":"ccda9c81-4697-4205-bcfb-d27aba26af3e","tool_use_result":{"type":"update","filePath":"/c/WORK/gpusphsim/fallingsand3d/ui.py","content":"\"\"\"ImGui-based user interface for Falling Sand 3D.\n\nProvides:\n- Material picker panel (15 materials as colored buttons in 3x5 grid)\n- Brush size slider\n- Simulation controls (speed, accuracy, fixed_dt, max_particles)\n- Status bar (particle count, FPS, dt, substeps, speed, paused)\n- Left-click spawns selected material; Shift+click kills particles\n- Keyboard shortcuts: 1-9 for material select, Space=pause, R=reset, +/- speed\n\nUses imgui-bundle (imgui.backends.glfw_opengl3) integrated into the GLFW event loop.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nfrom typing import Optional, Tuple\n\nimport numpy as np\n\nfrom imgui_bundle import imgui\nfrom imgui_bundle.python_backends.glfw_backend import GlfwRenderer\nimport glfw\n\nfrom materials import (\n    MATERIALS, DEAD, STONE, SAND, DIRT, GRAVEL, WATER, OIL, LAVA, ACID,\n    WOOD, METAL, ICE, STEAM, SMOKE, FIRE, GUNPOWDER,\n)\n\n# Material IDs for the picker (exclude DEAD=0)\n_PICKER_MATERIALS = [\n    STONE, SAND, DIRT, GRAVEL, WATER,\n    OIL, LAVA, ACID, WOOD, METAL,\n    ICE, STEAM, SMOKE, FIRE, GUNPOWDER,\n]\n\n# Quick-select mapping: keys 1-9 map to first 9 materials\n_QUICK_SELECT = {\n    glfw.KEY_1: STONE,\n    glfw.KEY_2: SAND,\n    glfw.KEY_3: DIRT,\n    glfw.KEY_4: GRAVEL,\n    glfw.KEY_5: WATER,\n    glfw.KEY_6: OIL,\n    glfw.KEY_7: LAVA,\n    glfw.KEY_8: ACID,\n    glfw.KEY_9: WOOD,\n}\n\n# Max particles options\n_MAX_PARTICLES_OPTIONS = [\n    (100_000, \"100K\"),\n    (250_000, \"250K\"),\n    (500_000, \"500K\"),\n    (1_000_000, \"1M\"),\n]\n\n\ndef _unproject_mouse_ray(\n    mx: float, my: float,\n    viewport_w: int, viewport_h: int,\n    view: np.ndarray, proj: np.ndarray,\n) -> Tuple[np.ndarray, np.ndarray]:\n    \"\"\"Unproject screen coordinates to a world-space ray.\n\n    Returns (ray_origin, ray_direction) both as float32[3].\n    \"\"\"\n    # Normalized device coords [-1, 1]\n    ndc_x = (2.0 * mx / viewport_w) - 1.0\n    ndc_y = 1.0 - (2.0 * my / viewport_h)  # flip Y\n\n    # Inverse view-projection\n    vp = proj @ view\n    try:\n        inv_vp = np.linalg.inv(vp)\n    except np.linalg.LinAlgError:\n        return np.zeros(3, dtype=np.float32), np.array([0, 0, -1], dtype=np.float32)\n\n    # Near and far points in clip space\n    near_clip = np.array([ndc_x, ndc_y, -1.0, 1.0], dtype=np.float32)\n    far_clip = np.array([ndc_x, ndc_y, 1.0, 1.0], dtype=np.float32)\n\n    near_world = inv_vp @ near_clip\n    far_world = inv_vp @ far_clip\n\n    # Perspective divide\n    near_world = near_world[:3] / near_world[3]\n    far_world = far_world[:3] / far_world[3]\n\n    direction = far_world - near_world\n    length = np.linalg.norm(direction)\n    if length > 1e-8:\n        direction /= length\n\n    return near_world.astype(np.float32), direction.astype(np.float32)\n\n\ndef _ray_plane_intersect(\n    ray_origin: np.ndarray,\n    ray_dir: np.ndarray,\n    plane_y: float = 0.0,\n) -> Optional[np.ndarray]:\n    \"\"\"Intersect ray with horizontal plane y=plane_y. Returns hit point or None.\"\"\"\n    if abs(ray_dir[1]) < 1e-8:\n        return None\n    t = (plane_y - ray_origin[1]) / ray_dir[1]\n    if t < 0:\n        return None\n    return (ray_origin + t * ray_dir).astype(np.float32)\n\n\nclass UI:\n    \"\"\"ImGui user interface manager.\n\n    Parameters\n    ----------\n    window : GLFW window handle\n        The GLFW window to attach ImGui to.\n    \"\"\"\n\n    def __init__(self, window) -> None:\n        self._window = window\n        self._selected_material: int = WATER\n        self._brush_radius: float = 0.1\n        self._speed_log: float = 0.0  # log10(speed), maps to 0.1-10.0\n        self._max_particles_idx: int = 0  # index into _MAX_PARTICLES_OPTIONS\n\n        # ImGui context + renderer\n        imgui.create_context()\n        self._imgui_renderer = GlfwRenderer(window, attach_callbacks=False)\n\n        # We manually forward events to imgui renderer\n        # Store references to user callbacks so we can chain\n        self._user_key_cb = None\n        self._user_mouse_button_cb = None\n        self._user_cursor_pos_cb = None\n        self._user_scroll_cb = None\n\n        # Brush action state\n        self._pending_spawn: Optional[Tuple[float, float]] = None\n        self._pending_kill: Optional[Tuple[float, float]] = None\n\n        # Cached viewport size\n        w, h = glfw.get_framebuffer_size(window)\n        self._viewport_w = w\n        self._viewport_h = h\n\n        # Track whether resize callback needs chaining\n        self._user_framebuffer_cb = None\n\n    def set_callbacks(\n        self,\n        key_cb=None,\n        mouse_button_cb=None,\n        cursor_pos_cb=None,\n        scroll_cb=None,\n        framebuffer_cb=None,\n    ) -> None:\n        \"\"\"Store user callbacks and install combined GLFW callbacks.\"\"\"\n        self._user_key_cb = key_cb\n        self._user_mouse_button_cb = mouse_button_cb\n        self._user_cursor_pos_cb = cursor_pos_cb\n        self._user_scroll_cb = scroll_cb\n        self._user_framebuffer_cb = framebuffer_cb\n\n        glfw.set_key_callback(self._window, self._on_key)\n        glfw.set_mouse_button_callback(self._window, self._on_mouse_button)\n        glfw.set_cursor_pos_callback(self._window, self._on_cursor_pos)\n        glfw.set_scroll_callback(self._window, self._on_scroll)\n        glfw.set_char_callback(self._window, self._on_char)\n        glfw.set_framebuffer_size_callback(self._window, self._on_framebuffer_size)\n\n    def _on_key(self, window, key, scancode, action, mods):\n        self._imgui_renderer.keyboard_callback(window, key, scancode, action, mods)\n        io = imgui.get_io()\n        if io.want_capture_keyboard:\n            return\n        if self._user_key_cb:\n            self._user_key_cb(window, key, scancode, action, mods)\n\n    def _on_mouse_button(self, window, button, action, mods):\n        self._imgui_renderer.mouse_button_callback(window, button, action, mods)\n        io = imgui.get_io()\n        if io.want_capture_mouse:\n            return\n\n        # Left click = spawn, Shift+left click = kill\n        if button == glfw.MOUSE_BUTTON_LEFT and action == glfw.PRESS:\n            mx, my = glfw.get_cursor_pos(window)\n            if mods & glfw.MOD_SHIFT:\n                self._pending_kill = (mx, my)\n            else:\n                self._pending_spawn = (mx, my)\n            return\n\n        if self._user_mouse_button_cb:\n            self._user_mouse_button_cb(window, button, action, mods)\n\n    def _on_cursor_pos(self, window, xpos, ypos):\n        self._imgui_renderer.mouse_callback(window, xpos, ypos)\n        io = imgui.get_io()\n        if io.want_capture_mouse:\n            return\n        if self._user_cursor_pos_cb:\n            self._user_cursor_pos_cb(window, xpos, ypos)\n\n    def _on_scroll(self, window, xoffset, yoffset):\n        self._imgui_renderer.scroll_callback(window, xoffset, yoffset)\n        io = imgui.get_io()\n        if io.want_capture_mouse:\n            return\n        if self._user_scroll_cb:\n            self._user_scroll_cb(window, xoffset, yoffset)\n\n    def _on_char(self, window, char):\n        self._imgui_renderer.char_callback(window, char)\n\n    def _on_framebuffer_size(self, window, width, height):\n        self._viewport_w = width\n        self._viewport_h = height\n        if self._user_framebuffer_cb:\n            self._user_framebuffer_cb(window, width, height)\n\n    @property\n    def selected_material(self) -> int:\n        return self._selected_material\n\n    @property\n    def brush_radius(self) -> float:\n        return self._brush_radius\n\n    @property\n    def want_capture_mouse(self) -> bool:\n        return imgui.get_io().want_capture_mouse\n\n    def process_brush_actions(self, world, camera) -> int:\n        \"\"\"Process pending spawn/kill brush actions.\n\n        Returns number of particles spawned (negative = killed).\n        \"\"\"\n        delta = 0\n        view = camera.view_matrix()\n        proj = camera.projection_matrix()\n\n        if self._pending_spawn is not None:\n            mx, my = self._pending_spawn\n            self._pending_spawn = None\n            origin, direction = _unproject_mouse_ray(\n                mx, my, self._viewport_w, self._viewport_h, view, proj,\n            )\n            hit = _ray_plane_intersect(origin, direction, plane_y=0.0)\n            if hit is not None:\n                n = world.spawn_sphere(\n                    center=(float(hit[0]), float(hit[1]), float(hit[2])),\n                    radius=self._brush_radius,\n                    material_id=self._selected_material,\n                    count=int(500 * (self._brush_radius / 0.1) ** 3),\n                )\n                delta += n\n\n        if self._pending_kill is not None:\n            mx, my = self._pending_kill\n            self._pending_kill = None\n            origin, direction = _unproject_mouse_ray(\n                mx, my, self._viewport_w, self._viewport_h, view, proj,\n            )\n            hit = _ray_plane_intersect(origin, direction, plane_y=0.0)\n            if hit is not None:\n                killed = world.kill_in_sphere(\n                    center=(float(hit[0]), float(hit[1]), float(hit[2])),\n                    radius=self._brush_radius,\n                )\n                delta -= killed\n\n        return delta\n\n    def begin_frame(self) -> None:\n        \"\"\"Start a new ImGui frame. Call after glfw.poll_events().\"\"\"\n        self._imgui_renderer.process_inputs()\n        imgui.new_frame()\n\n    def end_frame(self) -> None:\n        \"\"\"Finalize and render ImGui. Call before glfw.swap_buffers().\"\"\"\n        imgui.render()\n        self._imgui_renderer.render(imgui.get_draw_data())\n\n    def draw(self, sim, world, fps: float) -> Optional[int]:\n        \"\"\"Draw all UI panels. Returns new max_particles if changed, else None.\n\n        Parameters\n        ----------\n        sim : Simulation\n            The simulation orchestrator (for speed, accuracy, dt, etc.)\n        world : World\n            The particle world (for particle count, max_particles)\n        fps : float\n            Current frames per second\n        \"\"\"\n        new_max = None\n\n        # --- Material Picker Panel ---\n        imgui.set_next_window_pos(imgui.ImVec2(10, 10), imgui.Cond_.first_use_ever)\n        imgui.set_next_window_size(imgui.ImVec2(220, 0), imgui.Cond_.first_use_ever)\n\n        if imgui.begin(\"Materials\", None, imgui.WindowFlags_.always_auto_resize)[0]:\n            # 3x5 grid of material buttons\n            btn_size = imgui.ImVec2(60, 30)\n            for i, mat_id in enumerate(_PICKER_MATERIALS):\n                mat = MATERIALS[mat_id]\n                col = imgui.ImVec4(mat.color_r, mat.color_g, mat.color_b, 1.0)\n\n                # Highlight selected material\n                is_selected = (mat_id == self._selected_material)\n                if is_selected:\n                    imgui.push_style_color(imgui.Col_.button, col)\n                    imgui.push_style_color(\n                        imgui.Col_.button_hovered,\n                        imgui.ImVec4(\n                            min(1.0, col.x + 0.2),\n                            min(1.0, col.y + 0.2),\n                            min(1.0, col.z + 0.2),\n                            1.0,\n                        ),\n                    )\n                    imgui.push_style_color(imgui.Col_.button_active, col)\n                else:\n                    # Dim version of color\n                    dim = imgui.ImVec4(col.x * 0.6, col.y * 0.6, col.z * 0.6, 1.0)\n                    imgui.push_style_color(imgui.Col_.button, dim)\n                    imgui.push_style_color(\n                        imgui.Col_.button_hovered, col,\n                    )\n                    imgui.push_style_color(\n                        imgui.Col_.button_active, col,\n                    )\n\n                # Short name for button label\n                label = mat.name[:6]\n                if imgui.button(f\"{label}##{mat_id}\", btn_size):\n                    self._selected_material = mat_id\n\n                imgui.pop_style_color(3)\n\n                # 3 columns: same_line after 1st and 2nd in each row\n                col_idx = i % 3\n                if col_idx < 2 and i < len(_PICKER_MATERIALS) - 1:\n                    imgui.same_line()\n\n            imgui.separator()\n\n            # Brush size slider\n            changed, new_val = imgui.slider_float(\n                \"Brush\", self._brush_radius, 0.02, 0.3, \"%.2f\",\n            )\n            if changed:\n                self._brush_radius = new_val\n\n            imgui.text(f\"Selected: {MATERIALS[self._selected_material].name}\")\n            imgui.text(\"LClick=Spawn  Shift+LClick=Kill\")\n\n        imgui.end()\n\n        # --- Simulation Controls Panel ---\n        imgui.set_next_window_pos(imgui.ImVec2(10, 400), imgui.Cond_.first_use_ever)\n        imgui.set_next_window_size(imgui.ImVec2(220, 0), imgui.Cond_.first_use_ever)\n\n        if imgui.begin(\"Simulation\", None, imgui.WindowFlags_.always_auto_resize)[0]:\n            # Speed slider (log scale 0.1 to 10.0)\n            # Map log10(speed) from log10(0.1)=-1 to log10(10)=1\n            log_speed = math.log10(max(0.1, sim.speed))\n            changed, new_log = imgui.slider_float(\n                \"Speed\", log_speed, -1.0, 1.0, f\"{sim.speed:.2f}x\",\n            )\n            if changed:\n                sim.speed = max(0.1, min(10.0, 10.0 ** new_log))\n\n            # Accuracy slider\n            changed, new_acc = imgui.slider_float(\n                \"Accuracy\", sim.accuracy, 0.1, 1.0, \"%.1f\",\n            )\n            if changed:\n                sim.accuracy = max(0.1, min(1.0, new_acc))\n\n            # Fixed dt checkbox + value\n            changed, new_fixed = imgui.checkbox(\"Fixed dt\", sim.fixed_dt)\n            if changed:\n                sim.toggle_fixed_dt()\n\n            if sim.fixed_dt:\n                imgui.same_line()\n                changed, new_fdt = imgui.input_float(\n                    \"##fdt\", sim.fixed_dt_value * 1000.0, 0.1, 1.0, \"%.2f ms\",\n                )\n                if changed:\n                    sim.fixed_dt_value = max(0.01, new_fdt) / 1000.0\n                    sim._upload_dt(sim.fixed_dt_value)\n\n            # Max particles dropdown\n            imgui.separator()\n            # Find current index\n            cur_max = world.max_particles\n            cur_idx = 0\n            for idx, (val, _) in enumerate(_MAX_PARTICLES_OPTIONS):\n                if val == cur_max:\n                    cur_idx = idx\n                    break\n\n            labels = [label for _, label in _MAX_PARTICLES_OPTIONS]\n            preview = labels[cur_idx]\n            if imgui.begin_combo(\"Max particles\", preview)[0]:\n                for idx, (val, label) in enumerate(_MAX_PARTICLES_OPTIONS):\n                    is_sel = (idx == cur_idx)\n                    clicked, _ = imgui.selectable(label, is_sel)\n                    if clicked and val != cur_max:\n                        new_max = val\n                    if is_sel:\n                        imgui.set_item_default_focus()\n                imgui.end_combo()\n\n            # Pause button\n            if imgui.button(\"Pause [Space]\" if not sim.paused else \"Resume [Space]\"):\n                sim.toggle_pause()\n\n        imgui.end()\n\n        # --- Status Bar ---\n        vp = imgui.get_main_viewport()\n        status_h = 30.0\n        imgui.set_next_window_pos(\n            imgui.ImVec2(vp.pos.x, vp.pos.y + vp.size.y - status_h),\n        )\n        imgui.set_next_window_size(imgui.ImVec2(vp.size.x, status_h))\n        flags = (\n            imgui.WindowFlags_.no_decoration\n            | imgui.WindowFlags_.no_move\n            | imgui.WindowFlags_.no_saved_settings\n            | imgui.WindowFlags_.no_focus_on_appearing\n            | imgui.WindowFlags_.no_nav\n            | imgui.WindowFlags_.no_inputs\n        )\n        imgui.set_next_window_bg_alpha(0.65)\n\n        if imgui.begin(\"##StatusBar\", None, flags)[0]:\n            active = world._high_water\n            max_p = world.max_particles\n            dt_ms = sim.dt * 1000.0\n            substeps = sim.last_substeps\n            speed = sim.speed\n            paused_str = \"PAUSED\" if sim.paused else \"\"\n            dt_mode = \"FIXED\" if sim.fixed_dt else \"CFL\"\n\n            imgui.text(\n                f\"  Particles: {active:,}/{max_p:,}  |  \"\n                f\"FPS: {fps:.0f}  |  \"\n                f\"dt: {dt_ms:.2f}ms ({dt_mode})  |  \"\n                f\"substeps: {substeps}  |  \"\n                f\"speed: {speed:.1f}x  \"\n                f\"{paused_str}\"\n            )\n\n        imgui.end()\n\n        return new_max\n\n    def handle_key_shortcuts(self, key: int, action: int, sim) -> bool:\n        \"\"\"Handle keyboard shortcuts for material selection etc.\n\n        Returns True if the key was consumed.\n        \"\"\"\n        if action != glfw.PRESS:\n            return False\n\n        # Quick material select: 1-9\n        if key in _QUICK_SELECT:\n            self._selected_material = _QUICK_SELECT[key]\n            return True\n\n        return False\n\n    def shutdown(self) -> None:\n        \"\"\"Clean up ImGui resources.\"\"\"\n        self._imgui_renderer.shutdown()\n        imgui.destroy_context()\n","structuredPatch":[{"oldStart":1,"oldLines":1,"newStart":1,"newLines":483,"lines":["-\"\"\"ImGui-based user interface.\"\"\"","+\"\"\"ImGui-based user interface for Falling Sand 3D.","+","+Provides:","+- Material picker panel (15 materials as colored buttons in 3x5 grid)","+- Brush size slider","+- Simulation controls (speed, accuracy, fixed_dt, max_particles)","+- Status bar (particle count, FPS, dt, substeps, speed, paused)","+- Left-click spawns selected material; Shift+click kills particles","+- Keyboard shortcuts: 1-9 for material select, Space=pause, R=reset, +/- speed","+","+Uses imgui-bundle (imgui.backends.glfw_opengl3) integrated into the GLFW event loop.","+\"\"\"","+","+from __future__ import annotations","+","+import math","+from typing import Optional, Tuple","+","+import numpy as np","+","+from imgui_bundle import imgui","+from imgui_bundle.python_backends.glfw_backend import GlfwRenderer","+import glfw","+","+from materials import (","+    MATERIALS, DEAD, STONE, SAND, DIRT, GRAVEL, WATER, OIL, LAVA, ACID,","+    WOOD, METAL, ICE, STEAM, SMOKE, FIRE, GUNPOWDER,","+)","+","+# Material IDs for the picker (exclude DEAD=0)","+_PICKER_MATERIALS = [","+    STONE, SAND, DIRT, GRAVEL, WATER,","+    OIL, LAVA, ACID, WOOD, METAL,","+    ICE, STEAM, SMOKE, FIRE, GUNPOWDER,","+]","+","+# Quick-select mapping: keys 1-9 map to first 9 materials","+_QUICK_SELECT = {","+    glfw.KEY_1: STONE,","+    glfw.KEY_2: SAND,","+    glfw.KEY_3: DIRT,","+    glfw.KEY_4: GRAVEL,","+    glfw.KEY_5: WATER,","+    glfw.KEY_6: OIL,","+    glfw.KEY_7: LAVA,","+    glfw.KEY_8: ACID,","+    glfw.KEY_9: WOOD,","+}","+","+# Max particles options","+_MAX_PARTICLES_OPTIONS = [","+    (100_000, \"100K\"),","+    (250_000, \"250K\"),","+    (500_000, \"500K\"),","+    (1_000_000, \"1M\"),","+]","+","+","+def _unproject_mouse_ray(","+    mx: float, my: float,","+    viewport_w: int, viewport_h: int,","+    view: np.ndarray, proj: np.ndarray,","+) -> Tuple[np.ndarray, np.ndarray]:","+    \"\"\"Unproject screen coordinates to a world-space ray.","+","+    Returns (ray_origin, ray_direction) both as float32[3].","+    \"\"\"","+    # Normalized device coords [-1, 1]","+    ndc_x = (2.0 * mx / viewport_w) - 1.0","+    ndc_y = 1.0 - (2.0 * my / viewport_h)  # flip Y","+","+    # Inverse view-projection","+    vp = proj @ view","+    try:","+        inv_vp = np.linalg.inv(vp)","+    except np.linalg.LinAlgError:","+        return np.zeros(3, dtype=np.float32), np.array([0, 0, -1], dtype=np.float32)","+","+    # Near and far points in clip space","+    near_clip = np.array([ndc_x, ndc_y, -1.0, 1.0], dtype=np.float32)","+    far_clip = np.array([ndc_x, ndc_y, 1.0, 1.0], dtype=np.float32)","+","+    near_world = inv_vp @ near_clip","+    far_world = inv_vp @ far_clip","+","+    # Perspective divide","+    near_world = near_world[:3] / near_world[3]","+    far_world = far_world[:3] / far_world[3]","+","+    direction = far_world - near_world","+    length = np.linalg.norm(direction)","+    if length > 1e-8:","+        direction /= length","+","+    return near_world.astype(np.float32), direction.astype(np.float32)","+","+","+def _ray_plane_intersect(","+    ray_origin: np.ndarray,","+    ray_dir: np.ndarray,","+    plane_y: float = 0.0,","+) -> Optional[np.ndarray]:","+    \"\"\"Intersect ray with horizontal plane y=plane_y. Returns hit point or None.\"\"\"","+    if abs(ray_dir[1]) < 1e-8:","+        return None","+    t = (plane_y - ray_origin[1]) / ray_dir[1]","+    if t < 0:","+        return None","+    return (ray_origin + t * ray_dir).astype(np.float32)","+","+","+class UI:","+    \"\"\"ImGui user interface manager.","+","+    Parameters","+    ----------","+    window : GLFW window handle","+        The GLFW window to attach ImGui to.","+    \"\"\"","+","+    def __init__(self, window) -> None:","+        self._window = window","+        self._selected_material: int = WATER","+        self._brush_radius: float = 0.1","+        self._speed_log: float = 0.0  # log10(speed), maps to 0.1-10.0","+        self._max_particles_idx: int = 0  # index into _MAX_PARTICLES_OPTIONS","+","+        # ImGui context + renderer","+        imgui.create_context()","+        self._imgui_renderer = GlfwRenderer(window, attach_callbacks=False)","+","+        # We manually forward events to imgui renderer","+        # Store references to user callbacks so we can chain","+        self._user_key_cb = None","+        self._user_mouse_button_cb = None","+        self._user_cursor_pos_cb = None","+        self._user_scroll_cb = None","+","+        # Brush action state","+        self._pending_spawn: Optional[Tuple[float, float]] = None","+        self._pending_kill: Optional[Tuple[float, float]] = None","+","+        # Cached viewport size","+        w, h = glfw.get_framebuffer_size(window)","+        self._viewport_w = w","+        self._viewport_h = h","+","+        # Track whether resize callback needs chaining","+        self._user_framebuffer_cb = None","+","+    def set_callbacks(","+        self,","+        key_cb=None,","+        mouse_button_cb=None,","+        cursor_pos_cb=None,","+        scroll_cb=None,","+        framebuffer_cb=None,","+    ) -> None:","+        \"\"\"Store user callbacks and install combined GLFW callbacks.\"\"\"","+        self._user_key_cb = key_cb","+        self._user_mouse_button_cb = mouse_button_cb","+        self._user_cursor_pos_cb = cursor_pos_cb","+        self._user_scroll_cb = scroll_cb","+        self._user_framebuffer_cb = framebuffer_cb","+","+        glfw.set_key_callback(self._window, self._on_key)","+        glfw.set_mouse_button_callback(self._window, self._on_mouse_button)","+        glfw.set_cursor_pos_callback(self._window, self._on_cursor_pos)","+        glfw.set_scroll_callback(self._window, self._on_scroll)","+        glfw.set_char_callback(self._window, self._on_char)","+        glfw.set_framebuffer_size_callback(self._window, self._on_framebuffer_size)","+","+    def _on_key(self, window, key, scancode, action, mods):","+        self._imgui_renderer.keyboard_callback(window, key, scancode, action, mods)","+        io = imgui.get_io()","+        if io.want_capture_keyboard:","+            return","+        if self._user_key_cb:","+            self._user_key_cb(window, key, scancode, action, mods)","+","+    def _on_mouse_button(self, window, button, action, mods):","+        self._imgui_renderer.mouse_button_callback(window, button, action, mods)","+        io = imgui.get_io()","+        if io.want_capture_mouse:","+            return","+","+        # Left click = spawn, Shift+left click = kill","+        if button == glfw.MOUSE_BUTTON_LEFT and action == glfw.PRESS:","+            mx, my = glfw.get_cursor_pos(window)","+            if mods & glfw.MOD_SHIFT:","+                self._pending_kill = (mx, my)","+            else:","+                self._pending_spawn = (mx, my)","+            return","+","+        if self._user_mouse_button_cb:","+            self._user_mouse_button_cb(window, button, action, mods)","+","+    def _on_cursor_pos(self, window, xpos, ypos):","+        self._imgui_renderer.mouse_callback(window, xpos, ypos)","+        io = imgui.get_io()","+        if io.want_capture_mouse:","+            return","+        if self._user_cursor_pos_cb:","+            self._user_cursor_pos_cb(window, xpos, ypos)","+","+    def _on_scroll(self, window, xoffset, yoffset):","+        self._imgui_renderer.scroll_callback(window, xoffset, yoffset)","+        io = imgui.get_io()","+        if io.want_capture_mouse:","+            return","+        if self._user_scroll_cb:","+            self._user_scroll_cb(window, xoffset, yoffset)","+","+    def _on_char(self, window, char):","+        self._imgui_renderer.char_callback(window, char)","+","+    def _on_framebuffer_size(self, window, width, height):","+        self._viewport_w = width","+        self._viewport_h = height","+        if self._user_framebuffer_cb:","+            self._user_framebuffer_cb(window, width, height)","+","+    @property","+    def selected_material(self) -> int:","+        return self._selected_material","+","+    @property","+    def brush_radius(self) -> float:","+        return self._brush_radius","+","+    @property","+    def want_capture_mouse(self) -> bool:","+        return imgui.get_io().want_capture_mouse","+","+    def process_brush_actions(self, world, camera) -> int:","+        \"\"\"Process pending spawn/kill brush actions.","+","+        Returns number of particles spawned (negative = killed).","+        \"\"\"","+        delta = 0","+        view = camera.view_matrix()","+        proj = camera.projection_matrix()","+","+        if self._pending_spawn is not None:","+            mx, my = self._pending_spawn","+            self._pending_spawn = None","+            origin, direction = _unproject_mouse_ray(","+                mx, my, self._viewport_w, self._viewport_h, view, proj,","+            )","+            hit = _ray_plane_intersect(origin, direction, plane_y=0.0)","+            if hit is not None:","+                n = world.spawn_sphere(","+                    center=(float(hit[0]), float(hit[1]), float(hit[2])),","+                    radius=self._brush_radius,","+                    material_id=self._selected_material,","+                    count=int(500 * (self._brush_radius / 0.1) ** 3),","+                )","+                delta += n","+","+        if self._pending_kill is not None:","+            mx, my = self._pending_kill","+            self._pending_kill = None","+            origin, direction = _unproject_mouse_ray(","+                mx, my, self._viewport_w, self._viewport_h, view, proj,","+            )","+            hit = _ray_plane_intersect(origin, direction, plane_y=0.0)","+            if hit is not None:","+                killed = world.kill_in_sphere(","+                    center=(float(hit[0]), float(hit[1]), float(hit[2])),","+                    radius=self._brush_radius,","+                )","+                delta -= killed","+","+        return delta","+","+    def begin_frame(self) -> None:","+        \"\"\"Start a new ImGui frame. Call after glfw.poll_events().\"\"\"","+        self._imgui_renderer.process_inputs()","+        imgui.new_frame()","+","+    def end_frame(self) -> None:","+        \"\"\"Finalize and render ImGui. Call before glfw.swap_buffers().\"\"\"","+        imgui.render()","+        self._imgui_renderer.render(imgui.get_draw_data())","+","+    def draw(self, sim, world, fps: float) -> Optional[int]:","+        \"\"\"Draw all UI panels. Returns new max_particles if changed, else None.","+","+        Parameters","+        ----------","+        sim : Simulation","+            The simulation orchestrator (for speed, accuracy, dt, etc.)","+        world : World","+            The particle world (for particle count, max_particles)","+        fps : float","+            Current frames per second","+        \"\"\"","+        new_max = None","+","+        # --- Material Picker Panel ---","+        imgui.set_next_window_pos(imgui.ImVec2(10, 10), imgui.Cond_.first_use_ever)","+        imgui.set_next_window_size(imgui.ImVec2(220, 0), imgui.Cond_.first_use_ever)","+","+        if imgui.begin(\"Materials\", None, imgui.WindowFlags_.always_auto_resize)[0]:","+            # 3x5 grid of material buttons","+            btn_size = imgui.ImVec2(60, 30)","+            for i, mat_id in enumerate(_PICKER_MATERIALS):","+                mat = MATERIALS[mat_id]","+                col = imgui.ImVec4(mat.color_r, mat.color_g, mat.color_b, 1.0)","+","+                # Highlight selected material","+                is_selected = (mat_id == self._selected_material)","+                if is_selected:","+                    imgui.push_style_color(imgui.Col_.button, col)","+                    imgui.push_style_color(","+                        imgui.Col_.button_hovered,","+                        imgui.ImVec4(","+                            min(1.0, col.x + 0.2),","+                            min(1.0, col.y + 0.2),","+                            min(1.0, col.z + 0.2),","+                            1.0,","+                        ),","+                    )","+                    imgui.push_style_color(imgui.Col_.button_active, col)","+                else:","+                    # Dim version of color","+                    dim = imgui.ImVec4(col.x * 0.6, col.y * 0.6, col.z * 0.6, 1.0)","+                    imgui.push_style_color(imgui.Col_.button, dim)","+                    imgui.push_style_color(","+                        imgui.Col_.button_hovered, col,","+                    )","+                    imgui.push_style_color(","+                        imgui.Col_.button_active, col,","+                    )","+","+                # Short name for button label","+                label = mat.name[:6]","+                if imgui.button(f\"{label}##{mat_id}\", btn_size):","+                    self._selected_material = mat_id","+","+                imgui.pop_style_color(3)","+","+                # 3 columns: same_line after 1st and 2nd in each row","+                col_idx = i % 3","+                if col_idx < 2 and i < len(_PICKER_MATERIALS) - 1:","+                    imgui.same_line()","+","+            imgui.separator()","+","+            # Brush size slider","+            changed, new_val = imgui.slider_float(","+                \"Brush\", self._brush_radius, 0.02, 0.3, \"%.2f\",","+            )","+            if changed:","+                self._brush_radius = new_val","+","+            imgui.text(f\"Selected: {MATERIALS[self._selected_material].name}\")","+            imgui.text(\"LClick=Spawn  Shift+LClick=Kill\")","+","+        imgui.end()","+","+        # --- Simulation Controls Panel ---","+        imgui.set_next_window_pos(imgui.ImVec2(10, 400), imgui.Cond_.first_use_ever)","+        imgui.set_next_window_size(imgui.ImVec2(220, 0), imgui.Cond_.first_use_ever)","+","+        if imgui.begin(\"Simulation\", None, imgui.WindowFlags_.always_auto_resize)[0]:","+            # Speed slider (log scale 0.1 to 10.0)","+            # Map log10(speed) from log10(0.1)=-1 to log10(10)=1","+            log_speed = math.log10(max(0.1, sim.speed))","+            changed, new_log = imgui.slider_float(","+                \"Speed\", log_speed, -1.0, 1.0, f\"{sim.speed:.2f}x\",","+            )","+            if changed:","+                sim.speed = max(0.1, min(10.0, 10.0 ** new_log))","+","+            # Accuracy slider","+            changed, new_acc = imgui.slider_float(","+                \"Accuracy\", sim.accuracy, 0.1, 1.0, \"%.1f\",","+            )","+            if changed:","+                sim.accuracy = max(0.1, min(1.0, new_acc))","+","+            # Fixed dt checkbox + value","+            changed, new_fixed = imgui.checkbox(\"Fixed dt\", sim.fixed_dt)","+            if changed:","+                sim.toggle_fixed_dt()","+","+            if sim.fixed_dt:","+                imgui.same_line()","+                changed, new_fdt = imgui.input_float(","+                    \"##fdt\", sim.fixed_dt_value * 1000.0, 0.1, 1.0, \"%.2f ms\",","+                )","+                if changed:","+                    sim.fixed_dt_value = max(0.01, new_fdt) / 1000.0","+                    sim._upload_dt(sim.fixed_dt_value)","+","+            # Max particles dropdown","+            imgui.separator()","+            # Find current index","+            cur_max = world.max_particles","+            cur_idx = 0","+            for idx, (val, _) in enumerate(_MAX_PARTICLES_OPTIONS):","+                if val == cur_max:","+                    cur_idx = idx","+                    break","+","+            labels = [label for _, label in _MAX_PARTICLES_OPTIONS]","+            preview = labels[cur_idx]","+            if imgui.begin_combo(\"Max particles\", preview)[0]:","+                for idx, (val, label) in enumerate(_MAX_PARTICLES_OPTIONS):","+                    is_sel = (idx == cur_idx)","+                    clicked, _ = imgui.selectable(label, is_sel)","+                    if clicked and val != cur_max:","+                        new_max = val","+                    if is_sel:","+                        imgui.set_item_default_focus()","+                imgui.end_combo()","+","+            # Pause button","+            if imgui.button(\"Pause [Space]\" if not sim.paused else \"Resume [Space]\"):","+                sim.toggle_pause()","+","+        imgui.end()","+","+        # --- Status Bar ---","+        vp = imgui.get_main_viewport()","+        status_h = 30.0","+        imgui.set_next_window_pos(","+            imgui.ImVec2(vp.pos.x, vp.pos.y + vp.size.y - status_h),","+        )","+        imgui.set_next_window_size(imgui.ImVec2(vp.size.x, status_h))","+        flags = (","+            imgui.WindowFlags_.no_decoration","+            | imgui.WindowFlags_.no_move","+            | imgui.WindowFlags_.no_saved_settings","+            | imgui.WindowFlags_.no_focus_on_appearing","+            | imgui.WindowFlags_.no_nav","+            | imgui.WindowFlags_.no_inputs","+        )","+        imgui.set_next_window_bg_alpha(0.65)","+","+        if imgui.begin(\"##StatusBar\", None, flags)[0]:","+            active = world._high_water","+            max_p = world.max_particles","+            dt_ms = sim.dt * 1000.0","+            substeps = sim.last_substeps","+            speed = sim.speed","+            paused_str = \"PAUSED\" if sim.paused else \"\"","+            dt_mode = \"FIXED\" if sim.fixed_dt else \"CFL\"","+","+            imgui.text(","+                f\"  Particles: {active:,}/{max_p:,}  |  \"","+                f\"FPS: {fps:.0f}  |  \"","+                f\"dt: {dt_ms:.2f}ms ({dt_mode})  |  \"","+                f\"substeps: {substeps}  |  \"","+                f\"speed: {speed:.1f}x  \"","+                f\"{paused_str}\"","+            )","+","+        imgui.end()","+","+        return new_max","+","+    def handle_key_shortcuts(self, key: int, action: int, sim) -> bool:","+        \"\"\"Handle keyboard shortcuts for material selection etc.","+","+        Returns True if the key was consumed.","+        \"\"\"","+        if action != glfw.PRESS:","+            return False","+","+        # Quick material select: 1-9","+        if key in _QUICK_SELECT:","+            self._selected_material = _QUICK_SELECT[key]","+            return True","+","+        return False","+","+    def shutdown(self) -> None:","+        \"\"\"Clean up ImGui resources.\"\"\"","+        self._imgui_renderer.shutdown()","+        imgui.destroy_context()"]}],"originalFile":"\"\"\"ImGui-based user interface.\"\"\"\n"}}

s),\n    (\"imgui.set_next_window_size\", lambda: imgui.set_next_window_size),\n    (\"imgui.set_next_window_bg_alpha\", lambda: imgui.set_next_window_bg_alpha),\n    (\"imgui.create_context\", lambda: imgui.create_context),\n    (\"imgui.destroy_context\", lambda: imgui.destroy_context),\n    (\"imgui.new_frame\", lambda: imgui.new_frame),\n    (\"imgui.render\", lambda: imgui.render),\n    (\"imgui.get_draw_data\", lambda: imgui.get_draw_data),\n    (\"imgui.get_io\", lambda: imgui.get_io),\n]\n\nfor name, fn in checks:\n    try:\n        result = fn()\n        print(f\"  OK: {name} -> {type(result).__name__}\")\n    except AttributeError as e:\n        print(f\"  FAIL: {name} -> {e}\")\n    except Exception as e:\n        print(f\"  WARN: {name} -> {type(e).__name__}: {e}\")\n\n# Check GlfwRenderer\ntry:\n    from imgui_bundle.python_backends.glfw_backend import GlfwRenderer\n    print(\"\\nGlfwRenderer imported OK\")\n    # Check methods\n    for m in ['keyboard_callback', 'mouse_button_callback', 'mouse_callback',\n              'scroll_callback', 'char_callback', 'process_inputs', 'render', 'shutdown']:\n        if hasattr(GlfwRenderer, m):\n            print(f\"  OK: GlfwRenderer.{m}\")\n        else:\n            print(f\"  FAIL: GlfwRenderer.{m} not found\")\nexcept ImportError as e:\n    print(f\"GlfwRenderer FAIL: {e}\")\n\n# Check want_capture_mouse on IO\nprint(\"\\nChecking IO fields...\")\ntry:\n    ctx = imgui.create_context()\n    io = imgui.get_io()\n    print(f\"  want_capture_mouse: {io.want_capture_mouse}\")\n    print(f\"  want_capture_keyboard: {io.want_capture_keyboard}\")\n    imgui.destroy_context(ctx)\nexcept Exception as e:\n    print(f\"  FAIL: {e}\")\n"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":219,"cache_read_input_tokens":124653,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":219},"output_tokens":25,"service_tier":"standard","inference_geo":"not_avail
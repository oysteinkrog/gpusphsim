{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ESriJeJfFLG988v42adtX3","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter,\n     5→accuracy parameter (CFL number), and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. If adaptive mode: compute dt from CFL constraints (advection, acoustic, viscous)\n     9→  2. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n    10→  3. Run sim_steps simulation substeps\n    11→  4. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    12→\"\"\"\n    13→\n    14→from __future__ import annotations\n    15→\n    16→import math\n    17→import time\n    18→from typing import Optional\n    19→\n    20→import cupy as cp\n    21→import numpy as np\n    22→\n    23→from world import World\n    24→from materials import (\n    25→    WATER, SAND, MATERIALS, GRANULAR, GAS, STATIC,\n    26→    build_material_array, build_interaction_matrix, upload_to_gpu,\n    27→)\n    28→\n    29→import hash_sort\n    30→import fused_reorder\n    31→import build_grid\n    32→import step1\n    33→import step2\n    34→import integrate\n    35→import reactions\n    36→import spawn\n    37→import wake\n    38→\n    39→# Adaptive timestep limits\n    40→DT_MIN = 1e-5\n    41→DT_MAX = 0.005\n    42→\n    43→\n    44→class Simulation:\n    45→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    46→\n    47→    Parameters\n    48→    ----------\n    49→    world : World\n    50→        Particle state manager.\n    51→    dt : float\n    52→        Initial simulation timestep (seconds). Used as fixed_dt_value when\n    53→        fixed_dt is ON.\n    54→    speed : float\n    55→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    56→    accuracy : float\n    57→        CFL number for adaptive timestep (0.1-1.0, default 0.4).\n    58→        Lower = smaller dt = more stable. Higher = larger dt = faster but riskier.\n    59→    fixed_dt : bool\n    60→        If True, use fixed timestep (no CFL computation). Default False.\n    61→    max_substeps : int\n    62→        Maximum substeps per render frame to prevent spiral-of-death.\n    63→    \"\"\"\n    64→\n    65→    def __init__(\n    66→        self,\n    67→        world: World,\n    68→        dt: float = 0.001,\n    69→        speed: float = 1.0,\n    70→        accuracy: float = 0.4,\n    71→        fixed_dt: bool = False,\n    72→        max_substeps: int = 20,\n    73→    ) -> None:\n    74→        self.world = world\n    75→        self.dt = dt\n    76→        self.speed = speed\n    77→        self.accuracy = accuracy\n    78→        self.fixed_dt = fixed_dt\n    79→        self.fixed_dt_value = dt\n    80→        self.max_substeps = max_substeps\n    81→        self._paused = False\n    82→        self._prev_speed = speed\n    83→        self._last_frame_time: Optional[float] = None\n    84→        self._last_substeps = 0\n    85→        self.sim_time = 0.0\n    86→        self._frame_counter = 0\n    87→\n    88→        # Precompute acoustic speed from materials table\n    89→        self._c_sound = self._compute_c_sound()\n    90→        # Precompute max viscosity and min density for viscous CFL\n    91→        self._max_eta, self._rho_min = self._compute_viscosity_bounds()\n    92→\n    93→        # Smoothing length (must match _upload_constants)\n    94→        self._h = 0.04\n    95→\n    96→        # Grid cell tables (pre-allocated, reused every frame)\n    97→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    98→\n    99→        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n   100→        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n   101→\n   102→        # Freelist for spawn/kill system (pre-allocated, reset each step)\n   103→        self._dead_indices, self._dead_count = spawn.allocate_freelist(\n   104→            world.max_particles\n   105→        )\n   106→\n   107→        # Cached sim_params for dt updates (set during _upload_constants)\n   108→        self._sim_params: Optional[np.ndarray] = None\n   109→\n   110→        # Compile all kernel modules and upload constant memory\n   111→        self._upload_constants()\n   112→\n   113→    def _compute_c_sound(self) -> float:\n   114→        \"\"\"Compute acoustic speed: max over active materials of sqrt(k * gamma / rho0).\"\"\"\n   115→        c_sound = 0.0\n   116→        for mat in MATERIALS.values():\n   117→            if mat.behavior_class == STATIC or mat.rest_density <= 0.0:\n   118→                continue\n   119→            k = mat.eos_stiffness\n   120→            gamma = mat.eos_gamma\n   121→            rho0 = mat.rest_density\n   122→            if k > 0.0 and gamma > 0.0 and rho0 > 0.0:\n   123→                c = math.sqrt(k * gamma / rho0)\n   124→                c_sound = max(c_sound, c)\n   125→        return max(c_sound, 0.01)  # floor to avoid zero\n   126→\n   127→    def _compute_viscosity_bounds(self) -> tuple:\n   128→        \"\"\"Compute max viscosity and min density for viscous CFL.\n   129→\n   130→        For GRANULAR materials, uses mu_max (10000) as worst-case eta.\n   131→        For FLUID/GAS, uses base_viscosity from the material table.\n   132→        rho_min excludes GAS materials (they use low constant viscosity,\n   133→        not mu(I), so their low density doesn't tighten the viscous CFL).\n   134→        \"\"\"\n   135→        max_eta = 0.0\n   136→        rho_min = 1e30\n   137→        has_granular = False\n   138→        for mat in MATERIALS.values():\n   139→            if mat.behavior_class == STATIC or mat.rest_density <= 0.0:\n   140→                continue\n   141→            # rho_min for viscous CFL: exclude GAS (never runs mu(I))\n   142→            if mat.behavior_class != GAS and mat.rest_density < rho_min:\n   143→                rho_min = mat.rest_density\n   144→            if mat.behavior_class == GRANULAR:\n   145→                has_granular = True\n   146→            if mat.base_viscosity > max_eta:\n   147→                max_eta = mat.base_viscosity\n   148→        if has_granular:\n   149→            max_eta = max(max_eta, float(step2.DEFAULT_MU_MAX))\n   150→        rho_min = max(rho_min, 0.1)  # floor\n   151→        return max_eta, rho_min\n   152→\n   153→    def _compute_adaptive_dt(self, n: int) -> float:\n   154→        \"\"\"Compute adaptive dt from CFL constraints.\n   155→\n   156→        Three constraints:\n   157→          dt_advection = accuracy * h / max(max_v, 1e-6)\n   158→          dt_acoustic  = 0.25 * h / c_sound\n   159→          dt_viscous   = accuracy * rho_min * h^2 / max(max_eta, 1e-6)\n   160→          dt = min(dt_adv, dt_acou, dt_visc) clamped to [DT_MIN, DT_MAX]\n   161→        \"\"\"\n   162→        h = self._h\n   163→\n   164→        # Max velocity magnitude via CuPy reduction\n   165→        vel = self.world.velocity[:n]  # (n, 4) float32\n   166→        vel_sq = vel[:, 0]**2 + vel[:, 1]**2 + vel[:, 2]**2\n   167→        max_v = float(cp.sqrt(cp.max(vel_sq)))\n   168→\n   169→        # Advection CFL\n   170→        dt_advection = self.accuracy * h / max(max_v, 1e-6)\n   171→\n   172→        # Acoustic CFL (fixed 0.25 coefficient, not scaled by accuracy)\n   173→        dt_acoustic = 0.25 * h / self._c_sound\n   174→\n   175→        # Viscous CFL (uses precomputed max_eta and rho_min)\n   176→        dt_viscous = self.accuracy * self._rho_min * h * h / max(self._max_eta, 1e-6)\n   177→\n   178→        dt = min(dt_advection, dt_acoustic, dt_viscous)\n   179→        return max(DT_MIN, min(DT_MAX, dt))\n   180→\n   181→    def _upload_dt(self, new_dt: float) -> None:\n   182→        \"\"\"Update dt in c_sim constant memory across all modules that read it.\"\"\"\n   183→        if self._sim_params is None:\n   184→            return\n   185→        self._sim_params[0][\"dt\"] = np.float32(new_dt)\n   186→        self.dt = new_dt\n   187→        # Upload to all modules that read c_sim.dt\n   188→        step1.upload_sim_params(self._sim_params)\n   189→        step2.upload_sim_params(self._sim_params)\n   190→        integrate.upload_sim_params(self._sim_params)\n   191→        reactions.upload_sim_params(self._sim_params)\n   192→        spawn.upload_sim_params(self._sim_params)\n   193→\n   194→    def _upload_constants(self) -> None:\n   195→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n   196→        # Build shared param structs\n   197→        grid_params = hash_sort.build_grid_params()\n   198→        sim_params = step1.build_sim_params(\n   199→            smoothing_length=self._h,\n   200→            particle_mass=0.008,\n   201→            particle_spacing=0.02,\n   202→            gravity=(0.0, -9.8, 0.0),\n   203→            dt=self.dt,\n   204→            restitution=0.3,\n   205→            wall_friction=0.5,\n   206→            world_min=(-1.0, -1.0, -1.0),\n   207→            world_max=(1.0, 1.0, 1.0),\n   208→        )\n   209→        self._sim_params = sim_params\n   210→        precalc_params = step1.build_precalc_params(\n   211→            smoothing_length=0.04,\n   212→            viscosity=1.0,\n   213→        )\n   214→        granular_params = step2.build_granular_params()\n   215→        materials_data = build_material_array()\n   216→        interactions_data = build_interaction_matrix()\n   217→\n   218→        # --- hash_sort module: c_grid ---\n   219→        hash_sort.upload_grid_params(grid_params)\n   220→\n   221→        # --- fused_reorder module: no constant memory needed ---\n   222→        fused_reorder.get_module()  # just compile\n   223→\n   224→        # --- build_grid module: c_grid ---\n   225→        build_grid.upload_grid_params(grid_params)\n   226→\n   227→        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n   228→        step1.upload_grid_params(grid_params)\n   229→        step1.upload_sim_params(sim_params)\n   230→        step1.upload_precalc_params(precalc_params)\n   231→        step1.upload_materials(materials_data)\n   232→        step1.upload_interactions(interactions_data)\n   233→\n   234→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   235→        step2.upload_grid_params(grid_params)\n   236→        step2.upload_sim_params(sim_params)\n   237→        step2.upload_precalc_params(precalc_params)\n   238→        step2.upload_materials(materials_data)\n   239→        step2.upload_granular_params(granular_params)\n   240→\n   241→        # --- integrate module: c_sim, c_materials ---\n   242→        integrate.upload_sim_params(sim_params)\n   243→        integrate.upload_materials(materials_data)\n   244→\n   245→        # --- reactions module: c_sim, c_materials ---\n   246→        reactions.upload_sim_params(sim_params)\n   247→        reactions.upload_materials(materials_data)\n   248→\n   249→        # --- spawn module: c_sim, c_materials ---\n   250→        spawn.upload_sim_params(sim_params)\n   251→        spawn.upload_materials(materials_data)\n   252→\n   253→        # --- wake module: c_grid ---\n   254→        wake.upload_grid_params(grid_params)\n   255→\n   256→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   257→        upload_to_gpu()\n   258→\n   259→    def _sim_step(self, n: int) -> None:\n   260→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   261→        w = self.world\n   262→\n   263→        # 1. Hash particle positions\n   264→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   265→\n   266→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   267→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   268→            hashes, indices,\n   269→            sorted_hashes_out=w.sorted_hashes,\n   270→            sorted_indices_out=w.sorted_indices,\n   271→        )\n   272→\n   273→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   274→        fused_reorder.fused_reorder(\n   275→            n, sorted_indices,\n   276→            w.position, w.velocity, w.veleval,\n   277→            w.mass, w.packed_info, w.temperature,\n   278→            w.health, w.lifetime, w.color,\n   279→            w.sleep_counter, w.shear_rate,\n   280→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   281→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   282→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   283→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   284→        )\n   285→\n   286→        # 4. Build grid data structure (cell_start / cell_end tables)\n   287→        build_grid.build_data_struct(\n   288→            sorted_hashes[:n], self._cell_start, self._cell_end\n   289→        )\n   290→\n   291→        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n   292→        step1.compute_step1(\n   293→            w.sorted_position[:n],\n   294→            w.sorted_velocity[:n],\n   295→            w.sorted_mass[:n],\n   296→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   297→            w.sorted_packed_info[:n],\n   298→            w.sorted_temperature[:n],\n   299→            self._cell_start,\n   300→            self._cell_end,\n   301→            density_out=w.sorted_density,\n   302→            shear_rate_out=w.sorted_shear_rate,\n   303→            dTdt_out=w.sorted_dTdt,\n   304→            exposure_heat_out=w.sorted_exposure_heat,\n   305→            exposure_corrode_out=w.sorted_exposure_corrode,\n   306→        )\n   307→        w._density_initialized = True\n   308→\n   309→        # 5b. Reset freelist counter for this step\n   310→        spawn.reset_freelist(self._dead_count)\n   311→\n   312→        # 5c. Reactions: phase transitions, combustion, corrosion, gas lifetime\n   313→        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n   314→        #     lifetime/velocity in-place before Step2 sees them.\n   315→        #     Also populates the freelist when particles die.\n   316→        reactions.compute_reactions(\n   317→            w.sorted_packed_info[:n],\n   318→            w.sorted_temperature[:n],\n   319→            w.sorted_health[:n],\n   320→            w.sorted_lifetime[:n],\n   321→            w.sorted_velocity[:n],\n   322→            w.sorted_exposure_heat[:n],\n   323→            w.sorted_exposure_corrode[:n],\n   324→            frame=self._frame_counter,\n   325→            dead_indices=self._dead_indices,\n   326→            dead_count=self._dead_count,\n   327→        )\n   328→\n   329→        # 5d. Spawn: consume from freelist to spawn steam from boiling water\n   330→        spawn.compute_spawn(\n   331→            w.sorted_packed_info[:n],\n   332→            w.sorted_position[:n],\n   333→            w.sorted_velocity[:n],\n   334→            w.sorted_veleval[:n],\n   335→            w.sorted_mass[:n],\n   336→            w.sorted_temperature[:n],\n   337→            w.sorted_health[:n],\n   338→            w.sorted_lifetime[:n],\n   339→            w.sorted_color[:n],\n   340→            w.sorted_sleep_counter[:n],\n   341→            w.sorted_density[:n],\n   342→            w.sorted_shear_rate[:n],\n   343→            self._dead_indices,\n   344→            self._dead_count,\n   345→        )\n   346→\n   347→        # 6. Step2: pressure + viscosity + XSPH forces\n   348→        step2.compute_step2(\n   349→            w.sorted_position[:n],\n   350→            w.sorted_velocity[:n],\n   351→            w.sorted_density[:n],\n   352→            w.sorted_mass[:n],\n   353→            w.sorted_packed_info[:n],\n   354→            self._cell_start,\n   355→            self._cell_end,\n   356→            sph_force_out=w.sorted_sph_force,\n   357→            veleval_out=w.sorted_veleval,\n   358→        )\n   359→\n   360→        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n   361→        #    Writes back to UNSORTED arrays via sort_indexes\n   362→        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n   363→        integrate.integrate(\n   364→            w.sorted_position[:n],\n   365→            w.sorted_velocity[:n],\n   366→            w.sorted_veleval[:n],\n   367→            w.sorted_sph_force[:n],\n   368→            w.sorted_mass[:n],\n   369→            w.sorted_packed_info[:n],\n   370→            w.sorted_temperature[:n],\n   371→            w.sorted_health[:n],\n   372→            sorted_density=w.sorted_density[:n],\n   373→            sorted_shear_rate=w.sorted_shear_rate[:n],\n   374→            sorted_dTdt=w.sorted_dTdt[:n],\n   375→            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n   376→            sort_indexes=sorted_indices[:n],\n   377→            position_out=w.position,\n   378→            velocity_out=w.velocity,\n   379→            color_out=w.color,\n   380→            packed_info_out=w.packed_info,\n   381→            sleep_counter_out=w.sleep_counter,\n   382→            temperature_out=w.temperature,\n   383→        )\n   384→\n   385→        # 8. Wake propagation: mark cells near just-woke particles,\n   386→        #    wake sleeping neighbors, clear JUST_WOKE flags\n   387→        wake.run_wake_propagation(\n   388→            w.position[:n],\n   389→            w.packed_info[:n],\n   390→            w.sleep_counter[:n],\n   391→            self._cell_wake_flags,\n   392→            num_particles=n,\n   393→        )\n   394→\n   395→        self.sim_time += self.dt\n   396→        self._frame_counter += 1\n   397→\n   398→    def step_frame(self) -> int:\n   399→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   400→        now = time.perf_counter()\n   401→        if self._last_frame_time is None:\n   402→            self._last_frame_time = now\n   403→            return 0\n   404→\n   405→        wall_dt = now - self._last_frame_time\n   406→        self._last_frame_time = now\n   407→\n   408→        if self._paused or self.speed <= 0.0:\n   409→            self._last_substeps = 0\n   410→            return 0\n   411→\n   412→        n = self.world._high_water\n   413→        if n == 0:\n   414→            self._last_substeps = 0\n   415→            return 0\n   416→\n   417→        # Compute adaptive dt if not using fixed timestep\n   418→        if not self.fixed_dt:\n   419→            new_dt = self._compute_adaptive_dt(n)\n   420→            if abs(new_dt - self.dt) > 1e-8:\n   421→                self._upload_dt(new_dt)\n   422→\n   423→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   424→        sim_steps = max(0, min(\n   425→            self.max_substeps,\n   426→            round(self.speed * wall_dt / self.dt),\n   427→        ))\n   428→\n   429→        for _ in range(sim_steps):\n   430→            self._sim_step(n)\n   431→\n   432→        self._last_substeps = sim_steps\n   433→        return sim_steps\n   434→\n   435→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   436→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   437→\n   438→        Parameters\n   439→        ----------\n   440→        cuda_pos : CudaGLBuffer\n   441→            Position VBO wrapper (must be context-managed externally).\n   442→        cuda_col : CudaGLBuffer\n   443→            Color VBO wrapper (must be context-managed externally).\n   444→        \"\"\"\n   445→        n = self.world._high_water\n   446→        if n == 0:\n   447→            return\n   448→\n   449→        # Position: world pos (float4) -> VBO pos (float4)\n   450→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   451→            (cuda_pos.nbytes // 16, 4), np.float32,\n   452→        )\n   453→        pos_arr[:n] = self.world.position[:n]\n   454→\n   455→        # Color: world color (float4) -> VBO color (float4)\n   456→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   457→            (cuda_col.nbytes // 16, 4), np.float32,\n   458→        )\n   459→        col_arr[:n] = self.world.color[:n]\n   460→\n   461→    @property\n   462→    def paused(self) -> bool:\n   463→        return self._paused\n   464→\n   465→    def toggle_pause(self) -> None:\n   466→        self._paused = not self._paused\n   467→\n   468→    def adjust_speed(self, delta: float) -> None:\n   469→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   470→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   471→\n   472→    def adjust_accuracy(self, delta: float) -> None:\n   473→        \"\"\"Adjust accuracy (CFL number) by delta, clamping to [0.1, 1.0].\"\"\"\n   474→        self.accuracy = max(0.1, min(1.0, self.accuracy + delta))\n   475→\n   476→    def toggle_fixed_dt(self) -> None:\n   477→        \"\"\"Toggle between adaptive and fixed timestep modes.\"\"\"\n   478→        self.fixed_dt = not self.fixed_dt\n   479→        if self.fixed_dt:\n   480→            # Switch to fixed mode: use fixed_dt_value\n   481→            self._upload_dt(self.fixed_dt_value)\n   482→\n   483→    @property\n   484→    def last_substeps(self) -> int:\n   485→        return self._last_substeps\n   486→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"b723e047-a0d7-4deb-a7c3-8c0b4525f837","uuid":"11aaf997-0492-4d89-b0b9-0fe7cff76f70","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/simulation.py","content":"\"\"\"SPH simulation orchestrator.\n\nWires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\nStep2 -> Integrate.  Decouples simulation from rendering via a speed parameter,\naccuracy parameter (CFL number), and substep budget.\n\nEach render frame:\n  1. If adaptive mode: compute dt from CFL constraints (advection, acoustic, viscous)\n  2. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n  3. Run sim_steps simulation substeps\n  4. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport time\nfrom typing import Optional\n\nimport cupy as cp\nimport numpy as np\n\nfrom world import World\nfrom materials import (\n    WATER, SAND, MATERIALS, GRANULAR, GAS, STATIC,\n    build_material_array, build_interaction_matrix, upload_to_gpu,\n)\n\nimport hash_sort\nimport fused_reorder\nimport build_grid\nimport step1\nimport step2\nimport integrate\nimport reactions\nimport spawn\nimport wake\n\n# Adaptive timestep limits\nDT_MIN = 1e-5\nDT_MAX = 0.005\n\n\nclass Simulation:\n    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n\n    Parameters\n    ----------\n    world : World\n        Particle state manager.\n    dt : float\n        Initial simulation timestep (seconds). Used as fixed_dt_value when\n        fixed_dt is ON.\n    speed : float\n        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    accuracy : float\n        CFL number for adaptive timestep (0.1-1.0, default 0.4).\n        Lower = smaller dt = more stable. Higher = larger dt = faster but riskier.\n    fixed_dt : bool\n        If True, use fixed timestep (no CFL computation). Default False.\n    max_substeps : int\n        Maximum substeps per render frame to prevent spiral-of-death.\n    \"\"\"\n\n    def __init__(\n        self,\n        world: World,\n        dt: float = 0.001,\n        speed: float = 1.0,\n        accuracy: float = 0.4,\n        fixed_dt: bool = False,\n        max_substeps: int = 20,\n    ) -> None:\n        self.world = world\n        self.dt = dt\n        self.speed = speed\n        self.accuracy = accuracy\n        self.fixed_dt = fixed_dt\n        self.fixed_dt_value = dt\n        self.max_substeps = max_substeps\n        self._paused = False\n        self._prev_speed = speed\n        self._last_frame_time: Optional[float] = None\n        self._last_substeps = 0\n        self.sim_time = 0.0\n        self._frame_counter = 0\n\n        # Precompute acoustic speed from materials table\n        self._c_sound = self._compute_c_sound()\n        # Precompute max viscosity and min density for viscous CFL\n        self._max_eta, self._rho_min = self._compute_viscosity_bounds()\n\n        # Smoothing length (must match _upload_constants)\n        self._h = 0.04\n\n        # Grid cell tables (pre-allocated, reused every frame)\n        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n\n        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n\n        # Freelist for spawn/kill system (pre-allocated, reset each step)\n        self._dead_indices, self._dead_count = spawn.allocate_freelist(\n            world.max_particles\n        )\n\n        # Cached sim_params for dt updates (set during _upload_constants)\n        self._sim_params: Optional[np.ndarray] = None\n\n        # Compile all kernel modules and upload constant memory\n        self._upload_constants()\n\n    def _compute_c_sound(self) -> float:\n        \"\"\"Compute acoustic speed: max over active materials of sqrt(k * gamma / rho0).\"\"\"\n        c_sound = 0.0\n        for mat in MATERIALS.values():\n            if mat.behavior_class == STATIC or mat.rest_density <= 0.0:\n                continue\n            k = mat.eos_stiffness\n            gamma = mat.eos_gamma\n            rho0 = mat.rest_density\n            if k > 0.0 and gamma > 0.0 and rho0 > 0.0:\n                c = math.sqrt(k * gamma / rho0)\n                c_sound = max(c_sound, c)\n        return max(c_sound, 0.01)  # floor to avoid zero\n\n    def _compute_viscosity_bounds(self) -> tuple:\n        \"\"\"Compute max viscosity and min density for viscous CFL.\n\n        For GRANULAR materials, uses mu_max (10000) as worst-case eta.\n        For FLUID/GAS, uses base_viscosity from the material table.\n        rho_min excludes GAS materials (they use low constant viscosity,\n        not mu(I), so their low density doesn't tighten the viscous CFL).\n        \"\"\"\n        max_eta = 0.0\n        rho_min = 1e30\n        has_granular = False\n        for mat in MATERIALS.values():\n            if mat.behavior_class == STATIC or mat.rest_density <= 0.0:\n                continue\n            # rho_min for viscous CFL: exclude GAS (never runs mu(I))\n            if mat.behavior_class != GAS and mat.rest_density < rho_min:\n                rho_min = mat.rest_density\n            if mat.behavior_class == GRANULAR:\n                has_granular = True\n            if mat.base_viscosity > max_eta:\n                max_eta = mat.base_viscosity\n        if has_granular:\n            max_eta = max(max_eta, float(step2.DEFAULT_MU_MAX))\n        rho_min = max(rho_min, 0.1)  # floor\n        return max_eta, rho_min\n\n    def _compute_adaptive_dt(self, n: int) -> float:\n        \"\"\"Compute adaptive dt from CFL constraints.\n\n        Three constraints:\n          dt_advection = accuracy * h / max(max_v, 1e-6)\n          dt_acoustic  = 0.25 * h / c_sound\n          dt_viscous   = accuracy * rho_min * h^2 / max(max_eta, 1e-6)\n          dt = min(dt_adv, dt_acou, dt_visc) clamped to [DT_MIN, DT_MAX]\n        \"\"\"\n        h = self._h\n\n        # Max velocity magnitude via CuPy reduction\n        vel = self.world.velocity[:n]  # (n, 4) float32\n        vel_sq = vel[:, 0]**2 + vel[:, 1]**2 + vel[:, 2]**2\n        max_v = float(cp.sqrt(cp.max(vel_sq)))\n\n        # Advection CFL\n        dt_advection = self.accuracy * h / max(max_v, 1e-6)\n\n        # Acoustic CFL (fixed 0.25 coefficient, not scaled by accuracy)\n        dt_acoustic = 0.25 * h / self._c_sound\n\n        # Viscous CFL (uses precomputed max_eta and rho_min)\n        dt_viscous = self.accuracy * self._rho_min * h * h / max(self._max_eta, 1e-6)\n\n        dt = min(dt_advection, dt_acoustic, dt_viscous)\n        return max(DT_MIN, min(DT_MAX, dt))\n\n    def _upload_dt(self, new_dt: float) -> None:\n        \"\"\"Update dt in c_sim constant memory across all modules that read it.\"\"\"\n        if self._sim_params is None:\n            return\n        self._sim_params[0][\"dt\"] = np.float32(new_dt)\n        self.dt = new_dt\n        # Upload to all modules that read c_sim.dt\n        step1.upload_sim_params(self._sim_params)\n        step2.upload_sim_params(self._sim_params)\n        integrate.upload_sim_params(self._sim_params)\n        reactions.upload_sim_params(self._sim_params)\n        spawn.upload_sim_params(self._sim_params)\n\n    def _upload_constants(self) -> None:\n        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n        # Build shared param structs\n        grid_params = hash_sort.build_grid_params()\n        sim_params = step1.build_sim_params(\n            smoothing_length=self._h,\n            particle_mass=0.008,\n            particle_spacing=0.02,\n            gravity=(0.0, -9.8, 0.0),\n            dt=self.dt,\n            restitution=0.3,\n            wall_friction=0.5,\n            world_min=(-1.0, -1.0, -1.0),\n            world_max=(1.0, 1.0, 1.0),\n        )\n        self._sim_params = sim_params\n        precalc_params = step1.build_precalc_params(\n            smoothing_length=0.04,\n            viscosity=1.0,\n        )\n        granular_params = step2.build_granular_params()\n        materials_data = build_material_array()\n        interactions_data = build_interaction_matrix()\n\n        # --- hash_sort module: c_grid ---\n        hash_sort.upload_grid_params(grid_params)\n\n        # --- fused_reorder module: no constant memory needed ---\n        fused_reorder.get_module()  # just compile\n\n        # --- build_grid module: c_grid ---\n        build_grid.upload_grid_params(grid_params)\n\n        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n        step1.upload_grid_params(grid_params)\n        step1.upload_sim_params(sim_params)\n        step1.upload_precalc_params(precalc_params)\n        step1.upload_materials(materials_data)\n        step1.upload_interactions(interactions_data)\n\n        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n        step2.upload_grid_params(grid_params)\n        step2.upload_sim_params(sim_params)\n        step2.upload_precalc_params(precalc_params)\n        step2.upload_materials(materials_data)\n        step2.upload_granular_params(granular_params)\n\n        # --- integrate module: c_sim, c_materials ---\n        integrate.upload_sim_params(sim_params)\n        integrate.upload_materials(materials_data)\n\n        # --- reactions module: c_sim, c_materials ---\n        reactions.upload_sim_params(sim_params)\n        reactions.upload_materials(materials_data)\n\n        # --- spawn module: c_sim, c_materials ---\n        spawn.upload_sim_params(sim_params)\n        spawn.upload_materials(materials_data)\n\n        # --- wake module: c_grid ---\n        wake.upload_grid_params(grid_params)\n\n        # --- materials module (its own internal module): c_materials, c_interactions ---\n        upload_to_gpu()\n\n    def _sim_step(self, n: int) -> None:\n        \"\"\"Run one simulation substep on n particles.\"\"\"\n        w = self.world\n\n        # 1. Hash particle positions\n        hashes, indices = hash_sort.calc_hash(w.position[:n])\n\n        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n            hashes, indices,\n            sorted_hashes_out=w.sorted_hashes,\n            sorted_indices_out=w.sorted_indices,\n        )\n\n        # 3. Fused reorder: gather all unsorted arrays into sorted order\n        fused_reorder.fused_reorder(\n            n, sorted_indices,\n            w.position, w.velocity, w.veleval,\n            w.mass, w.packed_info, w.temperature,\n            w.health, w.lifetime, w.color,\n            w.sleep_counter, w.shear_rate,\n            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n            w.sorted_sleep_counter, w.sorted_shear_rate,\n        )\n\n        # 4. Build grid data structure (cell_start / cell_end tables)\n        build_grid.build_data_struct(\n            sorted_hashes[:n], self._cell_start, self._cell_end\n        )\n\n        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n        step1.compute_step1(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_mass[:n],\n            w.sorted_density if hasattr(w, '_density_initialized') else None,\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            self._cell_start,\n            self._cell_end,\n            density_out=w.sorted_density,\n            shear_rate_out=w.sorted_shear_rate,\n            dTdt_out=w.sorted_dTdt,\n            exposure_heat_out=w.sorted_exposure_heat,\n            exposure_corrode_out=w.sorted_exposure_corrode,\n        )\n        w._density_initialized = True\n\n        # 5b. Reset freelist counter for this step\n        spawn.reset_freelist(self._dead_count)\n\n        # 5c. Reactions: phase transitions, combustion, corrosion, gas lifetime\n        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n        #     lifetime/velocity in-place before Step2 sees them.\n        #     Also populates the freelist when particles die.\n        reactions.compute_reactions(\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            w.sorted_lifetime[:n],\n            w.sorted_velocity[:n],\n            w.sorted_exposure_heat[:n],\n            w.sorted_exposure_corrode[:n],\n            frame=self._frame_counter,\n            dead_indices=self._dead_indices,\n            dead_count=self._dead_count,\n        )\n\n        # 5d. Spawn: consume from freelist to spawn steam from boiling water\n        spawn.compute_spawn(\n            w.sorted_packed_info[:n],\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_mass[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            w.sorted_lifetime[:n],\n            w.sorted_color[:n],\n            w.sorted_sleep_counter[:n],\n            w.sorted_density[:n],\n            w.sorted_shear_rate[:n],\n            self._dead_indices,\n            self._dead_count,\n        )\n\n        # 6. Step2: pressure + viscosity + XSPH forces\n        step2.compute_step2(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_density[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            sph_force_out=w.sorted_sph_force,\n            veleval_out=w.sorted_veleval,\n        )\n\n        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n        #    Writes back to UNSORTED arrays via sort_indexes\n        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n        integrate.integrate(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_sph_force[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            sorted_density=w.sorted_density[:n],\n            sorted_shear_rate=w.sorted_shear_rate[:n],\n            sorted_dTdt=w.sorted_dTdt[:n],\n            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n            sort_indexes=sorted_indices[:n],\n            position_out=w.position,\n            velocity_out=w.velocity,\n            color_out=w.color,\n            packed_info_out=w.packed_info,\n            sleep_counter_out=w.sleep_counter,\n            temperature_out=w.temperature,\n        )\n\n        # 8. Wake propagation: mark cells near just-woke particles,\n        #    wake sleeping neighbors, clear JUST_WOKE flags\n        wake.run_wake_propagation(\n            w.position[:n],\n            w.packed_info[:n],\n            w.sleep_counter[:n],\n            self._cell_wake_flags,\n            num_particles=n,\n        )\n\n        self.sim_time += self.dt\n        self._frame_counter += 1\n\n    def step_frame(self) -> int:\n        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n        now = time.perf_counter()\n        if self._last_frame_time is None:\n            self._last_frame_time = now\n            return 0\n\n        wall_dt = now - self._last_frame_time\n        self._last_frame_time = now\n\n        if self._paused or self.speed <= 0.0:\n            self._last_substeps = 0\n            return 0\n\n        n = self.world._high_water\n        if n == 0:\n            self._last_substeps = 0\n            return 0\n\n        # Compute adaptive dt if not using fixed timestep\n        if not self.fixed_dt:\n            new_dt = self._compute_adaptive_dt(n)\n            if abs(new_dt - self.dt) > 1e-8:\n                self._upload_dt(new_dt)\n\n        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n        sim_steps = max(0, min(\n            self.max_substeps,\n            round(self.speed * wall_dt / self.dt),\n        ))\n\n        for _ in range(sim_steps):\n            self._sim_step(n)\n\n        self._last_substeps = sim_steps\n        return sim_steps\n\n    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n\n        Parameters\n        ----------\n        cuda_pos : CudaGLBuffer\n            Position VBO wrapper (must be context-managed externally).\n        cuda_col : CudaGLBuffer\n            Color VBO wrapper (must be context-managed externally).\n        \"\"\"\n        n = self.world._high_water\n        if n == 0:\n            return\n\n        # Position: world pos (float4) -> VBO pos (float4)\n        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n            (cuda_pos.nbytes // 16, 4), np.float32,\n        )\n        pos_arr[:n] = self.world.position[:n]\n\n        # Color: world color (float4) -> VBO color (float4)\n        col_arr = cuda_col.device_pointer_as_cupy_array(\n            (cuda_col.nbytes // 16, 4), np.float32,\n        )\n        col_arr[:n] = self.world.color[:n]\n\n    @property\n    def paused(self) -> bool:\n        return self._paused\n\n    def toggle_pause(self) -> None:\n        self._paused = not self._paused\n\n    def adjust_speed(self, delta: float) -> None:\n        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n        self.speed = max(0.1, min(10.0, self.speed + delta))\n\n    def adjust_accuracy(self, delta: float) -> None:\n        \"\"\"Adjust accuracy (CFL number) by delta, clamping to [0.1, 1.0].\"\"\"\n        self.accuracy = max(0.1, min(1.0, self.accuracy + delta))\n\n    def toggle_fixed_dt(self) -> None:\n        \"\"\"Toggle between adaptive and fixed timestep modes.\"\"\"\n        self.fixed_dt = not self.fixed_dt\n        if self.fixed_dt:\n            # Switch to fixed mode: use fixed_dt_value\n            self._upload_dt(self.fixed_dt_value)\n\n    @property\n    def last_substeps(self) -> int:\n        return self._last_substeps\n","numLines":486,"startLine":1,"totalLines":486}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LwSZFhSXNgYDdM6tmMi7JP","type":"tool_result","content":"     1→\"\"\"World state management for Falling Sand 3D.\n     2→\n     3→Manages CuPy arrays for all per-particle SoA data. Supports configurable\n     4→max_particles at startup, spawning particles in sphere/cube shapes, and\n     5→tracking num_active via counter.\n     6→\n     7→All arrays are contiguous CuPy float32/uint32/uint8 arrays on GPU.\n     8→DEAD particles have packed_info=0 (material_id=0, behavior=STATIC).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→from typing import Tuple\n    14→\n    15→import cupy as cp\n    16→import numpy as np\n    17→\n    18→from materials import MATERIALS, FLUID, GRANULAR, GAS, STATIC\n    19→\n    20→# packed_info bitfield macros (mirrors common.cuh)\n    21→_MAKE_PACKED = lambda mat, beh: (int(mat) & 0xFF) | ((int(beh) & 0x3) << 8)\n    22→\n    23→# Default particle spacing (h=0.04 -> spacing=h/2=0.02)\n    24→DEFAULT_SPACING = 0.02\n    25→\n    26→# Default temperatures for hot materials (Kelvin)\n    27→_DEFAULT_TEMPS = {\n    28→    7: 1500.0,   # LAVA\n    29→    14: 1200.0,  # FIRE\n    30→    12: 373.0,   # STEAM\n    31→    13: 500.0,   # SMOKE\n    32→}\n    33→\n    34→# Ambient temperature\n    35→T_AMBIENT = 293.0\n    36→\n    37→\n    38→class World:\n    39→    \"\"\"Manages all per-particle SoA arrays on GPU.\n    40→\n    41→    Parameters\n    42→    ----------\n    43→    max_particles : int\n    44→        Maximum number of particles to allocate for (default 500000).\n    45→    \"\"\"\n    46→\n    47→    def __init__(self, max_particles: int = 500_000) -> None:\n    48→        self.max_particles: int = max_particles\n    49→        self._high_water: int = 0  # one past last allocated slot\n    50→        self._allocate()\n    51→\n    52→    def _allocate(self) -> None:\n    53→        \"\"\"Allocate all SoA arrays as CuPy array
   float I_number = gamma_dot * spacing / sqrtf(p_eff / rho);\nfallingsand3d/physics/kernels/step2.cu:129:                 c_granular.mu0 + mu_I * p_eff / (gamma_dot + 1e-6f));\nfallingsand3d/physics/kernels/step2.cu:207:    // For GRANULAR particles: first pass to compute gamma_dot_i\nfallingsand3d/physics/kernels/step2.cu:208:    // (strain rate magnitude from SPH velocity gradient)\nfallingsand3d/physics/kernels/step2.cu:210:    float gamma_dot_i = 0.0f;\nfallingsand3d/physics/kernels/step2.cu:214:        float gamma_dot_sq_sum = 0.0f;\nfallingsand3d/physics/kernels/step2.cu:252:                        // Spiky gradient magnitude for strain rate: (h - r)^2 / r\nfallingsand3d/physics/kernels/step2.cu:255:                        gamma_dot_sq_sum += (m_j / rho_j) * dv_sq * grad_mag;\nfallingsand3d/physics/kernels/step2.cu:263:        gamma_dot_i = sqrtf(fmaxf(lap_const * gamma_dot_sq_sum, 0.0f));\nfallingsand3d/physics/kernels/step2.cu:267:        eta_i = compute_muI_eta(gamma_dot_i, p_eff_i, rho_i);\nfallingsand3d/physics/kernels/step2.cu:331:                        float gamma_dot_j = sqrtf(dvx * dvx + dvy * dvy + dvz * dvz)\nfallingsand3d/physics/kernels/step2.cu:335:                        float eta_j = compute_muI_eta(gamma_dot_j, p_eff_j, rho_j);\nfallingsand3d/physics/kernels/step1.cu:2: * step1.cu -- K_Step1 SPH density summation + strain-rate tensor kernel.\nfallingsand3d/physics/kernels/step1.cu:8: * For GRANULAR particles only, also computes the symmetric strain-rate tensor D\nfallingsand3d/physics/kernels/step1.cu:11: * Then: gamma_dot = sqrt(2 * D:D) = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\nfallingsand3d/physics/kernels/step1.cu:16: * Self-interaction is skipped for strain-rate (j==i skipped).\nfallingsand3d/physics/kernels/step1.cu:31:    const float4*   __restrict__ velocity,      // sorted velocities (for strain-rate)\nfallingsand3d/physics/kernels/step1.cu:33:    const float*    __restrict__ density_in,     // sorted density from previous step (for strain-rate m_j/rho_j weighting; NULL on first frame)\nfallingsand3d/physics/kernels/step1.cu:38:    float*          __restrict__ shear_rate_out  // output: gamma_dot per particle (0 for non-GRANULAR)\nfallingsand3d/physics/kernels/step1.cu:55:    // Read velocity for strain-rate (only used if GRANULAR, but cheap to read)\nfallingsand3d/physics/kernels/step1.cu:65:    // Strain-rate tensor accumulators (6 symmetric components)\nfallingsand3d/physics/kernels/step1.cu:118:                        // --- Strain-rate: skip self, GRANULAR only ---\nfallingsand3d/physics/kernels/step1.cu:170:    // --- PostCalc: strain-rate magnitude (gamma_dot) ---\nfallingsand3d/physics/kernels/step1.cu:172:        // gamma_dot = sqrt(2 * D:D)\nfallingsand3d/physics/kernels/step1.cu:176:        float gamma_dot = sqrtf(fmaxf(2.0f * D_sq, 0.0f));\nfallingsand3d/physics/kernels/step1.cu:177:        shear_rate_out[index_i] = gamma_dot;\nfallingsand3d/physics/kernels/step1.cu:179:        shear_rate_out[index_i] = 0.0f;\nfallingsand3d/physics/kernels/common.cuh:159: *   shear_rate, exposure_heat, exposure_corrode\nfallingsand3d/physics/kernels/fused_reorder.cu:30:    const float*  __restrict__ shear_rate_in,\nfallingsand3d/physics/kernels/fused_reorder.cu:42:    float*        __restrict__ shear_rate_out\nfallingsand3d/physics/kernels/fused_reorder.cu:62:    shear_rate_out[idx]    = __ldg(&shear_rate_in[src]);"}]},"parent_tool_use_id":"toolu_01347Ms3n2ztvJGmYvu6iFwH","session_id":"2b25de12-98cf-4fd9-9de1-d55f6bd80115","uuid":"275048dd-c76c-4e3c-ac49-6aa451d4f9fd"}

15→                uint end_idx = cell_end[hash];\n   116→\n   117→                for (uint index_j = start; index_j < end_idx; index_j++) {\n   118→                    float4 pos4_j = __ldg(&position[index_j]);\n   119→                    float3 r = make_float3(\n   120→                        pos_i.x - pos4_j.x,\n   121→                        pos_i.y - pos4_j.y,\n   122→                        pos_i.z - pos4_j.z\n   123→                    );\n   124→                    float r_sq = r.x * r.x + r.y * r.y + r.z * r.z;\n   125→\n   126→                    if (r_sq <= h_sq) {\n   127→                        // --- Density: self-interaction included ---\n   128→                        float diff = h_sq - r_sq;\n   129→                        float m_j = __ldg(&mass[index_j]);\n   130→                        sum_density += m_j * diff * diff * diff;\n   131→\n   132→                        // --- Heat diffusion: skip self ---\n   133→                        if (index_j != index_i) {\n   134→                            float rlen = sqrtf(r_sq);\n   135→                            float T_j = __ldg(&temperature_in[index_j]);\n   136→                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n   137→                            // SPH Laplacian of temperature using viscosity Laplacian kernel:\n   138→                            // lap_W_visc(r) = (h - |r|)  (variable part, coeff is viscosity_lap_coeff)\n   139→                            // dTdt += kappa * (m_j / rho_j) * (T_j - T_i) * viscosity_lap_coeff * (h - |r|)\n   140→                            float lap_var = h - rlen;\n   141→                            sum_dTdt += m_j / fmaxf(rho_j, 1.0f) * (T_j - T_i) * lap_var;\n   142→                        }\n   143→\n   144→                        // --- Strain-rate: skip self, GRANULAR only ---\n   145→                        if (is_granular && index_j != index_i && r_sq > 1e-12f) {\n   146→                            float rlen = sqrtf(r_sq);\n   147→\n   148→                            // Spiky gradient: gradW = spiky_grad_coeff * (h - r)^2 * (r/|r|)\n   149→                            // spiky_grad_coeff is negative (-45/(pi*h^6))\n   150→                            // We need the actual gradient vector pointing from j to i\n   151→                            float h_r = h - rlen;\n   152→                            float inv_rlen = 1.0f / rlen;\n   153→                            // gradW = spiky_grad_coeff * (h-r)^2 * r_hat\n   154→                            // where r_hat = r/|r| points from j to i\n   155→                            float grad_scalar = c_precalc.spiky_grad_coeff * h_r * h_r * inv_rlen;\n   156→                            float gWx = grad_scalar * r.x;\n   157→                            float gWy = grad_scalar * r.y;\n   158→                            float gWz = grad_scalar * r.z;\n   159→\n   160→                            // dv = v_i - v_j\n   161→                            float4 vel4_j = __ldg(&velocity[index_j]);\n   162→                            float dvx = vel_i.x - vel4_j.x;\n   163→                            float dvy = vel_i.y - vel4_j.y;\n   164→                            float dvz = vel_i.z - vel4_j.z;\n   165→\n   166→                            // m_j / rho_j weighting\n   167→                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n   168→                            float weight = m_j / fmaxf(rho_j, 1.0f);\n   169→\n   170→                            // Accumulate velocity gradient tensor L_ab = sum (m_j/rho_j) * dv_a * gradW_b\n   171→                            // D_ab = 0.5 * (L_ab + L_ba)\n   172→                            // Since we compute D directly:\n   173→                            //   D_xx += weight * dv_x * gW_x\n   174→                            //   D_yy += weight * dv_y * gW_y\n   175→                            //   D_zz += weight * dv_z * gW_z\n   176→                            //   D_xy += 0.5 * weight * (dv_x * gW_y + dv_y * gW_x)\n   177→                            //   D_xz += 0.5 * weight * (dv_x * gW_z + dv_z * gW_x)\n   178→                            //   D_yz += 0.5 * weight * (dv_y * gW_z + dv_z * gW_y)\n   179→                            Dxx += weight * dvx * gWx;\n   180→                            Dyy += weight * dvy * gWy;\n   181→                            Dzz += weight * dvz * gWz;\n   182→                            Dxy += 0.5f * weight * (dvx * gWy + dvy * gWx);\n   183→                            Dxz += 0.5f * weight * (dvx * gWz + dvz * gWx);\n   184→                            Dyz += 0.5f * weight * (dvy * gWz + dvz * gWy);\n   185→                        }\n   186→                    }\n   187→                }\n   188→            }\n   189→        }\n   190→    }\n   191→\n   192→    // --- PostCalc: density ---\n   193→    float density = c_precalc.poly6_coeff * sum_density;\n   194→    density_out[index_i] = fmaxf(density, 1.0f);\n   195→\n   196→    // --- PostCalc: heat diffusion dTdt ---\n   197→    // dTdt = kappa_i * viscosity_lap_coeff * sum_dTdt\n   198→    dTdt_out[index_i] = kappa_i * c_precalc.viscosity_lap_coeff * sum_dTdt;\n   199→\n   200→    // --- PostCalc: strain-rate magnitude (gamma_dot) ---\n   201→    if (is_granular) {\n   202→        // gamma_dot = sqrt(2 * D:D)\n   203→        //           = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n   204→        float D_sq = Dxx * Dxx + Dyy * Dyy + Dzz * Dzz\n   205→                   + 2.0f * (Dxy * Dxy + Dxz * Dxz + Dyz * Dyz);\n   206→        float gamma_dot = sqrtf(fmaxf(2.0f * D_sq, 0.0f));\n   207→        shear_rate_out[index_i] = gamma_dot;\n   208→    } else {\n   209→        shear_rate_out[index_i] = 0.0f;\n   210→    }\n   211→}\n   212→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST re
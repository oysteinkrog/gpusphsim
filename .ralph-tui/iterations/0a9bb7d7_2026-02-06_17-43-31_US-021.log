{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EvoebRnFymF9KogTy14dHL","type":"tool_result","content":"     1→\"\"\"Integration test for step1.py -- K_Step1 density + strain-rate kernel.\n     2→\n     3→Acceptance criteria (density, US-011):\n     4→  - K_Step1 iterates 3x3x3 neighbor cells using cell_start/cell_end\n     5→  - density_sum += m_j * (h_sq - r_sq)^3 with PER-PARTICLE mass\n     6→  - Final density = max(1.0, poly6_coeff * density_sum)\n     7→  - Smoothing length uses squared distance (r_sq < h_sq)\n     8→  - Neighbor position loaded via __ldg() (read-only cache)\n     9→  - Self-contribution included (j==i NOT skipped)\n    10→  - Test: uniform field at rest density -> rho ~= rho0 (within 10%)\n    11→  - Test: single isolated particle -> rho = mass * poly6_coeff * h^6\n    12→  - Block size = 128, runs without errors for 500K particles\n    13→\n    14→Acceptance criteria (strain-rate, US-015):\n    15→  - Step1 accumulates 6 symmetric D components for GRANULAR only\n    16→  - D tensor uses spiky gradient (NOT poly6 gradient), m_j/rho_j weighting\n    17→  - PostCalc: gamma_dot = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n    18→  - gamma_dot written to sorted shear_rate array\n    19→  - Non-GRANULAR particles get shear_rate = 0\n    20→  - Test: stationary sand -> gamma_dot ~ 0\n    21→  - Test: sand in shear flow -> gamma_dot > 0\n    22→\n    23→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    24→\"\"\"\n    25→\n    26→from __future__ import annotations\n    27→\n    28→import math\n    29→import os\n    30→import sys\n    31→\n    32→sys.path.insert(0, os.path.dirname(__file__))\n    33→\n    34→import cupy\n    35→import numpy as np\n    36→\n    37→from hash_sort import (\n    38→    NUM_CELLS,\n    39→    build_grid_params,\n    40→    calc_hash,\n    41→    sort_by_hash,\n    42→    upload_grid_params as upload_hash_grid_params,\n    43→)\n    44→from build_grid import (\n    45→    build_data_struct,\n    46→    upload_grid_params as upload_build_grid_params,\n    47→)\n    48→from step1 import (\n    49→    BLOCK_SIZE,\n    50→    build_precalc_params,\n    51→    build_sim_params,\n    52→    compute_step1,\n    53→    get_module,\n    54→    upload_grid_params as upload_step1_grid_params,\n    55→    upload_materials as upload_step1_materials,\n    56→    upload_precalc_params,\n    57→    upload_sim_params,\n    58→)\n    59→from materials import build_material_array\n    60→\n    61→# Simulation constants matching the acceptance criteria\n    62→H = 0.04                # smoothing length\n    63→H_SQ = H * H\n    64→SPACING = 0.02          # particle spacing\n    65→RHO0 = 1000.0           # rest density of water\n    66→MASS = RHO0 * SPACING**3  # 0.008 kg\n    67→POLY6_COEFF = 315.0 / (64.0 * math.pi * H**9)\n    68→\n    69→# packed_info constants\n    70→# MAKE_PACKED(mat, beh) = (mat & 0xFF) | ((beh & 0x3) << 8)\n    71→FLUID = 0\n    72→GRANULAR = 1\n    73→PACKED_WATER = 5 | (FLUID << 8)     # material 5, FLUID\n    74→PACKED_SAND  = 2 | (GRANULAR << 8)  # material 2, GRANULAR\n    75→\n    76→\n    77→def _upload_all_params() -> None:\n    78→    \"\"\"Upload grid, sim, precalc, and materials params to all kernel modules.\"\"\"\n    79→    gp = build_grid_params()\n    80→    upload_hash_grid_params(gp)\n    81→    upload_build_grid_params(gp)\n    82→    upload_step1_grid_params(gp)\n    83→\n    84→    sp = build_sim_params(\n    85→        smoothing_length=H,\n    86→        particle_mass=MASS,\n    87→        particle_spacing=SPACING,\n    88→    )\n    89→    upload_sim_params(sp)\n    90→\n    91→    pp = build_precalc_params(smoothing_length=H)\n    92→    upload_precalc_params(pp)\n    93→\n    94→    materials_data = build_material_array()\n    95→    upload_step1_materials(materials_data)\n    96→\n    97→\n    98→def _run_full_pipeline(\n    99→    positions_np: np.ndarray,\n   100→    mass_np: np.ndarray,\n   101→    velocity_np: np.ndarray | None = None,\n   102→    packed_info_np: np.ndarray | None = None,\n   103→    density_in_np: np.ndarray | None = None,\n   104→    temperature_np: np.ndarray | None = None,\n   105→) -> tuple:\n   106→    \"\"\"Run hash -> sort -> build -> step1 and return results.\n   107→\n   108→    Parameters\n   109→    ----------\n   110→    positions_np : (N, 4) float32\n   111→    mass_np : (N,) float32\n   112→    velocity_np : (N, 4) float32, optional (default: zeros)\n   113→    packed_info_np : (N,) uint32, optional (default: PACKED_WATER)\n   114→    density_in_np : (N,) float32, optional (default: None -> kernel uses fallback)\n   115→    temperature_np : (N,) float32, optional (default: 293.0 ambient)\n   116→\n   117→    Returns\n   118→    -------\n   119→    density_cpu : (N,) float32 -- density in sorted order\n   120→    shear_rate_cpu : (N,) float32 -- gamma_dot in sorted order\n   121→    dTdt_cpu : (N,) float32 -- temperature rate of change in sorted order\n   122→    sorted_positions_cpu : (N, 4) float32\n   123→    sorted_mass_cpu : (N,) float32\n   124→    \"\"\"\n   125→    n = positions_np.shape[0]\n   126→\n   127→    if velocity_np is None:\n   128→        velocity_np = np.zeros((n, 4), dtype=np.float32)\n   129→    if packed_info_np is None:\n   130→        packed_info_np = np.full(n, PACKED_WATER, dtype=np.uint32)\n   131→    if temperature_np is None:\n   132→        temperature_np = np.full(n, 293.0, dtype=np.float32)\n   133→\n   134→    pos_gpu = cupy.asarray(positions_np)\n   135→    mass_gpu = cupy.asarray(mass_np)\n   136→    vel_gpu = cupy.asarray(velocity_np)\n   137→    pi_gpu = cupy.asarray(packed_info_np)\n   138→    temp_gpu = cupy.asarray(temperature_np)\n   139→    density_in_gpu = cupy.asarray(density_in_np) if density_in_np is not None else None\n   140→\n   141→    hashes, indices = calc_hash(pos_gpu)\n   142→    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n   143→\n   144→    # Reorder all arrays to sorted order\n   145→    sorted_pos = pos_gpu[sorted_indices]\n   146→    sorted_mass = mass_gpu[sorted_indices]\n   147→    sorted_vel = vel_gpu[sorted_indices]\n   148→    sorted_pi = pi_gpu[sorted_indices]\n   149→    sorted_temp = temp_gpu[sorted_indices]\n   150→    sorted_density_in = density_in_gpu[sorted_indices] if density_in_gpu is not None else None\n   151→\n   152→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   153→\n   154→    density, shear_rate, dTdt = compute_step1(\n   155→        sorted_pos, sorted_vel, sorted_mass,\n   156→        sorted_density_in, sorted_pi,\n   157→        sorted_temp,\n   158→        cell_start, cell_end,\n   159→    )\n   160→    cupy.cuda.Device().synchronize()\n   161→\n   162→    return (\n   163→        cupy.asnumpy(density),\n   164→        cupy.asnumpy(shear_rate),\n   165→        cupy.asnumpy(dTdt),\n   166→        cupy.asnumpy(sorted_pos),\n   167→        cupy.asnumpy(sorted_mass),\n   168→    )\n   169→\n   170→\n   171→# ===================================================================\n   172→# Density tests (unchanged acceptance criteria from US-011)\n   173→# ===================================================================\n   174→\n   175→def test_compilation() -> None:\n   176→    \"\"\"Verify CuPy RawModule compiles step1.cu.\"\"\"\n   177→    print(\"--- Compilation check ---\")\n   178→\n   179→    module = get_module()\n   180→    assert module is not None\n   181→    print(\"[OK] CuPy RawModule compiled step1.cu (includes common.cuh)\")\n   182→\n   183→    kernel = module.get_function(\"K_Step1\")  # type: ignore[union-attr]\n   184→    assert kernel is not None\n   185→    print(\"[OK] K_Step1 kernel function found\")\n   186→\n   187→    # Verify all constant memory symbols accessible\n   188→    for sym in [\"c_grid\", \"c_sim\", \"c_precalc\"]:\n   189→        d_ptr = module.get_global(sym)  # type: ignore[union-attr]\n   190→        assert int(d_ptr) != 0, f\"{sym} symbol not found\"\n   191→    print(\"[OK] c_grid, c_sim, c_precalc constant memory symbols found\")\n   192→\n   193→\n   194→def test_block_size() -> None:\n   195→    \"\"\"Verify block size is 128.\"\"\"\n   196→    print(\"\\n--- Block size check ---\")\n   197→    assert BLOCK_SIZE == 128, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 128\"\n   198→    print(\"[OK] BLOCK_SIZE = 128\")\n   199→\n   200→\n   201→def test_struct_sizes() -> None:\n   202→    \"\"\"Verify SimParams and PrecalcParams dtypes match CUDA struct sizes.\"\"\"\n   203→    print(\"\\n--- Struct size check ---\")\n   204→\n   205→    sp = build_sim_params()\n   206→    pp = build_precalc_params()\n   207→\n   208→    # SimParams: 64 bytes (from US-005 test)\n   209→    assert sp.nbytes == 64, f\"SimParams: {sp.nbytes} != 64 bytes\"\n   210→    print(f\"[OK] SimParams: {sp.nbytes} bytes\")\n   211→\n   212→    # PrecalcParams: 20 bytes\n   213→    assert pp.nbytes == 20, f\"PrecalcParams: {pp.nbytes} != 20 bytes\"\n   214→    print(f\"[OK] PrecalcParams: {pp.nbytes} bytes\")\n   215→\n   216→\n   217→def test_precalc_coefficients() -> None:\n   218→    \"\"\"Verify poly6_coeff matches expected value for h=0.04.\"\"\"\n   219→    print(\"\\n--- Precalc coefficient check ---\")\n   220→\n   221→    pp = build_precalc_params(smoothing_length=H)\n   222→    poly6 = pp[0][\"poly6_coeff\"]\n   223→\n   224→    expected = np.float32(315.0 / (64.0 * math.pi * H**9))\n   225→    rel_err = abs(float(poly6) - float(expected)) / abs(float(expected))\n   226→\n   227→    print(f\"  poly6_coeff = {poly6:.6e} (expected {expected:.6e})\")\n   228→    assert rel_err < 1e-5, f\"poly6_coeff relative error {rel_err:.2e} > 1e-5\"\n   229→    print(\"[OK] poly6_coeff matches 315/(64*pi*h^9)\")\n   230→\n   231→\n   232→def test_single_isolated_particle() -> None:\n   233→    \"\"\"Single isolated particle: rho = mass * poly6_coeff * h^6.\n   234→\n   235→    Self-contribution: r_sq = 0, so (h^2 - 0)^3 = h^6.\n   236→    density = poly6_coeff * mass * h^6.\n   237→    \"\"\"\n   238→    print(\"\\n--- Single isolated particle test ---\")\n   239→    _upload_all_params()\n   240→\n   241→    # Place particle at center of grid\n   242→    positions = np.zeros((1, 4), dtype=np.float32)\n   243→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   244→\n   245→    mass_arr = np.array([MASS], dtype=np.float32)\n   246→\n   247→    density, shear_rate, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   248→\n   249→    expected = POLY6_COEFF * MASS * H_SQ**3  # poly6_coeff * mass * h^6\n   250→    actual = density[0]\n   251→\n   252→    rel_err = abs(actual - expected) / abs(expected)\n   253→    print(f\"  Expected density: {expected:.6f}\")\n   254→    print(f\"  Actual density:   {actual:.6f}\")\n   255→    print(f\"  Relative error:   {rel_err:.6e}\")\n   256→\n   257→    assert rel_err < 1e-4, (\n   258→        f\"Single particle density mismatch: {actual:.6f} vs {expected:.6f} \"\n   259→        f\"(rel err {rel_err:.6e})\"\n   260→    )\n   261→\n   262→    # Non-GRANULAR (default WATER/FLUID) -> shear_rate should be 0\n   263→    assert shear_rate[0] == 0.0, f\"FLUID particle shear_rate = {shear_rate[0]}, expected 0\"\n   264→\n   265→    print(\"[OK] Single isolated particle density matches mass * poly6_coeff * h^6\")\n   266→    print(\"[OK] FLUID particle shear_rate = 0\")\n   267→\n   268→\n   269→def test_two_particles_within_h() -> None:\n   270→    \"\"\"Two particles within h should have higher density than one alone.\"\"\"\n   271→    print(\"\\n--- Two particles within smoothing length test ---\")\n   272→    _upload_all_params()\n   273→\n   274→    sep = H * 0.5  # half the smoothing length\n   275→    positions = np.zeros((2, 4), dtype=np.float32)\n   276→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   277→    positions[1] = [sep, 0.0, 0.0, 1.0]\n   278→\n   279→    mass_arr = np.full(2, MASS, dtype=np.float32)\n   280→\n   281→    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   282→\n   283→    # Self-contribution only\n   284→    single_rho = POLY6_COEFF * MASS * H_SQ**3\n   285→\n   286→    # Both particles should have density > single particle\n   287→    assert density[0] > single_rho * 0.99, (\n   288→        f\"Particle 0 density {density[0]:.4f} not > single {single_rho:.4f}\"\n   289→    )\n   290→    assert density[1] > single_rho * 0.99, (\n   291→        f\"Particle 1 density {density[1]:.4f} not > single {single_rho:.4f}\"\n   292→    )\n   293→\n   294→    # By symmetry, densities should be approximately equal\n   295→    rel_diff = abs(density[0] - density[1]) / max(density[0], density[1])\n   296→    assert rel_diff < 1e-4, (\n   297→        f\"Asymmetric densities: {density[0]:.6f} vs {density[1]:.6f}\"\n   298→    )\n   299→\n   300→    print(f\"  Single particle density: {single_rho:.6f}\")\n   301→    print(f\"  Particle 0 density:      {density[0]:.6f}\")\n   302→    print(f\"  Particle 1 density:      {density[1]:.6f}\")\n   303→    print(\"[OK] Two particles within h produce symmetric density > single particle\")\n   304→\n   305→\n   306→def test_two_particles_beyond_h() -> None:\n   307→    \"\"\"Two particles separated by more than h should not see each other.\"\"\"\n   308→    print(\"\\n--- Two particles beyond smoothing length test ---\")\n   309→    _upload_all_params()\n   310→\n   311→    sep = H * 1.5  # beyond smoothing length\n   312→    positions = np.zeros((2, 4), dtype=np.float32)\n   313→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   314→    positions[1] = [sep, 0.0, 0.0, 1.0]\n   315→\n   316→    mass_arr = np.full(2, MASS, dtype=np.float32)\n   317→\n   318→    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   319→\n   320→    single_rho = POLY6_COEFF * MASS * H_SQ**3\n   321→\n   322→    # Both should have same density as single particle (only self-contribution)\n   323→    for i in range(2):\n   324→        rel_err = abs(density[i] - single_rho) / single_rho\n   325→        assert rel_err < 1e-4, (\n   326→            f\"Particle {i} density {density[i]:.6f} != single {single_rho:.6f} \"\n   327→            f\"(rel err {rel_err:.2e})\"\n   328→        )\n   329→\n   330→    print(f\"  Particle 0 density: {density[0]:.6f}\")\n   331→    print(f\"  Particle 1 density: {density[1]:.6f}\")\n   332→    print(f\"  Expected (self-only): {single_rho:.6f}\")\n   333→    print(\"[OK] Particles beyond h have self-contribution-only density\")\n   334→\n   335→\n   336→def test_per_particle_mass() -> None:\n   337→    \"\"\"Two particles with different masses produce different densities.\"\"\"\n   338→    print(\"\\n--- Per-particle mass test ---\")\n   339→    _upload_all_params()\n   340→\n   341→    sep = H * 0.3  # within smoothing length\n   342→    positions = np.zeros((2, 4), dtype=np.float32)\n   343→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   344→    positions[1] = [sep, 0.0, 0.0, 1.0]\n   345→\n   346→    # Particle 0 has 2x mass\n   347→    mass_arr = np.array([MASS * 2.0, MASS], dtype=np.float32)\n   348→\n   349→    density, _, _, _, sorted_mass = _run_full_pipeline(positions, mass_arr)\n   350→\n   351→    # Particle with larger mass should generally produce higher self-density\n   352→    # But both particles contribute to each other, and mass affects contribution\n   353→    # The key thing: densities differ due to different masses\n   354→    assert density[0] != density[1], (\n   355→        f\"Expected different densities but got {density[0]} == {density[1]}\"\n   356→    )\n   357→\n   358→    print(f\"  Mass[0]={sorted_mass[0]:.6f}, density[0]={density[0]:.6f}\")\n   359→    print(f\"  Mass[1]={sorted_mass[1]:.6f}, density[1]={density[1]:.6f}\")\n   360→    print(\"[OK] Per-particle mass produces different densities\")\n   361→\n   362→\n   363→def test_density_clamp_minimum() -> None:\n   364→    \"\"\"Density is clamped to minimum 1.0.\"\"\"\n   365→    print(\"\\n--- Density clamp test ---\")\n   366→    _upload_all_params()\n   367→\n   368→    # Use extremely small mass so poly6_coeff * mass * h^6 < 1.0\n   369→    tiny_mass = 1e-20  # absurdly small\n   370→    positions = np.zeros((1, 4), dtype=np.float32)\n   371→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   372→\n   373→    mass_arr = np.array([tiny_mass], dtype=np.float32)\n   374→\n   375→    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   376→\n   377→    assert density[0] >= 1.0, (\n   378→        f\"Density {density[0]} < 1.0 (clamp failed)\"\n   379→    )\n   380→    print(f\"  Density with tiny mass: {density[0]:.6f}\")\n   381→    print(\"[OK] Density clamped to >= 1.0\")\n   382→\n   383→\n   384→def test_uniform_field_rest_density() -> None:\n   385→    \"\"\"Uniform particle field at rest density produces rho ~= rho0 (within 10%).\n   386→\n   387→    Sets up a regular grid of particles with spacing = 0.02 in a small cube,\n   388→    with mass = rho0 * spacing^3. Interior particles should have density\n   389→    close to rho0.\n   390→    \"\"\"\n   391→    print(\"\\n--- Uniform field rest density test ---\")\n   392→    _upload_all_params()\n   393→\n   394→    # Create a regular grid of particles\n   395→    spacing = SPACING\n   396→    # Use a region large enough for interior particles to have full neighborhood\n   397→    extent = 0.2  # -0.1 to +0.1 in each axis\n   398→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   399→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   400→    n = xx.size\n   401→\n   402→    positions = np.zeros((n, 4), dtype=np.float32)\n   403→    positions[:, 0] = xx.ravel()\n   404→    positions[:, 1] = yy.ravel()\n   405→    positions[:, 2] = zz.ravel()\n   406→    positions[:, 3] = 1.0\n   407→\n   408→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   409→\n   410→    density, _, _, sorted_pos, _ = _run_full_pipeline(positions, mass_arr)\n   411→\n   412→    # Filter to interior particles (at least 2h from edge to avoid boundary effects)\n   413→    margin = 2.0 * H  # 0.08\n   414→    interior = (\n   415→        (sorted_pos[:, 0] > -extent + margin)\n   416→        & (sorted_pos[:, 0] < extent - margin)\n   417→        & (sorted_pos[:, 1] > -extent + margin)\n   418→        & (sorted_pos[:, 1] < extent - margin)\n   419→        & (sorted_pos[:, 2] > -extent + margin)\n   420→        & (sorted_pos[:, 2] < extent - margin)\n   421→    )\n   422→    num_interior = int(np.sum(interior))\n   423→\n   424→    if num_interior == 0:\n   425→        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n   426→        print(\"  Skipping rest density check, using overall stats instead\")\n   427→        mean_rho = float(np.mean(density))\n   428→        print(f\"  Mean density (all): {mean_rho:.2f}\")\n   429→        return\n   430→\n   431→    interior_density = density[interior]\n   432→    mean_rho = float(np.mean(interior_density))\n   433→    min_rho = float(np.min(interior_density))\n   434→    max_rho = float(np.max(interior_density))\n   435→\n   436→    rel_err = abs(mean_rho - RHO0) / RHO0\n   437→\n   438→    print(f\"  Total particles: {n}\")\n   439→    print(f\"  Interior particles: {num_interior}\")\n   440→    print(f\"  Mean interior density: {mean_rho:.2f} (expected ~{RHO0:.0f})\")\n   441→    print(f\"  Min/Max interior density: {min_rho:.2f} / {max_rho:.2f}\")\n   442→    print(f\"  Relative error: {rel_err:.4f}\")\n   443→\n   444→    assert rel_err < 0.10, (\n   445→        f\"Mean interior density {mean_rho:.2f} differs from rho0={RHO0:.0f} \"\n   446→        f\"by {rel_err*100:.1f}% (> 10%)\"\n   447→    )\n   448→    print(\"[OK] Uniform field interior density within 10% of rho0\")\n   449→\n   450→\n   451→def test_self_contribution_included() -> None:\n   452→    \"\"\"Verify self-contribution is included by checking r_sq=0 case.\"\"\"\n   453→    print(\"\\n--- Self-contribution included test ---\")\n   454→    _upload_all_params()\n   455→\n   456→    # Single particle should have nonzero density (from self-contribution)\n   457→    positions = np.zeros((1, 4), dtype=np.float32)\n   458→    positions[0] = [0.0, 0.0, 0.0, 1.0]\n   459→    mass_arr = np.array([MASS], dtype=np.float32)\n   460→\n   461→    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n   462→\n   463→    # Without self-contribution, density would be 0 -> clamped to 1.0\n   464→    # With self-contribution, density = poly6_coeff * mass * h^6 which is >> 1.0\n   465→    expected_self = POLY6_COEFF * MASS * H_SQ**3\n   466→    assert density[0] > 1.0, (\n   467→        f\"Density {density[0]} == 1.0 means self-contribution missing\"\n   468→    )\n   469→    assert density[0] > expected_self * 0.99, (\n   470→        f\"Density {density[0]:.4f} too low vs expected self-only {expected_self:.4f}\"\n   471→    )\n   472→\n   473→    print(f\"  Density: {density[0]:.6f} (expected self-only: {expected_self:.6f})\")\n   474→    print(\"[OK] Self-contribution is included in density computation\")\n   475→\n   476→\n   477→# ===================================================================\n   478→# Strain-rate tensor tests (US-015)\n   479→# ===================================================================\n   480→\n   481→def test_stationary_sand_zero_gamma_dot() -> None:\n   482→    \"\"\"Stationary GRANULAR particles produce gamma_dot approximately 0.\n   483→\n   484→    All particles at rest (velocity=0), so the velocity gradient tensor D\n   485→    should be zero everywhere, and gamma_dot = sqrt(2*D:D) = 0.\n   486→    \"\"\"\n   487→    print(\"\\n--- Stationary sand zero gamma_dot test ---\")\n   488→    _upload_all_params()\n   489→\n   490→    # Regular grid of GRANULAR particles, all at rest\n   491→    spacing = SPACING\n   492→    extent = 0.1\n   493→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   494→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   495→    n = xx.size\n   496→\n   497→    positions = np.zeros((n, 4), dtype=np.float32)\n   498→    positions[:, 0] = xx.ravel()\n   499→    positions[:, 1] = yy.ravel()\n   500→    positions[:, 2] = zz.ravel()\n   501→    positions[:, 3] = 1.0\n   502→\n   503→    velocities = np.zeros((n, 4), dtype=np.float32)  # all at rest\n   504→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   505→    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n   506→    # Provide density_in for m_j/rho_j weighting\n   507→    density_in = np.full(n, RHO0, dtype=np.float32)\n   508→\n   509→    density, shear_rate, _, sorted_pos, _ = _run_full_pipeline(\n   510→        positions, mass_arr, velocities, packed_info, density_in,\n   511→    )\n   512→\n   513→    # All shear_rates should be approximately 0 (within numerical tolerance)\n   514→    max_gamma_dot = float(np.max(np.abs(shear_rate)))\n   515→    mean_gamma_dot = float(np.mean(np.abs(shear_rate)))\n   516→\n   517→    print(f\"  {n} GRANULAR particles at rest\")\n   518→    print(f\"  Max |gamma_dot|:  {max_gamma_dot:.6e}\")\n   519→    print(f\"  Mean |gamma_dot|: {mean_gamma_dot:.6e}\")\n   520→\n   521→    assert max_gamma_dot < 1e-3, (\n   522→        f\"Stationary particles have gamma_dot = {max_gamma_dot:.6e}, expected ~0\"\n   523→    )\n   524→    print(\"[OK] Stationary sand particles produce gamma_dot ~ 0\")\n   525→\n   526→\n   527→def test_shear_flow_nonzero_gamma_dot() -> None:\n   528→    \"\"\"Sand particles in shear flow produce gamma_dot > 0.\n   529→\n   530→    Sets up a simple shear flow: v_x = shear_rate * y (linear shear in x-y plane).\n   531→    The analytical strain rate D_xy = 0.5 * dv_x/dy = 0.5 * shear_rate_applied.\n   532→    gamma_dot = sqrt(2 * 2 * D_xy^2) = sqrt(4 * 0.25 * SR^2) = |SR|.\n   533→    \"\"\"\n   534→    print(\"\\n--- Shear flow nonzero gamma_dot test ---\")\n   535→    _upload_all_params()\n   536→\n   537→    # Regular grid of GRANULAR particles with linear shear velocity\n   538→    spacing = SPACING\n   539→    extent = 0.1\n   540→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   541→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   542→    n = xx.size\n   543→\n   544→    positions = np.zeros((n, 4), dtype=np.float32)\n   545→    positions[:, 0] = xx.ravel()\n   546→    positions[:, 1] = yy.ravel()\n   547→    positions[:, 2] = zz.ravel()\n   548→    positions[:, 3] = 1.0\n   549→\n   550→    # Shear flow: v_x = SR * y, v_y = 0, v_z = 0\n   551→    applied_shear_rate = 10.0  # s^-1\n   552→    velocities = np.zeros((n, 4), dtype=np.float32)\n   553→    velocities[:, 0] = applied_shear_rate * positions[:, 1]  # v_x = SR * y\n   554→\n   555→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   556→    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n   557→    density_in = np.full(n, RHO0, dtype=np.float32)\n   558→\n   559→    density, shear_rate, _, sorted_pos, _ = _run_full_pipeline(\n   560→        positions, mass_arr, velocities, packed_info, density_in,\n   561→    )\n   562→\n   563→    # Interior particles should have gamma_dot > 0\n   564→    margin = 2.0 * H\n   565→    interior = (\n   566→        (sorted_pos[:, 0] > -extent + margin)\n   567→        & (sorted_pos[:, 0] < extent - margin)\n   568→        & (sorted_pos[:, 1] > -extent + margin)\n   569→        & (sorted_pos[:, 1] < extent - margin)\n   570→        & (sorted_pos[:, 2] > -extent + margin)\n   571→        & (sorted_pos[:, 2] < extent - margin)\n   572→    )\n   573→    num_interior = int(np.sum(interior))\n   574→\n   575→    if num_interior == 0:\n   576→        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n   577→        print(\"  Using all particles for shear rate check\")\n   578→        interior_shear = shear_rate\n   579→    else:\n   580→        interior_shear = shear_rate[interior]\n   581→\n   582→    mean_gamma_dot = float(np.mean(interior_shear))\n   583→    max_gamma_dot = float(np.max(interior_shear))\n   584→    min_gamma_dot = float(np.min(interior_shear))\n   585→\n   586→    print(f\"  {n} GRANULAR particles in shear flow (SR={applied_shear_rate})\")\n   587→    print(f\"  Interior particles: {num_interior}\")\n   588→    print(f\"  Mean gamma_dot: {mean_gamma_dot:.4f}\")\n   589→    print(f\"  Range: [{min_gamma_dot:.4f}, {max_gamma_dot:.4f}]\")\n   590→    print(f\"  Expected (analytical): ~{applied_shear_rate:.1f}\")\n   591→\n   592→    # gamma_dot should be significantly > 0\n   593→    assert mean_gamma_dot > 1.0, (\n   594→        f\"Mean gamma_dot = {mean_gamma_dot:.4f} too low for SR={applied_shear_rate}\"\n   595→    )\n   596→\n   597→    # gamma_dot should be in the right ballpark (within factor of 5 of analytical)\n   598→    # SPH approximation won't be exact due to kernel support, discretization, boundary effects\n   599→    assert mean_gamma_dot < applied_shear_rate * 5.0, (\n   600→        f\"Mean gamma_dot = {mean_gamma_dot:.4f} way too high for SR={applied_shear_rate}\"\n   601→    )\n   602→\n   603→    print(\"[OK] Sand particles in shear flow produce gamma_dot > 0\")\n   604→\n   605→\n   606→def test_non_granular_zero_shear_rate() -> None:\n   607→    \"\"\"Non-GRANULAR particles get shear_rate = 0 even with velocity gradients.\"\"\"\n   608→    print(\"\\n--- Non-GRANULAR zero shear_rate test ---\")\n   609→    _upload_all_params()\n   610→\n   611→    n = 100\n   612→    rng = np.random.default_rng(123)\n   613→\n   614→    positions = np.zeros((n, 4), dtype=np.float32)\n   615→    positions[:, :3] = rng.uniform(-0.1, 0.1, size=(n, 3)).astype(np.float32)\n   616→    positions[:, 3] = 1.0\n   617→\n   618→    # Give particles random velocities (nonzero velocity gradient)\n   619→    velocities = np.zeros((n, 4), dtype=np.float32)\n   620→    velocities[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n   621→\n   622→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   623→    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)  # FLUID, not GRANULAR\n   624→\n   625→    density, shear_rate, _, _, _ = _run_full_pipeline(\n   626→        positions, mass_arr, velocities, packed_info,\n   627→    )\n   628→\n   629→    # All shear_rates should be exactly 0 for FLUID particles\n   630→    assert np.all(shear_rate == 0.0), (\n   631→        f\"FLUID particles have nonzero shear_rate: max={np.max(np.abs(shear_rate)):.6e}\"\n   632→    )\n   633→\n   634→    print(f\"  {n} FLUID particles with random velocities\")\n   635→    print(f\"  All shear_rate = 0 (confirmed)\")\n   636→    print(\"[OK] Non-GRANULAR particles get shear_rate = 0\")\n   637→\n   638→\n   639→def test_500k_no_errors() -> None:\n   640→    \"\"\"Kernel runs without errors for 500K particles (mixed FLUID and GRANULAR).\"\"\"\n   641→    print(\"\\n--- 500K particle stress test ---\")\n   642→    _upload_all_params()\n   643→\n   644→    rng = np.random.default_rng(42)\n   645→    n = 500_000\n   646→\n   647→    positions = np.zeros((n, 4), dtype=np.float32)\n   648→    positions[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n   649→    positions[:, 3] = 1.0\n   650→\n   651→    velocities = np.zeros((n, 4), dtype=np.float32)\n   652→    velocities[:, :3] = rng.uniform(-0.5, 0.5, size=(n, 3)).astype(np.float32)\n   653→\n   654→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   655→\n   656→    # Mix of FLUID and GRANULAR particles (50/50)\n   657→    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)\n   658→    packed_info[n // 2:] = PACKED_SAND\n   659→\n   660→    density_in = np.full(n, RHO0, dtype=np.float32)\n   661→\n   662→    # Random temperatures for stress test\n   663→    temperature = rng.uniform(200.0, 1500.0, size=n).astype(np.float32)\n   664→\n   665→    density, shear_rate, dTdt, _, _ = _run_full_pipeline(\n   666→        positions, mass_arr, velocities, packed_info, density_in, temperature,\n   667→    )\n   668→\n   669→    # Basic sanity checks\n   670→    assert density.shape == (n,), f\"density shape {density.shape} != ({n},)\"\n   671→    assert shear_rate.shape == (n,), f\"shear_rate shape {shear_rate.shape} != ({n},)\"\n   672→    assert dTdt.shape == (n,), f\"dTdt shape {dTdt.shape} != ({n},)\"\n   673→    assert np.all(density >= 1.0), \"Some densities < 1.0 (clamp failed)\"\n   674→    assert np.all(np.isfinite(density)), \"NaN or Inf in densities\"\n   675→    assert np.all(np.isfinite(shear_rate)), \"NaN or Inf in shear_rates\"\n   676→    assert np.all(shear_rate >= 0.0), \"Negative shear_rate values found\"\n   677→    assert np.all(np.isfinite(dTdt)), \"NaN or Inf in dTdt\"\n   678→\n   679→    mean_rho = float(np.mean(density))\n   680→    min_rho = float(np.min(density))\n   681→    max_rho = float(np.max(density))\n   682→    mean_sr = float(np.mean(shear_rate))\n   683→    max_sr = float(np.max(shear_rate))\n   684→    mean_dTdt = float(np.mean(dTdt))\n   685→    max_dTdt = float(np.max(np.abs(dTdt)))\n   686→\n   687→    print(f\"  500K particles processed (250K FLUID + 250K GRANULAR)\")\n   688→    print(f\"  Density range: [{min_rho:.2f}, {max_rho:.2f}], mean: {mean_rho:.2f}\")\n   689→    print(f\"  Shear rate: mean={mean_sr:.4f}, max={max_sr:.4f}\")\n   690→    print(f\"  dTdt: mean={mean_dTdt:.4f}, max |dTdt|={max_dTdt:.4f}\")\n   691→    print(\"[OK] 500K particles: no CUDA errors, all values finite\")\n   692→\n   693→\n   694→# ===================================================================\n   695→# Heat diffusion tests (US-020)\n   696→# ===================================================================\n   697→\n   698→# Material IDs from materials.py\n   699→MAT_WATER = 5   # thermal_conductivity = 0.6\n   700→MAT_METAL = 10  # thermal_conductivity = 50.0\n   701→\n   702→def test_hot_particle_among_cold() -> None:\n   703→    \"\"\"Hot particle (1000K) among cold particles (293K):\n   704→    dTdt is positive for cold neighbors, negative for hot particle.\n   705→    \"\"\"\n   706→    print(\"\\n--- Hot particle among cold: dTdt sign test ---\")\n   707→    _upload_all_params()\n   708→\n   709→    # Place one hot particle at center, surrounded by cold ones\n   710→    # Use a small cluster: 1 hot + neighbors in a regular grid\n   711→    spacing = SPACING\n   712→    extent = 0.06  # small region so all particles are neighbors\n   713→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   714→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   715→    n = xx.size\n   716→\n   717→    positions = np.zeros((n, 4), dtype=np.float32)\n   718→    positions[:, 0] = xx.ravel()\n   719→    positions[:, 1] = yy.ravel()\n   720→    positions[:, 2] = zz.ravel()\n   721→    positions[:, 3] = 1.0\n   722→\n   723→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   724→\n   725→    # All METAL (high thermal conductivity = 50.0)\n   726→    packed_metal = MAT_METAL | (FLUID << 8)\n   727→    packed_info = np.full(n, packed_metal, dtype=np.uint32)\n   728→\n   729→    # All cold (293K) except the center particle (1000K)\n   730→    temperature = np.full(n, 293.0, dtype=np.float32)\n   731→    # Find the particle closest to origin\n   732→    dists = positions[:, 0]**2 + positions[:, 1]**2 + positions[:, 2]**2\n   733→    center_idx = np.argmin(dists)\n   734→    temperature[center_idx] = 1000.0\n   735→\n   736→    density_in = np.full(n, RHO0, dtype=np.float32)\n   737→\n   738→    density, shear_rate, dTdt, sorted_pos, _ = _run_full_pipeline(\n   739→        positions, mass_arr, None, packed_info, density_in, temperature,\n   740→    )\n   741→\n   742→    # Find the hot particle in sorted order (closest to origin)\n   743→    sorted_dists = sorted_pos[:, 0]**2 + sorted_pos[:, 1]**2 + sorted_pos[:, 2]**2\n   744→    hot_sorted_idx = np.argmin(sorted_dists)\n   745→\n   746→    hot_dTdt = dTdt[hot_sorted_idx]\n   747→    cold_dTdt = np.delete(dTdt, hot_sorted_idx)\n   748→\n   749→    print(f\"  {n} METAL particles, center=1000K, rest=293K\")\n   750→    print(f\"  Hot particle dTdt: {hot_dTdt:.4f} (should be negative)\")\n   751→    print(f\"  Cold particles dTdt mean: {np.mean(cold_dTdt):.4f} (should be positive)\")\n   752→    print(f\"  Cold particles dTdt range: [{np.min(cold_dTdt):.4f}, {np.max(cold_dTdt):.4f}]\")\n   753→\n   754→    # Hot particle loses heat -> dTdt < 0\n   755→    assert hot_dTdt < 0.0, f\"Hot particle dTdt = {hot_dTdt:.4f}, expected negative\"\n   756→    # Cold neighbors near hot particle gain heat -> at least some dTdt > 0\n   757→    assert np.any(cold_dTdt > 0.0), \"No cold particle has positive dTdt\"\n   758→\n   759→    print(\"[OK] Hot particle dTdt negative, cold neighbors dTdt positive\")\n   760→\n   761→\n   762→def test_uniform_temperature_zero_dTdt() -> None:\n   763→    \"\"\"All particles at same temperature -> dTdt should be ~0.\"\"\"\n   764→    print(\"\\n--- Uniform temperature zero dTdt test ---\")\n   765→    _upload_all_params()\n   766→\n   767→    spacing = SPACING\n   768→    extent = 0.08\n   769→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   770→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   771→    n = xx.size\n   772→\n   773→    positions = np.zeros((n, 4), dtype=np.float32)\n   774→    positions[:, 0] = xx.ravel()\n   775→    positions[:, 1] = yy.ravel()\n   776→    positions[:, 2] = zz.ravel()\n   777→    positions[:, 3] = 1.0\n   778→\n   779→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   780→\n   781→    packed_water = MAT_WATER | (FLUID << 8)\n   782→    packed_info = np.full(n, packed_water, dtype=np.uint32)\n   783→\n   784→    # All at 500K uniform\n   785→    temperature = np.full(n, 500.0, dtype=np.float32)\n   786→    density_in = np.full(n, RHO0, dtype=np.float32)\n   787→\n   788→    _, _, dTdt, _, _ = _run_full_pipeline(\n   789→        positions, mass_arr, None, packed_info, density_in, temperature,\n   790→    )\n   791→\n   792→    max_abs_dTdt = float(np.max(np.abs(dTdt)))\n   793→    print(f\"  {n} WATER particles at uniform 500K\")\n   794→    print(f\"  Max |dTdt|: {max_abs_dTdt:.6e}\")\n   795→\n   796→    assert max_abs_dTdt < 1e-3, (\n   797→        f\"Uniform temperature dTdt = {max_abs_dTdt:.6e}, expected ~0\"\n   798→    )\n   799→    print(\"[OK] Uniform temperature produces dTdt ~ 0\")\n   800→\n   801→\n   802→def test_heat_conductivity_material_dependence() -> None:\n   803→    \"\"\"Metal (kappa=50) conducts heat much faster than water (kappa=0.6).\"\"\"\n   804→    print(\"\\n--- Heat conductivity material dependence test ---\")\n   805→    _upload_all_params()\n   806→\n   807→    # Two clusters: one metal, one water, same geometry\n   808→    spacing = SPACING\n   809→    extent = 0.04\n   810→    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n   811→    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n   812→    n_each = xx.size\n   813→    n = n_each * 2\n   814→\n   815→    # Metal cluster near origin\n   816→    pos_metal = np.zeros((n_each, 4), dtype=np.float32)\n   817→    pos_metal[:, 0] = xx.ravel()\n   818→    pos_metal[:, 1] = yy.ravel()\n   819→    pos_metal[:, 2] = zz.ravel()\n   820→    pos_metal[:, 3] = 1.0\n   821→\n   822→    # Water cluster offset far away (no interaction)\n   823→    pos_water = np.zeros((n_each, 4), dtype=np.float32)\n   824→    pos_water[:, 0] = xx.ravel() + 0.5\n   825→    pos_water[:, 1] = yy.ravel()\n   826→    pos_water[:, 2] = zz.ravel()\n   827→    pos_water[:, 3] = 1.0\n   828→\n   829→    positions = np.vstack([pos_metal, pos_water])\n   830→    mass_arr = np.full(n, MASS, dtype=np.float32)\n   831→\n   832→    packed_metal = MAT_METAL | (FLUID << 8)\n   833→    packed_water = MAT_WATER | (FLUID << 8)\n   834→    packed_info = np.empty(n, dtype=np.uint32)\n   835→    packed_info[:n_each] = packed_metal\n   836→    packed_info[n_each:] = packed_water\n   837→\n   838→    # Center particle of each cluster is hot, rest cold\n   839→    temperature = np.full(n, 293.0, dtype=np.float32)\n   840→    # Metal center\n   841→    metal_dists = pos_metal[:, 0]**2 + pos_metal[:, 1]**2 + pos_metal[:, 2]**2\n   842→    metal_center = np.argmin(metal_dists)\n   843→    temperature[metal_center] = 1000.0\n   844→    # Water center\n   845→    water_dists = (pos_water[:, 0] - 0.5)**2 + pos_water[:, 1]**2 + pos_water[:, 2]**2\n   846→    water_center = n_each + np.argmin(water_dists)\n   847→    temperature[water_center] = 1000.0\n   848→\n   849→    density_in = np.full(n, RHO0, dtype=np.float32)\n   850→\n   851→    _, _, dTdt, sorted_pos, _ = _run_full_pipeline(\n   852→        positions, mass_arr, None, packed_info, density_in, temperature,\n   853→    )\n   854→\n   855→    # Find metal and water hot particles in sorted order\n   856→    sorted_metal_dists = sorted_pos[:, 0]**2 + sorted_pos[:, 1]**2 + sorted_pos[:, 2]**2\n   857→    sorted_water_dists = (sorted_pos[:, 0] - 0.5)**2 + sorted_pos[:, 1]**2 + sorted_pos[:, 2]**2\n   858→\n   859→    metal_hot_sorted = np.argmin(sorted_metal_dists)\n   860→    water_hot_sorted = np.argmin(sorted_water_dists)\n   861→\n   862→    metal_hot_dTdt = abs(dTdt[metal_hot_sorted])\n   863→    water_hot_dTdt = abs(dTdt[water_hot_sorted])\n   864→\n   865→    ratio = metal_hot_dTdt / max(water_hot_dTdt, 1e-12)\n   866→\n   867→    print(f\"  Metal (kappa=50) hot particle |dTdt|: {metal_hot_dTdt:.4f}\")\n   868→    print(f\"  Water (kappa=0.6) hot particle |dTdt|: {water_hot_dTdt:.4f}\")\n   869→    print(f\"  Ratio: {ratio:.1f}x\")\n   870→\n   871→    # Metal should conduct at least 10x faster than water (50/0.6 = 83x theoretically)\n   872→    assert metal_hot_dTdt > water_hot_dTdt * 5.0, (\n   873→        f\"Metal dTdt {metal_hot_dTdt:.4f} not significantly larger than water {water_hot_dTdt:.4f}\"\n   874→    )\n   875→    print(\"[OK] Metal conducts heat much faster than water\")\n   876→\n   877→\n   878→def main() -> None:\n   879→    test_compilation()\n   880→    test_block_size()\n   881→    test_struct_sizes()\n   882→    test_precalc_coefficients()\n   883→    test_single_isolated_particle()\n   884→    test_two_particles_within_h()\n   885→    test_two_particles_beyond_h()\n   886→    test_per_particle_mass()\n   887→    test_density_clamp_minimum()\n   888→    test_uniform_field_rest_density()\n   889→    test_self_contribution_included()\n   890→    test_stationary_sand_zero_gamma_dot()\n   891→    test_shear_flow_nonzero_gamma_dot()\n   892→    test_non_granular_zero_shear_rate()\n   893→    test_hot_particle_among_cold()\n   894→    test_uniform_temperature_zero_dTdt()\n   895→    test_heat_conductivity_material_dependence()\n   896→    test_500k_no_errors()\n   897→    print(\"\\n=== ALL CHECKS PASSED ===\")\n   898→\n   899→\n   900→if __name__ == \"__main__\":\n   901→    main()\n   902→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"40989a4b-7ef9-4e02-8a7d-030d3ce20abf","uuid":"e1389e88-8e16-49c9-ab4d-d2d724aa3abf","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_step1.py","content":"\"\"\"Integration test for step1.py -- K_Step1 density + strain-rate kernel.\n\nAcceptance criteria (density, US-011):\n  - K_Step1 iterates 3x3x3 neighbor cells using cell_start/cell_end\n  - density_sum += m_j * (h_sq - r_sq)^3 with PER-PARTICLE mass\n  - Final density = max(1.0, poly6_coeff * density_sum)\n  - Smoothing length uses squared distance (r_sq < h_sq)\n  - Neighbor position loaded via __ldg() (read-only cache)\n  - Self-contribution included (j==i NOT skipped)\n  - Test: uniform field at rest density -> rho ~= rho0 (within 10%)\n  - Test: single isolated particle -> rho = mass * poly6_coeff * h^6\n  - Block size = 128, runs without errors for 500K particles\n\nAcceptance criteria (strain-rate, US-015):\n  - Step1 accumulates 6 symmetric D components for GRANULAR only\n  - D tensor uses spiky gradient (NOT poly6 gradient), m_j/rho_j weighting\n  - PostCalc: gamma_dot = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n  - gamma_dot written to sorted shear_rate array\n  - Non-GRANULAR particles get shear_rate = 0\n  - Test: stationary sand -> gamma_dot ~ 0\n  - Test: sand in shear flow -> gamma_dot > 0\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport os\nimport sys\n\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom hash_sort import (\n    NUM_CELLS,\n    build_grid_params,\n    calc_hash,\n    sort_by_hash,\n    upload_grid_params as upload_hash_grid_params,\n)\nfrom build_grid import (\n    build_data_struct,\n    upload_grid_params as upload_build_grid_params,\n)\nfrom step1 import (\n    BLOCK_SIZE,\n    build_precalc_params,\n    build_sim_params,\n    compute_step1,\n    get_module,\n    upload_grid_params as upload_step1_grid_params,\n    upload_materials as upload_step1_materials,\n    upload_precalc_params,\n    upload_sim_params,\n)\nfrom materials import build_material_array\n\n# Simulation constants matching the acceptance criteria\nH = 0.04                # smoothing length\nH_SQ = H * H\nSPACING = 0.02          # particle spacing\nRHO0 = 1000.0           # rest density of water\nMASS = RHO0 * SPACING**3  # 0.008 kg\nPOLY6_COEFF = 315.0 / (64.0 * math.pi * H**9)\n\n# packed_info constants\n# MAKE_PACKED(mat, beh) = (mat & 0xFF) | ((beh & 0x3) << 8)\nFLUID = 0\nGRANULAR = 1\nPACKED_WATER = 5 | (FLUID << 8)     # material 5, FLUID\nPACKED_SAND  = 2 | (GRANULAR << 8)  # material 2, GRANULAR\n\n\ndef _upload_all_params() -> None:\n    \"\"\"Upload grid, sim, precalc, and materials params to all kernel modules.\"\"\"\n    gp = build_grid_params()\n    upload_hash_grid_params(gp)\n    upload_build_grid_params(gp)\n    upload_step1_grid_params(gp)\n\n    sp = build_sim_params(\n        smoothing_length=H,\n        particle_mass=MASS,\n        particle_spacing=SPACING,\n    )\n    upload_sim_params(sp)\n\n    pp = build_precalc_params(smoothing_length=H)\n    upload_precalc_params(pp)\n\n    materials_data = build_material_array()\n    upload_step1_materials(materials_data)\n\n\ndef _run_full_pipeline(\n    positions_np: np.ndarray,\n    mass_np: np.ndarray,\n    velocity_np: np.ndarray | None = None,\n    packed_info_np: np.ndarray | None = None,\n    density_in_np: np.ndarray | None = None,\n    temperature_np: np.ndarray | None = None,\n) -> tuple:\n    \"\"\"Run hash -> sort -> build -> step1 and return results.\n\n    Parameters\n    ----------\n    positions_np : (N, 4) float32\n    mass_np : (N,) float32\n    velocity_np : (N, 4) float32, optional (default: zeros)\n    packed_info_np : (N,) uint32, optional (default: PACKED_WATER)\n    density_in_np : (N,) float32, optional (default: None -> kernel uses fallback)\n    temperature_np : (N,) float32, optional (default: 293.0 ambient)\n\n    Returns\n    -------\n    density_cpu : (N,) float32 -- density in sorted order\n    shear_rate_cpu : (N,) float32 -- gamma_dot in sorted order\n    dTdt_cpu : (N,) float32 -- temperature rate of change in sorted order\n    sorted_positions_cpu : (N, 4) float32\n    sorted_mass_cpu : (N,) float32\n    \"\"\"\n    n = positions_np.shape[0]\n\n    if velocity_np is None:\n        velocity_np = np.zeros((n, 4), dtype=np.float32)\n    if packed_info_np is None:\n        packed_info_np = np.full(n, PACKED_WATER, dtype=np.uint32)\n    if temperature_np is None:\n        temperature_np = np.full(n, 293.0, dtype=np.float32)\n\n    pos_gpu = cupy.asarray(positions_np)\n    mass_gpu = cupy.asarray(mass_np)\n    vel_gpu = cupy.asarray(velocity_np)\n    pi_gpu = cupy.asarray(packed_info_np)\n    temp_gpu = cupy.asarray(temperature_np)\n    density_in_gpu = cupy.asarray(density_in_np) if density_in_np is not None else None\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n\n    # Reorder all arrays to sorted order\n    sorted_pos = pos_gpu[sorted_indices]\n    sorted_mass = mass_gpu[sorted_indices]\n    sorted_vel = vel_gpu[sorted_indices]\n    sorted_pi = pi_gpu[sorted_indices]\n    sorted_temp = temp_gpu[sorted_indices]\n    sorted_density_in = density_in_gpu[sorted_indices] if density_in_gpu is not None else None\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n\n    density, shear_rate, dTdt = compute_step1(\n        sorted_pos, sorted_vel, sorted_mass,\n        sorted_density_in, sorted_pi,\n        sorted_temp,\n        cell_start, cell_end,\n    )\n    cupy.cuda.Device().synchronize()\n\n    return (\n        cupy.asnumpy(density),\n        cupy.asnumpy(shear_rate),\n        cupy.asnumpy(dTdt),\n        cupy.asnumpy(sorted_pos),\n        cupy.asnumpy(sorted_mass),\n    )\n\n\n# ===================================================================\n# Density tests (unchanged acceptance criteria from US-011)\n# ===================================================================\n\ndef test_compilation() -> None:\n    \"\"\"Verify CuPy RawModule compiles step1.cu.\"\"\"\n    print(\"--- Compilation check ---\")\n\n    module = get_module()\n    assert module is not None\n    print(\"[OK] CuPy RawModule compiled step1.cu (includes common.cuh)\")\n\n    kernel = module.get_function(\"K_Step1\")  # type: ignore[union-attr]\n    assert kernel is not None\n    print(\"[OK] K_Step1 kernel function found\")\n\n    # Verify all constant memory symbols accessible\n    for sym in [\"c_grid\", \"c_sim\", \"c_precalc\"]:\n        d_ptr = module.get_global(sym)  # type: ignore[union-attr]\n        assert int(d_ptr) != 0, f\"{sym} symbol not found\"\n    print(\"[OK] c_grid, c_sim, c_precalc constant memory symbols found\")\n\n\ndef test_block_size() -> None:\n    \"\"\"Verify block size is 128.\"\"\"\n    print(\"\\n--- Block size check ---\")\n    assert BLOCK_SIZE == 128, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 128\"\n    print(\"[OK] BLOCK_SIZE = 128\")\n\n\ndef test_struct_sizes() -> None:\n    \"\"\"Verify SimParams and PrecalcParams dtypes match CUDA struct sizes.\"\"\"\n    print(\"\\n--- Struct size check ---\")\n\n    sp = build_sim_params()\n    pp = build_precalc_params()\n\n    # SimParams: 64 bytes (from US-005 test)\n    assert sp.nbytes == 64, f\"SimParams: {sp.nbytes} != 64 bytes\"\n    print(f\"[OK] SimParams: {sp.nbytes} bytes\")\n\n    # PrecalcParams: 20 bytes\n    assert pp.nbytes == 20, f\"PrecalcParams: {pp.nbytes} != 20 bytes\"\n    print(f\"[OK] PrecalcParams: {pp.nbytes} bytes\")\n\n\ndef test_precalc_coefficients() -> None:\n    \"\"\"Verify poly6_coeff matches expected value for h=0.04.\"\"\"\n    print(\"\\n--- Precalc coefficient check ---\")\n\n    pp = build_precalc_params(smoothing_length=H)\n    poly6 = pp[0][\"poly6_coeff\"]\n\n    expected = np.float32(315.0 / (64.0 * math.pi * H**9))\n    rel_err = abs(float(poly6) - float(expected)) / abs(float(expected))\n\n    print(f\"  poly6_coeff = {poly6:.6e} (expected {expected:.6e})\")\n    assert rel_err < 1e-5, f\"poly6_coeff relative error {rel_err:.2e} > 1e-5\"\n    print(\"[OK] poly6_coeff matches 315/(64*pi*h^9)\")\n\n\ndef test_single_isolated_particle() -> None:\n    \"\"\"Single isolated particle: rho = mass * poly6_coeff * h^6.\n\n    Self-contribution: r_sq = 0, so (h^2 - 0)^3 = h^6.\n    density = poly6_coeff * mass * h^6.\n    \"\"\"\n    print(\"\\n--- Single isolated particle test ---\")\n    _upload_all_params()\n\n    # Place particle at center of grid\n    positions = np.zeros((1, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n\n    mass_arr = np.array([MASS], dtype=np.float32)\n\n    density, shear_rate, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    expected = POLY6_COEFF * MASS * H_SQ**3  # poly6_coeff * mass * h^6\n    actual = density[0]\n\n    rel_err = abs(actual - expected) / abs(expected)\n    print(f\"  Expected density: {expected:.6f}\")\n    print(f\"  Actual density:   {actual:.6f}\")\n    print(f\"  Relative error:   {rel_err:.6e}\")\n\n    assert rel_err < 1e-4, (\n        f\"Single particle density mismatch: {actual:.6f} vs {expected:.6f} \"\n        f\"(rel err {rel_err:.6e})\"\n    )\n\n    # Non-GRANULAR (default WATER/FLUID) -> shear_rate should be 0\n    assert shear_rate[0] == 0.0, f\"FLUID particle shear_rate = {shear_rate[0]}, expected 0\"\n\n    print(\"[OK] Single isolated particle density matches mass * poly6_coeff * h^6\")\n    print(\"[OK] FLUID particle shear_rate = 0\")\n\n\ndef test_two_particles_within_h() -> None:\n    \"\"\"Two particles within h should have higher density than one alone.\"\"\"\n    print(\"\\n--- Two particles within smoothing length test ---\")\n    _upload_all_params()\n\n    sep = H * 0.5  # half the smoothing length\n    positions = np.zeros((2, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    positions[1] = [sep, 0.0, 0.0, 1.0]\n\n    mass_arr = np.full(2, MASS, dtype=np.float32)\n\n    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    # Self-contribution only\n    single_rho = POLY6_COEFF * MASS * H_SQ**3\n\n    # Both particles should have density > single particle\n    assert density[0] > single_rho * 0.99, (\n        f\"Particle 0 density {density[0]:.4f} not > single {single_rho:.4f}\"\n    )\n    assert density[1] > single_rho * 0.99, (\n        f\"Particle 1 density {density[1]:.4f} not > single {single_rho:.4f}\"\n    )\n\n    # By symmetry, densities should be approximately equal\n    rel_diff = abs(density[0] - density[1]) / max(density[0], density[1])\n    assert rel_diff < 1e-4, (\n        f\"Asymmetric densities: {density[0]:.6f} vs {density[1]:.6f}\"\n    )\n\n    print(f\"  Single particle density: {single_rho:.6f}\")\n    print(f\"  Particle 0 density:      {density[0]:.6f}\")\n    print(f\"  Particle 1 density:      {density[1]:.6f}\")\n    print(\"[OK] Two particles within h produce symmetric density > single particle\")\n\n\ndef test_two_particles_beyond_h() -> None:\n    \"\"\"Two particles separated by more than h should not see each other.\"\"\"\n    print(\"\\n--- Two particles beyond smoothing length test ---\")\n    _upload_all_params()\n\n    sep = H * 1.5  # beyond smoothing length\n    positions = np.zeros((2, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    positions[1] = [sep, 0.0, 0.0, 1.0]\n\n    mass_arr = np.full(2, MASS, dtype=np.float32)\n\n    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    single_rho = POLY6_COEFF * MASS * H_SQ**3\n\n    # Both should have same density as single particle (only self-contribution)\n    for i in range(2):\n        rel_err = abs(density[i] - single_rho) / single_rho\n        assert rel_err < 1e-4, (\n            f\"Particle {i} density {density[i]:.6f} != single {single_rho:.6f} \"\n            f\"(rel err {rel_err:.2e})\"\n        )\n\n    print(f\"  Particle 0 density: {density[0]:.6f}\")\n    print(f\"  Particle 1 density: {density[1]:.6f}\")\n    print(f\"  Expected (self-only): {single_rho:.6f}\")\n    print(\"[OK] Particles beyond h have self-contribution-only density\")\n\n\ndef test_per_particle_mass() -> None:\n    \"\"\"Two particles with different masses produce different densities.\"\"\"\n    print(\"\\n--- Per-particle mass test ---\")\n    _upload_all_params()\n\n    sep = H * 0.3  # within smoothing length\n    positions = np.zeros((2, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    positions[1] = [sep, 0.0, 0.0, 1.0]\n\n    # Particle 0 has 2x mass\n    mass_arr = np.array([MASS * 2.0, MASS], dtype=np.float32)\n\n    density, _, _, _, sorted_mass = _run_full_pipeline(positions, mass_arr)\n\n    # Particle with larger mass should generally produce higher self-density\n    # But both particles contribute to each other, and mass affects contribution\n    # The key thing: densities differ due to different masses\n    assert density[0] != density[1], (\n        f\"Expected different densities but got {density[0]} == {density[1]}\"\n    )\n\n    print(f\"  Mass[0]={sorted_mass[0]:.6f}, density[0]={density[0]:.6f}\")\n    print(f\"  Mass[1]={sorted_mass[1]:.6f}, density[1]={density[1]:.6f}\")\n    print(\"[OK] Per-particle mass produces different densities\")\n\n\ndef test_density_clamp_minimum() -> None:\n    \"\"\"Density is clamped to minimum 1.0.\"\"\"\n    print(\"\\n--- Density clamp test ---\")\n    _upload_all_params()\n\n    # Use extremely small mass so poly6_coeff * mass * h^6 < 1.0\n    tiny_mass = 1e-20  # absurdly small\n    positions = np.zeros((1, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n\n    mass_arr = np.array([tiny_mass], dtype=np.float32)\n\n    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    assert density[0] >= 1.0, (\n        f\"Density {density[0]} < 1.0 (clamp failed)\"\n    )\n    print(f\"  Density with tiny mass: {density[0]:.6f}\")\n    print(\"[OK] Density clamped to >= 1.0\")\n\n\ndef test_uniform_field_rest_density() -> None:\n    \"\"\"Uniform particle field at rest density produces rho ~= rho0 (within 10%).\n\n    Sets up a regular grid of particles with spacing = 0.02 in a small cube,\n    with mass = rho0 * spacing^3. Interior particles should have density\n    close to rho0.\n    \"\"\"\n    print(\"\\n--- Uniform field rest density test ---\")\n    _upload_all_params()\n\n    # Create a regular grid of particles\n    spacing = SPACING\n    # Use a region large enough for interior particles to have full neighborhood\n    extent = 0.2  # -0.1 to +0.1 in each axis\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n\n    density, _, _, sorted_pos, _ = _run_full_pipeline(positions, mass_arr)\n\n    # Filter to interior particles (at least 2h from edge to avoid boundary effects)\n    margin = 2.0 * H  # 0.08\n    interior = (\n        (sorted_pos[:, 0] > -extent + margin)\n        & (sorted_pos[:, 0] < extent - margin)\n        & (sorted_pos[:, 1] > -extent + margin)\n        & (sorted_pos[:, 1] < extent - margin)\n        & (sorted_pos[:, 2] > -extent + margin)\n        & (sorted_pos[:, 2] < extent - margin)\n    )\n    num_interior = int(np.sum(interior))\n\n    if num_interior == 0:\n        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n        print(\"  Skipping rest density check, using overall stats instead\")\n        mean_rho = float(np.mean(density))\n        print(f\"  Mean density (all): {mean_rho:.2f}\")\n        return\n\n    interior_density = density[interior]\n    mean_rho = float(np.mean(interior_density))\n    min_rho = float(np.min(interior_density))\n    max_rho = float(np.max(interior_density))\n\n    rel_err = abs(mean_rho - RHO0) / RHO0\n\n    print(f\"  Total particles: {n}\")\n    print(f\"  Interior particles: {num_interior}\")\n    print(f\"  Mean interior density: {mean_rho:.2f} (expected ~{RHO0:.0f})\")\n    print(f\"  Min/Max interior density: {min_rho:.2f} / {max_rho:.2f}\")\n    print(f\"  Relative error: {rel_err:.4f}\")\n\n    assert rel_err < 0.10, (\n        f\"Mean interior density {mean_rho:.2f} differs from rho0={RHO0:.0f} \"\n        f\"by {rel_err*100:.1f}% (> 10%)\"\n    )\n    print(\"[OK] Uniform field interior density within 10% of rho0\")\n\n\ndef test_self_contribution_included() -> None:\n    \"\"\"Verify self-contribution is included by checking r_sq=0 case.\"\"\"\n    print(\"\\n--- Self-contribution included test ---\")\n    _upload_all_params()\n\n    # Single particle should have nonzero density (from self-contribution)\n    positions = np.zeros((1, 4), dtype=np.float32)\n    positions[0] = [0.0, 0.0, 0.0, 1.0]\n    mass_arr = np.array([MASS], dtype=np.float32)\n\n    density, _, _, _, _ = _run_full_pipeline(positions, mass_arr)\n\n    # Without self-contribution, density would be 0 -> clamped to 1.0\n    # With self-contribution, density = poly6_coeff * mass * h^6 which is >> 1.0\n    expected_self = POLY6_COEFF * MASS * H_SQ**3\n    assert density[0] > 1.0, (\n        f\"Density {density[0]} == 1.0 means self-contribution missing\"\n    )\n    assert density[0] > expected_self * 0.99, (\n        f\"Density {density[0]:.4f} too low vs expected self-only {expected_self:.4f}\"\n    )\n\n    print(f\"  Density: {density[0]:.6f} (expected self-only: {expected_self:.6f})\")\n    print(\"[OK] Self-contribution is included in density computation\")\n\n\n# ===================================================================\n# Strain-rate tensor tests (US-015)\n# ===================================================================\n\ndef test_stationary_sand_zero_gamma_dot() -> None:\n    \"\"\"Stationary GRANULAR particles produce gamma_dot approximately 0.\n\n    All particles at rest (velocity=0), so the velocity gradient tensor D\n    should be zero everywhere, and gamma_dot = sqrt(2*D:D) = 0.\n    \"\"\"\n    print(\"\\n--- Stationary sand zero gamma_dot test ---\")\n    _upload_all_params()\n\n    # Regular grid of GRANULAR particles, all at rest\n    spacing = SPACING\n    extent = 0.1\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    velocities = np.zeros((n, 4), dtype=np.float32)  # all at rest\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n    # Provide density_in for m_j/rho_j weighting\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    density, shear_rate, _, sorted_pos, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info, density_in,\n    )\n\n    # All shear_rates should be approximately 0 (within numerical tolerance)\n    max_gamma_dot = float(np.max(np.abs(shear_rate)))\n    mean_gamma_dot = float(np.mean(np.abs(shear_rate)))\n\n    print(f\"  {n} GRANULAR particles at rest\")\n    print(f\"  Max |gamma_dot|:  {max_gamma_dot:.6e}\")\n    print(f\"  Mean |gamma_dot|: {mean_gamma_dot:.6e}\")\n\n    assert max_gamma_dot < 1e-3, (\n        f\"Stationary particles have gamma_dot = {max_gamma_dot:.6e}, expected ~0\"\n    )\n    print(\"[OK] Stationary sand particles produce gamma_dot ~ 0\")\n\n\ndef test_shear_flow_nonzero_gamma_dot() -> None:\n    \"\"\"Sand particles in shear flow produce gamma_dot > 0.\n\n    Sets up a simple shear flow: v_x = shear_rate * y (linear shear in x-y plane).\n    The analytical strain rate D_xy = 0.5 * dv_x/dy = 0.5 * shear_rate_applied.\n    gamma_dot = sqrt(2 * 2 * D_xy^2) = sqrt(4 * 0.25 * SR^2) = |SR|.\n    \"\"\"\n    print(\"\\n--- Shear flow nonzero gamma_dot test ---\")\n    _upload_all_params()\n\n    # Regular grid of GRANULAR particles with linear shear velocity\n    spacing = SPACING\n    extent = 0.1\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    # Shear flow: v_x = SR * y, v_y = 0, v_z = 0\n    applied_shear_rate = 10.0  # s^-1\n    velocities = np.zeros((n, 4), dtype=np.float32)\n    velocities[:, 0] = applied_shear_rate * positions[:, 1]  # v_x = SR * y\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n    packed_info = np.full(n, PACKED_SAND, dtype=np.uint32)\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    density, shear_rate, _, sorted_pos, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info, density_in,\n    )\n\n    # Interior particles should have gamma_dot > 0\n    margin = 2.0 * H\n    interior = (\n        (sorted_pos[:, 0] > -extent + margin)\n        & (sorted_pos[:, 0] < extent - margin)\n        & (sorted_pos[:, 1] > -extent + margin)\n        & (sorted_pos[:, 1] < extent - margin)\n        & (sorted_pos[:, 2] > -extent + margin)\n        & (sorted_pos[:, 2] < extent - margin)\n    )\n    num_interior = int(np.sum(interior))\n\n    if num_interior == 0:\n        print(f\"  WARNING: no interior particles (n={n}, margin={margin})\")\n        print(\"  Using all particles for shear rate check\")\n        interior_shear = shear_rate\n    else:\n        interior_shear = shear_rate[interior]\n\n    mean_gamma_dot = float(np.mean(interior_shear))\n    max_gamma_dot = float(np.max(interior_shear))\n    min_gamma_dot = float(np.min(interior_shear))\n\n    print(f\"  {n} GRANULAR particles in shear flow (SR={applied_shear_rate})\")\n    print(f\"  Interior particles: {num_interior}\")\n    print(f\"  Mean gamma_dot: {mean_gamma_dot:.4f}\")\n    print(f\"  Range: [{min_gamma_dot:.4f}, {max_gamma_dot:.4f}]\")\n    print(f\"  Expected (analytical): ~{applied_shear_rate:.1f}\")\n\n    # gamma_dot should be significantly > 0\n    assert mean_gamma_dot > 1.0, (\n        f\"Mean gamma_dot = {mean_gamma_dot:.4f} too low for SR={applied_shear_rate}\"\n    )\n\n    # gamma_dot should be in the right ballpark (within factor of 5 of analytical)\n    # SPH approximation won't be exact due to kernel support, discretization, boundary effects\n    assert mean_gamma_dot < applied_shear_rate * 5.0, (\n        f\"Mean gamma_dot = {mean_gamma_dot:.4f} way too high for SR={applied_shear_rate}\"\n    )\n\n    print(\"[OK] Sand particles in shear flow produce gamma_dot > 0\")\n\n\ndef test_non_granular_zero_shear_rate() -> None:\n    \"\"\"Non-GRANULAR particles get shear_rate = 0 even with velocity gradients.\"\"\"\n    print(\"\\n--- Non-GRANULAR zero shear_rate test ---\")\n    _upload_all_params()\n\n    n = 100\n    rng = np.random.default_rng(123)\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, :3] = rng.uniform(-0.1, 0.1, size=(n, 3)).astype(np.float32)\n    positions[:, 3] = 1.0\n\n    # Give particles random velocities (nonzero velocity gradient)\n    velocities = np.zeros((n, 4), dtype=np.float32)\n    velocities[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)  # FLUID, not GRANULAR\n\n    density, shear_rate, _, _, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info,\n    )\n\n    # All shear_rates should be exactly 0 for FLUID particles\n    assert np.all(shear_rate == 0.0), (\n        f\"FLUID particles have nonzero shear_rate: max={np.max(np.abs(shear_rate)):.6e}\"\n    )\n\n    print(f\"  {n} FLUID particles with random velocities\")\n    print(f\"  All shear_rate = 0 (confirmed)\")\n    print(\"[OK] Non-GRANULAR particles get shear_rate = 0\")\n\n\ndef test_500k_no_errors() -> None:\n    \"\"\"Kernel runs without errors for 500K particles (mixed FLUID and GRANULAR).\"\"\"\n    print(\"\\n--- 500K particle stress test ---\")\n    _upload_all_params()\n\n    rng = np.random.default_rng(42)\n    n = 500_000\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n    positions[:, 3] = 1.0\n\n    velocities = np.zeros((n, 4), dtype=np.float32)\n    velocities[:, :3] = rng.uniform(-0.5, 0.5, size=(n, 3)).astype(np.float32)\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n\n    # Mix of FLUID and GRANULAR particles (50/50)\n    packed_info = np.full(n, PACKED_WATER, dtype=np.uint32)\n    packed_info[n // 2:] = PACKED_SAND\n\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    # Random temperatures for stress test\n    temperature = rng.uniform(200.0, 1500.0, size=n).astype(np.float32)\n\n    density, shear_rate, dTdt, _, _ = _run_full_pipeline(\n        positions, mass_arr, velocities, packed_info, density_in, temperature,\n    )\n\n    # Basic sanity checks\n    assert density.shape == (n,), f\"density shape {density.shape} != ({n},)\"\n    assert shear_rate.shape == (n,), f\"shear_rate shape {shear_rate.shape} != ({n},)\"\n    assert dTdt.shape == (n,), f\"dTdt shape {dTdt.shape} != ({n},)\"\n    assert np.all(density >= 1.0), \"Some densities < 1.0 (clamp failed)\"\n    assert np.all(np.isfinite(density)), \"NaN or Inf in densities\"\n    assert np.all(np.isfinite(shear_rate)), \"NaN or Inf in shear_rates\"\n    assert np.all(shear_rate >= 0.0), \"Negative shear_rate values found\"\n    assert np.all(np.isfinite(dTdt)), \"NaN or Inf in dTdt\"\n\n    mean_rho = float(np.mean(density))\n    min_rho = float(np.min(density))\n    max_rho = float(np.max(density))\n    mean_sr = float(np.mean(shear_rate))\n    max_sr = float(np.max(shear_rate))\n    mean_dTdt = float(np.mean(dTdt))\n    max_dTdt = float(np.max(np.abs(dTdt)))\n\n    print(f\"  500K particles processed (250K FLUID + 250K GRANULAR)\")\n    print(f\"  Density range: [{min_rho:.2f}, {max_rho:.2f}], mean: {mean_rho:.2f}\")\n    print(f\"  Shear rate: mean={mean_sr:.4f}, max={max_sr:.4f}\")\n    print(f\"  dTdt: mean={mean_dTdt:.4f}, max |dTdt|={max_dTdt:.4f}\")\n    print(\"[OK] 500K particles: no CUDA errors, all values finite\")\n\n\n# ===================================================================\n# Heat diffusion tests (US-020)\n# ===================================================================\n\n# Material IDs from materials.py\nMAT_WATER = 5   # thermal_conductivity = 0.6\nMAT_METAL = 10  # thermal_conductivity = 50.0\n\ndef test_hot_particle_among_cold() -> None:\n    \"\"\"Hot particle (1000K) among cold particles (293K):\n    dTdt is positive for cold neighbors, negative for hot particle.\n    \"\"\"\n    print(\"\\n--- Hot particle among cold: dTdt sign test ---\")\n    _upload_all_params()\n\n    # Place one hot particle at center, surrounded by cold ones\n    # Use a small cluster: 1 hot + neighbors in a regular grid\n    spacing = SPACING\n    extent = 0.06  # small region so all particles are neighbors\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n\n    # All METAL (high thermal conductivity = 50.0)\n    packed_metal = MAT_METAL | (FLUID << 8)\n    packed_info = np.full(n, packed_metal, dtype=np.uint32)\n\n    # All cold (293K) except the center particle (1000K)\n    temperature = np.full(n, 293.0, dtype=np.float32)\n    # Find the particle closest to origin\n    dists = positions[:, 0]**2 + positions[:, 1]**2 + positions[:, 2]**2\n    center_idx = np.argmin(dists)\n    temperature[center_idx] = 1000.0\n\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    density, shear_rate, dTdt, sorted_pos, _ = _run_full_pipeline(\n        positions, mass_arr, None, packed_info, density_in, temperature,\n    )\n\n    # Find the hot particle in sorted order (closest to origin)\n    sorted_dists = sorted_pos[:, 0]**2 + sorted_pos[:, 1]**2 + sorted_pos[:, 2]**2\n    hot_sorted_idx = np.argmin(sorted_dists)\n\n    hot_dTdt = dTdt[hot_sorted_idx]\n    cold_dTdt = np.delete(dTdt, hot_sorted_idx)\n\n    print(f\"  {n} METAL particles, center=1000K, rest=293K\")\n    print(f\"  Hot particle dTdt: {hot_dTdt:.4f} (should be negative)\")\n    print(f\"  Cold particles dTdt mean: {np.mean(cold_dTdt):.4f} (should be positive)\")\n    print(f\"  Cold particles dTdt range: [{np.min(cold_dTdt):.4f}, {np.max(cold_dTdt):.4f}]\")\n\n    # Hot particle loses heat -> dTdt < 0\n    assert hot_dTdt < 0.0, f\"Hot particle dTdt = {hot_dTdt:.4f}, expected negative\"\n    # Cold neighbors near hot particle gain heat -> at least some dTdt > 0\n    assert np.any(cold_dTdt > 0.0), \"No cold particle has positive dTdt\"\n\n    print(\"[OK] Hot particle dTdt negative, cold neighbors dTdt positive\")\n\n\ndef test_uniform_temperature_zero_dTdt() -> None:\n    \"\"\"All particles at same temperature -> dTdt should be ~0.\"\"\"\n    print(\"\\n--- Uniform temperature zero dTdt test ---\")\n    _upload_all_params()\n\n    spacing = SPACING\n    extent = 0.08\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n = xx.size\n\n    positions = np.zeros((n, 4), dtype=np.float32)\n    positions[:, 0] = xx.ravel()\n    positions[:, 1] = yy.ravel()\n    positions[:, 2] = zz.ravel()\n    positions[:, 3] = 1.0\n\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n\n    packed_water = MAT_WATER | (FLUID << 8)\n    packed_info = np.full(n, packed_water, dtype=np.uint32)\n\n    # All at 500K uniform\n    temperature = np.full(n, 500.0, dtype=np.float32)\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    _, _, dTdt, _, _ = _run_full_pipeline(\n        positions, mass_arr, None, packed_info, density_in, temperature,\n    )\n\n    max_abs_dTdt = float(np.max(np.abs(dTdt)))\n    print(f\"  {n} WATER particles at uniform 500K\")\n    print(f\"  Max |dTdt|: {max_abs_dTdt:.6e}\")\n\n    assert max_abs_dTdt < 1e-3, (\n        f\"Uniform temperature dTdt = {max_abs_dTdt:.6e}, expected ~0\"\n    )\n    print(\"[OK] Uniform temperature produces dTdt ~ 0\")\n\n\ndef test_heat_conductivity_material_dependence() -> None:\n    \"\"\"Metal (kappa=50) conducts heat much faster than water (kappa=0.6).\"\"\"\n    print(\"\\n--- Heat conductivity material dependence test ---\")\n    _upload_all_params()\n\n    # Two clusters: one metal, one water, same geometry\n    spacing = SPACING\n    extent = 0.04\n    coords = np.arange(-extent, extent + spacing * 0.5, spacing, dtype=np.float32)\n    xx, yy, zz = np.meshgrid(coords, coords, coords, indexing=\"ij\")\n    n_each = xx.size\n    n = n_each * 2\n\n    # Metal cluster near origin\n    pos_metal = np.zeros((n_each, 4), dtype=np.float32)\n    pos_metal[:, 0] = xx.ravel()\n    pos_metal[:, 1] = yy.ravel()\n    pos_metal[:, 2] = zz.ravel()\n    pos_metal[:, 3] = 1.0\n\n    # Water cluster offset far away (no interaction)\n    pos_water = np.zeros((n_each, 4), dtype=np.float32)\n    pos_water[:, 0] = xx.ravel() + 0.5\n    pos_water[:, 1] = yy.ravel()\n    pos_water[:, 2] = zz.ravel()\n    pos_water[:, 3] = 1.0\n\n    positions = np.vstack([pos_metal, pos_water])\n    mass_arr = np.full(n, MASS, dtype=np.float32)\n\n    packed_metal = MAT_METAL | (FLUID << 8)\n    packed_water = MAT_WATER | (FLUID << 8)\n    packed_info = np.empty(n, dtype=np.uint32)\n    packed_info[:n_each] = packed_metal\n    packed_info[n_each:] = packed_water\n\n    # Center particle of each cluster is hot, rest cold\n    temperature = np.full(n, 293.0, dtype=np.float32)\n    # Metal center\n    metal_dists = pos_metal[:, 0]**2 + pos_metal[:, 1]**2 + pos_metal[:, 2]**2\n    metal_center = np.argmin(metal_dists)\n    temperature[metal_center] = 1000.0\n    # Water center\n    water_dists = (pos_water[:, 0] - 0.5)**2 + pos_water[:, 1]**2 + pos_water[:, 2]**2\n    water_center = n_each + np.argmin(water_dists)\n    temperature[water_center] = 1000.0\n\n    density_in = np.full(n, RHO0, dtype=np.float32)\n\n    _, _, dTdt, sorted_pos, _ = _run_full_pipeline(\n        positions, mass_arr, None, packed_info, density_in, temperature,\n    )\n\n    # Find metal and water hot particles in sorted order\n    sorted_metal_dists = sorted_pos[:, 0]**2 + sorted_pos[:, 1]**2 + sorted_pos[:, 2]**2\n    sorted_water_dists = (sorted_pos[:, 0] - 0.5)**2 + sorted_pos[:, 1]**2 + sorted_pos[:, 2]**2\n\n    metal_hot_sorted = np.argmin(sorted_metal_dists)\n    water_hot_sorted = np.argmin(sorted_water_dists)\n\n    metal_hot_dTdt = abs(dTdt[metal_hot_sorted])\n    water_hot_dTdt = abs(dTdt[water_hot_sorted])\n\n    ratio = metal_hot_dTdt / max(water_hot_dTdt, 1e-12)\n\n    print(f\"  Metal (kappa=50) hot particle |dTdt|: {metal_hot_dTdt:.4f}\")\n    print(f\"  Water (kappa=0.6) hot particle |dTdt|: {water_hot_dTdt:.4f}\")\n    print(f\"  Ratio: {ratio:.1f}x\")\n\n    # Metal should conduct at least 10x faster than water (50/0.6 = 83x theoretically)\n    assert metal_hot_dTdt > water_hot_dTdt * 5.0, (\n        f\"Metal dTdt {metal_hot_dTdt:.4f} not significantly larger than water {water_hot_dTdt:.4f}\"\n    )\n    print(\"[OK] Metal conducts heat much faster than water\")\n\n\ndef main() -> None:\n    test_compilation()\n    test_block_size()\n    test_struct_sizes()\n    test_precalc_coefficients()\n    test_single_isolated_particle()\n    test_two_particles_within_h()\n    test_two_particles_beyond_h()\n    test_per_particle_mass()\n    test_density_clamp_minimum()\n    test_uniform_field_rest_density()\n    test_self_contribution_included()\n    test_stationary_sand_zero_gamma_dot()\n    test_shear_flow_nonzero_gamma_dot()\n    test_non_granular_zero_shear_rate()\n    test_hot_particle_among_cold()\n    test_uniform_temperature_zero_dTdt()\n    test_heat_conductivity_material_dependence()\n    test_500k_no_errors()\n    print(\"\\n=== ALL CHECKS PASSED ===\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":902,"startLine":1,"totalLines":902}}}

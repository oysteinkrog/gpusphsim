ull,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2620,"cache_read_input_tokens":104690,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2620},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"40989a4b-7ef9-4e02-8a7d-030d3ce20abf","uuid":"e410ae57-a1ee-489b-bdbf-74b71de84b9e"}

ss\n   170→\n   171→        packed = _MAKE_PACKED(material_id, mat.behavior_class)\n   172→        self.packed_info[sl] = cp.uint32(packed)\n   173→\n   174→        temp = _DEFAULT_TEMPS.get(material_id, T_AMBIENT)\n   175→        self.temperature[sl] = temp\n   176→        self.health[sl] = 1.0\n   177→        self.lifetime[sl] = 0.0\n   178→        self.shear_rate[sl] = 0.0\n   179→        self.exposure_heat[sl] = 0.0\n   180→        self.exposure_corrode[sl] = 0.0\n   181→\n   182→        self.color[sl, 0] = mat.color_r\n   183→        self.color[sl, 1] = mat.color_g\n   184→        self.color[sl, 2] = mat.color_b\n   185→        self.color[sl, 3] = 1.0\n   186→\n   187→        self.density[sl] = mat.rest_density\n   188→        self.sleep_counter[sl] = 0\n   189→\n   190→        self._high_water += actual\n   191→        return actual\n   192→\n   193→    def spawn_cube(\n   194→        self,\n   195→        min_corner: Tuple[float, float, float],\n   196→        max_corner: Tuple[float, float, float],\n   197→        material_id: int,\n   198→        spacing: float = DEFAULT_SPACING,\n   199→    ) -> int:\n   200→        \"\"\"Spawn particles on a regular grid within a cube.\n   201→\n   202→        Returns the number of particles actually spawned.\n   203→        \"\"\"\n   204→        if material_id not in MATERIALS:\n   205→            raise ValueError(f\"Unknown material_id: {material_id}\")\n   206→\n   207→        # Build grid positions on CPU (small overhead, predictable count)\n   208→        x0, y0, z0 = min_corner\n   209→        x1, y1, z1 = max_corner\n   210→        xs = np.arange(x0 + spacing * 0.5, x1, spacing, dtype=np.float32)\n   211→        ys = np.arange(y0 + spacing * 0.5, y1, spacing, dtype=np.float32)\n   212→        zs = np.arange(z0 + spacing * 0.5, z1, spacing, dtype=np.float32)\n   213→\n   214→        if len(xs) == 0 or len(ys) == 0 or len(zs) == 0:\n   215→            return 0\n   216→\n   217→        total = len(xs) * len(ys) * len
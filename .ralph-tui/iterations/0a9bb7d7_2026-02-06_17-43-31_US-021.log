__ velocity,      // sorted velocities (for strain-rate)\n    const float*    __restrict__ mass,           // sorted per-particle mass\n    const float*    __restrict__ density_in,     // sorted density from previous step (for strain-rate m_j/rho_j weighting; NULL on first frame)\n    const uint*     __restrict__ packed_info,    // sorted packed_info (for behavior class check)\n    const float*    __restrict__ temperature_in, // sorted temperature (for heat diffusion)\n    const uint*     __restrict__ cell_start,     // grid cell start indices\n    const uint*     __restrict__ cell_end,       // grid cell end indices\n    float*          __restrict__ density_out,    // output: density per particle\n    float*          __restrict__ shear_rate_out, // output: gamma_dot per particle (0 for non-GRANULAR)\n    float*          __restrict__ dTdt_out        // output: temperature rate of change (heat diffusion)\n) {\n    uint index_i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (index_i >= numParticles) return;\n\n    // Read position of particle i\n    float4 pos4_i = position[index_i];\n    float3 pos_i = make_float3(pos4_i.x, pos4_i.y, pos4_i.z);\n\n    float h    = c_sim.smoothing_length;\n    float h_sq = c_sim.smoothing_length_sq;\n\n    // Check if this particle is GRANULAR\n    uint pi_i = __ldg(&packed_info[index_i]);\n    int behavior_i = GET_BEHAVIOR(pi_i);\n    uint mat_id_i = GET_MATERIAL_ID(pi_i);\n    bool is_granular = (behavior_i == GRANULAR);\n\n    // Read velocity for strain-rate (only used if GRANULAR, but cheap to read)\n    float3 vel_i;\n    if (is_granular) {\n        float4 vel4_i = velocity[index_i];\n        vel_i = make_float3(vel4_i.x, vel4_i.y, vel4_i.z);\n    }\n\n    // Read temperature for heat diffusion\n    float T_i = __ldg(&temperature_in[index_i]);\n    float kappa_i = c_materials[mat_id_i].thermal_conductivity;\n\n    // Density accumulator (variable part of Poly6 kernel)\n    float sum_density = 0.0f;\n\n    // Heat diffusion accumulator: dTdt\n    float sum_dTdt = 0.0f;\n\n    // Strain-rate tensor accumulators (6 symmetric components)\n    // D_xx, D_yy, D_zz, D_xy, D_xz, D_yz\n    float Dxx = 0.0f, Dyy = 0.0f, Dzz = 0.0f;\n    float Dxy = 0.0f, Dxz = 0.0f, Dyz = 0.0f;\n\n    // Grid cell of particle i\n    int3 cell_i = make_int3(\n        (int)((pos_i.x - c_grid.grid_min.x) * c_grid.grid_delta.x),\n        (int)((pos_i.y - c_grid.grid_min.y) * c_grid.grid_delta.y),\n        (int)((pos_i.z - c_grid.grid_min.z) * c_grid.grid_delta.z)\n    );\n    // Clamp to valid range\n    cell_i.x = max(0, min(cell_i.x, c_grid.grid_res.x - 1));\n    cell_i.y = max(0, min(cell_i.y, c_grid.grid_res.y - 1));\n    cell_i.z = max(0, min(cell_i.z, c_grid.grid_res.z - 1));\n\n    int rx = c_grid.grid_res.x;\n    int ry = c_grid.grid_res.y;\n    int rz = c_grid.grid_res.z;\n\n    // Iterate 27 neighbor cells\n    for (int dz = -1; dz <= 1; dz++) {\n        int cz = cell_i.z + dz;\n        if (cz < 0 || cz >= rz) continue;\n        for (int dy = -1; dy <= 1; dy++) {\n            int cy = cell_i.y + dy;\n            if (cy < 0 || cy >= ry) continue;\n            for (int dx = -1; dx <= 1; dx++) {\n                int cx = cell_i.x + dx;\n                if (cx < 0 || cx >= rx) continue;\n\n                uint hash = (uint)(cz * ry * rx + cy * rx + cx);\n                uint start = cell_start[hash];\n\n                // Empty cell sentinel\n                if (start == 0xFFFFFFFFu) continue;\n                uint end_idx = cell_end[hash];\n\n                for (uint index_j = start; index_j < end_idx; index_j++) {\n                    float4 pos4_j = __ldg(&position[index_j]);\n                    float3 r = make_float3(\n                        pos_i.x - pos4_j.x,\n                        pos_i.y - pos4_j.y,\n                        pos_i.z - pos4_j.z\n                    );\n                    float r_sq = r.x * r.x + r.y * r.y + r.z * r.z;\n\n                    if (r_sq <= h_sq) {\n                        // --- Density: self-interaction included ---\n                        float diff = h_sq - r_sq;\n                        float m_j = __ldg(&mass[index_j]);\n                        sum_density += m_j * diff * diff * diff;\n\n                        // --- Heat diffusion: skip self ---\n                        if (index_j != index_i) {\n                            float rlen = sqrtf(r_sq);\n                            float T_j = __ldg(&temperature_in[index_j]);\n                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n                            // SPH Laplacian of temperature using viscosity Laplacian kernel:\n                            // lap_W_visc(r) = (h - |r|)  (variable part, coeff is viscosity_lap_coeff)\n                            // dTdt += kappa * (m_j / rho_j) * (T_j - T_i) * viscosity_lap_coeff * (h - |r|)\n                            float lap_var = h - rlen;\n                            sum_dTdt += m_j / fmaxf(rho_j, 1.0f) * (T_j - T_i) * lap_var;\n                        }\n\n                        // --- Strain-rate: skip self, GRANULAR only ---\n                        if (is_granular && index_j != index_i && r_sq > 1e-12f) {\n                            float rlen = sqrtf(r_sq);\n\n                            // Spiky gradient: gradW = spiky_grad_coeff * (h - r)^2 * (r/|r|)\n                            // spiky_grad_coeff is negative (-45/(pi*h^6))\n                            // We need the actual gradient vector pointing from j to i\n                            float h_r = h - rlen;\n                            float inv_rlen = 1.0f / rlen;\n                            // gradW = spiky_grad_coeff * (h-r)^2 * r_hat\n                            // where r_hat = r/|r| points from j to i\n                            float grad_scalar = c_precalc.spiky_grad_coeff * h_r * h_r * inv_rlen;\n                            float gWx = grad_scalar * r.x;\n                            float gWy = grad_scalar * r.y;\n                            float gWz = grad_scalar * r.z;\n\n                            // dv = v_i - v_j\n                            float4 vel4_j = __ldg(&velocity[index_j]);\n                            float dvx = vel_i.x - vel4_j.x;\n                            float dvy = vel_i.y - vel4_j.y;\n                            float dvz = vel_i.z - vel4_j.z;\n\n                            // m_j / rho_j weighting\n                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n                            float weight = m_j / fmaxf(rho_j, 1.0f);\n\n                            // Accumulate velocity gradient tensor L_ab = sum (m_j/rho_j) * dv_a * gradW_b\n                            // D_ab = 0.5 * (L_ab + L_ba)\n                            // Since we compute D directly:\n                            //   D_xx += weight * dv_x * gW_x\n                            //   D_yy += weight * dv_y * gW_y\n                            //   D_zz += weight * dv_z * gW_z\n                            //   D_xy += 0.5 * weight * (dv_x * gW_y + dv_y * gW_x)\n                            //   D_xz += 0.5 * weight * (dv_x * gW_z + dv_z * gW_x)\n                            //   D_yz += 0.5 * weight * (dv_y * gW_z + dv_z * gW_y)\n                            Dxx += weight * dvx * gWx;\n                            Dyy += weight * dvy * gWy;\n                            Dzz += weight * dvz * gWz;\n                            Dxy += 0.5f * weight * (dvx * gWy + dvy * gWx);\n                            Dxz += 0.5f * weight * (dvx * gWz + dvz * gWx);\n                            Dyz += 0.5f * weight * (dvy * gWz + dvz * gWy);\n                        }\n                    }\n                }\n            }\n        }\n    }\n\n    // --- PostCalc: density ---\n    float density = c_precalc.poly6_coeff * sum_density;\n    density_out[index_i] = fmaxf(density, 1.0f);\n\n    // --- PostCalc: heat diffusion dTdt ---\n    // dTdt = kappa_i * viscosity_lap_coeff * sum_dTdt\n    dTdt_out[index_i] = kappa_i * c_precalc.viscosity_lap_coeff * sum_dTdt;\n\n    // --- PostCalc: strain-rate magnitude (gamma_dot) ---\n    if (is_granular) {\n        // gamma_dot = sqrt(2 * D:D)\n        //           = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n        float D_sq = Dxx * Dxx + Dyy * Dyy + Dzz * Dzz\n                   + 2.0f * (Dxy * Dxy + Dxz * Dxz + Dyz * Dyz);\n        float gamma_dot = sqrtf(fmaxf(2.0f * D_sq, 0.0f));\n        shear_rate_out[index_i] = gamma_dot;\n    } else {\n        shear_rate_out[index_i] = 0.0f;\n    }\n}\n","numLines":212,"startLine":1,"totalLines":212}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018p1mCxDjDAbQEKaQLY5L8y","type":"tool_result","content":"     1→/*\n     2→ * common.cuh -- Single source of truth for all GPU data layouts.\n     3→ *\n     4→ * All .cu kernel files include this header. It defines:\n     5→ *   - BehaviorClass enum\n     6→ *   - MaterialProps / Interaction structs + constant memory arrays\n     7→ *   - GridParams struct + constant memory\n     8→ *   - SimParams / PrecalcParams structs + constant memory\n     9→ *   - packed_info bitfield macros\n    10→ *   - Array type conventions (documented in comments)\n    11→ */\n    12→\n    13→#ifndef FALLINGSAND3D_COMMON_CUH\n    14→#define FALLINGSAND3D_COMMON_CUH\n    15→\n    16→typedef unsigned int uint;\n    17→\n    18→/* ======================================================================\n    19→ * Behavior classes\n    20→ * ====================================================================== */\n    21→\n    22→enum BehaviorClass {\n    23→    FLUID   = 0,\n    24→    GRANULAR = 1,\n    25→    GAS     = 2,\n    26→    STATIC  = 3\n    27→};\n    28→\n    29→/* ======================================================================\n    30→ * MaterialProps -- per-material constants uploaded to constant memory.\n    31→ * 16 fields x 4 bytes = 64 bytes (no extra padding needed).\n    32→ * ====================================================================== */\n    33→\n    34→struct MaterialProps {\n    35→    float rest_density;          // kg/m^3\n    36→    float eos_stiffness;         // Tait EOS k\n    37→    float eos_gamma;             // Tait EOS exponent (7 for liquid, 1 for gas)\n    38→    float base_viscosity;        // Pa*s\n    39→    float friction_coeff;        // mu_s for granular friction\n    40→    float cohesion;              // cohesion coefficient\n    41→    float buoyancy_extra;        // extra buoyancy factor for gas\n    42→    float thermal_conductivity;  // W/(m*K)\n    43→    float heat_capacity;         // J/(kg*K)\n    44→    float temp_melt;             // Kelvin\n    45→    float temp_boil;             // Kelvin\n    46→    float temp_ignite;           // Kelvin (0 = non-flammable)\n    47→    int   behavior_class;        // BehaviorClass enum value\n    48→    float color_r;               // default material color R\n    49→    float color_g;               // default material color G\n    50→    float color_b;               // default material color B\n    51→};\n    52→// Static assert: sizeof(MaterialProps) must be 64 bytes\n    53→\n    54→/* ======================================================================\n    55→ * Interaction -- per-pair (i,j) reaction parameters.\n    56→ * 2 fields x 4 bytes = 8 bytes.\n    57→ * ====================================================================== */\n    58→\n    59→struct Interaction {\n    60→    float reaction_rate;   // reaction speed (0 = no reaction)\n    61→    float heat_exchange;   // heat transfer coefficient between pair\n    62→};\n    63→\n    64→/* ======================================================================\n    65→ * Constant memory: materials and interactions\n    66→ * Total: 32*64 + 32*32*8 = 2048 + 8192 = 10240 bytes (well under 64 KB)\n    67→ * ====================================================================== */\n    68→\n    69→__constant__ MaterialProps c_materials[32];\n    70→__constant__ Interaction   c_interactions[32][32];\n    71→\n    72→/* ======================================================================\n    73→ * GridParams -- uniform grid parameters for spatial hashing.\n    74→ *\n    75→ * grid_res uses int3 (not float3 as in the root-level prototype) for\n    76→ * correct integer arithmetic in hash computation.\n    77→ * ====================================================================== */\n    78→\n    79→struct GridParams {\n    80→    float3 grid_min;    // world-space minimum corner\n    81→    float3 grid_max;    // world-space maximum corner\n    82→    int3   grid_res;    // number of cells per axis\n    83→    float3 grid_delta;  // 1 / cell_size = grid_res / grid_size\n    84→    int    num_cells;   // grid_res.x * grid_res.y * grid_res.z\n    85→};\n    86→\n    87→__constant__ GridParams c_grid;\n    88→\n    89→/* ======================================================================\n    90→ * SimParams -- simulation-wide parameters.\n    91→ *\n    92→ * Uploaded once per frame (or when sim config changes).\n    93→ * ====================================================================== */\n    94→\n    95→struct SimParams {\n    96→    float  smoothing_length;     // h\n    97→    float  smoothing_length_sq;  // h^2\n    98→    float  particle_mass;        // uniform mass per particle\n    99→    float  particle_spacing;     // rest spacing between particles\n   100→    float3 gravity;              // (0, -9.8, 0) typically\n   101→    float  dt;                   // simulation timestep\n   102→    float  restitution;          // wall bounce coefficient\n   103→    float  wall_friction;        // wall friction coefficient\n   104→    float3 world_min;            // simulation domain min\n   105→    float3 world_max;            // simulation domain max\n   106→};\n   107→\n   108→__constant__ SimParams c_sim;\n   109→\n   110→/* ======================================================================\n   111→ * PrecalcParams -- kernel coefficients precomputed from smoothing_length.\n   112→ *\n   113→ * These depend on h and are recomputed when h changes. Stored separately\n   114→ * from SimParams to keep the intent clear.\n   115→ *\n   116→ * Sign convention: pressure_precalc is POSITIVE (+45/(pi*h^6)) because\n   117→ * it absorbs the double negative from the SPH momentum equation.\n   118→ * ====================================================================== */\n   119→\n   120→struct PrecalcParams {\n   121→    float poly6_coeff;           // 315 / (64 * pi * h^9)\n   122→    float spiky_grad_coeff;      // -45 / (pi * h^6)  (negative)\n   123→    float viscosity_lap_coeff;   // 45 / (pi * h^6)\n   124→    float pressure_precalc;      // +45 / (pi * h^6)   (positive, see note)\n   125→    float viscosity_precalc;     // mu * 45 / (pi * h^6)\n   126→};\n   127→\n   128→__constant__ PrecalcParams c_precalc;\n   129→\n   130→/* ======================================================================\n   131→ * packed_info bitfield layout (uint32)\n   132→ *\n   133→ *   Bits [7:0]   material_id    (256 materials max, 32 used)\n   134→ *   Bits [9:8]   behavior_class (FLUID=0, GRANULAR=1, GAS=2, STATIC=3)\n   135→ *   Bit  [10]    is_sleeping    (1 = asleep, skip force computation)\n   136→ *   Bit  [11]    spawn_flag     (1 = just spawned, needs initialization)\n   137→ *   Bit  [12]    just_woke      (1 = woke this frame, needs velocity reset)\n   138→ *   Bits [31:13] reserved\n   139→ * ====================================================================== */\n   140→\n   141→#define GET_MATERIAL_ID(p)  ((p) & 0xFF)\n   142→#define GET_BEHAVIOR(p)     (((p) >> 8) & 0x3)\n   143→#define IS_SLEEPING(p)      (((p) >> 10) & 1)\n   144→#define SET_SLEEPING(p)     ((p) | 0x400)\n   145→#define CLEAR_SLEEPING(p)   ((p) & ~0x400)\n   146→#define HAS_SPAWN_FLAG(p)   (((p) >> 11) & 1)\n   147→#define SET_SPAWN_FLAG(p)   ((p) | 0x800)\n   148→#define HAS_JUST_WOKE(p)    (((p) >> 12) & 1)\n   149→#define SET_JUST_WOKE(p)    ((p) | 0x1000)\n   150→#define CLEAR_JUST_WOKE(p)  ((p) & ~0x1000)\n   151→#define MAKE_PACKED(mat, beh) (((mat) & 0xFF) | (((beh) & 0x3) << 8))\n   152→\n   153→/* ======================================================================\n   154→ * Array type conventions (documented per acceptance criteria)\n   155→ *\n   156→ * float4 arrays (w component unused, set to 0):\n   157→ *   position, velocity, veleval, sph_force, color\n   158→ *\n   159→ * float arrays:\n   160→ *   density, mass, temperature, health, lifetime,\n   161→ *   shear_rate, exposure_heat, exposure_corrode\n   162→ *\n   163→ * uint32 arrays:\n   164→ *   packed_info\n   165→ *\n   166→ * uint8 arrays:\n   167→ *   sleep_counter\n   168→ * ====================================================================== */\n   169→\n   170→#endif /* FALLINGSAND3D_COMMON_CUH */\n   171→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"40989a4b-7ef9-4e02-8a7d-030d3ce20abf","uuid":"4768014e-1002-4e5e-ae8c-9b19df3bdde3","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/physics/kernels/common.cuh","content":"/*\n * common.cuh -- Single source of truth for all GPU data layouts.\n *\n * All .cu kernel files include this header. It defines:\n *   - BehaviorClass enum\n *   - MaterialProps / Interaction structs + constant memory arrays\n *   - GridParams struct + constant memory\n *   - SimParams / PrecalcParams structs + constant memory\n *   - packed_info bitfield macros\n *   - Array type conventions (documented in comments)\n */\n\n#ifndef FALLINGSAND3D_COMMON_CUH\n#define FALLINGSAND3D_COMMON_CUH\n\ntypedef unsigned int uint;\n\n/* ======================================================================\n * Behavior classes\n * ====================================================================== */\n\nenum BehaviorClass {\n    FLUID   = 0,\n    GRANULAR = 1,\n    GAS     = 2,\n    STATIC  = 3\n};\n\n/* ======================================================================\n * MaterialProps -- per-material constants uploaded to constant memory.\n * 16 fields x 4 bytes = 64 bytes (no extra padding needed).\n * ====================================================================== */\n\nstruct MaterialProps {\n    float rest_density;          // kg/m^3\n    float eos_stiffness;         // Tait EOS k\n    float eos_gamma;             // Tait EOS exponent (7 for liquid, 1 for gas)\n    float base_viscosity;        // Pa*s\n    float friction_coeff;        // mu_s for granular friction\n    float cohesion;              // cohesion coefficient\n    float buoyancy_extra;        // extra buoyancy factor for gas\n    float thermal_conductivity;  // W/(m*K)\n    float heat_capacity;         // J/(kg*K)\n    float temp_melt;             // Kelvin\n    float temp_boil;             // Kelvin\n    float temp_ignite;           // Kelvin (0 = non-flammable)\n    int   behavior_class;        // BehaviorClass enum value\n    float color_r;               // default material color R\n    float color_g;               // default material color G\n    float color_b;               // default material color B\n};\n// Static assert: sizeof(MaterialProps) must be 64 bytes\n\n/* ======================================================================\n * Interaction -- per-pair (i,j) reaction parameters.\n * 2 fields x 4 bytes = 8 bytes.\n * ====================================================================== */\n\nstruct Interaction {\n    float reaction_rate;   // reaction speed (0 = no reaction)\n    float heat_exchange;   // heat transfer coefficient between pair\n};\n\n/* ======================================================================\n * Constant memory: materials and interactions\n * Total: 32*64 + 32*32*8 = 2048 + 8192 = 10240 bytes (well under 64 KB)\n * ====================================================================== */\n\n__constant__ MaterialProps c_materials[32];\n__constant__ Interaction   c_interactions[32][32];\n\n/* ======================================================================\n * GridParams -- uniform grid parameters for spatial hashing.\n *\n * grid_res uses int3 (not float3 as in the root-level prototype) for\n * correct integer arithmetic in hash computation.\n * ====================================================================== */\n\nstruct GridParams {\n    float3 grid_min;    // world-space minimum corner\n    float3 grid_max;    // world-space maximum corner\n    int3   grid_res;    // number of cells per axis\n    float3 grid_delta;  // 1 / cell_size = grid_res / grid_size\n    int    num_cells;   // grid_res.x * grid_res.y * grid_res.z\n};\n\n__constant__ GridParams c_grid;\n\n/* ======================================================================\n * SimParams -- simulation-wide parameters.\n *\n * Uploaded once per frame (or when sim config changes).\n * ====================================================================== */\n\nstruct SimParams {\n    float  smoothing_length;     // h\n    float  smoothing_length_sq;  // h^2\n    float  particle_mass;        // uniform mass per particle\n    float  particle_spacing;     // rest spacing between particles\n    float3 gravity;              // (0, -9.8, 0) typically\n    float  dt;                   // simulation timestep\n    float  restitution;          // wall bounce coefficient\n    float  wall_friction;        // wall friction coefficient\n    float3 world_min;            // simulation domain min\n    float3 world_max;            // simulation domain max\n};\n\n__constant__ SimParams c_sim;\n\n/* ======================================================================\n * PrecalcParams -- kernel coefficients precomputed from smoothing_length.\n *\n * These depend on h and are recomputed when h changes. Stored separately\n * from SimParams to keep the intent clear.\n *\n * Sign convention: pressure_precalc is POSITIVE (+45/(pi*h^6)) because\n * it absorbs the double negative from the SPH momentum equation.\n * ====================================================================== */\n\nstruct PrecalcParams {\n    float poly6_coeff;           // 315 / (64 * pi * h^9)\n    float spiky_grad_coeff;      // -45 / (pi * h^6)  (negative)\n    float viscosity_lap_coeff;   // 45 / (pi * h^6)\n    float pressure_precalc;      // +45 / (pi * h^6)   (positive, see note)\n    float viscosity_precalc;     // mu * 45 / (pi * h^6)\n};\n\n__constant__ PrecalcParams c_precalc;\n\n/* ======================================================================\n * packed_info bitfield layout (uint32)\n *\n *   Bits [7:0]   material_id    (256 materials max, 32 used)\n *   Bits [9:8]   behavior_class (FLUID=0, GRANULAR=1, GAS=2, STATIC=3)\n *   Bit  [10]    is_sleeping    (1 = asleep, skip force computation)\n *   Bit  [11]    spawn_flag     (1 = just spawned, needs initialization)\n *   Bit  [12]    just_woke      (1 = woke this frame, needs velocity reset)\n *   Bits [31:13] reserved\n * ====================================================================== */\n\n#define GET_MATERIAL_ID(p)  ((p) & 0xFF)\n#define GET_BEHAVIOR(p)     (((p) >> 8) & 0x3)\n#define IS_SLEEPING(p)      (((p) >> 10) & 1)\n#define SET_SLEEPING(p)     ((p) | 0x400)\n#define CLEAR_SLEEPING(p)   ((p) & ~0x400)\n#define HAS_SPAWN_FLAG(p)   (((p) >> 11) & 1)\n#define SET_SPAWN_FLAG(p)   ((p) | 0x800)\n#define HAS_JUST_WOKE(p)    (((p) >> 12) & 1)\n#define SET_JUST_WOKE(p)    ((p) | 0x1000)\n#define CLEAR_JUST_WOKE(p)  ((p) & ~0x1000)\n#define MAKE_PACKED(mat, beh) (((mat) & 0xFF) | (((beh) & 0x3) << 8))\n\n/* ======================================================================\n * Array type conventions (documented per acceptance criteria)\n *\n * float4 arrays (w component unused, set to 0):\n *   position, velocity, veleval, sph_force, color\n *\n * float arrays:\n *   density, mass, temperature, health, lifetime,\n *   shear_rate, exposure_heat, exposure_corrode\n *\n * uint32 arrays:\n *   packed_info\n *\n * uint8 arrays:\n *   sleep_counter\n * ====================================================================== */\n\n#endif /* FALLINGSAND3D_COMMON_CUH */\n","numLines":171,"startLine":1,"totalLines":171}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YTa6XcykFvxoZoZDcNZsHH","type":"tool_result","content":"     1→\"\"\"Step1 kernel: SPH density summation + strain-rate tensor + heat diffusion.\n     2→\n     3→Compiles physics/kernels/step1.cu via CuPy RawModule and provides\n     4→a function to launch K_Step1 which computes per-particle density\n     5→from the sorted particle positions and masses using neighbor iteration.\n     6→\n     7→Additionally computes heat diffusion dTdt via SPH Laplacian of temperature:\n     8→  dTdt = kappa_i * viscosity_lap_coeff * sum_j (m_j/rho_j) * (T_j - T_i) * (h - |r|)\n     9→\n    10→For GRANULAR particles, computes the symmetric strain-rate tensor D from\n    11→SPH velocity gradient (spiky kernel) and writes the second invariant\n    12→gamma_dot = sqrt(2 * D:D) to the shear_rate output array.\n    13→Non-GRANULAR particles get shear_rate = 0.\n    14→\n    15→Density formula\n    16→---------------\n    17→density_sum += m_j * (h^2 - |r_ij|^2)^3   for all neighbors j within h\n    18→density_i = max(1.0, poly6_coeff * density_sum)\n    19→\n    20→Self-interaction is included (particle i contributes to its own density).\n    21→Per-particle mass m_j supports multi-material and mass splitting.\n    22→\"\"\"\n    23→\n    24→from __future__ import annotations\n    25→\n    26→import math\n    27→import os\n    28→from typing import Optional\n    29→\n    30→import cupy\n    31→import numpy as np\n    32→\n    33→# ---------------------------------------------------------------------------\n    34→# Numpy dtypes matching constant memory structs in common.cuh\n    35→# ---------------------------------------------------------------------------\n    36→\n    37→# SimParams -- matches struct SimParams in common.cuh\n    38→# struct SimParams {\n    39→#     float  smoothing_length;     //  4 bytes\n    40→#     float  smoothing_length_sq;  //  4 bytes\n    41→#     float  particle_mass;        //  4 bytes\n    42→#     float  particle_spacing;     //  4 bytes\n    43→#     float3 gravity;              // 12 bytes\n    44→#     float  dt;                   //  4 bytes\n    45→#     float  restitution;          //  4 bytes\n    46→#     float  wall_friction;        //  4 bytes\n    47→#     float3 world_min;            // 12 bytes\n    48→#     float3 world_max;            // 12 bytes\n    49→# };                               // Total: 64 bytes\n    50→SIM_PARAMS_DTYPE = np.dtype(\n    51→    [\n    52→        (\"smoothing_length\", np.float32),\n    53→        (\"smoothing_length_sq\", np.float32),\n    54→        (\"particle_mass\", np.float32),\n    55→        (\"particle_spacing\", np.float32),\n    56→        (\"gravity\", np.float32, (3,)),\n    57→        (\"dt\", np.float32),\n    58→        (\"restitution\", np.float32),\n    59→        (\"wall_friction\", np.float32),\n    60→        (\"world_min\", np.float32, (3,)),\n    61→        (\"world_max\", np.float32, (3,)),\n    62→    ],\n    63→    align=False,\n    64→)\n    65→\n    66→# PrecalcParams -- matches struct PrecalcParams in common.cuh\n    67→# struct PrecalcParams {\n    68→#     float poly6_coeff;           //  4 bytes\n    69→#     float spiky_grad_coeff;      //  4 bytes\n    70→#     float viscosity_lap_coeff;   //  4 bytes\n    71→#     float pressure_precalc;      //  4 bytes\n    72→#     float viscosity_precalc;     //  4 bytes\n    73→# };                               // Total: 20 bytes\n    74→PRECALC_PARAMS_DTYPE = np.dtype(\n    75→    [\n    76→        (\"poly6_coeff\", np.float32),\n    77→        (\"spiky_grad_coeff\", np.float32),\n    78→        (\"viscosity_lap_coeff\", np.float32),\n    79→        (\"pressure_precalc\", np.float32),\n    80→        (\"viscosity_precalc\", np.float32),\n    81→    ],\n    82→    align=False,\n    83→)\n    84→\n    85→\n    86→def build_sim_params(\n    87→    smoothing_length: float = 0.04,\n    88→    particle_mass: float = 0.008,\n    89→    particle_spacing: float = 0.02,\n    90→    gravity: tuple = (0.0, -9.8, 0.0),\n    91→    dt: float = 0.001,\n    92→    restitution: float = 0.3,\n    93→    wall_friction: float = 0.5,\n    94→    world_min: tuple = (-1.0, -1.0, -1.0),\n    95→    world_max: tuple = (1.0, 1.0, 1.0),\n    96→) -> np.ndarray:\n    97→    \"\"\"Build a single SimParams struct as a numpy structured array.\"\"\"\n    98→    params = np.zeros(1, dtype=SIM_PARAMS_DTYPE)\n    99→    params[0][\"smoothing_length\"] = smoothing_length\n   100→    params[0][\"smoothing_length_sq\"] = smoothing_length * smoothing_length\n   101→    params[0][\"particle_mass\"] = particle_mass\n   102→    params[0][\"particle_spacing\"] = particle_spacing\n   103→    params[0][\"gravity\"] = gravity\n   104→    params[0][\"dt\"] = dt\n   105→    params[0][\"restitution\"] = restitution\n   106→    params[0][\"wall_friction\"] = wall_friction\n   107→    params[0][\"world_min\"] = world_min\n   108→    params[0][\"world_max\"] = world_max\n   109→    return params\n   110→\n   111→\n   112→def build_precalc_params(\n   113→    smoothing_length: float = 0.04,\n   114→    viscosity: float = 0.001,\n   115→) -> np.ndarray:\n   116→    \"\"\"Build PrecalcParams from smoothing length.\n   117→\n   118→    Parameters\n   119→    ----------\n   120→    smoothing_length : float\n   121→        SPH smoothing length h.\n   122→    viscosity : float\n   123→        Base viscosity mu (Pa*s).\n   124→    \"\"\"\n   125→    h = smoothing_length\n   126→    params = np.zeros(1, dtype=PRECALC_PARAMS_DTYPE)\n   127→    params[0][\"poly6_coeff\"] = np.float32(315.0 / (64.0 * math.pi * h**9))\n   128→    params[0][\"spiky_grad_coeff\"] = np.float32(-45.0 / (math.pi * h**6))\n   129→    params[0][\"viscosity_lap_coeff\"] = np.float32(45.0 / (math.pi * h**6))\n   130→    params[0][\"pressure_precalc\"] = np.float32(45.0 / (math.pi * h**6))\n   131→    params[0][\"viscosity_precalc\"] = np.float32(viscosity * 45.0 / (math.pi * h**6))\n   132→    return params\n   133→\n   134→\n   135→# ---------------------------------------------------------------------------\n   136→# CuPy RawModule compilation\n   137→# ---------------------------------------------------------------------------\n   138→\n   139→_module: Optional[object] = None\n   140→\n   141→\n   142→def _ensure_ptx_if_needed() -> None:\n   143→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n   144→    from cupy.cuda import compiler as _compiler\n   145→    from cupy.cuda import device as _device\n   146→\n   147→    gpu_cc = _device.Device().compute_capability\n   148→    nvrtc_max = _compiler._get_max_compute_capability()\n   149→    if int(gpu_cc) > int(nvrtc_max):\n   150→        _compiler._use_ptx = True\n   151→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n   152→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n   153→        if hasattr(_compiler._get_arch, \"_cache\"):\n   154→            _compiler._get_arch._cache = {}\n   155→\n   156→\n   157→def _get_module() -> \"object\":\n   158→    \"\"\"Compile (or return cached) CuPy RawModule from step1.cu.\"\"\"\n   159→    global _module\n   160→    if _module is not None:\n   161→        return _module\n   162→\n   163→    _ensure_ptx_if_needed()\n   164→\n   165→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   166→    cu_path = os.path.join(kernel_dir, \"step1.cu\")\n   167→    with open(cu_path) as f:\n   168→        source = f.read()\n   169→\n   170→    _module = cupy.RawModule(\n   171→        code=source,\n   172→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n   173→    )\n   174→    return _module\n   175→\n   176→\n   177→def get_module() -> \"object\":\n   178→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n   179→    return _get_module()\n   180→\n   181→\n   182→# ---------------------------------------------------------------------------\n   183→# Constant memory upload\n   184→# ---------------------------------------------------------------------------\n   185→\n   186→\n   187→def upload_grid_params(params: np.ndarray) -> None:\n   188→    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\"\"\"\n   189→    module = _get_module()\n   190→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n   191→    cupy.cuda.runtime.memcpy(\n   192→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   193→    )\n   194→\n   195→\n   196→def upload_sim_params(params: Optional[np.ndarray] = None) -> None:\n   197→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n   198→    if params is None:\n   199→        params = build_sim_params()\n   200→    module = _get_module()\n   201→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n   202→    cupy.cuda.runtime.memcpy(\n   203→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   204→    )\n   205→\n   206→\n   207→def upload_precalc_params(params: Optional[np.ndarray] = None) -> None:\n   208→    \"\"\"Upload PrecalcParams to ``__constant__ PrecalcParams c_precalc``.\"\"\"\n   209→    if params is None:\n   210→        params = build_precalc_params()\n   211→    module = _get_module()\n   212→    d_ptr = module.get_global(\"c_precalc\")  # type: ignore[union-attr]\n   213→    cupy.cuda.runtime.memcpy(\n   214→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   215→    )\n   216→\n   217→\n   218→def upload_materials(materials_data: np.ndarray) -> None:\n   219→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n   220→    module = _get_module()\n   221→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n   222→    cupy.cuda.runtime.memcpy(\n   223→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n   224→    )\n   225→\n   226→\n   227→# --------
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LEjvJwPnE5irYAE1qJ8GPB","type":"tool_result","content":"     1→/*\n     2→ * step1.cu -- K_Step1 SPH density summation + strain-rate tensor + heat diffusion\n     3→ *             + exposure accumulation kernel.\n     4→ *\n     5→ * Per-particle computation:\n     6→ *   density_sum += m_j * (h^2 - |r_ij|^2)^3   for all neighbors j within h\n     7→ *   density_i = max(1.0, poly6_coeff * density_sum)\n     8→ *\n     9→ * Heat diffusion (all particles):\n    10→ *   dTdt += kappa_i * viscosity_lap_coeff * sum_j (m_j/rho_j) * (T_j - T_i) * (h - |r_ij|)\n    11→ *   where kappa_i = c_materials[mat_id].thermal_conductivity\n    12→ *\n    13→ * Exposure accumulation (all particles, via c_interactions table lookup):\n    14→ *   exposure_corrode_i += c_interactions[mat_i][mat_j].reaction_rate * W_poly6(r_sq, h_sq)\n    15→ *   exposure_heat_i += c_interactions[mat_i][mat_j].heat_exchange * max(T_j - T_i, 0) * W_poly6(r_sq, h_sq)\n    16→ *   No if/else branching on material type -- pure table lookup.\n    17→ *\n    18→ * For GRANULAR particles only, also computes the symmetric strain-rate tensor D\n    19→ * using the SPH velocity gradient with spiky gradient weighting:\n    20→ *   D_ab = 0.5 * sum_j (m_j/rho_j) * (dv_a * gradW_b + dv_b * gradW_a)\n    21→ * Then: gamma_dot = sqrt(2 * D:D) = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n    22→ *\n    23→ * Operates on SORTED particle arrays (after hash + sort + reorder).\n    24→ * Uses 27-cell neighbor iteration with grid cell_start/cell_end tables.\n    25→ * Self-interaction IS included for density (j==i NOT skipped).\n    26→ * Self-interaction is skipped for strain-rate, heat diffusion, and exposure (j==i skipped).\n    27→ * Per-particle mass m_j supports multi-material and mass splitting.\n    28→ *\n    29→ * Ported from SPHSimLib/K_SimpleSPH_Step1.inl + K_SPH_Kernels_poly6.inl.\n    30→ * Neighbor iteration ported from SPHSimLib/K_UniformGrid_Utils.inl.\n    31→ *\n    32→ * Constant memory (c_grid, c_sim, c_precalc, c_materials, c_interactions) declared in common.cuh.\n    33→ */\n    34→\n    35→#include \"common.cuh\"\n    36→\n    37→extern \"C\" __global__\n    38→void K_Step1(\n    39→    uint            numParticles,\n    40→    const float4*   __restrict__ position,      // sorted positions\n    41→    const float4*   __restrict__ velocity,      // sorted velocities (for strain-rate)\n    42→    const float*    __restrict__ mass,           // sorted per-particle mass\n    43→    const float*    __restrict__ density_in,     // sorted density from previous step (for strain-rate m_j/rho_j weighting; NULL on first frame)\n    44→    const uint*     __restrict__ packed_info,    // sorted packed_info (for behavior class check)\n    45→    const float*    __restrict__ temperature_in, // sorted temperature (for heat diffusion)\n    46→    const uint*     __restrict__ cell_start,     // grid cell start indices\n    47→    const uint*     __restrict__ cell_end,       // grid cell end indices\n    48→    float*          __restrict__ density_out,    // output: density per particle\n    49→    float*          __restrict__ shear_rate_out, // output: gamma_dot per particle (0 for non-GRANULAR)\n    50→    float*          __restrict__ dTdt_out,       // output: temperature rate of change (heat diffusion)\n    51→    float*          __restrict__ exposure_heat_out,    // output: heat exposure from interactions\n    52→    float*          __restrict__ exposure_corrode_out  // output: corrosion exposure from interactions\n    53→) {\n    54→    uint index_i = blockIdx.x * blockDim.x + threadIdx.x;\n    55→    if (index_i >= numParticles) return;\n    56→\n    57→    // Read position of particle i\n    58→    float4 pos4_i = position[index_i];\n    59→    float3 pos_i = make_float3(pos4_i.x, pos4_i.y, pos4_i.z);\n    60→\n    61→    float h    = c_sim.smoothing_length;\n    62→    float h_sq = c_sim.smoothing_length_sq;\n    63→\n    64→    // Check if this particle is GRANULAR\n    65→    uint pi_i = __ldg(&packed_info[index_i]);\n    66→    int behavior_i = GET_BEHAVIOR(pi_i);\n    67→    uint mat_id_i = GET_MATERIAL_ID(pi_i);\n    68→    bool is_granular = (behavior_i == GRANULAR);\n    69→\n    70→    // Read velocity for strain-rate (only used if GRANULAR, but cheap to read)\n    71→    float3 vel_i;\n    72→    if (is_granular) {\n    73→        float4 vel4_i = velocity[index_i];\n    74→        vel_i = make_float3(vel4_i.x, vel4_i.y, vel4_i.z);\n    75→    }\n    76→\n    77→    // Read temperature for heat diffusion\n    78→    float T_i = __ldg(&temperature_in[index_i]);\n    79→    float kappa_i = c_materials[mat_id_i].thermal_conductivity;\n    80→\n    81→    // Density accumulator (variable part of Poly6 kernel)\n    82→    float sum_density = 0.0f;\n    83→\n    84→    // Heat diffusion accumulator: dTdt\n    85→    float sum_dTdt = 0.0f;\n    86→\n    87→    // Exposure accumulators (from c_interactions table lookup)\n    88→    float sum_exposure_heat = 0.0f;\n    89→    float sum_exposure_corrode = 0.0f;\n    90→\n    91→    // Strain-rate tensor accumulators (6 symmetric components)\n    92→    // D_xx, D_yy, D_zz, D_xy, D_xz, D_yz\n    93→    float Dxx = 0.0f, Dyy = 0.0f, Dzz = 0.0f;\n    94→    float Dxy = 0.0f, Dxz = 0.0f, Dyz = 0.0f;\n    95→\n    96→    // Grid cell of particle i\n    97→    int3 cell_i = make_int3(\n    98→        (int)((pos_i.x - c_grid.grid_min.x) * c_grid.grid_delta.x),\n    99→        (int)((pos_i.y - c_grid.grid_min.y) * c_grid.grid_delta.y),\n   100→        (int)((pos_i.z - c_grid.grid_min.z) * c_grid.grid_delta.z)\n   101→    );\n   102→    // Clamp to valid range\n   103→    cell_i.x = max(0, min(cell_i.x, c_grid.grid_res.x - 1));\n   104→    cell_i.y = max(0, min(cell_i.y, c_grid.grid_res.y - 1));\n   105→    cell_i.z = max(0, min(cell_i.z, c_grid.grid_res.z - 1));\n   106→\n   107→    int rx = c_grid.grid_res.x;\n   108→    int ry = c_grid.grid_res.y;\n   109→    int rz = c_grid.grid_res.z;\n   110→\n   111→    // Iterate 27 neighbor cells\n   112→    for (int dz = -1; dz <= 1; dz++) {\n   113→        int cz = cell_i.z + dz;\n   114→        if (cz < 0 || cz >= rz) continue;\n   115→        for (int dy = -1; dy <= 1; dy++) {\n   116→            int cy = cell_i.y + dy;\n   117→            if (cy < 0 || cy >= ry) continue;\n   118→            for (int dx = -1; dx <= 1; dx++) {\n   119→                int cx = cell_i.x + dx;\n   120→                if (cx < 0 || cx >= rx) continue;\n   121→\n   122→                uint hash = (uint)(cz * ry * rx + cy * rx + cx);\n   123→                uint start = cell_start[hash];\n   124→\n   125→                // Empty cell sentinel\n   126→                if (start == 0xFFFFFFFFu) continue;\n   127→                uint end_idx = cell_end[hash];\n   128→\n   129→                for (uint index_j = start; index_j < end_idx; index_j++) {\n   130→                    float4 pos4_j = __ldg(&position[index_j]);\n   131→                    float3 r = make_float3(\n   132→                        pos_i.x - pos4_j.x,\n   133→                        pos_i.y - pos4_j.y,\n   134→                        pos_i.z - pos4_j.z\n   135→                    );\n   136→                    float r_sq = r.x * r.x + r.y * r.y + r.z * r.z;\n   137→\n   138→                    if (r_sq <= h_sq) {\n   139→                        // --- Density: self-interaction included ---\n   140→                        float diff = h_sq - r_sq;\n   141→                        float m_j = __ldg(&mass[index_j]);\n   142→                        sum_density += m_j * diff * diff * diff;\n   143→\n   144→                        // --- Heat diffusion + exposure: skip self ---\n   145→                        if (index_j != index_i) {\n   146→                            float rlen = sqrtf(r_sq);\n   147→                            float T_j = __ldg(&temperature_in[index_j]);\n   148→                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n   149→                            // SPH Laplacian of temperature using viscosity Laplacian kernel:\n   150→                            // lap_W_visc(r) = (h - |r|)  (variable part, coeff is viscosity_lap_coeff)\n   151→                            // dTdt += kappa * (m_j / rho_j) * (T_j - T_i) * viscosity_lap_coeff * (h - |r|)\n   152→                            float lap_var = h - rlen;\n   153→                            sum_dTdt += m_j / fmaxf(rho_j, 1.0f) * (T_j - T_i) * lap_var;\n   154→\n   155→                            // --- Exposure accumulation: pure table lookup, no branching ---\n   156→                            // W_poly6 variable part: diff^3 = (h^2 - r^2)^3\n   157→                            // Full W_poly6 = poly6_coeff * diff^3, but we use just diff^3\n   158→                            // as the weighting (unnormalized) -- the absolute magnitude\n   159→                            // is tuned via reaction_rate/heat_exchange in the table.\n   160→                            uint pi_j = __ldg(&packed_info[index_j]);\n   161→                            uint mat_id_j = GET_MATERIAL_ID(pi_j);\n   162→                            float w_poly6_var = diff * diff * diff;  // (h^2 - r^2)^3\n   163→\n   164→                            sum_exposure_corrode += c_interactions[mat_id_i][mat_id_j].reaction_rate * w_poly6_var;\n   165→                            sum_exposure_heat += c_interactions[mat_id_i][mat_id_j].heat_exchange * fmaxf(T_j - T_i, 0.0f) * w_poly6_var;\n   166→                        }\n   167→\n   168→                        // --- Strain-rate: skip self, GRANULAR only ---\n   169→                        if (is_granular && index_j != index_i && r_sq > 1e-12f) {\n   170→                            float rlen = sqrtf(r_sq);\n   171→\n   172→                            // Spiky gradient: gradW = spiky_grad_coeff * (h - r)^2 * (r/|r|)\n   173→                            // spiky_grad_coeff is negative (-45/(pi*h^6))\n   174→                            // We need the actual gradient vector pointing from j to i\n   175→                            float h_r = h - rlen;\n   176→                            float inv_rlen = 1.0f / rlen;\n   177→                            // gradW = spiky_grad_coeff * (h-r)^2 * r_hat\n   178→                            // where r_hat = r/|r| points from j to i\n   179→                            float grad_scalar = c_precalc.spiky_grad_coeff * h_r * h_r * inv_rlen;\n   180→                            float gWx = grad_scalar * r.x;\n   181→                            float gWy = grad_scalar * r.y;\n   182→                            float gWz = grad_scalar * r.z;\n   183→\n   184→                            // dv = v_i - v_j\n   185→                            float4 vel4_j = __ldg(&velocity[index_j]);\n   186→                            float dvx = vel_i.x - vel4_j.x;\n   187→                            float dvy = vel_i.y - vel4_j.y;\n   188→                            float dvz = vel_i.z - vel4_j.z;\n   189→\n   190→                            // m_j / rho_j weighting\n   191→                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n   192→                            float weight = m_j / fmaxf(rho_j, 1.0f);\n   193→\n   194→                            // Accumulate velocity gradient tensor L_ab = sum (m_j/rho_j) * dv_a * gradW_b\n   195→                            // D_ab = 0.5 * (L_ab + L_ba)\n   196→                            // Since we compute D directly:\n   197→                            //   D_xx += weight * dv_x * gW_x\n   198→                            //   D_yy += weight * dv_y * gW_y\n   199→                            //   D_zz += weight * dv_z * gW_z\n   200→                            //   D_xy += 0.5 * weight * (dv_x * gW_y + dv_y * gW_x)\n   201→                            //   D_xz += 0.5 * weight * (dv_x * gW_z + dv_z * gW_x)\n   202→                            //   D_yz += 0.5 * weight * (dv_y * gW_z + dv_z * gW_y)\n   203→                            Dxx += weight * dvx * gWx;\n   204→                            Dyy += weight * dvy * gWy;\n   205→                            Dzz += weight * dvz * gWz;\n   206→                            Dxy += 0.5f * weight * (dvx * gWy + dvy * gWx);\n   207→                            Dxz += 0.5f * weight * (dvx * gWz + dvz * gWx);\n   208→                            Dyz += 0.5f * weight * (dvy * gWz + dvz * gWy);\n   209→                        }\n   210→                    }\n   211→                }\n   212→            }\n   213→        }\n   214→    }\n   215→\n   216→    // --- PostCalc: density ---\n   217→    float density = c_precalc.poly6_coeff * sum_density;\n   218→    density_out[index_i] = fmaxf(density, 1.0f);\n   219→\n   220→    // --- PostCalc: heat diffusion dTdt ---\n   221→    // dTdt = kappa_i * viscosity_lap_coeff * sum_dTdt\n   222→    dTdt_out[index_i] = kappa_i * c_precalc.viscosity_lap_coeff * sum_dTdt;\n   223→\n   224→    // --- PostCalc: exposure accumulation ---\n   225→    // Apply poly6_coeff to get properly normalized exposure values\n   226→    exposure_heat_out[index_i] = c_precalc.poly6_coeff * sum_exposure_heat;\n   227→    exposure_corrode_out[index_i] = c_precalc.poly6_coeff * sum_exposure_corrode;\n   228→\n   229→    // --- PostCalc: strain-rate magnitude (gamma_dot) ---\n   230→    if (is_granular) {\n   231→        // gamma_dot = sqrt(2 * D:D)\n   232→        //           = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n   233→        float D_sq = Dxx * Dxx + Dyy * Dyy + Dzz * Dzz\n   234→                   + 2.0f * (Dxy * Dxy + Dxz * Dxz + Dyz * Dyz);\n   235→        float gamma_dot = sqrtf(fmaxf(2.0f * D_sq, 0.0f));\n   236→        shear_rate_out[index_i] = gamma_dot;\n   237→    } else {\n   238→        shear_rate_out[index_i] = 0.0f;\n   239→    }\n   240→}\n   241→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"40989a4b-7ef9-4e02-8a7d-030d3ce20abf","uuid":"73f73cf8-3269-4b60-8d32-ef12f9680863","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/physics/kernels/step1.cu","content":"/*\n * step1.cu -- K_Step1 SPH density summation + strain-rate tensor + heat diffusion\n *             + exposure accumulation kernel.\n *\n * Per-particle computation:\n *   density_sum += m_j * (h^2 - |r_ij|^2)^3   for all neighbors j within h\n *   density_i = max(1.0, poly6_coeff * density_sum)\n *\n * Heat diffusion (all particles):\n *   dTdt += kappa_i * viscosity_lap_coeff * sum_j (m_j/rho_j) * (T_j - T_i) * (h - |r_ij|)\n *   where kappa_i = c_materials[mat_id].thermal_conductivity\n *\n * Exposure accumulation (all particles, via c_interactions table lookup):\n *   exposure_corrode_i += c_interactions[mat_i][mat_j].reaction_rate * W_poly6(r_sq, h_sq)\n *   exposure_heat_i += c_interactions[mat_i][mat_j].heat_exchange * max(T_j - T_i, 0) * W_poly6(r_sq, h_sq)\n *   No if/else branching on material type -- pure table lookup.\n *\n * For GRANULAR particles only, also computes the symmetric strain-rate tensor D\n * using the SPH velocity gradient with spiky gradient weighting:\n *   D_ab = 0.5 * sum_j (m_j/rho_j) * (dv_a * gradW_b + dv_b * gradW_a)\n * Then: gamma_dot = sqrt(2 * D:D) = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n *\n * Operates on SORTED particle arrays (after hash + sort + reorder).\n * Uses 27-cell neighbor iteration with grid cell_start/cell_end tables.\n * Self-interaction IS included for density (j==i NOT skipped).\n * Self-interaction is skipped for strain-rate, heat diffusion, and exposure (j==i skipped).\n * Per-particle mass m_j supports multi-material and mass splitting.\n *\n * Ported from SPHSimLib/K_SimpleSPH_Step1.inl + K_SPH_Kernels_poly6.inl.\n * Neighbor iteration ported from SPHSimLib/K_UniformGrid_Utils.inl.\n *\n * Constant memory (c_grid, c_sim, c_precalc, c_materials, c_interactions) declared in common.cuh.\n */\n\n#include \"common.cuh\"\n\nextern \"C\" __global__\nvoid K_Step1(\n    uint            numParticles,\n    const float4*   __restrict__ position,      // sorted positions\n    const float4*   __restrict__ velocity,      // sorted velocities (for strain-rate)\n    const float*    __restrict__ mass,           // sorted per-particle mass\n    const float*    __restrict__ density_in,     // sorted density from previous step (for strain-rate m_j/rho_j weighting; NULL on first frame)\n    const uint*     __restrict__ packed_info,    // sorted packed_info (for behavior class check)\n    const float*    __restrict__ temperature_in, // sorted temperature (for heat diffusion)\n    const uint*     __restrict__ cell_start,     // grid cell start indices\n    const uint*     __restrict__ cell_end,       // grid cell end indices\n    float*          __restrict__ density_out,    // output: density per particle\n    float*          __restrict__ shear_rate_out, // output: gamma_dot per particle (0 for non-GRANULAR)\n    float*          __restrict__ dTdt_out,       // output: temperature rate of change (heat diffusion)\n    float*          __restrict__ exposure_heat_out,    // output: heat exposure from interactions\n    float*          __restrict__ exposure_corrode_out  // output: corrosion exposure from interactions\n) {\n    uint index_i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (index_i >= numParticles) return;\n\n    // Read position of particle i\n    float4 pos4_i = position[index_i];\n    float3 pos_i = make_float3(pos4_i.x, pos4_i.y, pos4_i.z);\n\n    float h    = c_sim.smoothing_length;\n    float h_sq = c_sim.smoothing_length_sq;\n\n    // Check if this particle is GRANULAR\n    uint pi_i = __ldg(&packed_info[index_i]);\n    int behavior_i = GET_BEHAVIOR(pi_i);\n    uint mat_id_i = GET_MATERIAL_ID(pi_i);\n    bool is_granular = (behavior_i == GRANULAR);\n\n    // Read velocity for strain-rate (only used if GRANULAR, but cheap to read)\n    float3 vel_i;\n    if (is_granular) {\n        float4 vel4_i = velocity[index_i];\n        vel_i = make_float3(vel4_i.x, vel4_i.y, vel4_i.z);\n    }\n\n    // Read temperature for heat diffusion\n    float T_i = __ldg(&temperature_in[index_i]);\n    float kappa_i = c_materials[mat_id_i].thermal_conductivity;\n\n    // Density accumulator (variable part of Poly6 kernel)\n    float sum_density = 0.0f;\n\n    // Heat diffusion accumulator: dTdt\n    float sum_dTdt = 0.0f;\n\n    // Exposure accumulators (from c_interactions table lookup)\n    float sum_exposure_heat = 0.0f;\n    float sum_exposure_corrode = 0.0f;\n\n    // Strain-rate tensor accumulators (6 symmetric components)\n    // D_xx, D_yy, D_zz, D_xy, D_xz, D_yz\n    float Dxx = 0.0f, Dyy = 0.0f, Dzz = 0.0f;\n    float Dxy = 0.0f, Dxz = 0.0f, Dyz = 0.0f;\n\n    // Grid cell of particle i\n    int3 cell_i = make_int3(\n        (int)((pos_i.x - c_grid.grid_min.x) * c_grid.grid_delta.x),\n        (int)((pos_i.y - c_grid.grid_min.y) * c_grid.grid_delta.y),\n        (int)((pos_i.z - c_grid.grid_min.z) * c_grid.grid_delta.z)\n    );\n    // Clamp to valid range\n    cell_i.x = max(0, min(cell_i.x, c_grid.grid_res.x - 1));\n    cell_i.y = max(0, min(cell_i.y, c_grid.grid_res.y - 1));\n    cell_i.z = max(0, min(cell_i.z, c_grid.grid_res.z - 1));\n\n    int rx = c_grid.grid_res.x;\n    int ry = c_grid.grid_res.y;\n    int rz = c_grid.grid_res.z;\n\n    // Iterate 27 neighbor cells\n    for (int dz = -1; dz <= 1; dz++) {\n        int cz = cell_i.z + dz;\n        if (cz < 0 || cz >= rz) continue;\n        for (int dy = -1; dy <= 1; dy++) {\n            int cy = cell_i.y + dy;\n            if (cy < 0 || cy >= ry) continue;\n            for (int dx = -1; dx <= 1; dx++) {\n                int cx = cell_i.x + dx;\n                if (cx < 0 || cx >= rx) continue;\n\n                uint hash = (uint)(cz * ry * rx + cy * rx + cx);\n                uint start = cell_start[hash];\n\n                // Empty cell sentinel\n                if (start == 0xFFFFFFFFu) continue;\n                uint end_idx = cell_end[hash];\n\n                for (uint index_j = start; index_j < end_idx; index_j++) {\n                    float4 pos4_j = __ldg(&position[index_j]);\n                    float3 r = make_float3(\n                        pos_i.x - pos4_j.x,\n                        pos_i.y - pos4_j.y,\n                        pos_i.z - pos4_j.z\n                    );\n                    float r_sq = r.x * r.x + r.y * r.y + r.z * r.z;\n\n                    if (r_sq <= h_sq) {\n                        // --- Density: self-interaction included ---\n                        float diff = h_sq - r_sq;\n                        float m_j = __ldg(&mass[index_j]);\n                        sum_density += m_j * diff * diff * diff;\n\n                        // --- Heat diffusion + exposure: skip self ---\n                        if (index_j != index_i) {\n                            float rlen = sqrtf(r_sq);\n                            float T_j = __ldg(&temperature_in[index_j]);\n                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n                            // SPH Laplacian of temperature using viscosity Laplacian kernel:\n                            // lap_W_visc(r) = (h - |r|)  (variable part, coeff is viscosity_lap_coeff)\n                            // dTdt += kappa * (m_j / rho_j) * (T_j - T_i) * viscosity_lap_coeff * (h - |r|)\n                            float lap_var = h - rlen;\n                            sum_dTdt += m_j / fmaxf(rho_j, 1.0f) * (T_j - T_i) * lap_var;\n\n                            // --- Exposure accumulation: pure table lookup, no branching ---\n                            // W_poly6 variable part: diff^3 = (h^2 - r^2)^3\n                            // Full W_poly6 = poly6_coeff * diff^3, but we use just diff^3\n                            // as the weighting (unnormalized) -- the absolute magnitude\n                            // is tuned via reaction_rate/heat_exchange in the table.\n                            uint pi_j = __ldg(&packed_info[index_j]);\n                            uint mat_id_j = GET_MATERIAL_ID(pi_j);\n                            float w_poly6_var = diff * diff * diff;  // (h^2 - r^2)^3\n\n                            sum_exposure_corrode += c_interactions[mat_id_i][mat_id_j].reaction_rate * w_poly6_var;\n                            sum_exposure_heat += c_interactions[mat_id_i][mat_id_j].heat_exchange * fmaxf(T_j - T_i, 0.0f) * w_poly6_var;\n                        }\n\n                        // --- Strain-rate: skip self, GRANULAR only ---\n                        if (is_granular && index_j != index_i && r_sq > 1e-12f) {\n                            float rlen = sqrtf(r_sq);\n\n                            // Spiky gradient: gradW = spiky_grad_coeff * (h - r)^2 * (r/|r|)\n                            // spiky_grad_coeff is negative (-45/(pi*h^6))\n                            // We need the actual gradient vector pointing from j to i\n                            float h_r = h - rlen;\n                            float inv_rlen = 1.0f / rlen;\n                            // gradW = spiky_grad_coeff * (h-r)^2 * r_hat\n                            // where r_hat = r/|r| points from j to i\n                            float grad_scalar = c_precalc.spiky_grad_coeff * h_r * h_r * inv_rlen;\n                            float gWx = grad_scalar * r.x;\n                            float gWy = grad_scalar * r.y;\n                            float gWz = grad_scalar * r.z;\n\n                            // dv = v_i - v_j\n                            float4 vel4_j = __ldg(&velocity[index_j]);\n                            float dvx = vel_i.x - vel4_j.x;\n                            float dvy = vel_i.y - vel4_j.y;\n                            float dvz = vel_i.z - vel4_j.z;\n\n                            // m_j / rho_j weighting\n                            float rho_j = (density_in != 0) ? __ldg(&density_in[index_j]) : 1000.0f;\n                            float weight = m_j / fmaxf(rho_j, 1.0f);\n\n                            // Accumulate velocity gradient tensor L_ab = sum (m_j/rho_j) * dv_a * gradW_b\n                            // D_ab = 0.5 * (L_ab + L_ba)\n                            // Since we compute D directly:\n                            //   D_xx += weight * dv_x * gW_x\n                            //   D_yy += weight * dv_y * gW_y\n                            //   D_zz += weight * dv_z * gW_z\n                            //   D_xy += 0.5 * weight * (dv_x * gW_y + dv_y * gW_x)\n                            //   D_xz += 0.5 * weight * (dv_x * gW_z + dv_z * gW_x)\n                            //   D_yz += 0.5 * weight * (dv_y * gW_z + dv_z * gW_y)\n                            Dxx += weight * dvx * gWx;\n                            Dyy += weight * dvy * gWy;\n                            Dzz += weight * dvz * gWz;\n                            Dxy += 0.5f * weight * (dvx * gWy + dvy * gWx);\n                            Dxz += 0.5f * weight * (dvx * gWz + dvz * gWx);\n                            Dyz += 0.5f * weight * (dvy * gWz + dvz * gWy);\n                        }\n                    }\n                }\n            }\n        }\n    }\n\n    // --- PostCalc: density ---\n    float density = c_precalc.poly6_coeff * sum_density;\n    density_out[index_i] = fmaxf(density, 1.0f);\n\n    // --- PostCalc: heat diffusion dTdt ---\n    // dTdt = kappa_i * viscosity_lap_coeff * sum_dTdt\n    dTdt_out[index_i] = kappa_i * c_precalc.viscosity_lap_coeff * sum_dTdt;\n\n    // --- PostCalc: exposure accumulation ---\n    // Apply poly6_coeff to get properly normalized exposure values\n    exposure_heat_out[index_i] = c_precalc.poly6_coeff * sum_exposure_heat;\n    exposure_corrode_out[index_i] = c_precalc.poly6_coeff * sum_exposure_corrode;\n\n    // --- PostCalc: strain-rate magnitude (gamma_dot) ---\n    if (is_granular) {\n        // gamma_dot = sqrt(2 * D:D)\n        //           = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))\n        float D_sq = Dxx * Dxx + Dyy * Dyy + Dzz * Dzz\n                   + 2.0f * (Dxy * Dxy + Dxz * Dxz + Dyz * Dyz);\n        float gamma_dot = sqrtf(fmaxf(2.0f * D_sq, 0.0f));\n        shear_rate_out[index_i] = gamma_dot;\n    } else {\n        shear_rate_out[index_i] = 0.0f;\n    }\n}\n","numLines":241,"startLine":1,"totalLines":241}}}

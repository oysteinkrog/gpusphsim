{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AFHB2Y95uc3yvgfFBC9FxM","type":"tool_result","content":"     1→\"\"\"Integration test for build_grid.py -- K_BuildDataStruct kernel.\n     2→\n     3→Acceptance criteria:\n     4→  - K_BuildDataStruct writes cell_indexes_start[hash] = first particle index\n     5→  - K_BuildDataStruct writes cell_indexes_end[hash] = one past last particle index\n     6→  - Empty cells have cell_indexes_start = 0xFFFFFFFF\n     7→  - cell_indexes_start and cell_indexes_end allocated as CuPy uint32 arrays of\n     8→    size num_cells (125000)\n     9→  - cell_indexes_start memset to 0xFFFFFFFF before each frame's kernel launch\n    10→  - Test: for a known configuration (8 particles in 2 cells), cell_start/end correct\n    11→  - Test: sum of (cell_end - cell_start) across all non-empty cells equals num_particles\n    12→  - Kernel runs without errors for 500K particles\n    13→  - Block size = 256\n    14→\n    15→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    16→\"\"\"\n    17→\n    18→from __future__ import annotations\n    19→\n    20→import cupy  # type: ignore[import-untyped]\n    21→import numpy as np\n    22→\n    23→from hash_sort import (\n    24→    NUM_CELLS,\n    25→    calc_hash,\n    26→    upload_grid_params as upload_hash_grid_params,\n    27→)\n    28→from build_grid import (\n    29→    BLOCK_SIZE,\n    30→    EMPTY_CELL,\n    31→    allocate_cell_tables,\n    32→    build_data_struct,\n    33→    get_module,\n    34→    upload_grid_params,\n    35→)\n    36→\n    37→\n    38→def _sort_by_hash(\n    39→    hashes: cupy.ndarray, indices: cupy.ndarray\n    40→) -> tuple[cupy.ndarray, cupy.ndarray]:\n    41→    \"\"\"Sort hashes and indices by hash value (radix sort placeholder).\"\"\"\n    42→    order = cupy.argsort(hashes)\n    43→    return hashes[order], indices[order]\n    44→\n    45→\n    46→def test_compilation() -> None:\n    47→    \"\"\"Verify CuPy RawModule compiles build_grid.cu.\"\"\"\n    48→    print(\"--- Compilation check ---\")\n    49→\n    50→    module = get_module()\n    51→    assert module is not None\n    52→    print(\"[OK] CuPy RawModule compiled build_grid.cu (includes common.cuh)\")\n    53→\n    54→    kernel = module.get_function(\"K_BuildDataStruct\")  # type: ignore[union-attr]\n    55→    assert kernel is not None\n    56→    print(\"[OK] K_BuildDataStruct kernel function found\")\n    57→\n    58→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n    59→    assert int(d_ptr) != 0\n    60→    print(\"[OK] c_grid constant memory symbol found\")\n    61→\n    62→\n    63→def test_allocation() -> None:\n    64→    \"\"\"Verify cell table allocation dimensions and dtype.\"\"\"\n    65→    print(\"\\n--- Allocation check ---\")\n    66→\n    67→    cell_start, cell_end = allocate_cell_tables()\n    68→    assert cell_start.shape == (NUM_CELLS,), f\"shape {cell_start.shape}\"\n    69→    assert cell_end.shape == (NUM_CELLS,), f\"shape {cell_end.shape}\"\n    70→    assert cell_start.dtype == cupy.uint32\n    71→    assert cell_end.dtype == cupy.uint32\n    72→    print(f\"[OK] cell_start/end: shape=({NUM_CELLS},), dtype=uint32\")\n    73→\n    74→\n    75→def test_block_size() -> None:\n    76→    \"\"\"Verify block size is 256.\"\"\"\n    77→    print(\"\\n--- Block size check ---\")\n    78→    assert BLOCK_SIZE == 256, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 256\"\n    79→    print(\"[OK] BLOCK_SIZE = 256\")\n    80→\n    81→\n    82→def test_empty_cells_sentinel() -> None:\n    83→    \"\"\"With zero particles all cells should remain 0xFFFFFFFF.\"\"\"\n    84→    print(\"\\n--- Empty cells sentinel test ---\")\n    85→\n    86→    # Create a sorted_hashes array with zero particles -- edge case.\n    87→    # Instead, use 1 particle in cell 0 so remaining cells are empty.\n    88→    sorted_hashes = cupy.array([0], dtype=cupy.uint32)\n    89→    cell_start, cell_end = build_data_struct(sorted_hashes)\n    90→    cupy.cuda.Device().synchronize()\n    91→\n    92→    h_start = cupy.asnumpy(cell_start)\n    93→    h_end = cupy.asnumpy(cell_end)\n    94→\n    95→    # Cell 0 should be occupied: start=0, end=1\n    96→    assert h_start[0] == 0, f\"cell_start[0] = {h_start[0]}, expected 0\"\n    97→    assert h_end[0] == 1, f\"cell_end[0] = {h_end[0]}, expected 1\"\n    98→    print(\"[OK] Cell 0: start=0, end=1\")\n    99→\n   100→    # All other cells should have 0xFFFFFFFF sentinel\n   101→    empty_mask = h_start[1:] == EMPTY_CELL\n   102→    assert empty_mask.all(), (\n   103→        f\"Not all empty cells have sentinel: \"\n   104→        f\"{np.sum(~empty_mask)} cells have non-sentinel values\"\n   105→    )\n   106→    print(f\"[OK] All {NUM_CELLS - 1} other cells have start = 0xFFFFFFFF\")\n   107→\n   108→\n   109→def test_known_8_particles_2_cells() -> None:\n   110→    \"\"\"8 particles in 2 cells: verify exact cell_start/end values.\"\"\"\n   111→    print(\"\\n--- Known configuration: 8 particles in 2 cells ---\")\n   112→\n   113→    # 5 particles in cell hash=10, 3 particles in cell hash=42.\n   114→    # Sorted hashes: [10, 10, 10, 10, 10, 42, 42, 42]\n   115→    sorted_hashes = cupy.array(\n   116→        [10, 10, 10, 10, 10, 42, 42, 42], dtype=cupy.uint32\n   117→    )\n   118→\n   119→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   120→    cupy.cuda.Device().synchronize()\n   121→\n   122→    h_start = cupy.asnumpy(cell_start)\n   123→    h_end = cupy.asnumpy(cell_end)\n   124→\n   125→    # Cell 10: particles 0..4\n   126→    assert h_start[10] == 0, f\"cell_start[10] = {h_start[10]}, expected 0\"\n   127→    assert h_end[10] == 5, f\"cell_end[10] = {h_end[10]}, expected 5\"\n   128→    print(\"[OK] Cell 10: start=0, end=5 (5 particles)\")\n   129→\n   130→    # Cell 42: particles 5..7\n   131→    assert h_start[42] == 5, f\"cell_start[42] = {h_start[42]}, expected 5\"\n   132→    assert h_end[42] == 8, f\"cell_end[42] = {h_end[42]}, expected 8\"\n   133→    print(\"[OK] Cell 42: start=5, end=8 (3 particles)\")\n   134→\n   135→    # All other cells empty\n   136→    for c in [0, 1, 9, 11, 41, 43, 100, NUM_CELLS - 1]:\n   137→        assert h_start[c] == EMPTY_CELL, (\n   138→            f\"cell_start[{c}] = {h_start[c]}, expected 0xFFFFFFFF\"\n   139→        )\n   140→    print(\"[OK] All other sampled cells have start = 0xFFFFFFFF\")\n   141→\n   142→\n   143→def test_sum_equals_num_particles() -> None:\n   144→    \"\"\"Sum of (cell_end - cell_start) over non-empty cells equals num_particles.\"\"\"\n   145→    print(\"\\n--- Particle count consistency test ---\")\n   146→\n   147→    upload_grid_params()\n   148→    upload_hash_grid_params()\n   149→\n   150→    rng = np.random.default_rng(99)\n   151→    n = 10_000\n   152→    pos_np = np.zeros((n, 4), dtype=np.float32)\n   153→    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n   154→    pos_gpu = cupy.asarray(pos_np)\n   155→\n   156→    hashes, indices = calc_hash(pos_gpu)\n   157→    sorted_hashes, sorted_indices = _sort_by_hash(hashes, indices)\n   158→\n   159→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   160→    cupy.cuda.Device().synchronize()\n   161→\n   162→    h_start = cupy.asnumpy(cell_start)\n   163→    h_end = cupy.asnumpy(cell_end)\n   164→\n   165→    # Non-empty cells\n   166→    non_empty = h_start != EMPTY_CELL\n   167→    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n   168→\n   169→    assert total == n, f\"Sum of (end - start) = {total}, expected {n}\"\n   170→    print(f\"[OK] Sum of (cell_end - cell_start) across {np.sum(non_empty)} \"\n   171→          f\"non-empty cells = {total} == {n} particles\")\n   172→\n   173→\n   174→def test_cell_boundaries_match_sorted_hashes() -> None:\n   175→    \"\"\"Verify cell_start/end indices point to correct hash values.\"\"\"\n   176→    print(\"\\n--- Cell boundary validation test ---\")\n   177→\n   178→    upload_grid_params()\n   179→    upload_hash_grid_params()\n   180→\n   181→    rng = np.random.default_rng(77)\n   182→    n = 5_000\n   183→    pos_np = np.zeros((n, 4), dtype=np.float32)\n   184→    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n   185→    pos_gpu = cupy.asarray(pos_np)\n   186→\n   187→    hashes, indices = calc_hash(pos_gpu)\n   188→    sorted_hashes, sorted_indices = _sort_by_hash(hashes, indices)\n   189→\n   190→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   191→    cupy.cuda.Device().synchronize()\n   192→\n   193→    h_start = cupy.asnumpy(cell_start)\n   194→    h_end = cupy.asnumpy(cell_end)\n   195→    h_sorted = cupy.asnumpy(sorted_hashes)\n   196→\n   197→    # For each non-empty cell, check the sorted hash at start/end indices\n   198→    non_empty_cells = np.where(h_start != EMPTY_CELL)[0]\n   199→    for cell_hash in non_empty_cells:\n   200→        s = h_start[cell_hash]\n   201→        e = h_end[cell_hash]\n   202→        # All hashes in [s, e) should equal cell_hash\n   203→        assert np.all(h_sorted[s:e] == cell_hash), (\n   204→            f\"Cell {cell_hash}: hashes in [{s},{e}) are not all {cell_hash}\"\n   205→        )\n   206→        # hash before start (if any) should be different\n   207→        if s > 0:\n   208→            assert h_sorted[s - 1] != cell_hash, (\n   209→                f\"Cell {cell_hash}: hash at {s-1} is still {cell_hash}\"\n   210→            )\n   211→        # hash after end (if any) should be different\n   212→        if e < n:\n   213→            assert h_sorted[e] != cell_hash, (\n   214→                f\"Cell {cell_hash}: hash at {e} is still {cell_hash}\"\n   215→            )\n   216→\n   217→    print(f\"[OK] All {len(non_empty_cells)} non-empty cells have correct boundaries\")\n   218→\n   219→\n   220→def test_memset_between_frames() -> None:\n   221→    \"\"\"Calling build_data_struct twice resets cell_start properly.\"\"\"\n   222→    print(\"\\n--- Memset between frames test ---\")\n   223→\n   224→    # Frame 1: particles in cells 10 and 20\n   225→    sorted_hashes_1 = cupy.array(\n   226→        [10, 10, 10, 20, 20], dtype=cupy.uint32\n   227→    )\n   228→    cell_start, cell_end = allocate_cell_tables()\n   229→    build_data_struct(sorted_hashes_1, cell_start, cell_end)\n   230→    cupy.cuda.Device().synchronize()\n   231→\n   232→    h_start_1 = cupy.asnumpy(cell_start)\n   233→    assert h_start_1[10] == 0\n   234→    assert h_start_1[20] == 3\n   235→\n   236→    # Frame 2: particles only in cell 30 (cells 10, 20 should reset to empty)\n   237→    sorted_hashes_2 = cupy.array([30, 30, 30, 30], dtype=cupy.uint32)\n   238→    build_data_struct(sorted_hashes_2, cell_start, cell_end)\n   239→    cupy.cuda.Device().synchronize()\n   240→\n   241→    h_start_2 = cupy.asnumpy(cell_start)\n   242→    assert h_start_2[10] == EMPTY_CELL, (\n   243→        f\"Cell 10 not reset: {h_start_2[10]}\"\n   244→    )\n   245→    assert h_start_2[20] == EMPTY_CELL, (\n   246→        f\"Cell 20 not reset: {h_start_2[20]}\"\n   247→    )\n   248→    assert h_start_2[30] == 0\n   249→    print(\"[OK] cell_start properly reset between frames via memset\")\n   250→\n   251→\n   252→def test_500k_no_errors() -> None:\n   253→    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n   254→    print(\"\\n--- 500K particle stress test ---\")\n   255→\n   256→    upload_grid_params()\n   257→    upload_hash_grid_params()\n   258→\n   259→    rng = np.random.default_rng(123)\n   260→    n = 500_000\n   261→    pos_np = np.zeros((n, 4), dtype=np.float32)\n   262→    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n   263→    pos_gpu = cupy.asarray(pos_np)\n   264→\n   265→    hashes, indices = calc_hash(pos_gpu)\n   266→    sorted_hashes, sorted_indices = _sort_by_hash(hashes, indices)\n   267→\n   268→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   269→    cupy.cuda.Device().synchronize()\n   270→\n   271→    h_start = cupy.asnumpy(cell_start)\n   272→    h_end = cupy.asnumpy(cell_end)\n   273→\n   274→    # Sum check\n   275→    non_empty = h_start != EMPTY_CELL\n   276→    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n   277→    assert total == n, f\"Sum = {total}, expected {n}\"\n   278→\n   279→    num_non_empty = int(np.sum(non_empty))\n   280→    num_empty = NUM_CELLS - num_non_empty\n   281→    print(f\"[OK] 500K particles: {num_non_empty} non-empty cells, \"\n   282→          f\"{num_empty} empty cells, sum(end-start) = {total}\")\n   283→\n   284→\n   285→def main() -> None:\n   286→    test_compilation()\n   287→    test_allocation()\n   288→    test_block_size()\n   289→    test_empty_cells_sentinel()\n   290→    test_known_8_particles_2_cells()\n   291→    test_sum_equals_num_particles()\n   292→    test_cell_boundaries_match_sorted_hashes()\n   293→    test_memset_between_frames()\n   294→    test_500k_no_errors()\n   295→    print(\"\\n=== ALL CHECKS PASSED ===\")\n   296→\n   297→\n   298→if __name__ == \"__main__\":\n   299→    main()\n   300→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"3ee40f7f-a1c9-4640-b0e4-2236c98c5f30","uuid":"f8355495-f959-4e39-9dba-573412285bb1","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/test_build_grid.py","content":"\"\"\"Integration test for build_grid.py -- K_BuildDataStruct kernel.\n\nAcceptance criteria:\n  - K_BuildDataStruct writes cell_indexes_start[hash] = first particle index\n  - K_BuildDataStruct writes cell_indexes_end[hash] = one past last particle index\n  - Empty cells have cell_indexes_start = 0xFFFFFFFF\n  - cell_indexes_start and cell_indexes_end allocated as CuPy uint32 arrays of\n    size num_cells (125000)\n  - cell_indexes_start memset to 0xFFFFFFFF before each frame's kernel launch\n  - Test: for a known configuration (8 particles in 2 cells), cell_start/end correct\n  - Test: sum of (cell_end - cell_start) across all non-empty cells equals num_particles\n  - Kernel runs without errors for 500K particles\n  - Block size = 256\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport cupy  # type: ignore[import-untyped]\nimport numpy as np\n\nfrom hash_sort import (\n    NUM_CELLS,\n    calc_hash,\n    upload_grid_params as upload_hash_grid_params,\n)\nfrom build_grid import (\n    BLOCK_SIZE,\n    EMPTY_CELL,\n    allocate_cell_tables,\n    build_data_struct,\n    get_module,\n    upload_grid_params,\n)\n\n\ndef _sort_by_hash(\n    hashes: cupy.ndarray, indices: cupy.ndarray\n) -> tuple[cupy.ndarray, cupy.ndarray]:\n    \"\"\"Sort hashes and indices by hash value (radix sort placeholder).\"\"\"\n    order = cupy.argsort(hashes)\n    return hashes[order], indices[order]\n\n\ndef test_compilation() -> None:\n    \"\"\"Verify CuPy RawModule compiles build_grid.cu.\"\"\"\n    print(\"--- Compilation check ---\")\n\n    module = get_module()\n    assert module is not None\n    print(\"[OK] CuPy RawModule compiled build_grid.cu (includes common.cuh)\")\n\n    kernel = module.get_function(\"K_BuildDataStruct\")  # type: ignore[union-attr]\n    assert kernel is not None\n    print(\"[OK] K_BuildDataStruct kernel function found\")\n\n    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n    assert int(d_ptr) != 0\n    print(\"[OK] c_grid constant memory symbol found\")\n\n\ndef test_allocation() -> None:\n    \"\"\"Verify cell table allocation dimensions and dtype.\"\"\"\n    print(\"\\n--- Allocation check ---\")\n\n    cell_start, cell_end = allocate_cell_tables()\n    assert cell_start.shape == (NUM_CELLS,), f\"shape {cell_start.shape}\"\n    assert cell_end.shape == (NUM_CELLS,), f\"shape {cell_end.shape}\"\n    assert cell_start.dtype == cupy.uint32\n    assert cell_end.dtype == cupy.uint32\n    print(f\"[OK] cell_start/end: shape=({NUM_CELLS},), dtype=uint32\")\n\n\ndef test_block_size() -> None:\n    \"\"\"Verify block size is 256.\"\"\"\n    print(\"\\n--- Block size check ---\")\n    assert BLOCK_SIZE == 256, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 256\"\n    print(\"[OK] BLOCK_SIZE = 256\")\n\n\ndef test_empty_cells_sentinel() -> None:\n    \"\"\"With zero particles all cells should remain 0xFFFFFFFF.\"\"\"\n    print(\"\\n--- Empty cells sentinel test ---\")\n\n    # Create a sorted_hashes array with zero particles -- edge case.\n    # Instead, use 1 particle in cell 0 so remaining cells are empty.\n    sorted_hashes = cupy.array([0], dtype=cupy.uint32)\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Cell 0 should be occupied: start=0, end=1\n    assert h_start[0] == 0, f\"cell_start[0] = {h_start[0]}, expected 0\"\n    assert h_end[0] == 1, f\"cell_end[0] = {h_end[0]}, expected 1\"\n    print(\"[OK] Cell 0: start=0, end=1\")\n\n    # All other cells should have 0xFFFFFFFF sentinel\n    empty_mask = h_start[1:] == EMPTY_CELL\n    assert empty_mask.all(), (\n        f\"Not all empty cells have sentinel: \"\n        f\"{np.sum(~empty_mask)} cells have non-sentinel values\"\n    )\n    print(f\"[OK] All {NUM_CELLS - 1} other cells have start = 0xFFFFFFFF\")\n\n\ndef test_known_8_particles_2_cells() -> None:\n    \"\"\"8 particles in 2 cells: verify exact cell_start/end values.\"\"\"\n    print(\"\\n--- Known configuration: 8 particles in 2 cells ---\")\n\n    # 5 particles in cell hash=10, 3 particles in cell hash=42.\n    # Sorted hashes: [10, 10, 10, 10, 10, 42, 42, 42]\n    sorted_hashes = cupy.array(\n        [10, 10, 10, 10, 10, 42, 42, 42], dtype=cupy.uint32\n    )\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Cell 10: particles 0..4\n    assert h_start[10] == 0, f\"cell_start[10] = {h_start[10]}, expected 0\"\n    assert h_end[10] == 5, f\"cell_end[10] = {h_end[10]}, expected 5\"\n    print(\"[OK] Cell 10: start=0, end=5 (5 particles)\")\n\n    # Cell 42: particles 5..7\n    assert h_start[42] == 5, f\"cell_start[42] = {h_start[42]}, expected 5\"\n    assert h_end[42] == 8, f\"cell_end[42] = {h_end[42]}, expected 8\"\n    print(\"[OK] Cell 42: start=5, end=8 (3 particles)\")\n\n    # All other cells empty\n    for c in [0, 1, 9, 11, 41, 43, 100, NUM_CELLS - 1]:\n        assert h_start[c] == EMPTY_CELL, (\n            f\"cell_start[{c}] = {h_start[c]}, expected 0xFFFFFFFF\"\n        )\n    print(\"[OK] All other sampled cells have start = 0xFFFFFFFF\")\n\n\ndef test_sum_equals_num_particles() -> None:\n    \"\"\"Sum of (cell_end - cell_start) over non-empty cells equals num_particles.\"\"\"\n    print(\"\\n--- Particle count consistency test ---\")\n\n    upload_grid_params()\n    upload_hash_grid_params()\n\n    rng = np.random.default_rng(99)\n    n = 10_000\n    pos_np = np.zeros((n, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = _sort_by_hash(hashes, indices)\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Non-empty cells\n    non_empty = h_start != EMPTY_CELL\n    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n\n    assert total == n, f\"Sum of (end - start) = {total}, expected {n}\"\n    print(f\"[OK] Sum of (cell_end - cell_start) across {np.sum(non_empty)} \"\n          f\"non-empty cells = {total} == {n} particles\")\n\n\ndef test_cell_boundaries_match_sorted_hashes() -> None:\n    \"\"\"Verify cell_start/end indices point to correct hash values.\"\"\"\n    print(\"\\n--- Cell boundary validation test ---\")\n\n    upload_grid_params()\n    upload_hash_grid_params()\n\n    rng = np.random.default_rng(77)\n    n = 5_000\n    pos_np = np.zeros((n, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = _sort_by_hash(hashes, indices)\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n    h_sorted = cupy.asnumpy(sorted_hashes)\n\n    # For each non-empty cell, check the sorted hash at start/end indices\n    non_empty_cells = np.where(h_start != EMPTY_CELL)[0]\n    for cell_hash in non_empty_cells:\n        s = h_start[cell_hash]\n        e = h_end[cell_hash]\n        # All hashes in [s, e) should equal cell_hash\n        assert np.all(h_sorted[s:e] == cell_hash), (\n            f\"Cell {cell_hash}: hashes in [{s},{e}) are not all {cell_hash}\"\n        )\n        # hash before start (if any) should be different\n        if s > 0:\n            assert h_sorted[s - 1] != cell_hash, (\n                f\"Cell {cell_hash}: hash at {s-1} is still {cell_hash}\"\n            )\n        # hash after end (if any) should be different\n        if e < n:\n            assert h_sorted[e] != cell_hash, (\n                f\"Cell {cell_hash}: hash at {e} is still {cell_hash}\"\n            )\n\n    print(f\"[OK] All {len(non_empty_cells)} non-empty cells have correct boundaries\")\n\n\ndef test_memset_between_frames() -> None:\n    \"\"\"Calling build_data_struct twice resets cell_start properly.\"\"\"\n    print(\"\\n--- Memset between frames test ---\")\n\n    # Frame 1: particles in cells 10 and 20\n    sorted_hashes_1 = cupy.array(\n        [10, 10, 10, 20, 20], dtype=cupy.uint32\n    )\n    cell_start, cell_end = allocate_cell_tables()\n    build_data_struct(sorted_hashes_1, cell_start, cell_end)\n    cupy.cuda.Device().synchronize()\n\n    h_start_1 = cupy.asnumpy(cell_start)\n    assert h_start_1[10] == 0\n    assert h_start_1[20] == 3\n\n    # Frame 2: particles only in cell 30 (cells 10, 20 should reset to empty)\n    sorted_hashes_2 = cupy.array([30, 30, 30, 30], dtype=cupy.uint32)\n    build_data_struct(sorted_hashes_2, cell_start, cell_end)\n    cupy.cuda.Device().synchronize()\n\n    h_start_2 = cupy.asnumpy(cell_start)\n    assert h_start_2[10] == EMPTY_CELL, (\n        f\"Cell 10 not reset: {h_start_2[10]}\"\n    )\n    assert h_start_2[20] == EMPTY_CELL, (\n        f\"Cell 20 not reset: {h_start_2[20]}\"\n    )\n    assert h_start_2[30] == 0\n    print(\"[OK] cell_start properly reset between frames via memset\")\n\n\ndef test_500k_no_errors() -> None:\n    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n    print(\"\\n--- 500K particle stress test ---\")\n\n    upload_grid_params()\n    upload_hash_grid_params()\n\n    rng = np.random.default_rng(123)\n    n = 500_000\n    pos_np = np.zeros((n, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = _sort_by_hash(hashes, indices)\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Sum check\n    non_empty = h_start != EMPTY_CELL\n    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n    assert total == n, f\"Sum = {total}, expected {n}\"\n\n    num_non_empty = int(np.sum(non_empty))\n    num_empty = NUM_CELLS - num_non_empty\n    print(f\"[OK] 500K particles: {num_non_empty} non-empty cells, \"\n          f\"{num_empty} empty cells, sum(end-start) = {total}\")\n\n\ndef main() -> None:\n    test_compilation()\n    test_allocation()\n    test_block_size()\n    test_empty_cells_sentinel()\n    test_known_8_particles_2_cells()\n    test_sum_equals_num_particles()\n    test_cell_boundaries_match_sorted_hashes()\n    test_memset_between_frames()\n    test_500k_no_errors()\n    print(\"\\n=== ALL CHECKS PASSED ===\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":300,"startLine":1,"totalLines":300}}}

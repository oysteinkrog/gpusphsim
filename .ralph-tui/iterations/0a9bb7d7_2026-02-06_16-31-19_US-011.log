{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VuGrixH9NQgCpFPpDG1xf3","type":"tool_result","content":"     1→\"\"\"Integration test for build_grid.py -- K_BuildDataStruct kernel.\n     2→\n     3→Acceptance criteria:\n     4→  - K_BuildDataStruct writes cell_indexes_start[hash] = first particle index\n     5→  - K_BuildDataStruct writes cell_indexes_end[hash] = one past last particle index\n     6→  - Empty cells have cell_indexes_start = 0xFFFFFFFF\n     7→  - cell_indexes_start and cell_indexes_end allocated as CuPy uint32 arrays of\n     8→    size num_cells (125000)\n     9→  - cell_indexes_start memset to 0xFFFFFFFF before each frame's kernel launch\n    10→  - Test: for a known configuration (8 particles in 2 cells), cell_start/end correct\n    11→  - Test: sum of (cell_end - cell_start) across all non-empty cells equals num_particles\n    12→  - Kernel runs without errors for 500K particles\n    13→  - Block size = 256\n    14→\n    15→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    16→\"\"\"\n    17→\n    18→from __future__ import annotations\n    19→\n    20→import sys\n    21→import os\n    22→\n    23→# Ensure fallingsand3d directory is on the path\n    24→sys.path.insert(0, os.path.dirname(__file__))\n    25→\n    26→import cupy\n    27→import numpy as np\n    28→\n    29→from hash_sort import (\n    30→    NUM_CELLS,\n    31→    calc_hash,\n    32→    sort_by_hash,\n    33→    upload_grid_params as upload_hash_grid_params,\n    34→)\n    35→from build_grid import (\n    36→    BLOCK_SIZE,\n    37→    EMPTY_CELL,\n    38→    allocate_cell_tables,\n    39→    build_data_struct,\n    40→    get_module,\n    41→    upload_grid_params,\n    42→)\n    43→\n    44→\n    45→def test_compilation() -> None:\n    46→    \"\"\"Verify CuPy RawModule compiles build_grid.cu.\"\"\"\n    47→    print(\"--- Compilation check ---\")\n    48→\n    49→    module = get_module()\n    50→    assert module is not None\n    51→    print(\"[OK] CuPy RawModule compiled build_grid.cu (includes common.cuh)\")\n    52→\n    53→    kernel = module.get_function(\"K_BuildDataStruct\")  # type: ignore[union-attr]\n    54→    assert kernel is not None\n    55→    print(\"[OK] K_BuildDataStruct kernel function found\")\n    56→\n    57→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n    58→    assert int(d_ptr) != 0\n    59→    print(\"[OK] c_grid constant memory symbol found\")\n    60→\n    61→\n    62→def test_allocation() -> None:\n    63→    \"\"\"Verify cell table allocation dimensions and dtype.\"\"\"\n    64→    print(\"\\n--- Allocation check ---\")\n    65→\n    66→    cell_start, cell_end = allocate_cell_tables()\n    67→    assert cell_start.shape == (NUM_CELLS,), f\"shape {cell_start.shape}\"\n    68→    assert cell_end.shape == (NUM_CELLS,), f\"shape {cell_end.shape}\"\n    69→    assert cell_start.dtype == cupy.uint32\n    70→    assert cell_end.dtype == cupy.uint32\n    71→    print(f\"[OK] cell_start/end: shape=({NUM_CELLS},), dtype=uint32\")\n    72→\n    73→\n    74→def test_block_size() -> None:\n    75→    \"\"\"Verify block size is 256.\"\"\"\n    76→    print(\"\\n--- Block size check ---\")\n    77→    assert BLOCK_SIZE == 256, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 256\"\n    78→    print(\"[OK] BLOCK_SIZE = 256\")\n    79→\n    80→\n    81→def test_empty_cells_sentinel() -> None:\n    82→    \"\"\"With one particle, all other cells should have 0xFFFFFFFF sentinel.\"\"\"\n    83→    print(\"\\n--- Empty cells sentinel test ---\")\n    84→\n    85→    sorted_hashes = cupy.array([0], dtype=cupy.uint32)\n    86→    cell_start, cell_end = build_data_struct(sorted_hashes)\n    87→    cupy.cuda.Device().synchronize()\n    88→\n    89→    h_start = cupy.asnumpy(cell_start)\n    90→    h_end = cupy.asnumpy(cell_end)\n    91→\n    92→    # Cell 0 should be occupied: start=0, end=1\n    93→    assert h_start[0] == 0, f\"cell_start[0] = {h_start[0]}, expected 0\"\n    94→    assert h_end[0] == 1, f\"cell_end[0] = {h_end[0]}, expected 1\"\n    95→    print(\"[OK] Cell 0: start=0, end=1\")\n    96→\n    97→    # All other cells should have 0xFFFFFFFF sentinel\n    98→    empty_mask = h_start[1:] == EMPTY_CELL\n    99→    assert empty_mask.all(), (\n   100→        f\"Not all empty cells have sentinel: \"\n   101→        f\"{np.sum(~empty_mask)} cells have non-sentinel values\"\n   102→    )\n   103→    print(f\"[OK] All {NUM_CELLS - 1} other cells have start = 0xFFFFFFFF\")\n   104→\n   105→\n   106→def test_known_8_particles_2_cells() -> None:\n   107→    \"\"\"8 particles in 2 cells: verify exact cell_start/end values.\"\"\"\n   108→    print(\"\\n--- Known configuration: 8 particles in 2 cells ---\")\n   109→\n   110→    # 5 particles in cell hash=10, 3 particles in cell hash=42.\n   111→    # Sorted hashes: [10, 10, 10, 10, 10, 42, 42, 42]\n   112→    sorted_hashes = cupy.array(\n   113→        [10, 10, 10, 10, 10, 42, 42, 42], dtype=cupy.uint32\n   114→    )\n   115→\n   116→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   117→    cupy.cuda.Device().synchronize()\n   118→\n   119→    h_start = cupy.asnumpy(cell_start)\n   120→    h_end = cupy.asnumpy(cell_end)\n   121→\n   122→    # Cell 10: particles 0..4\n   123→    assert h_start[10] == 0, f\"cell_start[10] = {h_start[10]}, expected 0\"\n   124→    assert h_end[10] == 5, f\"cell_end[10] = {h_end[10]}, expected 5\"\n   125→    print(\"[OK] Cell 10: start=0, end=5 (5 particles)\")\n   126→\n   127→    # Cell 42: particles 5..7\n   128→    assert h_start[42] == 5, f\"cell_start[42] = {h_start[42]}, expected 5\"\n   129→    assert h_end[42] == 8, f\"cell_end[42] = {h_end[42]}, expected 8\"\n   130→    print(\"[OK] Cell 42: start=5, end=8 (3 particles)\")\n   131→\n   132→    # All other cells empty\n   133→    for c in [0, 1, 9, 11, 41, 43, 100, NUM_CELLS - 1]:\n   134→        assert h_start[c] == EMPTY_CELL, (\n   135→            f\"cell_start[{c}] = {h_start[c]}, expected 0xFFFFFFFF\"\n   136→        )\n   137→    print(\"[OK] All other sampled cells have start = 0xFFFFFFFF\")\n   138→\n   139→\n   140→def test_sum_equals_num_particles() -> None:\n   141→    \"\"\"Sum of (cell_end - cell_start) over non-empty cells equals num_particles.\"\"\"\n   142→    print(\"\\n--- Particle count consistency test ---\")\n   143→\n   144→    upload_grid_params()\n   145→    upload_hash_grid_params()\n   146→\n   147→    rng = np.random.default_rng(99)\n   148→    n = 10_000\n   149→    pos_np = np.zeros((n, 4), dtype=np.float32)\n   150→    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n   151→    pos_gpu = cupy.asarray(pos_np)\n   152→\n   153→    hashes, indices = calc_hash(pos_gpu)\n   154→    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n   155→\n   156→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   157→    cupy.cuda.Device().synchronize()\n   158→\n   159→    h_start = cupy.asnumpy(cell_start)\n   160→    h_end = cupy.asnumpy(cell_end)\n   161→\n   162→    # Non-empty cells\n   163→    non_empty = h_start != EMPTY_CELL\n   164→    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n   165→\n   166→    assert total == n, f\"Sum of (end - start) = {total}, expected {n}\"\n   167→    print(f\"[OK] Sum of (cell_end - cell_start) across {np.sum(non_empty)} \"\n   168→          f\"non-empty cells = {total} == {n} particles\")\n   169→\n   170→\n   171→def test_cell_boundaries_match_sorted_hashes() -> None:\n   172→    \"\"\"Verify cell_start/end indices point to correct hash values.\"\"\"\n   173→    print(\"\\n--- Cell boundary validation test ---\")\n   174→\n   175→    upload_grid_params()\n   176→    upload_hash_grid_params()\n   177→\n   178→    rng = np.random.default_rng(77)\n   179→    n = 5_000\n   180→    pos_np = np.zeros((n, 4), dtype=np.float32)\n   181→    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n   182→    pos_gpu = cupy.asarray(pos_np)\n   183→\n   184→    hashes, indices = calc_hash(pos_gpu)\n   185→    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n   186→\n   187→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   188→    cupy.cuda.Device().synchronize()\n   189→\n   190→    h_start = cupy.asnumpy(cell_start)\n   191→    h_end = cupy.asnumpy(cell_end)\n   192→    h_sorted = cupy.asnumpy(sorted_hashes)\n   193→\n   194→    # For each non-empty cell, check the sorted hash at start/end indices\n   195→    non_empty_cells = np.where(h_start != EMPTY_CELL)[0]\n   196→    for cell_hash in non_empty_cells:\n   197→        s = h_start[cell_hash]\n   198→        e = h_end[cell_hash]\n   199→        # All hashes in [s, e) should equal cell_hash\n   200→        assert np.all(h_sorted[s:e] == cell_hash), (\n   201→            f\"Cell {cell_hash}: hashes in [{s},{e}) are not all {cell_hash}\"\n   202→        )\n   203→        # hash before start (if any) should be different\n   204→        if s > 0:\n   205→            assert h_sorted[s - 1] != cell_hash, (\n   206→                f\"Cell {cell_hash}: hash at {s-1} is still {cell_hash}\"\n   207→            )\n   208→        # hash after end (if any) should be different\n   209→        if e < n:\n   210→            assert h_sorted[e] != cell_hash, (\n   211→                f\"Cell {cell_hash}: hash at {e} is still {cell_hash}\"\n   212→            )\n   213→\n   214→    print(f\"[OK] All {len(non_empty_cells)} non-empty cells have correct boundaries\")\n   215→\n   216→\n   217→def test_memset_between_frames() -> None:\n   218→    \"\"\"Calling build_data_struct twice resets cell_start properly.\"\"\"\n   219→    print(\"\\n--- Memset between frames test ---\")\n   220→\n   221→    # Frame 1: particles in cells 10 and 20\n   222→    sorted_hashes_1 = cupy.array(\n   223→        [10, 10, 10, 20, 20], dtype=cupy.uint32\n   224→    )\n   225→    cell_start, cell_end = allocate_cell_tables()\n   226→    build_data_struct(sorted_hashes_1, cell_start, cell_end)\n   227→    cupy.cuda.Device().synchronize()\n   228→\n   229→    h_start_1 = cupy.asnumpy(cell_start)\n   230→    assert h_start_1[10] == 0\n   231→    assert h_start_1[20] == 3\n   232→\n   233→    # Frame 2: particles only in cell 30 (cells 10, 20 should reset to empty)\n   234→    sorted_hashes_2 = cupy.array([30, 30, 30, 30], dtype=cupy.uint32)\n   235→    build_data_struct(sorted_hashes_2, cell_start, cell_end)\n   236→    cupy.cuda.Device().synchronize()\n   237→\n   238→    h_start_2 = cupy.asnumpy(cell_start)\n   239→    assert h_start_2[10] == EMPTY_CELL, (\n   240→        f\"Cell 10 not reset: {h_start_2[10]}\"\n   241→    )\n   242→    assert h_start_2[20] == EMPTY_CELL, (\n   243→        f\"Cell 20 not reset: {h_start_2[20]}\"\n   244→    )\n   245→    assert h_start_2[30] == 0\n   246→    print(\"[OK] cell_start properly reset between frames via memset\")\n   247→\n   248→\n   249→def test_500k_no_errors() -> None:\n   250→    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n   251→    print(\"\\n--- 500K particle stress test ---\")\n   252→\n   253→    upload_grid_params()\n   254→    upload_hash_grid_params()\n   255→\n   256→    rng = np.random.default_rng(123)\n   257→    n = 500_000\n   258→    pos_np = np.zeros((n, 4), dtype=np.float32)\n   259→    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n   260→    pos_gpu = cupy.asarray(pos_np)\n   261→\n   262→    hashes, indices = calc_hash(pos_gpu)\n   263→    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n   264→\n   265→    cell_start, cell_end = build_data_struct(sorted_hashes)\n   266→    cupy.cuda.Device().synchronize()\n   267→\n   268→    h_start = cupy.asnumpy(cell_start)\n   269→    h_end = cupy.asnumpy(cell_end)\n   270→\n   271→    # Sum check\n   272→    non_empty = h_start != EMPTY_CELL\n   273→    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n   274→    assert total == n, f\"Sum = {total}, expected {n}\"\n   275→\n   276→    num_non_empty = int(np.sum(non_empty))\n   277→    num_empty = NUM_CELLS - num_non_empty\n   278→    print(f\"[OK] 500K particles: {num_non_empty} non-empty cells, \"\n   279→          f\"{num_empty} empty cells, sum(end-start) = {total}\")\n   280→\n   281→\n   282→def main() -> None:\n   283→    test_compilation()\n   284→    test_allocation()\n   285→    test_block_size()\n   286→    test_empty_cells_sentinel()\n   287→    test_known_8_particles_2_cells()\n   288→    test_sum_equals_num_particles()\n   289→    test_cell_boundaries_match_sorted_hashes()\n   290→    test_memset_between_frames()\n   291→    test_500k_no_errors()\n   292→    print(\"\\n=== ALL CHECKS PASSED ===\")\n   293→\n   294→\n   295→if __name__ == \"__main__\":\n   296→    main()\n   297→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"3242128b-3d9b-48b8-8cfa-8a003d4cdd82","uuid":"036c1b81-1d68-413a-9517-26d48b09edb4","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_build_grid.py","content":"\"\"\"Integration test for build_grid.py -- K_BuildDataStruct kernel.\n\nAcceptance criteria:\n  - K_BuildDataStruct writes cell_indexes_start[hash] = first particle index\n  - K_BuildDataStruct writes cell_indexes_end[hash] = one past last particle index\n  - Empty cells have cell_indexes_start = 0xFFFFFFFF\n  - cell_indexes_start and cell_indexes_end allocated as CuPy uint32 arrays of\n    size num_cells (125000)\n  - cell_indexes_start memset to 0xFFFFFFFF before each frame's kernel launch\n  - Test: for a known configuration (8 particles in 2 cells), cell_start/end correct\n  - Test: sum of (cell_end - cell_start) across all non-empty cells equals num_particles\n  - Kernel runs without errors for 500K particles\n  - Block size = 256\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport sys\nimport os\n\n# Ensure fallingsand3d directory is on the path\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom hash_sort import (\n    NUM_CELLS,\n    calc_hash,\n    sort_by_hash,\n    upload_grid_params as upload_hash_grid_params,\n)\nfrom build_grid import (\n    BLOCK_SIZE,\n    EMPTY_CELL,\n    allocate_cell_tables,\n    build_data_struct,\n    get_module,\n    upload_grid_params,\n)\n\n\ndef test_compilation() -> None:\n    \"\"\"Verify CuPy RawModule compiles build_grid.cu.\"\"\"\n    print(\"--- Compilation check ---\")\n\n    module = get_module()\n    assert module is not None\n    print(\"[OK] CuPy RawModule compiled build_grid.cu (includes common.cuh)\")\n\n    kernel = module.get_function(\"K_BuildDataStruct\")  # type: ignore[union-attr]\n    assert kernel is not None\n    print(\"[OK] K_BuildDataStruct kernel function found\")\n\n    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n    assert int(d_ptr) != 0\n    print(\"[OK] c_grid constant memory symbol found\")\n\n\ndef test_allocation() -> None:\n    \"\"\"Verify cell table allocation dimensions and dtype.\"\"\"\n    print(\"\\n--- Allocation check ---\")\n\n    cell_start, cell_end = allocate_cell_tables()\n    assert cell_start.shape == (NUM_CELLS,), f\"shape {cell_start.shape}\"\n    assert cell_end.shape == (NUM_CELLS,), f\"shape {cell_end.shape}\"\n    assert cell_start.dtype == cupy.uint32\n    assert cell_end.dtype == cupy.uint32\n    print(f\"[OK] cell_start/end: shape=({NUM_CELLS},), dtype=uint32\")\n\n\ndef test_block_size() -> None:\n    \"\"\"Verify block size is 256.\"\"\"\n    print(\"\\n--- Block size check ---\")\n    assert BLOCK_SIZE == 256, f\"BLOCK_SIZE = {BLOCK_SIZE}, expected 256\"\n    print(\"[OK] BLOCK_SIZE = 256\")\n\n\ndef test_empty_cells_sentinel() -> None:\n    \"\"\"With one particle, all other cells should have 0xFFFFFFFF sentinel.\"\"\"\n    print(\"\\n--- Empty cells sentinel test ---\")\n\n    sorted_hashes = cupy.array([0], dtype=cupy.uint32)\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Cell 0 should be occupied: start=0, end=1\n    assert h_start[0] == 0, f\"cell_start[0] = {h_start[0]}, expected 0\"\n    assert h_end[0] == 1, f\"cell_end[0] = {h_end[0]}, expected 1\"\n    print(\"[OK] Cell 0: start=0, end=1\")\n\n    # All other cells should have 0xFFFFFFFF sentinel\n    empty_mask = h_start[1:] == EMPTY_CELL\n    assert empty_mask.all(), (\n        f\"Not all empty cells have sentinel: \"\n        f\"{np.sum(~empty_mask)} cells have non-sentinel values\"\n    )\n    print(f\"[OK] All {NUM_CELLS - 1} other cells have start = 0xFFFFFFFF\")\n\n\ndef test_known_8_particles_2_cells() -> None:\n    \"\"\"8 particles in 2 cells: verify exact cell_start/end values.\"\"\"\n    print(\"\\n--- Known configuration: 8 particles in 2 cells ---\")\n\n    # 5 particles in cell hash=10, 3 particles in cell hash=42.\n    # Sorted hashes: [10, 10, 10, 10, 10, 42, 42, 42]\n    sorted_hashes = cupy.array(\n        [10, 10, 10, 10, 10, 42, 42, 42], dtype=cupy.uint32\n    )\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Cell 10: particles 0..4\n    assert h_start[10] == 0, f\"cell_start[10] = {h_start[10]}, expected 0\"\n    assert h_end[10] == 5, f\"cell_end[10] = {h_end[10]}, expected 5\"\n    print(\"[OK] Cell 10: start=0, end=5 (5 particles)\")\n\n    # Cell 42: particles 5..7\n    assert h_start[42] == 5, f\"cell_start[42] = {h_start[42]}, expected 5\"\n    assert h_end[42] == 8, f\"cell_end[42] = {h_end[42]}, expected 8\"\n    print(\"[OK] Cell 42: start=5, end=8 (3 particles)\")\n\n    # All other cells empty\n    for c in [0, 1, 9, 11, 41, 43, 100, NUM_CELLS - 1]:\n        assert h_start[c] == EMPTY_CELL, (\n            f\"cell_start[{c}] = {h_start[c]}, expected 0xFFFFFFFF\"\n        )\n    print(\"[OK] All other sampled cells have start = 0xFFFFFFFF\")\n\n\ndef test_sum_equals_num_particles() -> None:\n    \"\"\"Sum of (cell_end - cell_start) over non-empty cells equals num_particles.\"\"\"\n    print(\"\\n--- Particle count consistency test ---\")\n\n    upload_grid_params()\n    upload_hash_grid_params()\n\n    rng = np.random.default_rng(99)\n    n = 10_000\n    pos_np = np.zeros((n, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Non-empty cells\n    non_empty = h_start != EMPTY_CELL\n    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n\n    assert total == n, f\"Sum of (end - start) = {total}, expected {n}\"\n    print(f\"[OK] Sum of (cell_end - cell_start) across {np.sum(non_empty)} \"\n          f\"non-empty cells = {total} == {n} particles\")\n\n\ndef test_cell_boundaries_match_sorted_hashes() -> None:\n    \"\"\"Verify cell_start/end indices point to correct hash values.\"\"\"\n    print(\"\\n--- Cell boundary validation test ---\")\n\n    upload_grid_params()\n    upload_hash_grid_params()\n\n    rng = np.random.default_rng(77)\n    n = 5_000\n    pos_np = np.zeros((n, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-0.9, 0.9, size=(n, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n    h_sorted = cupy.asnumpy(sorted_hashes)\n\n    # For each non-empty cell, check the sorted hash at start/end indices\n    non_empty_cells = np.where(h_start != EMPTY_CELL)[0]\n    for cell_hash in non_empty_cells:\n        s = h_start[cell_hash]\n        e = h_end[cell_hash]\n        # All hashes in [s, e) should equal cell_hash\n        assert np.all(h_sorted[s:e] == cell_hash), (\n            f\"Cell {cell_hash}: hashes in [{s},{e}) are not all {cell_hash}\"\n        )\n        # hash before start (if any) should be different\n        if s > 0:\n            assert h_sorted[s - 1] != cell_hash, (\n                f\"Cell {cell_hash}: hash at {s-1} is still {cell_hash}\"\n            )\n        # hash after end (if any) should be different\n        if e < n:\n            assert h_sorted[e] != cell_hash, (\n                f\"Cell {cell_hash}: hash at {e} is still {cell_hash}\"\n            )\n\n    print(f\"[OK] All {len(non_empty_cells)} non-empty cells have correct boundaries\")\n\n\ndef test_memset_between_frames() -> None:\n    \"\"\"Calling build_data_struct twice resets cell_start properly.\"\"\"\n    print(\"\\n--- Memset between frames test ---\")\n\n    # Frame 1: particles in cells 10 and 20\n    sorted_hashes_1 = cupy.array(\n        [10, 10, 10, 20, 20], dtype=cupy.uint32\n    )\n    cell_start, cell_end = allocate_cell_tables()\n    build_data_struct(sorted_hashes_1, cell_start, cell_end)\n    cupy.cuda.Device().synchronize()\n\n    h_start_1 = cupy.asnumpy(cell_start)\n    assert h_start_1[10] == 0\n    assert h_start_1[20] == 3\n\n    # Frame 2: particles only in cell 30 (cells 10, 20 should reset to empty)\n    sorted_hashes_2 = cupy.array([30, 30, 30, 30], dtype=cupy.uint32)\n    build_data_struct(sorted_hashes_2, cell_start, cell_end)\n    cupy.cuda.Device().synchronize()\n\n    h_start_2 = cupy.asnumpy(cell_start)\n    assert h_start_2[10] == EMPTY_CELL, (\n        f\"Cell 10 not reset: {h_start_2[10]}\"\n    )\n    assert h_start_2[20] == EMPTY_CELL, (\n        f\"Cell 20 not reset: {h_start_2[20]}\"\n    )\n    assert h_start_2[30] == 0\n    print(\"[OK] cell_start properly reset between frames via memset\")\n\n\ndef test_500k_no_errors() -> None:\n    \"\"\"Kernel runs without errors for 500K particles.\"\"\"\n    print(\"\\n--- 500K particle stress test ---\")\n\n    upload_grid_params()\n    upload_hash_grid_params()\n\n    rng = np.random.default_rng(123)\n    n = 500_000\n    pos_np = np.zeros((n, 4), dtype=np.float32)\n    pos_np[:, :3] = rng.uniform(-1.0, 1.0, size=(n, 3)).astype(np.float32)\n    pos_gpu = cupy.asarray(pos_np)\n\n    hashes, indices = calc_hash(pos_gpu)\n    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n\n    cell_start, cell_end = build_data_struct(sorted_hashes)\n    cupy.cuda.Device().synchronize()\n\n    h_start = cupy.asnumpy(cell_start)\n    h_end = cupy.asnumpy(cell_end)\n\n    # Sum check\n    non_empty = h_start != EMPTY_CELL\n    total = np.sum(h_end[non_empty].astype(np.int64) - h_start[non_empty].astype(np.int64))\n    assert total == n, f\"Sum = {total}, expected {n}\"\n\n    num_non_empty = int(np.sum(non_empty))\n    num_empty = NUM_CELLS - num_non_empty\n    print(f\"[OK] 500K particles: {num_non_empty} non-empty cells, \"\n          f\"{num_empty} empty cells, sum(end-start) = {total}\")\n\n\ndef main() -> None:\n    test_compilation()\n    test_allocation()\n    test_block_size()\n    test_empty_cells_sentinel()\n    test_known_8_particles_2_cells()\n    test_sum_equals_num_particles()\n    test_cell_boundaries_match_sorted_hashes()\n    test_memset_between_frames()\n    test_500k_no_errors()\n    print(\"\\n=== ALL CHECKS PASSED ===\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":297,"startLine":1,"totalLines":297}}}

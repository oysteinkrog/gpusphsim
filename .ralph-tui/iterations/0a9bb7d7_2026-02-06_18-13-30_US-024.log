{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PBU4ADG1PkM1BfcFuv5Aox","type":"tool_result","content":"     1→\"\"\"Integration test for US-024: Gas particles with buoyancy, drag, and lifetime.\n     2→\n     3→Verifies gas particles (STEAM, SMOKE, FIRE) use correct linear EOS (gamma=1),\n     4→buoyancy force, drag, and lifetime decay across Step2, Integrate, and Reactions.\n     5→\n     6→Acceptance criteria:\n     7→  - Gas pressure uses linear EOS: p = k_gas * max(rho - rho0_gas, 0)\n     8→  - Gas buoyancy in Integrate: gas particles rise upward\n     9→  - Gas drag in Integrate: gas particles slow down over time\n    10→  - FIRE: T=1200K, lifetime ~1s, heats nearby wood via exposure_heat\n    11→  - SMOKE: T=500K, lifetime ~3s, no chemical interactions\n    12→  - STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions)\n    13→  - Test: fire particles rise, slow down, and disappear after ~1 second\n    14→  - Test: steam particles rise and some condense to water as they cool\n    15→  - Test: gas particles don't collapse (linear EOS provides gentle repulsion)\n    16→  - No NaN or explosions with mixed gas + fluid + granular over 5000 steps\n    17→\n    18→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    19→\"\"\"\n    20→\n    21→from __future__ import annotations\n    22→\n    23→import math\n    24→import os\n    25→import sys\n    26→\n    27→sys.path.insert(0, os.path.dirname(__file__))\n    28→\n    29→import cupy\n    30→import numpy as np\n    31→\n    32→from step1 import (\n    33→    SIM_PARAMS_DTYPE,\n    34→    PRECALC_PARAMS_DTYPE,\n    35→    build_sim_params,\n    36→    build_precalc_params,\n    37→    compute_step1,\n    38→)\n    39→from step2 import (\n    40→    build_granular_params,\n    41→    compute_step2,\n    42→)\n    43→from integrate import integrate\n    44→from reactions import compute_reactions\n    45→from hash_sort import (\n    46→    GRID_PARAMS_DTYPE,\n    47→    NUM_CELLS,\n    48→    build_grid_params,\n    49→    calc_hash,\n    50→    sort_by_hash,\n    51→)\n    52→from build_grid import build_data_struct, allocate_cell_tables\n    53→from fused_reorder import fused_reorder\n    54→from materials import (\n    55→    FLUID,\n    56→    GRANULAR,\n    57→    GAS,\n    58→    STATIC,\n    59→    DEAD,\n    60→    WATER,\n    61→    SAND,\n    62→    STEAM,\n    63→    SMOKE,\n    64→    FIRE,\n    65→    WOOD,\n    66→    METAL,\n    67→    build_material_array,\n    68→    build_interaction_matrix,\n    69→)\n    70→\n    71→# ---------------------------------------------------------------------------\n    72→# Constants\n    73→# ---------------------------------------------------------------------------\n    74→\n    75→H = 0.04\n    76→SPACING = 0.02\n    77→DT = 0.001\n    78→\n    79→# packed_info helpers\n    80→def MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    81→    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n    82→\n    83→def GET_MATERIAL_ID(p: int) -> int:\n    84→    return p & 0xFF\n    85→\n    86→def GET_BEHAVIOR(p: int) -> int:\n    87→    return (p >> 8) & 0x3\n    88→\n    89→\n    90→# ---------------------------------------------------------------------------\n    91→# Helper: upload all constant memory to all kernel modules\n    92→# ---------------------------------------------------------------------------\n    93→\n    94→def setup_all_modules(dt=DT, gravity=(0.0, -9.8, 0.0)):\n    95→    \"\"\"Upload constant memory to step1, step2, integrate, reactions modules.\"\"\"\n    96→    import step1 as s1_mod\n    97→    import step2 as s2_mod\n    98→    import integrate as int_mod\n    99→    import reactions as rx_mod\n   100→\n   101→    sim_params = build_sim_params(\n   102→        smoothing_length=H,\n   103→        particle_mass=0.008,\n   104→        particle_spacing=SPACING,\n   105→        gravity=gravity,\n   106→        dt=dt,\n   107→        restitution=0.3,\n   108→        wall_friction=0.5,\n   109→        world_min=(-1.0, -1.0, -1.0),\n   110→        world_max=(1.0, 1.0, 1.0),\n   111→    )\n   112→    precalc = build_precalc_params(smoothing_length=H, viscosity=1.0)\n   113→    grid_params = build_grid_params()\n   114→    materials = build_material_array()\n   115→    interactions = build_interaction_matrix()\n   116→    granular_params = build_granular_params()\n   117→\n   118→    # Step1\n   119→    s1_mod.upload_grid_params(grid_params)\n   120→    s1_mod.upload_sim_params(sim_params)\n   121→    s1_mod.upload_precalc_params(precalc)\n   122→    s1_mod.upload_materials(materials)\n   123→    s1_mod.upload_interactions(interactions)\n   124→\n   125→    # Step2\n   126→    s2_mod.upload_grid_params(grid_params)\n   127→    s2_mod.upload_sim_params(sim_params)\n   128→    s2_mod.upload_precalc_params(precalc)\n   129→    s2_mod.upload_materials(materials)\n   130→    s2_mod.upload_granular_params(granular_params)\n   131→\n   132→    # Integrate\n   133→    int_mod.upload_sim_params(sim_params)\n   134→    int_mod.upload_materials(materials)\n   135→\n   136→    # Reactions\n   137→    rx_mod.upload_sim_params(sim_params)\n   138→    rx_mod.upload_materials(materials)\n   139→\n   140→    return sim_params, precalc, grid_params, materials, interactions\n   141→\n   142→\n   143→def make_gas_particles(n, mat_id, pos_center=(0.0, 0.0, 0.0), spread=0.03,\n   144→                       temp=293.0, lifetime=5.0):\n   145→    \"\"\"Create n gas particles near pos_center with some random spread.\"\"\"\n   146→    np.random.seed(42)\n   147→    pos = np.zeros((n, 4), dtype=np.float32)\n   148→    pos[:, 0] = pos_center[0] + np.random.uniform(-spread, spread, n).astype(np.float32)\n   149→    pos[:, 1] = pos_center[1] + np.random.uniform(-spread, spread, n).astype(np.float32)\n   150→    pos[:, 2] = pos_center[2] + np.random.uniform(-spread, spread, n).astype(np.float32)\n   151→    pos[:, 3] = 1.0\n   152→\n   153→    vel = np.zeros((n, 4), dtype=np.float32)\n   154→\n   155→    # Gas mass: rest_density * spacing^3\n   156→    # STEAM rho0=0.6, SMOKE rho0=0.3, FIRE rho0=0.2\n   157→    rho0_map = {STEAM: 0.6, SMOKE: 0.3, FIRE: 0.2}\n   158→    rho0 = rho0_map.get(mat_id, 0.5)\n   159→    mass_val = rho0 * SPACING**3\n   160→\n   161→    mass = np.full(n, mass_val, dtype=np.float32)\n   162→    packed_info = np.full(n, MAKE_PACKED(mat_id, GAS), dtype=np.uint32)\n   163→    temperature = np.full(n, temp, dtype=np.float32)\n   164→    health = np.full(n, 1.0, dtype=np.float32)\n   165→    lt = np.full(n, lifetime, dtype=np.float32)\n   166→    sleep_counter = np.zeros(n, dtype=np.uint8)\n   167→    shear_rate = np.zeros(n, dtype=np.float32)\n   168→    color = np.zeros((n, 4), dtype=np.float32)\n   169→    color[:, 3] = 1.0\n   170→\n   171→    return {\n   172→        \"position\": cupy.asarray(pos),\n   173→        \"velocity\": cupy.asarray(vel),\n   174→        \"veleval\": cupy.asarray(vel.copy()),\n   175→        \"mass\": cupy.asarray(mass),\n   176→        \"packed_info\": cupy.asarray(packed_info),\n   177→        \"temperature\": cupy.asarray(temperature),\n   178→        \"health\": cupy.asarray(health),\n   179→        \"lifetime\": cupy.asarray(lt),\n   180→        \"sleep_counter\": cupy.asarray(sleep_counter),\n   181→        \"shear_rate\": cupy.asarray(shear_rate),\n   182→        \"color\": cupy.asarray(color),\n   183→    }\n   184→\n   185→\n   186→def run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=0):\n   187→    \"\"\"Run one full simulation step: hash -> sort -> reorder -> build -> step1 -> reactions -> step2 -> integrate.\n   188→\n   189→    w is a dict of unsorted arrays. Returns updated w dict.\n   190→    \"\"\"\n   191→    import hash_sort as hs_mod\n   192→    import build_grid as bg_mod\n   193→\n   194→    n = w[\"position\"].shape[0]\n   195→    if n == 0:\n   196→        return w\n   197→\n   198→    # Hash\n   199→    hashes = cupy.empty(n, dtype=cupy.uint32)\n   200→    hs_mod.upload_grid_params(grid_params)\n   201→    calc_hash(w[\"position\"], hashes)\n   202→\n   203→    # Sort\n   204→    sorted_hashes, sorted_indices = sort_by_hash(hashes)\n   205→\n   206→    # Reorder\n   207→    sorted_pos = cupy.empty_like(w[\"position\"])\n   208→    sorted_vel = cupy.empty_like(w[\"velocity\"])\n   209→    sorted_veleval = cupy.empty_like(w[\"veleval\"])\n   210→    sorted_mass = cupy.empty(n, dtype=cupy.float32)\n   211→    sorted_pi = cupy.empty(n, dtype=cupy.uint32)\n   212→    sorted_temp = cupy.empty(n, dtype=cupy.float32)\n   213→    sorted_health = cupy.empty(n, dtype=cupy.float32)\n   214→    sorted_lifetime = cupy.empty(n, dtype=cupy.float32)\n   215→    sorted_sc = cupy.empty(n, dtype=cupy.uint8)\n   216→    sorted_sr = cupy.empty(n, dtype=cupy.float32)\n   217→    sorted_color = cupy.empty_like(w[\"color\"])\n   218→\n   219→    fused_reorder(\n   220→        n, sorted_indices,\n   221→        w[\"position\"], w[\"velocity\"], w[\"veleval\"],\n   222→        w[\"mass\"], w[\"packed_info\"], w[\"temperature\"],\n   223→        w[\"health\"], w[\"lifetime\"], w[\"color\"],\n   224→        w[\"sleep_counter\"], w[\"shear_rate\"],\n   225→        sorted_pos, sorted_vel, sorted_veleval,\n   226→        sorted_mass, sorted_pi, sorted_temp,\n   227→        sorted_health, sorted_lifetime, sorted_color,\n   228→        sorted_sc, sorted_sr,\n   229→    )\n   230→\n   231→    # Build grid\n   232→    bg_mod.upload_grid_params(grid_params)\n   233→    cell_start.data.memset(0xFF, cell_start.nbytes)\n   234→    cell_end.data.memset(0x00, cell_end.nbytes)\n   235→    build_data_struct(sorted_hashes, cell_start, cell_end)\n   236→\n   237→    # Step1: density, shear_rate, dTdt, exposure\n   238→    density, shear_rate, dTdt, exp_heat, exp_corrode = compute_step1(\n   239→        sorted_pos, sorted_vel, sorted_mass, None, sorted_pi,\n   240→        sorted_temp, cell_start, cell_end,\n   241→    )\n   242→\n   243→    # Reactions\n   244→    compute_reactions(\n   245→        sorted_pi, sorted_temp, sorted_health, sorted_lifetime,\n   246→        sorted_vel, exp_heat, exp_corrode, frame=frame,\n   247→    )\n   248→\n   249→    # Step2\n   250→    sph_force, veleval_out = compute_step2(\n   251→        sorted_pos, sorted_vel, density, sorted_mass, sorted_pi,\n   252→        cell_start, cell_end,\n   253→    )\n   254→\n   255→    # Integrate\n   256→    pos_out, vel_out, color_out, pi_out, sc_out, temp_out = integrate(\n   257→        sorted_pos, sorted_vel, veleval_out, sph_force,\n   258→        sorted_mass, sorted_pi, sorted_temp, sorted_health,\n   259→        sorted_density=density, sorted_shear_rate=shear_rate,\n   260→        sorted_dTdt=dTdt, sorted_sleep_counter=sorted_sc,\n   261→        sort_indexes=sorted_indices,\n   262→        position_out=w[\"position\"],\n   263→        velocity_out=w[\"velocity\"],\n   264→        color_out=w[\"color\"],\n   265→        packed_info_out=w[\"packed_info\"],\n   266→        sleep_counter_out=w[\"sleep_counter\"],\n   267→        temperature_out=w[\"temperature\"],\n   268→    )\n   269→\n   270→    w[\"position\"] = pos_out\n   271→    w[\"velocity\"] = vel_out\n   272→    w[\"color\"] = color_out\n   273→    w[\"packed_info\"] = pi_out\n   274→    w[\"sleep_counter\"] = sc_out\n   275→    w[\"temperature\"] = temp_out\n   276→    # veleval = velocity for next frame (no separate persistence needed)\n   277→    w[\"veleval\"] = w[\"velocity\"].copy()\n   278→\n   279→    return w\n   280→\n   281→\n   282→# ===========================================================================\n   283→# Tests\n   284→# ===========================================================================\n   285→\n   286→\n   287→def test_gas_linear_eos():\n   288→    \"\"\"Gas pressure uses linear EOS: p = k_gas * max(rho - rho0, 0).\n   289→\n   290→    Two GAS particles compressed (closer than rest spacing) should produce\n   291→    a positive repulsive force. The key check is that force exists and is\n   292→    directed outward (separation).\n   293→    \"\"\"\n   294→    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity for pure EOS test\n   295→\n   296→    # Two STEAM particles close together (within h)\n   297→    n = 2\n   298→    sep = 0.02  # within h=0.04\n   299→    pos = np.array([\n   300→        [-sep/2, 0.0, 0.0, 1.0],\n   301→        [sep/2, 0.0, 0.0, 1.0],\n   302→    ], dtype=np.float32)\n   303→    vel = np.zeros((n, 4), dtype=np.float32)\n   304→    rho0 = 0.6  # STEAM rest density\n   305→    mass_val = rho0 * SPACING**3\n   306→    mass = np.full(n, mass_val, dtype=np.float32)\n   307→    packed_info = np.full(n, MAKE_PACKED(STEAM, GAS), dtype=np.uint32)\n   308→\n   309→    d_pos = cupy.asarray(pos)\n   310→    d_vel = cupy.asarray(vel)\n   311→    d_mass = cupy.asarray(mass)\n   312→    d_pi = cupy.asarray(packed_info)\n   313→\n   314→    # Build grid for these 2 particles\n   315→    grid_params = build_grid_params()\n   316→    import hash_sort as hs_mod\n   317→    import build_grid as bg_mod\n   318→    hs_mod.upload_grid_params(grid_params)\n   319→    bg_mod.upload_grid_params(grid_params)\n   320→\n   321→    hashes = cupy.empty(n, dtype=cupy.uint32)\n   322→    calc_hash(d_pos, hashes)\n   323→    sorted_hashes, sorted_indices = sort_by_hash(hashes)\n   324→\n   325→    # Reorder (trivial for 2 particles)\n   326→    s_pos = d_pos[sorted_indices]\n   327→    s_vel = d_vel[sorted_indices]\n   328→    s_mass = d_mass[sorted_indices]\n   329→    s_pi = d_pi[sorted_indices]\n   330→\n   331→    cell_start, cell_end = allocate_cell_tables()\n   332→    cell_start.data.memset(0xFF, cell_start.nbytes)\n   333→    cell_end.data.memset(0x00, cell_end.nbytes)\n   334→    build_data_struct(sorted_hashes, cell_start, cell_end)\n   335→\n   336→    # Step1: density\n   337→    s_temp = cupy.full(n, 373.0, dtype=cupy.float32)\n   338→    density, _, _, _, _ = compute_step1(\n   339→        s_pos, s_vel, s_mass, None, s_pi, s_temp, cell_start, cell_end,\n   340→    )\n   341→\n   342→    # Step2: force\n   343→    sph_force, veleval_out = compute_step2(\n   344→        s_pos, s_vel, density, s_mass, s_pi, cell_start, cell_end,\n   345→    )\n   346→\n   347→    force_h = sph_force.get()\n   348→    # Particles should be pushed apart: particle 0 (left) gets negative x force,\n   349→    # particle 1 (right) gets positive x force (Newton's 3rd law)\n   350→    # OR both get repulsive force away from each other\n   351→    f0x = force_h[0, 0]\n   352→    f1x = force_h[1, 0]\n   353→\n   354→    # Forces should be roughly opposite (Newton's 3rd law)\n   355→    assert abs(f0x + f1x) < 0.1 * max(abs(f0x), abs(f1x), 1e-6), \\\n   356→        f\"Newton's 3rd law violation: f0x={f0x}, f1x={f1x}\"\n   357→\n   358→    # At least one should be non-zero (EOS produces pressure)\n   359→    assert abs(f0x) > 1e-10 or abs(f1x) > 1e-10, \\\n   360→        f\"Zero forces: linear EOS not producing pressure for compressed gas\"\n   361→\n   362→    print(\"PASS: test_gas_linear_eos\")\n   363→\n   364→\n   365→def test_gas_buoyancy_rise():\n   366→    \"\"\"Gas particles rise upward due to buoyancy: accel.y += beta*(T-293)*g.\n   367→\n   368→    Spawn 100 fire particles (T=1200K) at origin with zero velocity.\n   369→    After several integration steps, y position should increase.\n   370→    \"\"\"\n   371→    setup_all_modules(gravity=(0.0, -9.8, 0.0))\n   372→\n   373→    grid_params = build_grid_params()\n   374→    cell_start, cell_end = allocate_cell_tables()\n   375→\n   376→    w = make_gas_particles(100, FIRE, pos_center=(0.0, 0.0, 0.0),\n   377→                           spread=0.03, temp=1200.0, lifetime=5.0)\n   378→\n   379→    # Record initial y positions\n   380→    y_initial = w[\"position\"].get()[:, 1].copy()\n   381→\n   382→    # Run 50 steps\n   383→    for step in range(50):\n   384→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   385→\n   386→    y_final = w[\"position\"].get()[:, 1]\n   387→\n   388→    # All (or most) fire particles should have risen\n   389→    # Buoyancy = 0.01 * (1200 - 293) * 9.81 = 0.01 * 907 * 9.81 ~= 89 m/s^2 upward\n   390→    # After 50 steps of dt=0.001: ~0.05s of sim time\n   391→    # Expected velocity ~= 89 * 0.05 * drag_reduction\n   392→    alive_mask = w[\"packed_info\"].get() != 0\n   393→    y_diff = y_final[alive_mask] - y_initial[alive_mask]\n   394→    risen_count = np.sum(y_diff > 0)\n   395→    total_alive = np.sum(alive_mask)\n   396→\n   397→    assert total_alive > 0, \"All particles died unexpectedly\"\n   398→    assert risen_count > total_alive * 0.8, \\\n   399→        f\"Only {risen_count}/{total_alive} fire particles rose (expected >80%)\"\n   400→\n   401→    mean_rise = np.mean(y_diff[y_diff > 0])\n   402→    assert mean_rise > 0.001, \\\n   403→        f\"Mean rise {mean_rise:.6f} too small -- buoyancy may not be working\"\n   404→\n   405→    print(f\"PASS: test_gas_buoyancy_rise (mean rise={mean_rise:.4f}, {risen_count}/{total_alive} rose)\")\n   406→\n   407→\n   408→def test_gas_drag_slowdown():\n   409→    \"\"\"Gas particles slow down over time due to drag: vel *= (1 - c_drag * dt).\n   410→\n   411→    Spawn gas particles with an initial horizontal velocity and check that\n   412→    velocity magnitude decreases over time.\n   413→    \"\"\"\n   414→    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity to isolate drag\n   415→\n   416→    n = 50\n   417→    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n   418→                           spread=0.02, temp=500.0, lifetime=10.0)\n   419→\n   420→    # Give initial velocity in x direction\n   421→    vel_init = np.zeros((n, 4), dtype=np.float32)\n   422→    vel_init[:, 0] = 1.0  # 1 m/s in x\n   423→    w[\"velocity\"] = cupy.asarray(vel_init)\n   424→    w[\"veleval\"] = cupy.asarray(vel_init.copy())\n   425→\n   426→    grid_params = build_grid_params()\n   427→    cell_start, cell_end = allocate_cell_tables()\n   428→\n   429→    # Measure velocity after 100 steps\n   430→    for step in range(100):\n   431→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   432→\n   433→    vel_final = w[\"velocity\"].get()\n   434→    alive_mask = w[\"packed_info\"].get() != 0\n   435→\n   436→    # c_drag=2.0, dt=0.001 -> factor = 1 - 2.0*0.001 = 0.998 per step\n   437→    # After 100 steps: expected ~0.998^100 = ~0.818 of original\n   438→    # But SPH forces also act, so we just check it's significantly less than 1.0\n   439→    vx_alive = vel_final[alive_mask, 0]\n   440→    if len(vx_alive) > 0:\n   441→        mean_vx = np.mean(np.abs(vx_alive))\n   442→        assert mean_vx < 0.95, \\\n   443→            f\"Mean |vx|={mean_vx:.4f} too high -- drag may not be working\"\n   444→        assert mean_vx > 0.01, \\\n   445→            f\"Mean |vx|={mean_vx:.6f} too low -- particles should still be moving\"\n   446→\n   447→    print(f\"PASS: test_gas_drag_slowdown (mean |vx|={mean_vx:.4f})\")\n   448→\n   449→\n   450→def test_fire_properties():\n   451→    \"\"\"FIRE: T=1200K, lifetime ~1s. Fire particles should disappear after ~1000 steps.\"\"\"\n   452→    setup_all_modules()\n   453→\n   454→    n = 100\n   455→    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n   456→                           spread=0.03, temp=1200.0, lifetime=1.0)\n   457→\n   458→    grid_params = build_grid_params()\n   459→    cell_start, cell_end = allocate_cell_tables()\n   460→\n   461→    # Run 500 steps (~0.5s): should still have most particles alive\n   462→    for step in range(500):\n   463→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   464→\n   465→    pi_h = w[\"packed_info\"].get()\n   466→    alive_500 = np.sum(pi_h != 0)\n   467→    # Should still have a fair number alive (lifetime=1.0s, only 0.5s elapsed)\n   468→    assert alive_500 > n * 0.3, \\\n   469→        f\"Only {alive_500}/{n} fire particles alive at t=0.5s (expected >30%)\"\n   470→\n   471→    # Run another 600 steps (~1.1s total): most should be dead\n   472→    for step in range(500, 1100):\n   473→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   474→\n   475→    pi_h = w[\"packed_info\"].get()\n   476→    alive_1100 = np.sum(pi_h != 0)\n   477→    assert alive_1100 < n * 0.3, \\\n   478→        f\"Still {alive_1100}/{n} fire particles alive at t=1.1s (expected <30%)\"\n   479→\n   480→    print(f\"PASS: test_fire_properties (alive@0.5s={alive_500}, alive@1.1s={alive_1100})\")\n   481→\n   482→\n   483→def test_smoke_properties():\n   484→    \"\"\"SMOKE: T=500K, lifetime ~3s. No chemical interactions.\"\"\"\n   485→    setup_all_modules()\n   486→\n   487→    n = 100\n   488→    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n   489→                           spread=0.03, temp=500.0, lifetime=3.0)\n   490→\n   491→    grid_params = build_grid_params()\n   492→    cell_start, cell_end = allocate_cell_tables()\n   493→\n   494→    # Run 1000 steps (~1.0s): all should still be alive\n   495→    for step in range(1000):\n   496→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   497→\n   498→    pi_h = w[\"packed_info\"].get()\n   499→    alive_1000 = np.sum(pi_h != 0)\n   500→    assert alive_1000 > n * 0.9, \\\n   501→        f\"Only {alive_1000}/{n} smoke particles alive at t=1.0s (expected >90%, lifetime=3s)\"\n   502→\n   503→    # Verify particles are rising due to buoyancy (T=500K > 293K)\n   504→    y_final = w[\"position\"].get()[:, 1]\n   505→    alive_mask = pi_h != 0\n   506→    mean_y = np.mean(y_final[alive_mask])\n   507→    assert mean_y > 0.0, \\\n   508→        f\"Mean y position {mean_y:.4f} not positive -- smoke should rise\"\n   509→\n   510→    print(f\"PASS: test_smoke_properties (alive@1.0s={alive_1000}, mean_y={mean_y:.4f})\")\n   511→\n   512→\n   513→def test_steam_condensation():\n   514→    \"\"\"STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions).\n   515→\n   516→    Spawn steam particles at T just above 373K. After cooling, some should\n   517→    transition to WATER.\n   518→    \"\"\"\n   519→    setup_all_modules()\n   520→\n   521→    n = 100\n   522→    # Start at 374K (just above boiling point) so cooling kicks in quickly\n   523→    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n   524→                           spread=0.03, temp=374.0, lifetime=10.0)\n   525→\n   526→    grid_params = build_grid_params()\n   527→    cell_start, cell_end = allocate_cell_tables()\n   528→\n   529→    # Run 500 steps (~0.5s): cooling should bring some below 373K\n   530→    # cool_rate=0.1, T_ambient=293: dT/dt = -0.1*(T-293) ~ -8.1 K/s\n   531→    # After 0.5s: T ~ 374 - 4.05 ~ 370K (below 373K threshold)\n   532→    for step in range(500):\n   533→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   534→\n   535→    pi_h = w[\"packed_info\"].get()\n   536→    water_count = 0\n   537→    steam_count = 0\n   538→    for pi in pi_h:\n   539→        mat_id = GET_MATERIAL_ID(int(pi))\n   540→        if mat_id == WATER:\n   541→            water_count += 1\n   542→        elif mat_id == STEAM:\n   543→            steam_count += 1\n   544→\n   545→    # Some should have condensed to water\n   546→    assert water_count > 0, \\\n   547→        f\"No steam particles condensed to water after 500 steps (steam={steam_count})\"\n   548→\n   549→    print(f\"PASS: test_steam_condensation (water={water_count}, steam={steam_count})\")\n   550→\n   551→\n   552→def test_gas_no_clumping():\n   553→    \"\"\"Gas particles don't collapse into clumps -- linear EOS provides gentle repulsion.\n   554→\n   555→    Spawn gas particles in a tight cluster. After many steps, they should\n   556→    spread out (not collapse to a single point).\n   557→    \"\"\"\n   558→    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity\n   559→\n   560→    n = 50\n   561→    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n   562→                           spread=0.01, temp=500.0, lifetime=10.0)\n   563→\n   564→    grid_params = build_grid_params()\n   565→    cell_start, cell_end = allocate_cell_tables()\n   566→\n   567→    # Measure initial spread (std dev of positions)\n   568→    pos_init = w[\"position\"].get()[:, :3]\n   569→    std_init = np.std(pos_init)\n   570→\n   571→    # Run 200 steps\n   572→    for step in range(200):\n   573→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   574→\n   575→    pos_final = w[\"position\"].get()[:, :3]\n   576→    alive_mask = w[\"packed_info\"].get() != 0\n   577→    std_final = np.std(pos_final[alive_mask])\n   578→\n   579→    # Spread should NOT decrease significantly (particles shouldn't collapse)\n   580→    assert std_final >= std_init * 0.5, \\\n   581→        f\"Gas cloud collapsed: std went from {std_init:.6f} to {std_final:.6f}\"\n   582→\n   583→    print(f\"PASS: test_gas_no_clumping (std_init={std_init:.6f}, std_final={std_final:.6f})\")\n   584→\n   585→\n   586→def test_mixed_gas_fluid_granular_no_nan():\n   587→    \"\"\"No NaN or explosions with mixed gas + fluid + granular over 5000 steps.\n   588→\n   589→    This is the main stability test. Spawn particles of all three behavior\n   590→    classes and run for 5000 steps. Verify no NaN and no escaped particles.\n   591→    \"\"\"\n   592→    setup_all_modules()\n   593→\n   594→    grid_params = build_grid_params()\n   595→    cell_start, cell_end = allocate_cell_tables()\n   596→\n   597→    # Create mixed particles\n   598→    n_water = 100\n   599→    n_sand = 100\n   600→    n_fire = 50\n   601→    n_smoke = 50\n   602→    n_steam = 50\n   603→    n_total = n_water + n_sand + n_fire + n_smoke + n_steam\n   604→\n   605→    np.random.seed(123)\n   606→\n   607→    pos = np.zeros((n_total, 4), dtype=np.float32)\n   608→    vel = np.zeros((n_total, 4), dtype=np.float32)\n   609→    mass = np.zeros(n_total, dtype=np.float32)\n   610→    packed_info = np.zeros(n_total, dtype=np.uint32)\n   611→    temperature = np.full(n_total, 293.0, dtype=np.float32)\n   612→    health = np.full(n_total, 1.0, dtype=np.float32)\n   613→    lifetime = np.zeros(n_total, dtype=np.float32)\n   614→    sleep_counter = np.zeros(n_total, dtype=np.uint8)\n   615→    shear_rate = np.zeros(n_total, dtype=np.float32)\n   616→    color = np.zeros((n_total, 4), dtype=np.float32)\n   617→    color[:, 3] = 1.0\n   618→\n   619→    idx = 0\n   620→\n   621→    # Water: spawn in a cube at y=0.3\n   622→    for i in range(n_water):\n   623→        pos[idx] = [\n   624→            np.random.uniform(-0.2, 0.2),\n   625→            np.random.uniform(0.2, 0.5),\n   626→            np.random.uniform(-0.2, 0.2),\n   627→            1.0,\n   628→        ]\n   629→        mass[idx] = 1000.0 * SPACING**3\n   630→        packed_info[idx] = MAKE_PACKED(WATER, FLUID)\n   631→        idx += 1\n   632→\n   633→    # Sand: spawn in a bed at y=-0.3\n   634→    for i in range(n_sand):\n   635→        pos[idx] = [\n   636→            np.random.uniform(-0.3, 0.3),\n   637→            np.random.uniform(-0.5, -0.3),\n   638→            np.random.uniform(-0.3, 0.3),\n   639→            1.0,\n   640→        ]\n   641→        mass[idx] = 1600.0 * SPACING**3\n   642→        packed_info[idx] = MAKE_PACKED(SAND, GRANULAR)\n   643→        idx += 1\n   644→\n   645→    # Fire: spawn at y=0\n   646→    for i in range(n_fire):\n   647→        pos[idx] = [\n   648→            np.random.uniform(-0.1, 0.1),\n   649→            np.random.uniform(-0.1, 0.1),\n   650→            np.random.uniform(-0.1, 0.1),\n   651→            1.0,\n   652→        ]\n   653→        mass[idx] = 0.2 * SPACING**3\n   654→        packed_info[idx] = MAKE_PACKED(FIRE, GAS)\n   655→        temperature[idx] = 1200.0\n   656→        lifetime[idx] = 1.0\n   657→        idx += 1\n   658→\n   659→    # Smoke: spawn at y=0.1\n   660→    for i in range(n_smoke):\n   661→        pos[idx] = [\n   662→            np.random.uniform(-0.1, 0.1),\n   663→            np.random.uniform(0.0, 0.2),\n   664→            np.random.uniform(-0.1, 0.1),\n   665→            1.0,\n   666→        ]\n   667→        mass[idx] = 0.3 * SPACING**3\n   668→        packed_info[idx] = MAKE_PACKED(SMOKE, GAS)\n   669→        temperature[idx] = 500.0\n   670→        lifetime[idx] = 3.0\n   671→        idx += 1\n   672→\n   673→    # Steam: spawn at y=0.2\n   674→    for i in range(n_steam):\n   675→        pos[idx] = [\n   676→            np.random.uniform(-0.1, 0.1),\n   677→            np.random.uniform(0.1, 0.3),\n   678→            np.random.uniform(-0.1, 0.1),\n   679→            1.0,\n   680→        ]\n   681→        mass[idx] = 0.6 * SPACING**3\n   682→        packed_info[idx] = MAKE_PACKED(STEAM, GAS)\n   683→        temperature[idx] = 373.0\n   684→        lifetime[idx] = 5.0\n   685→        idx += 1\n   686→\n   687→    pos[:, 3] = 1.0\n   688→\n   689→    w = {\n   690→        \"position\": cupy.asarray(pos),\n   691→        \"velocity\": cupy.asarray(vel),\n   692→        \"veleval\": cupy.asarray(vel.copy()),\n   693→        \"mass\": cupy.asarray(mass),\n   694→        \"packed_info\": cupy.asarray(packed_info),\n   695→        \"temperature\": cupy.asarray(temperature),\n   696→        \"health\": cupy.asarray(health),\n   697→        \"lifetime\": cupy.asarray(lifetime),\n   698→        \"sleep_counter\": cupy.asarray(sleep_counter),\n   699→        \"shear_rate\": cupy.asarray(shear_rate),\n   700→        \"color\": cupy.asarray(color),\n   701→    }\n   702→\n   703→    # Run 5000 steps\n   704→    for step in range(5000):\n   705→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   706→\n   707→        # Check for NaN every 500 steps\n   708→        if (step + 1) % 500 == 0:\n   709→            pos_h = w[\"position\"].get()\n   710→            vel_h = w[\"velocity\"].get()\n   711→            temp_h = w[\"temperature\"].get()\n   712→\n   713→            assert not np.any(np.isnan(pos_h)), \\\n   714→                f\"NaN in positions at step {step+1}\"\n   715→            assert not np.any(np.isnan(vel_h)), \\\n   716→                f\"NaN in velocities at step {step+1}\"\n   717→            assert not np.any(np.isnan(temp_h)), \\\n   718→                f\"NaN in temperatures at step {step+1}\"\n   719→\n   720→            # Check no particles escaped boundaries (pos magnitude < 10)\n   721→            alive_mask = w[\"packed_info\"].get() != 0\n   722→            if np.any(alive_mask):\n   723→                alive_pos = pos_h[alive_mask, :3]\n   724→                max_mag = np.max(np.abs(alive_pos))\n   725→                assert max_mag < 10.0, \\\n   726→                    f\"Particle escaped boundaries at step {step+1}: max |pos|={max_mag:.2f}\"\n   727→\n   728→    print(f\"PASS: test_mixed_gas_fluid_granular_no_nan (5000 steps complete)\")\n   729→\n   730→\n   731→def test_fire_rise_slow_disappear():\n   732→    \"\"\"Spawn 100 fire particles -- they rise, slow down, and disappear after ~1 second.\n   733→\n   734→    Full acceptance criterion test for fire behavior.\n   735→    \"\"\"\n   736→    setup_all_modules()\n   737→\n   738→    n = 100\n   739→    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n   740→                           spread=0.03, temp=1200.0, lifetime=1.0)\n   741→\n   742→    grid_params = build_grid_params()\n   743→    cell_start, cell_end = allocate_cell_tables()\n   744→\n   745→    y_history = []\n   746→    alive_history = []\n   747→\n   748→    # Run 1200 steps (1.2 seconds) in increments of 100\n   749→    for epoch in range(12):\n   750→        for step in range(100):\n   751→            frame = epoch * 100 + step\n   752→            w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=frame)\n   753→\n   754→        pos_h = w[\"position\"].get()\n   755→        pi_h = w[\"packed_info\"].get()\n   756→        alive_mask = pi_h != 0\n   757→        alive_count = np.sum(alive_mask)\n   758→        mean_y = np.mean(pos_h[alive_mask, 1]) if alive_count > 0 else 0.0\n   759→        y_history.append(mean_y)\n   760→        alive_history.append(int(alive_count))\n   761→\n   762→    # Check 1: particles rose (mean y at epoch 2 > epoch 0)\n   763→    assert y_history[2] > y_history[0], \\\n   764→        f\"Fire particles didn't rise: y@200steps={y_history[0]:.4f}, y@400steps={y_history[2]:.4f}\"\n   765→\n   766→    # Check 2: most disappeared by epoch 11 (~1.1s)\n   767→    assert alive_history[11] < n * 0.3, \\\n   768→        f\"Too many fire particles still alive at 1.1s: {alive_history[11]}/{n}\"\n   769→\n   770→    # Check 3: no NaN in final state\n   771→    pos_h = w[\"position\"].get()\n   772→    vel_h = w[\"velocity\"].get()\n   773→    assert not np.any(np.isnan(pos_h)), \"NaN in final positions\"\n   774→    assert not np.any(np.isnan(vel_h)), \"NaN in final velocities\"\n   775→\n   776→    print(f\"PASS: test_fire_rise_slow_disappear (alive history: {alive_history})\")\n   777→\n   778→\n   779→def test_steam_rise_and_condense():\n   780→    \"\"\"Spawn 100 steam particles -- they rise and some condense back to water as they cool.\n   781→\n   782→    Full acceptance criterion test for steam behavior.\n   783→    \"\"\"\n   784→    setup_all_modules()\n   785→\n   786→    n = 100\n   787→    # Start at 380K (slightly above boiling point) to allow realistic cooling\n   788→    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n   789→                           spread=0.03, temp=380.0, lifetime=10.0)\n   790→\n   791→    grid_params = build_grid_params()\n   792→    cell_start, cell_end = allocate_cell_tables()\n   793→\n   794→    # Run 2000 steps (2.0 seconds)\n   795→    for step in range(2000):\n   796→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   797→\n   798→    pi_h = w[\"packed_info\"].get()\n   799→    temp_h = w[\"temperature\"].get()\n   800→    pos_h = w[\"position\"].get()\n   801→\n   802→    water_count = 0\n   803→    steam_count = 0\n   804→    dead_count = 0\n   805→    for i, pi in enumerate(pi_h):\n   806→        mat_id = GET_MATERIAL_ID(int(pi))\n   807→        if mat_id == WATER:\n   808→            water_count += 1\n   809→        elif mat_id == STEAM:\n   810→            steam_count += 1\n   811→        elif mat_id == DEAD or pi == 0:\n   812→            dead_count += 1\n   813→\n   814→    # Check 1: some condensed to water\n   815→    assert water_count > 0, \\\n   816→        f\"No steam particles condensed (steam={steam_count}, dead={dead_count})\"\n   817→\n   818→    # Check 2: verify rising (water condensed from steam may have fallen back down)\n   819→    alive_mask = pi_h != 0\n   820→    if np.any(alive_mask):\n   821→        mean_y_alive = np.mean(pos_h[alive_mask, 1])\n   822→        # Should be at least slightly elevated (started at y=0)\n   823→        # Note: condensed water falls back, so check is lenient\n   824→\n   825→    # Check 3: no NaN\n   826→    assert not np.any(np.isnan(pos_h)), \"NaN in positions\"\n   827→    assert not np.any(np.isnan(temp_h)), \"NaN in temperatures\"\n   828→\n   829→    print(f\"PASS: test_steam_rise_and_condense (water={water_count}, steam={steam_count}, dead={dead_count})\")\n   830→\n   831→\n   832→# ===========================================================================\n   833→# Main\n   834→# ===========================================================================\n   835→\n   836→if __name__ == \"__main__\":\n   837→    tests = [\n   838→        test_gas_linear_eos,\n   839→        test_gas_buoyancy_rise,\n   840→        test_gas_drag_slowdown,\n   841→        test_fire_properties,\n   842→        test_smoke_properties,\n   843→        test_steam_condensation,\n   844→        test_gas_no_clumping,\n   845→        test_fire_rise_slow_disappear,\n   846→        test_steam_rise_and_condense,\n   847→        test_mixed_gas_fluid_granular_no_nan,\n   848→    ]\n   849→\n   850→    passed = 0\n   851→    failed = 0\n   852→    for test_fn in tests:\n   853→        try:\n   854→            test_fn()\n   855→            passed += 1\n   856→        except Exception as e:\n   857→            print(f\"FAIL: {test_fn.__name__}: {e}\")\n   858→            import traceback\n   859→            traceback.print_exc()\n   860→            failed += 1\n   861→\n   862→    print(f\"\\n{'='*60}\")\n   863→    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)}\")\n   864→    if failed == 0:\n   865→        print(\"All tests passed!\")\n   866→    else:\n   867→        sys.exit(1)\n   868→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"e01bb850-3d98-461b-825e-005d7a10b01f","uuid":"eef70657-f469-4b8e-83c8-cc51922d1a22","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_gas_physics.py","content":"\"\"\"Integration test for US-024: Gas particles with buoyancy, drag, and lifetime.\n\nVerifies gas particles (STEAM, SMOKE, FIRE) use correct linear EOS (gamma=1),\nbuoyancy force, drag, and lifetime decay across Step2, Integrate, and Reactions.\n\nAcceptance criteria:\n  - Gas pressure uses linear EOS: p = k_gas * max(rho - rho0_gas, 0)\n  - Gas buoyancy in Integrate: gas particles rise upward\n  - Gas drag in Integrate: gas particles slow down over time\n  - FIRE: T=1200K, lifetime ~1s, heats nearby wood via exposure_heat\n  - SMOKE: T=500K, lifetime ~3s, no chemical interactions\n  - STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions)\n  - Test: fire particles rise, slow down, and disappear after ~1 second\n  - Test: steam particles rise and some condense to water as they cool\n  - Test: gas particles don't collapse (linear EOS provides gentle repulsion)\n  - No NaN or explosions with mixed gas + fluid + granular over 5000 steps\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport os\nimport sys\n\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom step1 import (\n    SIM_PARAMS_DTYPE,\n    PRECALC_PARAMS_DTYPE,\n    build_sim_params,\n    build_precalc_params,\n    compute_step1,\n)\nfrom step2 import (\n    build_granular_params,\n    compute_step2,\n)\nfrom integrate import integrate\nfrom reactions import compute_reactions\nfrom hash_sort import (\n    GRID_PARAMS_DTYPE,\n    NUM_CELLS,\n    build_grid_params,\n    calc_hash,\n    sort_by_hash,\n)\nfrom build_grid import build_data_struct, allocate_cell_tables\nfrom fused_reorder import fused_reorder\nfrom materials import (\n    FLUID,\n    GRANULAR,\n    GAS,\n    STATIC,\n    DEAD,\n    WATER,\n    SAND,\n    STEAM,\n    SMOKE,\n    FIRE,\n    WOOD,\n    METAL,\n    build_material_array,\n    build_interaction_matrix,\n)\n\n# ---------------------------------------------------------------------------\n# Constants\n# ---------------------------------------------------------------------------\n\nH = 0.04\nSPACING = 0.02\nDT = 0.001\n\n# packed_info helpers\ndef MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n\ndef GET_MATERIAL_ID(p: int) -> int:\n    return p & 0xFF\n\ndef GET_BEHAVIOR(p: int) -> int:\n    return (p >> 8) & 0x3\n\n\n# ---------------------------------------------------------------------------\n# Helper: upload all constant memory to all kernel modules\n# ---------------------------------------------------------------------------\n\ndef setup_all_modules(dt=DT, gravity=(0.0, -9.8, 0.0)):\n    \"\"\"Upload constant memory to step1, step2, integrate, reactions modules.\"\"\"\n    import step1 as s1_mod\n    import step2 as s2_mod\n    import integrate as int_mod\n    import reactions as rx_mod\n\n    sim_params = build_sim_params(\n        smoothing_length=H,\n        particle_mass=0.008,\n        particle_spacing=SPACING,\n        gravity=gravity,\n        dt=dt,\n        restitution=0.3,\n        wall_friction=0.5,\n        world_min=(-1.0, -1.0, -1.0),\n        world_max=(1.0, 1.0, 1.0),\n    )\n    precalc = build_precalc_params(smoothing_length=H, viscosity=1.0)\n    grid_params = build_grid_params()\n    materials = build_material_array()\n    interactions = build_interaction_matrix()\n    granular_params = build_granular_params()\n\n    # Step1\n    s1_mod.upload_grid_params(grid_params)\n    s1_mod.upload_sim_params(sim_params)\n    s1_mod.upload_precalc_params(precalc)\n    s1_mod.upload_materials(materials)\n    s1_mod.upload_interactions(interactions)\n\n    # Step2\n    s2_mod.upload_grid_params(grid_params)\n    s2_mod.upload_sim_params(sim_params)\n    s2_mod.upload_precalc_params(precalc)\n    s2_mod.upload_materials(materials)\n    s2_mod.upload_granular_params(granular_params)\n\n    # Integrate\n    int_mod.upload_sim_params(sim_params)\n    int_mod.upload_materials(materials)\n\n    # Reactions\n    rx_mod.upload_sim_params(sim_params)\n    rx_mod.upload_materials(materials)\n\n    return sim_params, precalc, grid_params, materials, interactions\n\n\ndef make_gas_particles(n, mat_id, pos_center=(0.0, 0.0, 0.0), spread=0.03,\n                       temp=293.0, lifetime=5.0):\n    \"\"\"Create n gas particles near pos_center with some random spread.\"\"\"\n    np.random.seed(42)\n    pos = np.zeros((n, 4), dtype=np.float32)\n    pos[:, 0] = pos_center[0] + np.random.uniform(-spread, spread, n).astype(np.float32)\n    pos[:, 1] = pos_center[1] + np.random.uniform(-spread, spread, n).astype(np.float32)\n    pos[:, 2] = pos_center[2] + np.random.uniform(-spread, spread, n).astype(np.float32)\n    pos[:, 3] = 1.0\n\n    vel = np.zeros((n, 4), dtype=np.float32)\n\n    # Gas mass: rest_density * spacing^3\n    # STEAM rho0=0.6, SMOKE rho0=0.3, FIRE rho0=0.2\n    rho0_map = {STEAM: 0.6, SMOKE: 0.3, FIRE: 0.2}\n    rho0 = rho0_map.get(mat_id, 0.5)\n    mass_val = rho0 * SPACING**3\n\n    mass = np.full(n, mass_val, dtype=np.float32)\n    packed_info = np.full(n, MAKE_PACKED(mat_id, GAS), dtype=np.uint32)\n    temperature = np.full(n, temp, dtype=np.float32)\n    health = np.full(n, 1.0, dtype=np.float32)\n    lt = np.full(n, lifetime, dtype=np.float32)\n    sleep_counter = np.zeros(n, dtype=np.uint8)\n    shear_rate = np.zeros(n, dtype=np.float32)\n    color = np.zeros((n, 4), dtype=np.float32)\n    color[:, 3] = 1.0\n\n    return {\n        \"position\": cupy.asarray(pos),\n        \"velocity\": cupy.asarray(vel),\n        \"veleval\": cupy.asarray(vel.copy()),\n        \"mass\": cupy.asarray(mass),\n        \"packed_info\": cupy.asarray(packed_info),\n        \"temperature\": cupy.asarray(temperature),\n        \"health\": cupy.asarray(health),\n        \"lifetime\": cupy.asarray(lt),\n        \"sleep_counter\": cupy.asarray(sleep_counter),\n        \"shear_rate\": cupy.asarray(shear_rate),\n        \"color\": cupy.asarray(color),\n    }\n\n\ndef run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=0):\n    \"\"\"Run one full simulation step: hash -> sort -> reorder -> build -> step1 -> reactions -> step2 -> integrate.\n\n    w is a dict of unsorted arrays. Returns updated w dict.\n    \"\"\"\n    import hash_sort as hs_mod\n    import build_grid as bg_mod\n\n    n = w[\"position\"].shape[0]\n    if n == 0:\n        return w\n\n    # Hash\n    hashes = cupy.empty(n, dtype=cupy.uint32)\n    hs_mod.upload_grid_params(grid_params)\n    calc_hash(w[\"position\"], hashes)\n\n    # Sort\n    sorted_hashes, sorted_indices = sort_by_hash(hashes)\n\n    # Reorder\n    sorted_pos = cupy.empty_like(w[\"position\"])\n    sorted_vel = cupy.empty_like(w[\"velocity\"])\n    sorted_veleval = cupy.empty_like(w[\"veleval\"])\n    sorted_mass = cupy.empty(n, dtype=cupy.float32)\n    sorted_pi = cupy.empty(n, dtype=cupy.uint32)\n    sorted_temp = cupy.empty(n, dtype=cupy.float32)\n    sorted_health = cupy.empty(n, dtype=cupy.float32)\n    sorted_lifetime = cupy.empty(n, dtype=cupy.float32)\n    sorted_sc = cupy.empty(n, dtype=cupy.uint8)\n    sorted_sr = cupy.empty(n, dtype=cupy.float32)\n    sorted_color = cupy.empty_like(w[\"color\"])\n\n    fused_reorder(\n        n, sorted_indices,\n        w[\"position\"], w[\"velocity\"], w[\"veleval\"],\n        w[\"mass\"], w[\"packed_info\"], w[\"temperature\"],\n        w[\"health\"], w[\"lifetime\"], w[\"color\"],\n        w[\"sleep_counter\"], w[\"shear_rate\"],\n        sorted_pos, sorted_vel, sorted_veleval,\n        sorted_mass, sorted_pi, sorted_temp,\n        sorted_health, sorted_lifetime, sorted_color,\n        sorted_sc, sorted_sr,\n    )\n\n    # Build grid\n    bg_mod.upload_grid_params(grid_params)\n    cell_start.data.memset(0xFF, cell_start.nbytes)\n    cell_end.data.memset(0x00, cell_end.nbytes)\n    build_data_struct(sorted_hashes, cell_start, cell_end)\n\n    # Step1: density, shear_rate, dTdt, exposure\n    density, shear_rate, dTdt, exp_heat, exp_corrode = compute_step1(\n        sorted_pos, sorted_vel, sorted_mass, None, sorted_pi,\n        sorted_temp, cell_start, cell_end,\n    )\n\n    # Reactions\n    compute_reactions(\n        sorted_pi, sorted_temp, sorted_health, sorted_lifetime,\n        sorted_vel, exp_heat, exp_corrode, frame=frame,\n    )\n\n    # Step2\n    sph_force, veleval_out = compute_step2(\n        sorted_pos, sorted_vel, density, sorted_mass, sorted_pi,\n        cell_start, cell_end,\n    )\n\n    # Integrate\n    pos_out, vel_out, color_out, pi_out, sc_out, temp_out = integrate(\n        sorted_pos, sorted_vel, veleval_out, sph_force,\n        sorted_mass, sorted_pi, sorted_temp, sorted_health,\n        sorted_density=density, sorted_shear_rate=shear_rate,\n        sorted_dTdt=dTdt, sorted_sleep_counter=sorted_sc,\n        sort_indexes=sorted_indices,\n        position_out=w[\"position\"],\n        velocity_out=w[\"velocity\"],\n        color_out=w[\"color\"],\n        packed_info_out=w[\"packed_info\"],\n        sleep_counter_out=w[\"sleep_counter\"],\n        temperature_out=w[\"temperature\"],\n    )\n\n    w[\"position\"] = pos_out\n    w[\"velocity\"] = vel_out\n    w[\"color\"] = color_out\n    w[\"packed_info\"] = pi_out\n    w[\"sleep_counter\"] = sc_out\n    w[\"temperature\"] = temp_out\n    # veleval = velocity for next frame (no separate persistence needed)\n    w[\"veleval\"] = w[\"velocity\"].copy()\n\n    return w\n\n\n# ===========================================================================\n# Tests\n# ===========================================================================\n\n\ndef test_gas_linear_eos():\n    \"\"\"Gas pressure uses linear EOS: p = k_gas * max(rho - rho0, 0).\n\n    Two GAS particles compressed (closer than rest spacing) should produce\n    a positive repulsive force. The key check is that force exists and is\n    directed outward (separation).\n    \"\"\"\n    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity for pure EOS test\n\n    # Two STEAM particles close together (within h)\n    n = 2\n    sep = 0.02  # within h=0.04\n    pos = np.array([\n        [-sep/2, 0.0, 0.0, 1.0],\n        [sep/2, 0.0, 0.0, 1.0],\n    ], dtype=np.float32)\n    vel = np.zeros((n, 4), dtype=np.float32)\n    rho0 = 0.6  # STEAM rest density\n    mass_val = rho0 * SPACING**3\n    mass = np.full(n, mass_val, dtype=np.float32)\n    packed_info = np.full(n, MAKE_PACKED(STEAM, GAS), dtype=np.uint32)\n\n    d_pos = cupy.asarray(pos)\n    d_vel = cupy.asarray(vel)\n    d_mass = cupy.asarray(mass)\n    d_pi = cupy.asarray(packed_info)\n\n    # Build grid for these 2 particles\n    grid_params = build_grid_params()\n    import hash_sort as hs_mod\n    import build_grid as bg_mod\n    hs_mod.upload_grid_params(grid_params)\n    bg_mod.upload_grid_params(grid_params)\n\n    hashes = cupy.empty(n, dtype=cupy.uint32)\n    calc_hash(d_pos, hashes)\n    sorted_hashes, sorted_indices = sort_by_hash(hashes)\n\n    # Reorder (trivial for 2 particles)\n    s_pos = d_pos[sorted_indices]\n    s_vel = d_vel[sorted_indices]\n    s_mass = d_mass[sorted_indices]\n    s_pi = d_pi[sorted_indices]\n\n    cell_start, cell_end = allocate_cell_tables()\n    cell_start.data.memset(0xFF, cell_start.nbytes)\n    cell_end.data.memset(0x00, cell_end.nbytes)\n    build_data_struct(sorted_hashes, cell_start, cell_end)\n\n    # Step1: density\n    s_temp = cupy.full(n, 373.0, dtype=cupy.float32)\n    density, _, _, _, _ = compute_step1(\n        s_pos, s_vel, s_mass, None, s_pi, s_temp, cell_start, cell_end,\n    )\n\n    # Step2: force\n    sph_force, veleval_out = compute_step2(\n        s_pos, s_vel, density, s_mass, s_pi, cell_start, cell_end,\n    )\n\n    force_h = sph_force.get()\n    # Particles should be pushed apart: particle 0 (left) gets negative x force,\n    # particle 1 (right) gets positive x force (Newton's 3rd law)\n    # OR both get repulsive force away from each other\n    f0x = force_h[0, 0]\n    f1x = force_h[1, 0]\n\n    # Forces should be roughly opposite (Newton's 3rd law)\n    assert abs(f0x + f1x) < 0.1 * max(abs(f0x), abs(f1x), 1e-6), \\\n        f\"Newton's 3rd law violation: f0x={f0x}, f1x={f1x}\"\n\n    # At least one should be non-zero (EOS produces pressure)\n    assert abs(f0x) > 1e-10 or abs(f1x) > 1e-10, \\\n        f\"Zero forces: linear EOS not producing pressure for compressed gas\"\n\n    print(\"PASS: test_gas_linear_eos\")\n\n\ndef test_gas_buoyancy_rise():\n    \"\"\"Gas particles rise upward due to buoyancy: accel.y += beta*(T-293)*g.\n\n    Spawn 100 fire particles (T=1200K) at origin with zero velocity.\n    After several integration steps, y position should increase.\n    \"\"\"\n    setup_all_modules(gravity=(0.0, -9.8, 0.0))\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    w = make_gas_particles(100, FIRE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=1200.0, lifetime=5.0)\n\n    # Record initial y positions\n    y_initial = w[\"position\"].get()[:, 1].copy()\n\n    # Run 50 steps\n    for step in range(50):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    y_final = w[\"position\"].get()[:, 1]\n\n    # All (or most) fire particles should have risen\n    # Buoyancy = 0.01 * (1200 - 293) * 9.81 = 0.01 * 907 * 9.81 ~= 89 m/s^2 upward\n    # After 50 steps of dt=0.001: ~0.05s of sim time\n    # Expected velocity ~= 89 * 0.05 * drag_reduction\n    alive_mask = w[\"packed_info\"].get() != 0\n    y_diff = y_final[alive_mask] - y_initial[alive_mask]\n    risen_count = np.sum(y_diff > 0)\n    total_alive = np.sum(alive_mask)\n\n    assert total_alive > 0, \"All particles died unexpectedly\"\n    assert risen_count > total_alive * 0.8, \\\n        f\"Only {risen_count}/{total_alive} fire particles rose (expected >80%)\"\n\n    mean_rise = np.mean(y_diff[y_diff > 0])\n    assert mean_rise > 0.001, \\\n        f\"Mean rise {mean_rise:.6f} too small -- buoyancy may not be working\"\n\n    print(f\"PASS: test_gas_buoyancy_rise (mean rise={mean_rise:.4f}, {risen_count}/{total_alive} rose)\")\n\n\ndef test_gas_drag_slowdown():\n    \"\"\"Gas particles slow down over time due to drag: vel *= (1 - c_drag * dt).\n\n    Spawn gas particles with an initial horizontal velocity and check that\n    velocity magnitude decreases over time.\n    \"\"\"\n    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity to isolate drag\n\n    n = 50\n    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.02, temp=500.0, lifetime=10.0)\n\n    # Give initial velocity in x direction\n    vel_init = np.zeros((n, 4), dtype=np.float32)\n    vel_init[:, 0] = 1.0  # 1 m/s in x\n    w[\"velocity\"] = cupy.asarray(vel_init)\n    w[\"veleval\"] = cupy.asarray(vel_init.copy())\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Measure velocity after 100 steps\n    for step in range(100):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    vel_final = w[\"velocity\"].get()\n    alive_mask = w[\"packed_info\"].get() != 0\n\n    # c_drag=2.0, dt=0.001 -> factor = 1 - 2.0*0.001 = 0.998 per step\n    # After 100 steps: expected ~0.998^100 = ~0.818 of original\n    # But SPH forces also act, so we just check it's significantly less than 1.0\n    vx_alive = vel_final[alive_mask, 0]\n    if len(vx_alive) > 0:\n        mean_vx = np.mean(np.abs(vx_alive))\n        assert mean_vx < 0.95, \\\n            f\"Mean |vx|={mean_vx:.4f} too high -- drag may not be working\"\n        assert mean_vx > 0.01, \\\n            f\"Mean |vx|={mean_vx:.6f} too low -- particles should still be moving\"\n\n    print(f\"PASS: test_gas_drag_slowdown (mean |vx|={mean_vx:.4f})\")\n\n\ndef test_fire_properties():\n    \"\"\"FIRE: T=1200K, lifetime ~1s. Fire particles should disappear after ~1000 steps.\"\"\"\n    setup_all_modules()\n\n    n = 100\n    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=1200.0, lifetime=1.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 500 steps (~0.5s): should still have most particles alive\n    for step in range(500):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    alive_500 = np.sum(pi_h != 0)\n    # Should still have a fair number alive (lifetime=1.0s, only 0.5s elapsed)\n    assert alive_500 > n * 0.3, \\\n        f\"Only {alive_500}/{n} fire particles alive at t=0.5s (expected >30%)\"\n\n    # Run another 600 steps (~1.1s total): most should be dead\n    for step in range(500, 1100):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    alive_1100 = np.sum(pi_h != 0)\n    assert alive_1100 < n * 0.3, \\\n        f\"Still {alive_1100}/{n} fire particles alive at t=1.1s (expected <30%)\"\n\n    print(f\"PASS: test_fire_properties (alive@0.5s={alive_500}, alive@1.1s={alive_1100})\")\n\n\ndef test_smoke_properties():\n    \"\"\"SMOKE: T=500K, lifetime ~3s. No chemical interactions.\"\"\"\n    setup_all_modules()\n\n    n = 100\n    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=500.0, lifetime=3.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 1000 steps (~1.0s): all should still be alive\n    for step in range(1000):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    alive_1000 = np.sum(pi_h != 0)\n    assert alive_1000 > n * 0.9, \\\n        f\"Only {alive_1000}/{n} smoke particles alive at t=1.0s (expected >90%, lifetime=3s)\"\n\n    # Verify particles are rising due to buoyancy (T=500K > 293K)\n    y_final = w[\"position\"].get()[:, 1]\n    alive_mask = pi_h != 0\n    mean_y = np.mean(y_final[alive_mask])\n    assert mean_y > 0.0, \\\n        f\"Mean y position {mean_y:.4f} not positive -- smoke should rise\"\n\n    print(f\"PASS: test_smoke_properties (alive@1.0s={alive_1000}, mean_y={mean_y:.4f})\")\n\n\ndef test_steam_condensation():\n    \"\"\"STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions).\n\n    Spawn steam particles at T just above 373K. After cooling, some should\n    transition to WATER.\n    \"\"\"\n    setup_all_modules()\n\n    n = 100\n    # Start at 374K (just above boiling point) so cooling kicks in quickly\n    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=374.0, lifetime=10.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 500 steps (~0.5s): cooling should bring some below 373K\n    # cool_rate=0.1, T_ambient=293: dT/dt = -0.1*(T-293) ~ -8.1 K/s\n    # After 0.5s: T ~ 374 - 4.05 ~ 370K (below 373K threshold)\n    for step in range(500):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    water_count = 0\n    steam_count = 0\n    for pi in pi_h:\n        mat_id = GET_MATERIAL_ID(int(pi))\n        if mat_id == WATER:\n            water_count += 1\n        elif mat_id == STEAM:\n            steam_count += 1\n\n    # Some should have condensed to water\n    assert water_count > 0, \\\n        f\"No steam particles condensed to water after 500 steps (steam={steam_count})\"\n\n    print(f\"PASS: test_steam_condensation (water={water_count}, steam={steam_count})\")\n\n\ndef test_gas_no_clumping():\n    \"\"\"Gas particles don't collapse into clumps -- linear EOS provides gentle repulsion.\n\n    Spawn gas particles in a tight cluster. After many steps, they should\n    spread out (not collapse to a single point).\n    \"\"\"\n    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity\n\n    n = 50\n    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.01, temp=500.0, lifetime=10.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Measure initial spread (std dev of positions)\n    pos_init = w[\"position\"].get()[:, :3]\n    std_init = np.std(pos_init)\n\n    # Run 200 steps\n    for step in range(200):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pos_final = w[\"position\"].get()[:, :3]\n    alive_mask = w[\"packed_info\"].get() != 0\n    std_final = np.std(pos_final[alive_mask])\n\n    # Spread should NOT decrease significantly (particles shouldn't collapse)\n    assert std_final >= std_init * 0.5, \\\n        f\"Gas cloud collapsed: std went from {std_init:.6f} to {std_final:.6f}\"\n\n    print(f\"PASS: test_gas_no_clumping (std_init={std_init:.6f}, std_final={std_final:.6f})\")\n\n\ndef test_mixed_gas_fluid_granular_no_nan():\n    \"\"\"No NaN or explosions with mixed gas + fluid + granular over 5000 steps.\n\n    This is the main stability test. Spawn particles of all three behavior\n    classes and run for 5000 steps. Verify no NaN and no escaped particles.\n    \"\"\"\n    setup_all_modules()\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Create mixed particles\n    n_water = 100\n    n_sand = 100\n    n_fire = 50\n    n_smoke = 50\n    n_steam = 50\n    n_total = n_water + n_sand + n_fire + n_smoke + n_steam\n\n    np.random.seed(123)\n\n    pos = np.zeros((n_total, 4), dtype=np.float32)\n    vel = np.zeros((n_total, 4), dtype=np.float32)\n    mass = np.zeros(n_total, dtype=np.float32)\n    packed_info = np.zeros(n_total, dtype=np.uint32)\n    temperature = np.full(n_total, 293.0, dtype=np.float32)\n    health = np.full(n_total, 1.0, dtype=np.float32)\n    lifetime = np.zeros(n_total, dtype=np.float32)\n    sleep_counter = np.zeros(n_total, dtype=np.uint8)\n    shear_rate = np.zeros(n_total, dtype=np.float32)\n    color = np.zeros((n_total, 4), dtype=np.float32)\n    color[:, 3] = 1.0\n\n    idx = 0\n\n    # Water: spawn in a cube at y=0.3\n    for i in range(n_water):\n        pos[idx] = [\n            np.random.uniform(-0.2, 0.2),\n            np.random.uniform(0.2, 0.5),\n            np.random.uniform(-0.2, 0.2),\n            1.0,\n        ]\n        mass[idx] = 1000.0 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(WATER, FLUID)\n        idx += 1\n\n    # Sand: spawn in a bed at y=-0.3\n    for i in range(n_sand):\n        pos[idx] = [\n            np.random.uniform(-0.3, 0.3),\n            np.random.uniform(-0.5, -0.3),\n            np.random.uniform(-0.3, 0.3),\n            1.0,\n        ]\n        mass[idx] = 1600.0 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(SAND, GRANULAR)\n        idx += 1\n\n    # Fire: spawn at y=0\n    for i in range(n_fire):\n        pos[idx] = [\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(-0.1, 0.1),\n            1.0,\n        ]\n        mass[idx] = 0.2 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(FIRE, GAS)\n        temperature[idx] = 1200.0\n        lifetime[idx] = 1.0\n        idx += 1\n\n    # Smoke: spawn at y=0.1\n    for i in range(n_smoke):\n        pos[idx] = [\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(0.0, 0.2),\n            np.random.uniform(-0.1, 0.1),\n            1.0,\n        ]\n        mass[idx] = 0.3 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(SMOKE, GAS)\n        temperature[idx] = 500.0\n        lifetime[idx] = 3.0\n        idx += 1\n\n    # Steam: spawn at y=0.2\n    for i in range(n_steam):\n        pos[idx] = [\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(0.1, 0.3),\n            np.random.uniform(-0.1, 0.1),\n            1.0,\n        ]\n        mass[idx] = 0.6 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(STEAM, GAS)\n        temperature[idx] = 373.0\n        lifetime[idx] = 5.0\n        idx += 1\n\n    pos[:, 3] = 1.0\n\n    w = {\n        \"position\": cupy.asarray(pos),\n        \"velocity\": cupy.asarray(vel),\n        \"veleval\": cupy.asarray(vel.copy()),\n        \"mass\": cupy.asarray(mass),\n        \"packed_info\": cupy.asarray(packed_info),\n        \"temperature\": cupy.asarray(temperature),\n        \"health\": cupy.asarray(health),\n        \"lifetime\": cupy.asarray(lifetime),\n        \"sleep_counter\": cupy.asarray(sleep_counter),\n        \"shear_rate\": cupy.asarray(shear_rate),\n        \"color\": cupy.asarray(color),\n    }\n\n    # Run 5000 steps\n    for step in range(5000):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n        # Check for NaN every 500 steps\n        if (step + 1) % 500 == 0:\n            pos_h = w[\"position\"].get()\n            vel_h = w[\"velocity\"].get()\n            temp_h = w[\"temperature\"].get()\n\n            assert not np.any(np.isnan(pos_h)), \\\n                f\"NaN in positions at step {step+1}\"\n            assert not np.any(np.isnan(vel_h)), \\\n                f\"NaN in velocities at step {step+1}\"\n            assert not np.any(np.isnan(temp_h)), \\\n                f\"NaN in temperatures at step {step+1}\"\n\n            # Check no particles escaped boundaries (pos magnitude < 10)\n            alive_mask = w[\"packed_info\"].get() != 0\n            if np.any(alive_mask):\n                alive_pos = pos_h[alive_mask, :3]\n                max_mag = np.max(np.abs(alive_pos))\n                assert max_mag < 10.0, \\\n                    f\"Particle escaped boundaries at step {step+1}: max |pos|={max_mag:.2f}\"\n\n    print(f\"PASS: test_mixed_gas_fluid_granular_no_nan (5000 steps complete)\")\n\n\ndef test_fire_rise_slow_disappear():\n    \"\"\"Spawn 100 fire particles -- they rise, slow down, and disappear after ~1 second.\n\n    Full acceptance criterion test for fire behavior.\n    \"\"\"\n    setup_all_modules()\n\n    n = 100\n    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=1200.0, lifetime=1.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    y_history = []\n    alive_history = []\n\n    # Run 1200 steps (1.2 seconds) in increments of 100\n    for epoch in range(12):\n        for step in range(100):\n            frame = epoch * 100 + step\n            w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=frame)\n\n        pos_h = w[\"position\"].get()\n        pi_h = w[\"packed_info\"].get()\n        alive_mask = pi_h != 0\n        alive_count = np.sum(alive_mask)\n        mean_y = np.mean(pos_h[alive_mask, 1]) if alive_count > 0 else 0.0\n        y_history.append(mean_y)\n        alive_history.append(int(alive_count))\n\n    # Check 1: particles rose (mean y at epoch 2 > epoch 0)\n    assert y_history[2] > y_history[0], \\\n        f\"Fire particles didn't rise: y@200steps={y_history[0]:.4f}, y@400steps={y_history[2]:.4f}\"\n\n    # Check 2: most disappeared by epoch 11 (~1.1s)\n    assert alive_history[11] < n * 0.3, \\\n        f\"Too many fire particles still alive at 1.1s: {alive_history[11]}/{n}\"\n\n    # Check 3: no NaN in final state\n    pos_h = w[\"position\"].get()\n    vel_h = w[\"velocity\"].get()\n    assert not np.any(np.isnan(pos_h)), \"NaN in final positions\"\n    assert not np.any(np.isnan(vel_h)), \"NaN in final velocities\"\n\n    print(f\"PASS: test_fire_rise_slow_disappear (alive history: {alive_history})\")\n\n\ndef test_steam_rise_and_condense():\n    \"\"\"Spawn 100 steam particles -- they rise and some condense back to water as they cool.\n\n    Full acceptance criterion test for steam behavior.\n    \"\"\"\n    setup_all_modules()\n\n    n = 100\n    # Start at 380K (slightly above boiling point) to allow realistic cooling\n    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=380.0, lifetime=10.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 2000 steps (2.0 seconds)\n    for step in range(2000):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    temp_h = w[\"temperature\"].get()\n    pos_h = w[\"position\"].get()\n\n    water_count = 0\n    steam_count = 0\n    dead_count = 0\n    for i, pi in enumerate(pi_h):\n        mat_id = GET_MATERIAL_ID(int(pi))\n        if mat_id == WATER:\n            water_count += 1\n        elif mat_id == STEAM:\n            steam_count += 1\n        elif mat_id == DEAD or pi == 0:\n            dead_count += 1\n\n    # Check 1: some condensed to water\n    assert water_count > 0, \\\n        f\"No steam particles condensed (steam={steam_count}, dead={dead_count})\"\n\n    # Check 2: verify rising (water condensed from steam may have fallen back down)\n    alive_mask = pi_h != 0\n    if np.any(alive_mask):\n        mean_y_alive = np.mean(pos_h[alive_mask, 1])\n        # Should be at least slightly elevated (started at y=0)\n        # Note: condensed water falls back, so check is lenient\n\n    # Check 3: no NaN\n    assert not np.any(np.isnan(pos_h)), \"NaN in positions\"\n    assert not np.any(np.isnan(temp_h)), \"NaN in temperatures\"\n\n    print(f\"PASS: test_steam_rise_and_condense (water={water_count}, steam={steam_count}, dead={dead_count})\")\n\n\n# ===========================================================================\n# Main\n# ===========================================================================\n\nif __name__ == \"__main__\":\n    tests = [\n        test_gas_linear_eos,\n        test_gas_buoyancy_rise,\n        test_gas_drag_slowdown,\n        test_fire_properties,\n        test_smoke_properties,\n        test_steam_condensation,\n        test_gas_no_clumping,\n        test_fire_rise_slow_disappear,\n        test_steam_rise_and_condense,\n        test_mixed_gas_fluid_granular_no_nan,\n    ]\n\n    passed = 0\n    failed = 0\n    for test_fn in tests:\n        try:\n            test_fn()\n            passed += 1\n        except Exception as e:\n            print(f\"FAIL: {test_fn.__name__}: {e}\")\n            import traceback\n            traceback.print_exc()\n          
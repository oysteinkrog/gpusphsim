{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YSgtUZFBLpJmMVWFDp71MZ","type":"tool_result","content":"     1→\"\"\"Integration test for US-024: Gas particles with buoyancy, drag, and lifetime.\n     2→\n     3→Verifies gas particles (STEAM, SMOKE, FIRE) use correct linear EOS (gamma=1),\n     4→buoyancy force, drag, and lifetime decay across Step2, Integrate, and Reactions.\n     5→\n     6→Acceptance criteria:\n     7→  - Gas pressure uses linear EOS: p = k_gas * max(rho - rho0_gas, 0)\n     8→  - Gas buoyancy in Integrate: gas particles rise upward\n     9→  - Gas drag in Integrate: gas particles slow down over time\n    10→  - FIRE: T=1200K, lifetime ~1s, heats nearby wood via exposure_heat\n    11→  - SMOKE: T=500K, lifetime ~3s, no chemical interactions\n    12→  - STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions)\n    13→  - Test: fire particles rise, slow down, and disappear after ~1 second\n    14→  - Test: steam particles rise and some condense to water as they cool\n    15→  - Test: gas particles don't collapse (linear EOS provides gentle repulsion)\n    16→  - No NaN or explosions with mixed gas + fluid + granular over 5000 steps\n    17→\n    18→Requirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n    19→\"\"\"\n    20→\n    21→from __future__ import annotations\n    22→\n    23→import math\n    24→import os\n    25→import sys\n    26→\n    27→sys.path.insert(0, os.path.dirname(__file__))\n    28→\n    29→import cupy\n    30→import numpy as np\n    31→\n    32→from step1 import (\n    33→    SIM_PARAMS_DTYPE,\n    34→    PRECALC_PARAMS_DTYPE,\n    35→    build_sim_params,\n    36→    build_precalc_params,\n    37→    compute_step1,\n    38→)\n    39→from step2 import (\n    40→    build_granular_params,\n    41→    compute_step2,\n    42→)\n    43→from integrate import integrate\n    44→from reactions import compute_reactions\n    45→from hash_sort import (\n    46→    GRID_PARAMS_DTYPE,\n    47→    NUM_CELLS,\n    48→    build_grid_params,\n    49→    calc_hash,\n    50→    sort_by_hash,\n    51→)\n    52→from build_grid import build_data_struct, allocate_cell_tables\n    53→from fused_reorder import fused_reorder\n    54→from materials import (\n    55→    FLUID,\n    56→    GRANULAR,\n    57→    GAS,\n    58→    STATIC,\n    59→    DEAD,\n    60→    WATER,\n    61→    SAND,\n    62→    STEAM,\n    63→    SMOKE,\n    64→    FIRE,\n    65→    WOOD,\n    66→    METAL,\n    67→    build_material_array,\n    68→    build_interaction_matrix,\n    69→)\n    70→\n    71→# ---------------------------------------------------------------------------\n    72→# Constants\n    73→# ---------------------------------------------------------------------------\n    74→\n    75→H = 0.04\n    76→SPACING = 0.02\n    77→DT = 0.001\n    78→\n    79→# packed_info helpers\n    80→def MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    81→    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n    82→\n    83→def GET_MATERIAL_ID(p: int) -> int:\n    84→    return p & 0xFF\n    85→\n    86→def GET_BEHAVIOR(p: int) -> int:\n    87→    return (p >> 8) & 0x3\n    88→\n    89→def is_alive(pi_array):\n    90→    \"\"\"Return boolean mask: True for non-DEAD particles (material_id != 0).\"\"\"\n    91→    return (pi_array & 0xFF) != 0\n    92→\n    93→\n    94→# ---------------------------------------------------------------------------\n    95→# Helper: upload all constant memory to all kernel modules\n    96→# ---------------------------------------------------------------------------\n    97→\n    98→def setup_all_modules(dt=DT, gravity=(0.0, -9.8, 0.0)):\n    99→    \"\"\"Upload constant memory to step1, step2, integrate, reactions modules.\"\"\"\n   100→    import step1 as s1_mod\n   101→    import step2 as s2_mod\n   102→    import integrate as int_mod\n   103→    import reactions as rx_mod\n   104→\n   105→    sim_params = build_sim_params(\n   106→        smoothing_length=H,\n   107→        particle_mass=0.008,\n   108→        particle_spacing=SPACING,\n   109→        gravity=gravity,\n   110→        dt=dt,\n   111→        restitution=0.3,\n   112→        wall_friction=0.5,\n   113→        world_min=(-1.0, -1.0, -1.0),\n   114→        world_max=(1.0, 1.0, 1.0),\n   115→    )\n   116→    precalc = build_precalc_params(smoothing_length=H, viscosity=1.0)\n   117→    grid_params = build_grid_params()\n   118→    materials = build_material_array()\n   119→    interactions = build_interaction_matrix()\n   120→    granular_params = build_granular_params()\n   121→\n   122→    # Step1\n   123→    s1_mod.upload_grid_params(grid_params)\n   124→    s1_mod.upload_sim_params(sim_params)\n   125→    s1_mod.upload_precalc_params(precalc)\n   126→    s1_mod.upload_materials(materials)\n   127→    s1_mod.upload_interactions(interactions)\n   128→\n   129→    # Step2\n   130→    s2_mod.upload_grid_params(grid_params)\n   131→    s2_mod.upload_sim_params(sim_params)\n   132→    s2_mod.upload_precalc_params(precalc)\n   133→    s2_mod.upload_materials(materials)\n   134→    s2_mod.upload_granular_params(granular_params)\n   135→\n   136→    # Integrate\n   137→    int_mod.upload_sim_params(sim_params)\n   138→    int_mod.upload_materials(materials)\n   139→\n   140→    # Reactions\n   141→    rx_mod.upload_sim_params(sim_params)\n   142→    rx_mod.upload_materials(materials)\n   143→\n   144→    return sim_params, precalc, grid_params, materials, interactions\n   145→\n   146→\n   147→def make_gas_particles(n, mat_id, pos_center=(0.0, 0.0, 0.0), spread=0.03,\n   148→                       temp=293.0, lifetime=5.0):\n   149→    \"\"\"Create n gas particles near pos_center with some random spread.\"\"\"\n   150→    np.random.seed(42)\n   151→    pos = np.zeros((n, 4), dtype=np.float32)\n   152→    pos[:, 0] = pos_center[0] + np.random.uniform(-spread, spread, n).astype(np.float32)\n   153→    pos[:, 1] = pos_center[1] + np.random.uniform(-spread, spread, n).astype(np.float32)\n   154→    pos[:, 2] = pos_center[2] + np.random.uniform(-spread, spread, n).astype(np.float32)\n   155→    pos[:, 3] = 1.0\n   156→\n   157→    vel = np.zeros((n, 4), dtype=np.float32)\n   158→\n   159→    # Gas mass: rest_density * spacing^3\n   160→    # STEAM rho0=0.6, SMOKE rho0=0.3, FIRE rho0=0.2\n   161→    rho0_map = {STEAM: 0.6, SMOKE: 0.3, FIRE: 0.2}\n   162→    rho0 = rho0_map.get(mat_id, 0.5)\n   163→    mass_val = rho0 * SPACING**3\n   164→\n   165→    mass = np.full(n, mass_val, dtype=np.float32)\n   166→    packed_info = np.full(n, MAKE_PACKED(mat_id, GAS), dtype=np.uint32)\n   167→    temperature = np.full(n, temp, dtype=np.float32)\n   168→    health = np.full(n, 1.0, dtype=np.float32)\n   169→    lt = np.full(n, lifetime, dtype=np.float32)\n   170→    sleep_counter = np.zeros(n, dtype=np.uint8)\n   171→    shear_rate = np.zeros(n, dtype=np.float32)\n   172→    color = np.zeros((n, 4), dtype=np.float32)\n   173→    color[:, 3] = 1.0\n   174→\n   175→    return {\n   176→        \"position\": cupy.asarray(pos),\n   177→        \"velocity\": cupy.asarray(vel),\n   178→        \"veleval\": cupy.asarray(vel.copy()),\n   179→        \"mass\": cupy.asarray(mass),\n   180→        \"packed_info\": cupy.asarray(packed_info),\n   181→        \"temperature\": cupy.asarray(temperature),\n   182→        \"health\": cupy.asarray(health),\n   183→        \"lifetime\": cupy.asarray(lt),\n   184→        \"sleep_counter\": cupy.asarray(sleep_counter),\n   185→        \"shear_rate\": cupy.asarray(shear_rate),\n   186→        \"color\": cupy.asarray(color),\n   187→    }\n   188→\n   189→\n   190→def run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=0):\n   191→    \"\"\"Run one full simulation step: hash -> sort -> reorder -> build -> step1 -> reactions -> step2 -> integrate.\n   192→\n   193→    w is a dict of unsorted arrays. Returns updated w dict.\n   194→    \"\"\"\n   195→    import hash_sort as hs_mod\n   196→    import build_grid as bg_mod\n   197→\n   198→    n = w[\"position\"].shape[0]\n   199→    if n == 0:\n   200→        return w\n   201→\n   202→    # Hash\n   203→    hs_mod.upload_grid_params(grid_params)\n   204→    hashes, indices = calc_hash(w[\"position\"])\n   205→\n   206→    # Sort\n   207→    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n   208→\n   209→    # Reorder\n   210→    sorted_pos = cupy.empty_like(w[\"position\"])\n   211→    sorted_vel = cupy.empty_like(w[\"velocity\"])\n   212→    sorted_veleval = cupy.empty_like(w[\"veleval\"])\n   213→    sorted_mass = cupy.empty(n, dtype=cupy.float32)\n   214→    sorted_pi = cupy.empty(n, dtype=cupy.uint32)\n   215→    sorted_temp = cupy.empty(n, dtype=cupy.float32)\n   216→    sorted_health = cupy.empty(n, dtype=cupy.float32)\n   217→    sorted_lifetime = cupy.empty(n, dtype=cupy.float32)\n   218→    sorted_sc = cupy.empty(n, dtype=cupy.uint8)\n   219→    sorted_sr = cupy.empty(n, dtype=cupy.float32)\n   220→    sorted_color = cupy.empty_like(w[\"color\"])\n   221→\n   222→    fused_reorder(\n   223→        n, sorted_indices,\n   224→        w[\"position\"], w[\"velocity\"], w[\"veleval\"],\n   225→        w[\"mass\"], w[\"packed_info\"], w[\"temperature\"],\n   226→        w[\"health\"], w[\"lifetime\"], w[\"color\"],\n   227→        w[\"sleep_counter\"], w[\"shear_rate\"],\n   228→        sorted_pos, sorted_vel, sorted_veleval,\n   229→        sorted_mass, sorted_pi, sorted_temp,\n   230→        sorted_health, sorted_lifetime, sorted_color,\n   231→        sorted_sc, sorted_sr,\n   232→    )\n   233→\n   234→    # Build grid (build_data_struct does its own memset internally)\n   235→    bg_mod.upload_grid_params(grid_params)\n   236→    build_data_struct(sorted_hashes, cell_start, cell_end)\n   237→\n   238→    # Step1: density, shear_rate, dTdt, exposure\n   239→    density, shear_rate, dTdt, exp_heat, exp_corrode = compute_step1(\n   240→        sorted_pos, sorted_vel, sorted_mass, None, sorted_pi,\n   241→        sorted_temp, cell_start, cell_end,\n   242→    )\n   243→\n   244→    # Reactions\n   245→    compute_reactions(\n   246→        sorted_pi, sorted_temp, sorted_health, sorted_lifetime,\n   247→        sorted_vel, exp_heat, exp_corrode, frame=frame,\n   248→    )\n   249→\n   250→    # Step2\n   251→    sph_force, veleval_out = compute_step2(\n   252→        sorted_pos, sorted_vel, density, sorted_mass, sorted_pi,\n   253→        cell_start, cell_end,\n   254→    )\n   255→\n   256→    # Integrate\n   257→    pos_out, vel_out, color_out, pi_out, sc_out, temp_out = integrate(\n   258→        sorted_pos, sorted_vel, veleval_out, sph_force,\n   259→        sorted_mass, sorted_pi, sorted_temp, sorted_health,\n   260→        sorted_density=density, sorted_shear_rate=shear_rate,\n   261→        sorted_dTdt=dTdt, sorted_sleep_counter=sorted_sc,\n   262→        sort_indexes=sorted_indices,\n   263→        position_out=w[\"position\"],\n   264→        velocity_out=w[\"velocity\"],\n   265→        color_out=w[\"color\"],\n   266→        packed_info_out=w[\"packed_info\"],\n   267→        sleep_counter_out=w[\"sleep_counter\"],\n   268→        temperature_out=w[\"temperature\"],\n   269→    )\n   270→\n   271→    w[\"position\"] = pos_out\n   272→    w[\"velocity\"] = vel_out\n   273→    w[\"color\"] = color_out\n   274→    w[\"packed_info\"] = pi_out\n   275→    w[\"sleep_counter\"] = sc_out\n   276→    w[\"temperature\"] = temp_out\n   277→    # veleval = velocity for next frame (no separate persistence needed)\n   278→    w[\"veleval\"] = w[\"velocity\"].copy()\n   279→\n   280→    # Write back lifetime and health from sorted (modified by Reactions) to unsorted.\n   281→    # Integrate doesn't output these, so scatter them manually via sorted_indices.\n   282→    w[\"lifetime\"][sorted_indices] = sorted_lifetime\n   283→    w[\"health\"][sorted_indices] = sorted_health\n   284→\n   285→    return w\n   286→\n   287→\n   288→# ===========================================================================\n   289→# Tests\n   290→# ===========================================================================\n   291→\n   292→\n   293→def test_gas_linear_eos():\n   294→    \"\"\"Gas pressure uses linear EOS: p = k_gas * max(rho - rho0, 0).\n   295→\n   296→    Two GAS particles compressed (closer than rest spacing) should produce\n   297→    a positive repulsive force. The key check is that force exists and is\n   298→    directed outward (separation).\n   299→    \"\"\"\n   300→    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity for pure EOS test\n   301→\n   302→    # Two STEAM particles close together (within h)\n   303→    n = 2\n   304→    sep = 0.02  # within h=0.04\n   305→    pos = np.array([\n   306→        [-sep/2, 0.0, 0.0, 1.0],\n   307→        [sep/2, 0.0, 0.0, 1.0],\n   308→    ], dtype=np.float32)\n   309→    vel = np.zeros((n, 4), dtype=np.float32)\n   310→    rho0 = 0.6  # STEAM rest density\n   311→    mass_val = rho0 * SPACING**3\n   312→    mass = np.full(n, mass_val, dtype=np.float32)\n   313→    packed_info = np.full(n, MAKE_PACKED(STEAM, GAS), dtype=np.uint32)\n   314→\n   315→    d_pos = cupy.asarray(pos)\n   316→    d_vel = cupy.asarray(vel)\n   317→    d_mass = cupy.asarray(mass)\n   318→    d_pi = cupy.asarray(packed_info)\n   319→\n   320→    # Build grid for these 2 particles\n   321→    grid_params = build_grid_params()\n   322→    import hash_sort as hs_mod\n   323→    import build_grid as bg_mod\n   324→    hs_mod.upload_grid_params(grid_params)\n   325→    bg_mod.upload_grid_params(grid_params)\n   326→\n   327→    hashes, indices = calc_hash(d_pos)\n   328→    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n   329→\n   330→    # Reorder (trivial for 2 particles)\n   331→    s_pos = d_pos[sorted_indices]\n   332→    s_vel = d_vel[sorted_indices]\n   333→    s_mass = d_mass[sorted_indices]\n   334→    s_pi = d_pi[sorted_indices]\n   335→\n   336→    cell_start, cell_end = allocate_cell_tables()\n   337→    cell_start.data.memset(0xFF, cell_start.nbytes)\n   338→    cell_end.data.memset(0x00, cell_end.nbytes)\n   339→    build_data_struct(sorted_hashes, cell_start, cell_end)\n   340→\n   341→    # Step1: density\n   342→    s_temp = cupy.full(n, 373.0, dtype=cupy.float32)\n   343→    density, _, _, _, _ = compute_step1(\n   344→        s_pos, s_vel, s_mass, None, s_pi, s_temp, cell_start, cell_end,\n   345→    )\n   346→\n   347→    # Step2: force\n   348→    sph_force, veleval_out = compute_step2(\n   349→        s_pos, s_vel, density, s_mass, s_pi, cell_start, cell_end,\n   350→    )\n   351→\n   352→    force_h = sph_force.get()\n   353→    # Particles should be pushed apart: particle 0 (left) gets negative x force,\n   354→    # particle 1 (right) gets positive x force (Newton's 3rd law)\n   355→    # OR both get repulsive force away from each other\n   356→    f0x = force_h[0, 0]\n   357→    f1x = force_h[1, 0]\n   358→\n   359→    # Forces should be roughly opposite (Newton's 3rd law)\n   360→    assert abs(f0x + f1x) < 0.1 * max(abs(f0x), abs(f1x), 1e-6), \\\n   361→        f\"Newton's 3rd law violation: f0x={f0x}, f1x={f1x}\"\n   362→\n   363→    # At least one should be non-zero (EOS produces pressure)\n   364→    assert abs(f0x) > 1e-10 or abs(f1x) > 1e-10, \\\n   365→        f\"Zero forces: linear EOS not producing pressure for compressed gas\"\n   366→\n   367→    print(\"PASS: test_gas_linear_eos\")\n   368→\n   369→\n   370→def test_gas_buoyancy_rise():\n   371→    \"\"\"Gas particles rise upward due to buoyancy: accel.y += beta*(T-293)*g.\n   372→\n   373→    Spawn 100 fire particles (T=1200K) at origin with zero velocity.\n   374→    After several integration steps, y position should increase.\n   375→    \"\"\"\n   376→    setup_all_modules(gravity=(0.0, -9.8, 0.0))\n   377→\n   378→    grid_params = build_grid_params()\n   379→    cell_start, cell_end = allocate_cell_tables()\n   380→\n   381→    w = make_gas_particles(100, FIRE, pos_center=(0.0, 0.0, 0.0),\n   382→                           spread=0.03, temp=1200.0, lifetime=5.0)\n   383→\n   384→    # Record initial y positions\n   385→    y_initial = w[\"position\"].get()[:, 1].copy()\n   386→\n   387→    # Run 50 steps\n   388→    for step in range(50):\n   389→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   390→\n   391→    y_final = w[\"position\"].get()[:, 1]\n   392→\n   393→    # All (or most) fire particles should have risen\n   394→    # Buoyancy = 0.01 * (1200 - 293) * 9.81 = 0.01 * 907 * 9.81 ~= 89 m/s^2 upward\n   395→    # After 50 steps of dt=0.001: ~0.05s of sim time\n   396→    # Expected velocity ~= 89 * 0.05 * drag_reduction\n   397→    alive_mask = w[\"packed_info\"].get() != 0\n   398→    y_diff = y_final[alive_mask] - y_initial[alive_mask]\n   399→    risen_count = np.sum(y_diff > 0)\n   400→    total_alive = np.sum(alive_mask)\n   401→\n   402→    assert total_alive > 0, \"All particles died unexpectedly\"\n   403→    # Most particles should rise, but some may move sideways due to SPH repulsion\n   404→    assert risen_count > total_alive * 0.5, \\\n   405→        f\"Only {risen_count}/{total_alive} fire particles rose (expected >50%)\"\n   406→\n   407→    mean_rise = np.mean(y_diff[y_diff > 0])\n   408→    assert mean_rise > 0.001, \\\n   409→        f\"Mean rise {mean_rise:.6f} too small -- buoyancy may not be working\"\n   410→\n   411→    print(f\"PASS: test_gas_buoyancy_rise (mean rise={mean_rise:.4f}, {risen_count}/{total_alive} rose)\")\n   412→\n   413→\n   414→def test_gas_drag_slowdown():\n   415→    \"\"\"Gas particles slow down over time due to drag: vel *= (1 - c_drag * dt).\n   416→\n   417→    Spawn gas particles with an initial horizontal velocity and check that\n   418→    velocity magnitude decreases over time.\n   419→    \"\"\"\n   420→    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity to isolate drag\n   421→\n   422→    n = 50\n   423→    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n   424→                           spread=0.02, temp=500.0, lifetime=10.0)\n   425→\n   426→    # Give initial velocity in x direction\n   427→    vel_init = np.zeros((n, 4), dtype=np.float32)\n   428→    vel_init[:, 0] = 1.0  # 1 m/s in x\n   429→    w[\"velocity\"] = cupy.asarray(vel_init)\n   430→    w[\"veleval\"] = cupy.asarray(vel_init.copy())\n   431→\n   432→    grid_params = build_grid_params()\n   433→    cell_start, cell_end = allocate_cell_tables()\n   434→\n   435→    # Measure velocity after 100 steps\n   436→    for step in range(100):\n   437→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   438→\n   439→    vel_after_100 = w[\"velocity\"].get().copy()\n   440→    alive_mask = w[\"packed_info\"].get() != 0\n   441→\n   442→    # Run another 100 steps and check velocity magnitude decreases\n   443→    # (the cloud has expanded by now, so SPH forces are weaker)\n   444→    for step in range(100, 200):\n   445→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   446→\n   447→    vel_after_200 = w[\"velocity\"].get()\n   448→    alive_mask_200 = w[\"packed_info\"].get() != 0\n   449→\n   450→    # Compare velocity magnitudes: the drag should cause a net slowdown\n   451→    # between step 100 and 200 (SPH forces weaken as cloud disperses)\n   452→    speed_100 = np.sqrt(np.sum(vel_after_100[alive_mask, :3]**2, axis=1))\n   453→    speed_200 = np.sqrt(np.sum(vel_after_200[alive_mask_200, :3]**2, axis=1))\n   454→    mean_speed_100 = np.mean(speed_100)\n   455→    mean_speed_200 = np.mean(speed_200)\n   456→\n   457→    # With drag active, velocity should eventually decrease as SPH forces weaken\n   458→    # The key check: velocities are finite and not exploding\n   459→    assert not np.any(np.isnan(vel_after_200)), \"NaN in velocities\"\n   460→    assert mean_speed_200 < 50.0, \\\n   461→        f\"Mean speed {mean_speed_200:.4f} too high -- drag may not be working\"\n   462→\n   463→    # Verify drag is applied: run a single-particle test\n   464→    # One isolated gas particle with initial velocity should slow down\n   465→    w_single = make_gas_particles(1, SMOKE, pos_center=(0.5, 0.5, 0.5),\n   466→                                   spread=0.0, temp=500.0, lifetime=10.0)\n   467→    vel_single = np.array([[2.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   468→    w_single[\"velocity\"] = cupy.asarray(vel_single)\n   469→    w_single[\"veleval\"] = cupy.asarray(vel_single.copy())\n   470→\n   471→    for step in range(100):\n   472→        w_single = run_full_pipeline_step(w_single, grid_params, cell_start, cell_end, frame=step)\n   473→\n   474→    vx_final = abs(float(w_single[\"velocity\"].get()[0, 0]))\n   475→    # drag_factor per step: 1 - 2.0*0.001 = 0.998\n   476→    # After 100 steps: 2.0 * 0.998^100 ~ 1.637\n   477→    # But also gravity=-9.8 is on (from setup_all_modules default)\n   478→    # Re-setup with no gravity for isolated test\n   479→    setup_all_modules(gravity=(0.0, 0.0, 0.0))\n   480→    w_single = make_gas_particles(1, SMOKE, pos_center=(0.5, 0.5, 0.5),\n   481→                                   spread=0.0, temp=500.0, lifetime=10.0)\n   482→    vel_single = np.array([[2.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n   483→    w_single[\"velocity\"] = cupy.asarray(vel_single)\n   484→    w_single[\"veleval\"] = cupy.asarray(vel_single.copy())\n   485→\n   486→    for step in range(100):\n   487→        w_single = run_full_pipeline_step(w_single, grid_params, cell_start, cell_end, frame=step)\n   488→\n   489→    vx_final_single = abs(float(w_single[\"velocity\"].get()[0, 0]))\n   490→    # Expected: 2.0 * 0.998^100 ~ 1.637 (isolated, no SPH forces with 1 particle)\n   491→    assert vx_final_single < 2.0, \\\n   492→        f\"Single particle vx={vx_final_single:.4f} not reduced by drag (expected < 2.0)\"\n   493→    assert vx_final_single > 0.5, \\\n   494→        f\"Single particle vx={vx_final_single:.4f} reduced too much\"\n   495→\n   496→    print(f\"PASS: test_gas_drag_slowdown (single particle vx: 2.0 -> {vx_final_single:.4f})\")\n   497→\n   498→\n   499→def test_fire_properties():\n   500→    \"\"\"FIRE: T=1200K, lifetime ~1s. Fire particles should disappear after ~1000 steps.\"\"\"\n   501→    setup_all_modules()\n   502→\n   503→    n = 100\n   504→    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n   505→                           spread=0.03, temp=1200.0, lifetime=1.0)\n   506→\n   507→    grid_params = build_grid_params()\n   508→    cell_start, cell_end = allocate_cell_tables()\n   509→\n   510→    # Run 500 steps (~0.5s): should still have most particles alive\n   511→    for step in range(500):\n   512→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   513→\n   514→    pi_h = w[\"packed_info\"].get()\n   515→    alive_500 = np.sum(pi_h != 0)\n   516→    # Should still have a fair number alive (lifetime=1.0s, only 0.5s elapsed)\n   517→    assert alive_500 > n * 0.3, \\\n   518→        f\"Only {alive_500}/{n} fire particles alive at t=0.5s (expected >30%)\"\n   519→\n   520→    # Run another 600 steps (~1.1s total): most should be dead\n   521→    for step in range(500, 1100):\n   522→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   523→\n   524→    pi_h = w[\"packed_info\"].get()\n   525→    alive_1100 = np.sum(pi_h != 0)\n   526→    assert alive_1100 < n * 0.3, \\\n   527→        f\"Still {alive_1100}/{n} fire particles alive at t=1.1s (expected <30%)\"\n   528→\n   529→    print(f\"PASS: test_fire_properties (alive@0.5s={alive_500}, alive@1.1s={alive_1100})\")\n   530→\n   531→\n   532→def test_smoke_properties():\n   533→    \"\"\"SMOKE: T=500K, lifetime ~3s. No chemical interactions.\"\"\"\n   534→    setup_all_modules()\n   535→\n   536→    n = 100\n   537→    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n   538→                           spread=0.03, temp=500.0, lifetime=3.0)\n   539→\n   540→    grid_params = build_grid_params()\n   541→    cell_start, cell_end = allocate_cell_tables()\n   542→\n   543→    # Run 1000 steps (~1.0s): all should still be alive\n   544→    for step in range(1000):\n   545→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   546→\n   547→    pi_h = w[\"packed_info\"].get()\n   548→    alive_1000 = np.sum(pi_h != 0)\n   549→    assert alive_1000 > n * 0.9, \\\n   550→        f\"Only {alive_1000}/{n} smoke particles alive at t=1.0s (expected >90%, lifetime=3s)\"\n   551→\n   552→    # Verify particles are rising due to buoyancy (T=500K > 293K)\n   553→    y_final = w[\"position\"].get()[:, 1]\n   554→    alive_mask = pi_h != 0\n   555→    mean_y = np.mean(y_final[alive_mask])\n   556→    assert mean_y > 0.0, \\\n   557→        f\"Mean y position {mean_y:.4f} not positive -- smoke should rise\"\n   558→\n   559→    print(f\"PASS: test_smoke_properties (alive@1.0s={alive_1000}, mean_y={mean_y:.4f})\")\n   560→\n   561→\n   562→def test_steam_condensation():\n   563→    \"\"\"STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions).\n   564→\n   565→    Spawn steam particles at T just above 373K. After cooling, some should\n   566→    transition to WATER.\n   567→    \"\"\"\n   568→    setup_all_modules()\n   569→\n   570→    n = 100\n   571→    # Start at 374K (just above boiling point) so cooling kicks in quickly\n   572→    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n   573→                           spread=0.03, temp=374.0, lifetime=10.0)\n   574→\n   575→    grid_params = build_grid_params()\n   576→    cell_start, cell_end = allocate_cell_tables()\n   577→\n   578→    # Run 500 steps (~0.5s): cooling should bring some below 373K\n   579→    # cool_rate=0.1, T_ambient=293: dT/dt = -0.1*(T-293) ~ -8.1 K/s\n   580→    # After 0.5s: T ~ 374 - 4.05 ~ 370K (below 373K threshold)\n   581→    for step in range(500):\n   582→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   583→\n   584→    pi_h = w[\"packed_info\"].get()\n   585→    water_count = 0\n   586→    steam_count = 0\n   587→    for pi in pi_h:\n   588→        mat_id = GET_MATERIAL_ID(int(pi))\n   589→        if mat_id == WATER:\n   590→            water_count += 1\n   591→        elif mat_id == STEAM:\n   592→            steam_count += 1\n   593→\n   594→    # Some should have condensed to water\n   595→    assert water_count > 0, \\\n   596→        f\"No steam particles condensed to water after 500 steps (steam={steam_count})\"\n   597→\n   598→    print(f\"PASS: test_steam_condensation (water={water_count}, steam={steam_count})\")\n   599→\n   600→\n   601→def test_gas_no_clumping():\n   602→    \"\"\"Gas particles don't collapse into clumps -- linear EOS provides gentle repulsion.\n   603→\n   604→    Spawn gas particles in a tight cluster. After many steps, they should\n   605→    spread out (not collapse to a single point).\n   606→    \"\"\"\n   607→    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity\n   608→\n   609→    n = 50\n   610→    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n   611→                           spread=0.01, temp=500.0, lifetime=10.0)\n   612→\n   613→    grid_params = build_grid_params()\n   614→    cell_start, cell_end = allocate_cell_tables()\n   615→\n   616→    # Measure initial spread (std dev of positions)\n   617→    pos_init = w[\"position\"].get()[:, :3]\n   618→    std_init = np.std(pos_init)\n   619→\n   620→    # Run 200 steps\n   621→    for step in range(200):\n   622→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   623→\n   624→    pos_final = w[\"position\"].get()[:, :3]\n   625→    alive_mask = w[\"packed_info\"].get() != 0\n   626→    std_final = np.std(pos_final[alive_mask])\n   627→\n   628→    # Spread should NOT decrease significantly (particles shouldn't collapse)\n   629→    assert std_final >= std_init * 0.5, \\\n   630→        f\"Gas cloud collapsed: std went from {std_init:.6f} to {std_final:.6f}\"\n   631→\n   632→    print(f\"PASS: test_gas_no_clumping (std_init={std_init:.6f}, std_final={std_final:.6f})\")\n   633→\n   634→\n   635→def test_mixed_gas_fluid_granular_no_nan():\n   636→    \"\"\"No NaN or explosions with mixed gas + fluid + granular over 5000 steps.\n   637→\n   638→    This is the main stability test. Spawn particles of all three behavior\n   639→    classes and run for 5000 steps. Verify no NaN and no escaped particles.\n   640→    \"\"\"\n   641→    setup_all_modules()\n   642→\n   643→    grid_params = build_grid_params()\n   644→    cell_start, cell_end = allocate_cell_tables()\n   645→\n   646→    # Create mixed particles\n   647→    n_water = 100\n   648→    n_sand = 100\n   649→    n_fire = 50\n   650→    n_smoke = 50\n   651→    n_steam = 50\n   652→    n_total = n_water + n_sand + n_fire + n_smoke + n_steam\n   653→\n   654→    np.random.seed(123)\n   655→\n   656→    pos = np.zeros((n_total, 4), dtype=np.float32)\n   657→    vel = np.zeros((n_total, 4), dtype=np.float32)\n   658→    mass = np.zeros(n_total, dtype=np.float32)\n   659→    packed_info = np.zeros(n_total, dtype=np.uint32)\n   660→    temperature = np.full(n_total, 293.0, dtype=np.float32)\n   661→    health = np.full(n_total, 1.0, dtype=np.float32)\n   662→    lifetime = np.zeros(n_total, dtype=np.float32)\n   663→    sleep_counter = np.zeros(n_total, dtype=np.uint8)\n   664→    shear_rate = np.zeros(n_total, dtype=np.float32)\n   665→    color = np.zeros((n_total, 4), dtype=np.float32)\n   666→    color[:, 3] = 1.0\n   667→\n   668→    idx = 0\n   669→\n   670→    # Water: spawn in a cube at y=0.3\n   671→    for i in range(n_water):\n   672→        pos[idx] = [\n   673→            np.random.uniform(-0.2, 0.2),\n   674→            np.random.uniform(0.2, 0.5),\n   675→            np.random.uniform(-0.2, 0.2),\n   676→            1.0,\n   677→        ]\n   678→        mass[idx] = 1000.0 * SPACING**3\n   679→        packed_info[idx] = MAKE_PACKED(WATER, FLUID)\n   680→        idx += 1\n   681→\n   682→    # Sand: spawn in a bed at y=-0.3\n   683→    for i in range(n_sand):\n   684→        pos[idx] = [\n   685→            np.random.uniform(-0.3, 0.3),\n   686→            np.random.uniform(-0.5, -0.3),\n   687→            np.random.uniform(-0.3, 0.3),\n   688→            1.0,\n   689→        ]\n   690→        mass[idx] = 1600.0 * SPACING**3\n   691→        packed_info[idx] = MAKE_PACKED(SAND, GRANULAR)\n   692→        idx += 1\n   693→\n   694→    # Fire: spawn at y=0\n   695→    for i in range(n_fire):\n   696→        pos[idx] = [\n   697→            np.random.uniform(-0.1, 0.1),\n   698→            np.random.uniform(-0.1, 0.1),\n   699→            np.random.uniform(-0.1, 0.1),\n   700→            1.0,\n   701→        ]\n   702→        mass[idx] = 0.2 * SPACING**3\n   703→        packed_info[idx] = MAKE_PACKED(FIRE, GAS)\n   704→        temperature[idx] = 1200.0\n   705→        lifetime[idx] = 1.0\n   706→        idx += 1\n   707→\n   708→    # Smoke: spawn at y=0.1\n   709→    for i in range(n_smoke):\n   710→        pos[idx] = [\n   711→            np.random.uniform(-0.1, 0.1),\n   712→            np.random.uniform(0.0, 0.2),\n   713→            np.random.uniform(-0.1, 0.1),\n   714→            1.0,\n   715→        ]\n   716→        mass[idx] = 0.3 * SPACING**3\n   717→        packed_info[idx] = MAKE_PACKED(SMOKE, GAS)\n   718→        temperature[idx] = 500.0\n   719→        lifetime[idx] = 3.0\n   720→        idx += 1\n   721→\n   722→    # Steam: spawn at y=0.2\n   723→    for i in range(n_steam):\n   724→        pos[idx] = [\n   725→            np.random.uniform(-0.1, 0.1),\n   726→            np.random.uniform(0.1, 0.3),\n   727→            np.random.uniform(-0.1, 0.1),\n   728→            1.0,\n   729→        ]\n   730→        mass[idx] = 0.6 * SPACING**3\n   731→        packed_info[idx] = MAKE_PACKED(STEAM, GAS)\n   732→        temperature[idx] = 373.0\n   733→        lifetime[idx] = 5.0\n   734→        idx += 1\n   735→\n   736→    pos[:, 3] = 1.0\n   737→\n   738→    w = {\n   739→        \"position\": cupy.asarray(pos),\n   740→        \"velocity\": cupy.asarray(vel),\n   741→        \"veleval\": cupy.asarray(vel.copy()),\n   742→        \"mass\": cupy.asarray(mass),\n   743→        \"packed_info\": cupy.asarray(packed_info),\n   744→        \"temperature\": cupy.asarray(temperature),\n   745→        \"health\": cupy.asarray(health),\n   746→        \"lifetime\": cupy.asarray(lifetime),\n   747→        \"sleep_counter\": cupy.asarray(sleep_counter),\n   748→        \"shear_rate\": cupy.asarray(shear_rate),\n   749→        \"color\": cupy.asarray(color),\n   750→    }\n   751→\n   752→    # Run 5000 steps\n   753→    for step in range(5000):\n   754→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   755→\n   756→        # Check for NaN every 500 steps\n   757→        if (step + 1) % 500 == 0:\n   758→            pos_h = w[\"position\"].get()\n   759→            vel_h = w[\"velocity\"].get()\n   760→            temp_h = w[\"temperature\"].get()\n   761→\n   762→            assert not np.any(np.isnan(pos_h)), \\\n   763→                f\"NaN in positions at step {step+1}\"\n   764→            assert not np.any(np.isnan(vel_h)), \\\n   765→                f\"NaN in velocities at step {step+1}\"\n   766→            assert not np.any(np.isnan(temp_h)), \\\n   767→                f\"NaN in temperatures at step {step+1}\"\n   768→\n   769→            # Check no particles escaped boundaries (pos magnitude < 10)\n   770→            alive_mask = w[\"packed_info\"].get() != 0\n   771→            if np.any(alive_mask):\n   772→                alive_pos = pos_h[alive_mask, :3]\n   773→                max_mag = np.max(np.abs(alive_pos))\n   774→                assert max_mag < 10.0, \\\n   775→                    f\"Particle escaped boundaries at step {step+1}: max |pos|={max_mag:.2f}\"\n   776→\n   777→    print(f\"PASS: test_mixed_gas_fluid_granular_no_nan (5000 steps complete)\")\n   778→\n   779→\n   780→def test_fire_rise_slow_disappear():\n   781→    \"\"\"Spawn 100 fire particles -- they rise, slow down, and disappear after ~1 second.\n   782→\n   783→    Full acceptance criterion test for fire behavior.\n   784→    \"\"\"\n   785→    setup_all_modules()\n   786→\n   787→    n = 100\n   788→    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n   789→                           spread=0.03, temp=1200.0, lifetime=1.0)\n   790→\n   791→    grid_params = build_grid_params()\n   792→    cell_start, cell_end = allocate_cell_tables()\n   793→\n   794→    y_history = []\n   795→    alive_history = []\n   796→\n   797→    # Run 1200 steps (1.2 seconds) in increments of 100\n   798→    for epoch in range(12):\n   799→        for step in range(100):\n   800→            frame = epoch * 100 + step\n   801→            w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=frame)\n   802→\n   803→        pos_h = w[\"position\"].get()\n   804→        pi_h = w[\"packed_info\"].get()\n   805→        alive_mask = pi_h != 0\n   806→        alive_count = np.sum(alive_mask)\n   807→        mean_y = np.mean(pos_h[alive_mask, 1]) if alive_count > 0 else 0.0\n   808→        y_history.append(mean_y)\n   809→        alive_history.append(int(alive_count))\n   810→\n   811→    # Check 1: particles rose (mean y at epoch 2 > epoch 0)\n   812→    assert y_history[2] > y_history[0], \\\n   813→        f\"Fire particles didn't rise: y@200steps={y_history[0]:.4f}, y@400steps={y_history[2]:.4f}\"\n   814→\n   815→    # Check 2: most disappeared by epoch 11 (~1.1s)\n   816→    assert alive_history[11] < n * 0.3, \\\n   817→        f\"Too many fire particles still alive at 1.1s: {alive_history[11]}/{n}\"\n   818→\n   819→    # Check 3: no NaN in final state\n   820→    pos_h = w[\"position\"].get()\n   821→    vel_h = w[\"velocity\"].get()\n   822→    assert not np.any(np.isnan(pos_h)), \"NaN in final positions\"\n   823→    assert not np.any(np.isnan(vel_h)), \"NaN in final velocities\"\n   824→\n   825→    print(f\"PASS: test_fire_rise_slow_disappear (alive history: {alive_history})\")\n   826→\n   827→\n   828→def test_steam_rise_and_condense():\n   829→    \"\"\"Spawn 100 steam particles -- they rise and some condense back to water as they cool.\n   830→\n   831→    Full acceptance criterion test for steam behavior.\n   832→    \"\"\"\n   833→    setup_all_modules()\n   834→\n   835→    n = 100\n   836→    # Start at 380K (slightly above boiling point) to allow realistic cooling\n   837→    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n   838→                           spread=0.03, temp=380.0, lifetime=10.0)\n   839→\n   840→    grid_params = build_grid_params()\n   841→    cell_start, cell_end = allocate_cell_tables()\n   842→\n   843→    # Run 2000 steps (2.0 seconds)\n   844→    for step in range(2000):\n   845→        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n   846→\n   847→    pi_h = w[\"packed_info\"].get()\n   848→    temp_h = w[\"temperature\"].get()\n   849→    pos_h = w[\"position\"].get()\n   850→\n   851→    water_count = 0\n   852→    steam_count = 0\n   853→    dead_count = 0\n   854→    for i, pi in enumerate(pi_h):\n   855→        mat_id = GET_MATERIAL_ID(int(pi))\n   856→        if mat_id == WATER:\n   857→            water_count += 1\n   858→        elif mat_id == STEAM:\n   859→            steam_count += 1\n   860→        elif mat_id == DEAD or pi == 0:\n   861→            dead_count += 1\n   862→\n   863→    # Check 1: some condensed to water\n   864→    assert water_count > 0, \\\n   865→        f\"No steam particles condensed (steam={steam_count}, dead={dead_count})\"\n   866→\n   867→    # Check 2: verify rising (water condensed from steam may have fallen back down)\n   868→    alive_mask = pi_h != 0\n   869→    if np.any(alive_mask):\n   870→        mean_y_alive = np.mean(pos_h[alive_mask, 1])\n   871→        # Should be at least slightly elevated (started at y=0)\n   872→        # Note: condensed water falls back, so check is lenient\n   873→\n   874→    # Check 3: no NaN\n   875→    assert not np.any(np.isnan(pos_h)), \"NaN in positions\"\n   876→    assert not np.any(np.isnan(temp_h)), \"NaN in temperatures\"\n   877→\n   878→    print(f\"PASS: test_steam_rise_and_condense (water={water_count}, steam={steam_count}, dead={dead_count})\")\n   879→\n   880→\n   881→# ===========================================================================\n   882→# Main\n   883→# ===========================================================================\n   884→\n   885→if __name__ == \"__main__\":\n   886→    tests = [\n   887→        test_gas_linear_eos,\n   888→        test_gas_buoyancy_rise,\n   889→        test_gas_drag_slowdown,\n   890→        test_fire_properties,\n   891→        test_smoke_properties,\n   892→        test_steam_condensation,\n   893→        test_gas_no_clumping,\n   894→        test_fire_rise_slow_disappear,\n   895→        test_steam_rise_and_condense,\n   896→        test_mixed_gas_fluid_granular_no_nan,\n   897→    ]\n   898→\n   899→    passed = 0\n   900→    failed = 0\n   901→    for test_fn in tests:\n   902→        try:\n   903→            test_fn()\n   904→            passed += 1\n   905→        except Exception as e:\n   906→            print(f\"FAIL: {test_fn.__name__}: {e}\")\n   907→            import traceback\n   908→            traceback.print_exc()\n   909→            failed += 1\n   910→\n   911→    print(f\"\\n{'='*60}\")\n   912→    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)}\")\n   913→    if failed == 0:\n   914→        print(\"All tests passed!\")\n   915→    else:\n   916→        sys.exit(1)\n   917→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"e01bb850-3d98-461b-825e-005d7a10b01f","uuid":"f263476f-794d-4ea0-bc95-66316ce5b45b","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/test_gas_physics.py","content":"\"\"\"Integration test for US-024: Gas particles with buoyancy, drag, and lifetime.\n\nVerifies gas particles (STEAM, SMOKE, FIRE) use correct linear EOS (gamma=1),\nbuoyancy force, drag, and lifetime decay across Step2, Integrate, and Reactions.\n\nAcceptance criteria:\n  - Gas pressure uses linear EOS: p = k_gas * max(rho - rho0_gas, 0)\n  - Gas buoyancy in Integrate: gas particles rise upward\n  - Gas drag in Integrate: gas particles slow down over time\n  - FIRE: T=1200K, lifetime ~1s, heats nearby wood via exposure_heat\n  - SMOKE: T=500K, lifetime ~3s, no chemical interactions\n  - STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions)\n  - Test: fire particles rise, slow down, and disappear after ~1 second\n  - Test: steam particles rise and some condense to water as they cool\n  - Test: gas particles don't collapse (linear EOS provides gentle repulsion)\n  - No NaN or explosions with mixed gas + fluid + granular over 5000 steps\n\nRequirements: cupy, numpy, an NVIDIA GPU with CUDA 12.x.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport os\nimport sys\n\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport cupy\nimport numpy as np\n\nfrom step1 import (\n    SIM_PARAMS_DTYPE,\n    PRECALC_PARAMS_DTYPE,\n    build_sim_params,\n    build_precalc_params,\n    compute_step1,\n)\nfrom step2 import (\n    build_granular_params,\n    compute_step2,\n)\nfrom integrate import integrate\nfrom reactions import compute_reactions\nfrom hash_sort import (\n    GRID_PARAMS_DTYPE,\n    NUM_CELLS,\n    build_grid_params,\n    calc_hash,\n    sort_by_hash,\n)\nfrom build_grid import build_data_struct, allocate_cell_tables\nfrom fused_reorder import fused_reorder\nfrom materials import (\n    FLUID,\n    GRANULAR,\n    GAS,\n    STATIC,\n    DEAD,\n    WATER,\n    SAND,\n    STEAM,\n    SMOKE,\n    FIRE,\n    WOOD,\n    METAL,\n    build_material_array,\n    build_interaction_matrix,\n)\n\n# ---------------------------------------------------------------------------\n# Constants\n# ---------------------------------------------------------------------------\n\nH = 0.04\nSPACING = 0.02\nDT = 0.001\n\n# packed_info helpers\ndef MAKE_PACKED(mat_id: int, behavior: int) -> int:\n    return (mat_id & 0xFF) | ((behavior & 0x3) << 8)\n\ndef GET_MATERIAL_ID(p: int) -> int:\n    return p & 0xFF\n\ndef GET_BEHAVIOR(p: int) -> int:\n    return (p >> 8) & 0x3\n\ndef is_alive(pi_array):\n    \"\"\"Return boolean mask: True for non-DEAD particles (material_id != 0).\"\"\"\n    return (pi_array & 0xFF) != 0\n\n\n# ---------------------------------------------------------------------------\n# Helper: upload all constant memory to all kernel modules\n# ---------------------------------------------------------------------------\n\ndef setup_all_modules(dt=DT, gravity=(0.0, -9.8, 0.0)):\n    \"\"\"Upload constant memory to step1, step2, integrate, reactions modules.\"\"\"\n    import step1 as s1_mod\n    import step2 as s2_mod\n    import integrate as int_mod\n    import reactions as rx_mod\n\n    sim_params = build_sim_params(\n        smoothing_length=H,\n        particle_mass=0.008,\n        particle_spacing=SPACING,\n        gravity=gravity,\n        dt=dt,\n        restitution=0.3,\n        wall_friction=0.5,\n        world_min=(-1.0, -1.0, -1.0),\n        world_max=(1.0, 1.0, 1.0),\n    )\n    precalc = build_precalc_params(smoothing_length=H, viscosity=1.0)\n    grid_params = build_grid_params()\n    materials = build_material_array()\n    interactions = build_interaction_matrix()\n    granular_params = build_granular_params()\n\n    # Step1\n    s1_mod.upload_grid_params(grid_params)\n    s1_mod.upload_sim_params(sim_params)\n    s1_mod.upload_precalc_params(precalc)\n    s1_mod.upload_materials(materials)\n    s1_mod.upload_interactions(interactions)\n\n    # Step2\n    s2_mod.upload_grid_params(grid_params)\n    s2_mod.upload_sim_params(sim_params)\n    s2_mod.upload_precalc_params(precalc)\n    s2_mod.upload_materials(materials)\n    s2_mod.upload_granular_params(granular_params)\n\n    # Integrate\n    int_mod.upload_sim_params(sim_params)\n    int_mod.upload_materials(materials)\n\n    # Reactions\n    rx_mod.upload_sim_params(sim_params)\n    rx_mod.upload_materials(materials)\n\n    return sim_params, precalc, grid_params, materials, interactions\n\n\ndef make_gas_particles(n, mat_id, pos_center=(0.0, 0.0, 0.0), spread=0.03,\n                       temp=293.0, lifetime=5.0):\n    \"\"\"Create n gas particles near pos_center with some random spread.\"\"\"\n    np.random.seed(42)\n    pos = np.zeros((n, 4), dtype=np.float32)\n    pos[:, 0] = pos_center[0] + np.random.uniform(-spread, spread, n).astype(np.float32)\n    pos[:, 1] = pos_center[1] + np.random.uniform(-spread, spread, n).astype(np.float32)\n    pos[:, 2] = pos_center[2] + np.random.uniform(-spread, spread, n).astype(np.float32)\n    pos[:, 3] = 1.0\n\n    vel = np.zeros((n, 4), dtype=np.float32)\n\n    # Gas mass: rest_density * spacing^3\n    # STEAM rho0=0.6, SMOKE rho0=0.3, FIRE rho0=0.2\n    rho0_map = {STEAM: 0.6, SMOKE: 0.3, FIRE: 0.2}\n    rho0 = rho0_map.get(mat_id, 0.5)\n    mass_val = rho0 * SPACING**3\n\n    mass = np.full(n, mass_val, dtype=np.float32)\n    packed_info = np.full(n, MAKE_PACKED(mat_id, GAS), dtype=np.uint32)\n    temperature = np.full(n, temp, dtype=np.float32)\n    health = np.full(n, 1.0, dtype=np.float32)\n    lt = np.full(n, lifetime, dtype=np.float32)\n    sleep_counter = np.zeros(n, dtype=np.uint8)\n    shear_rate = np.zeros(n, dtype=np.float32)\n    color = np.zeros((n, 4), dtype=np.float32)\n    color[:, 3] = 1.0\n\n    return {\n        \"position\": cupy.asarray(pos),\n        \"velocity\": cupy.asarray(vel),\n        \"veleval\": cupy.asarray(vel.copy()),\n        \"mass\": cupy.asarray(mass),\n        \"packed_info\": cupy.asarray(packed_info),\n        \"temperature\": cupy.asarray(temperature),\n        \"health\": cupy.asarray(health),\n        \"lifetime\": cupy.asarray(lt),\n        \"sleep_counter\": cupy.asarray(sleep_counter),\n        \"shear_rate\": cupy.asarray(shear_rate),\n        \"color\": cupy.asarray(color),\n    }\n\n\ndef run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=0):\n    \"\"\"Run one full simulation step: hash -> sort -> reorder -> build -> step1 -> reactions -> step2 -> integrate.\n\n    w is a dict of unsorted arrays. Returns updated w dict.\n    \"\"\"\n    import hash_sort as hs_mod\n    import build_grid as bg_mod\n\n    n = w[\"position\"].shape[0]\n    if n == 0:\n        return w\n\n    # Hash\n    hs_mod.upload_grid_params(grid_params)\n    hashes, indices = calc_hash(w[\"position\"])\n\n    # Sort\n    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n\n    # Reorder\n    sorted_pos = cupy.empty_like(w[\"position\"])\n    sorted_vel = cupy.empty_like(w[\"velocity\"])\n    sorted_veleval = cupy.empty_like(w[\"veleval\"])\n    sorted_mass = cupy.empty(n, dtype=cupy.float32)\n    sorted_pi = cupy.empty(n, dtype=cupy.uint32)\n    sorted_temp = cupy.empty(n, dtype=cupy.float32)\n    sorted_health = cupy.empty(n, dtype=cupy.float32)\n    sorted_lifetime = cupy.empty(n, dtype=cupy.float32)\n    sorted_sc = cupy.empty(n, dtype=cupy.uint8)\n    sorted_sr = cupy.empty(n, dtype=cupy.float32)\n    sorted_color = cupy.empty_like(w[\"color\"])\n\n    fused_reorder(\n        n, sorted_indices,\n        w[\"position\"], w[\"velocity\"], w[\"veleval\"],\n        w[\"mass\"], w[\"packed_info\"], w[\"temperature\"],\n        w[\"health\"], w[\"lifetime\"], w[\"color\"],\n        w[\"sleep_counter\"], w[\"shear_rate\"],\n        sorted_pos, sorted_vel, sorted_veleval,\n        sorted_mass, sorted_pi, sorted_temp,\n        sorted_health, sorted_lifetime, sorted_color,\n        sorted_sc, sorted_sr,\n    )\n\n    # Build grid (build_data_struct does its own memset internally)\n    bg_mod.upload_grid_params(grid_params)\n    build_data_struct(sorted_hashes, cell_start, cell_end)\n\n    # Step1: density, shear_rate, dTdt, exposure\n    density, shear_rate, dTdt, exp_heat, exp_corrode = compute_step1(\n        sorted_pos, sorted_vel, sorted_mass, None, sorted_pi,\n        sorted_temp, cell_start, cell_end,\n    )\n\n    # Reactions\n    compute_reactions(\n        sorted_pi, sorted_temp, sorted_health, sorted_lifetime,\n        sorted_vel, exp_heat, exp_corrode, frame=frame,\n    )\n\n    # Step2\n    sph_force, veleval_out = compute_step2(\n        sorted_pos, sorted_vel, density, sorted_mass, sorted_pi,\n        cell_start, cell_end,\n    )\n\n    # Integrate\n    pos_out, vel_out, color_out, pi_out, sc_out, temp_out = integrate(\n        sorted_pos, sorted_vel, veleval_out, sph_force,\n        sorted_mass, sorted_pi, sorted_temp, sorted_health,\n        sorted_density=density, sorted_shear_rate=shear_rate,\n        sorted_dTdt=dTdt, sorted_sleep_counter=sorted_sc,\n        sort_indexes=sorted_indices,\n        position_out=w[\"position\"],\n        velocity_out=w[\"velocity\"],\n        color_out=w[\"color\"],\n        packed_info_out=w[\"packed_info\"],\n        sleep_counter_out=w[\"sleep_counter\"],\n        temperature_out=w[\"temperature\"],\n    )\n\n    w[\"position\"] = pos_out\n    w[\"velocity\"] = vel_out\n    w[\"color\"] = color_out\n    w[\"packed_info\"] = pi_out\n    w[\"sleep_counter\"] = sc_out\n    w[\"temperature\"] = temp_out\n    # veleval = velocity for next frame (no separate persistence needed)\n    w[\"veleval\"] = w[\"velocity\"].copy()\n\n    # Write back lifetime and health from sorted (modified by Reactions) to unsorted.\n    # Integrate doesn't output these, so scatter them manually via sorted_indices.\n    w[\"lifetime\"][sorted_indices] = sorted_lifetime\n    w[\"health\"][sorted_indices] = sorted_health\n\n    return w\n\n\n# ===========================================================================\n# Tests\n# ===========================================================================\n\n\ndef test_gas_linear_eos():\n    \"\"\"Gas pressure uses linear EOS: p = k_gas * max(rho - rho0, 0).\n\n    Two GAS particles compressed (closer than rest spacing) should produce\n    a positive repulsive force. The key check is that force exists and is\n    directed outward (separation).\n    \"\"\"\n    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity for pure EOS test\n\n    # Two STEAM particles close together (within h)\n    n = 2\n    sep = 0.02  # within h=0.04\n    pos = np.array([\n        [-sep/2, 0.0, 0.0, 1.0],\n        [sep/2, 0.0, 0.0, 1.0],\n    ], dtype=np.float32)\n    vel = np.zeros((n, 4), dtype=np.float32)\n    rho0 = 0.6  # STEAM rest density\n    mass_val = rho0 * SPACING**3\n    mass = np.full(n, mass_val, dtype=np.float32)\n    packed_info = np.full(n, MAKE_PACKED(STEAM, GAS), dtype=np.uint32)\n\n    d_pos = cupy.asarray(pos)\n    d_vel = cupy.asarray(vel)\n    d_mass = cupy.asarray(mass)\n    d_pi = cupy.asarray(packed_info)\n\n    # Build grid for these 2 particles\n    grid_params = build_grid_params()\n    import hash_sort as hs_mod\n    import build_grid as bg_mod\n    hs_mod.upload_grid_params(grid_params)\n    bg_mod.upload_grid_params(grid_params)\n\n    hashes, indices = calc_hash(d_pos)\n    sorted_hashes, sorted_indices = sort_by_hash(hashes, indices)\n\n    # Reorder (trivial for 2 particles)\n    s_pos = d_pos[sorted_indices]\n    s_vel = d_vel[sorted_indices]\n    s_mass = d_mass[sorted_indices]\n    s_pi = d_pi[sorted_indices]\n\n    cell_start, cell_end = allocate_cell_tables()\n    cell_start.data.memset(0xFF, cell_start.nbytes)\n    cell_end.data.memset(0x00, cell_end.nbytes)\n    build_data_struct(sorted_hashes, cell_start, cell_end)\n\n    # Step1: density\n    s_temp = cupy.full(n, 373.0, dtype=cupy.float32)\n    density, _, _, _, _ = compute_step1(\n        s_pos, s_vel, s_mass, None, s_pi, s_temp, cell_start, cell_end,\n    )\n\n    # Step2: force\n    sph_force, veleval_out = compute_step2(\n        s_pos, s_vel, density, s_mass, s_pi, cell_start, cell_end,\n    )\n\n    force_h = sph_force.get()\n    # Particles should be pushed apart: particle 0 (left) gets negative x force,\n    # particle 1 (right) gets positive x force (Newton's 3rd law)\n    # OR both get repulsive force away from each other\n    f0x = force_h[0, 0]\n    f1x = force_h[1, 0]\n\n    # Forces should be roughly opposite (Newton's 3rd law)\n    assert abs(f0x + f1x) < 0.1 * max(abs(f0x), abs(f1x), 1e-6), \\\n        f\"Newton's 3rd law violation: f0x={f0x}, f1x={f1x}\"\n\n    # At least one should be non-zero (EOS produces pressure)\n    assert abs(f0x) > 1e-10 or abs(f1x) > 1e-10, \\\n        f\"Zero forces: linear EOS not producing pressure for compressed gas\"\n\n    print(\"PASS: test_gas_linear_eos\")\n\n\ndef test_gas_buoyancy_rise():\n    \"\"\"Gas particles rise upward due to buoyancy: accel.y += beta*(T-293)*g.\n\n    Spawn 100 fire particles (T=1200K) at origin with zero velocity.\n    After several integration steps, y position should increase.\n    \"\"\"\n    setup_all_modules(gravity=(0.0, -9.8, 0.0))\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    w = make_gas_particles(100, FIRE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=1200.0, lifetime=5.0)\n\n    # Record initial y positions\n    y_initial = w[\"position\"].get()[:, 1].copy()\n\n    # Run 50 steps\n    for step in range(50):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    y_final = w[\"position\"].get()[:, 1]\n\n    # All (or most) fire particles should have risen\n    # Buoyancy = 0.01 * (1200 - 293) * 9.81 = 0.01 * 907 * 9.81 ~= 89 m/s^2 upward\n    # After 50 steps of dt=0.001: ~0.05s of sim time\n    # Expected velocity ~= 89 * 0.05 * drag_reduction\n    alive_mask = w[\"packed_info\"].get() != 0\n    y_diff = y_final[alive_mask] - y_initial[alive_mask]\n    risen_count = np.sum(y_diff > 0)\n    total_alive = np.sum(alive_mask)\n\n    assert total_alive > 0, \"All particles died unexpectedly\"\n    # Most particles should rise, but some may move sideways due to SPH repulsion\n    assert risen_count > total_alive * 0.5, \\\n        f\"Only {risen_count}/{total_alive} fire particles rose (expected >50%)\"\n\n    mean_rise = np.mean(y_diff[y_diff > 0])\n    assert mean_rise > 0.001, \\\n        f\"Mean rise {mean_rise:.6f} too small -- buoyancy may not be working\"\n\n    print(f\"PASS: test_gas_buoyancy_rise (mean rise={mean_rise:.4f}, {risen_count}/{total_alive} rose)\")\n\n\ndef test_gas_drag_slowdown():\n    \"\"\"Gas particles slow down over time due to drag: vel *= (1 - c_drag * dt).\n\n    Spawn gas particles with an initial horizontal velocity and check that\n    velocity magnitude decreases over time.\n    \"\"\"\n    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity to isolate drag\n\n    n = 50\n    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.02, temp=500.0, lifetime=10.0)\n\n    # Give initial velocity in x direction\n    vel_init = np.zeros((n, 4), dtype=np.float32)\n    vel_init[:, 0] = 1.0  # 1 m/s in x\n    w[\"velocity\"] = cupy.asarray(vel_init)\n    w[\"veleval\"] = cupy.asarray(vel_init.copy())\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Measure velocity after 100 steps\n    for step in range(100):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    vel_after_100 = w[\"velocity\"].get().copy()\n    alive_mask = w[\"packed_info\"].get() != 0\n\n    # Run another 100 steps and check velocity magnitude decreases\n    # (the cloud has expanded by now, so SPH forces are weaker)\n    for step in range(100, 200):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    vel_after_200 = w[\"velocity\"].get()\n    alive_mask_200 = w[\"packed_info\"].get() != 0\n\n    # Compare velocity magnitudes: the drag should cause a net slowdown\n    # between step 100 and 200 (SPH forces weaken as cloud disperses)\n    speed_100 = np.sqrt(np.sum(vel_after_100[alive_mask, :3]**2, axis=1))\n    speed_200 = np.sqrt(np.sum(vel_after_200[alive_mask_200, :3]**2, axis=1))\n    mean_speed_100 = np.mean(speed_100)\n    mean_speed_200 = np.mean(speed_200)\n\n    # With drag active, velocity should eventually decrease as SPH forces weaken\n    # The key check: velocities are finite and not exploding\n    assert not np.any(np.isnan(vel_after_200)), \"NaN in velocities\"\n    assert mean_speed_200 < 50.0, \\\n        f\"Mean speed {mean_speed_200:.4f} too high -- drag may not be working\"\n\n    # Verify drag is applied: run a single-particle test\n    # One isolated gas particle with initial velocity should slow down\n    w_single = make_gas_particles(1, SMOKE, pos_center=(0.5, 0.5, 0.5),\n                                   spread=0.0, temp=500.0, lifetime=10.0)\n    vel_single = np.array([[2.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n    w_single[\"velocity\"] = cupy.asarray(vel_single)\n    w_single[\"veleval\"] = cupy.asarray(vel_single.copy())\n\n    for step in range(100):\n        w_single = run_full_pipeline_step(w_single, grid_params, cell_start, cell_end, frame=step)\n\n    vx_final = abs(float(w_single[\"velocity\"].get()[0, 0]))\n    # drag_factor per step: 1 - 2.0*0.001 = 0.998\n    # After 100 steps: 2.0 * 0.998^100 ~ 1.637\n    # But also gravity=-9.8 is on (from setup_all_modules default)\n    # Re-setup with no gravity for isolated test\n    setup_all_modules(gravity=(0.0, 0.0, 0.0))\n    w_single = make_gas_particles(1, SMOKE, pos_center=(0.5, 0.5, 0.5),\n                                   spread=0.0, temp=500.0, lifetime=10.0)\n    vel_single = np.array([[2.0, 0.0, 0.0, 0.0]], dtype=np.float32)\n    w_single[\"velocity\"] = cupy.asarray(vel_single)\n    w_single[\"veleval\"] = cupy.asarray(vel_single.copy())\n\n    for step in range(100):\n        w_single = run_full_pipeline_step(w_single, grid_params, cell_start, cell_end, frame=step)\n\n    vx_final_single = abs(float(w_single[\"velocity\"].get()[0, 0]))\n    # Expected: 2.0 * 0.998^100 ~ 1.637 (isolated, no SPH forces with 1 particle)\n    assert vx_final_single < 2.0, \\\n        f\"Single particle vx={vx_final_single:.4f} not reduced by drag (expected < 2.0)\"\n    assert vx_final_single > 0.5, \\\n        f\"Single particle vx={vx_final_single:.4f} reduced too much\"\n\n    print(f\"PASS: test_gas_drag_slowdown (single particle vx: 2.0 -> {vx_final_single:.4f})\")\n\n\ndef test_fire_properties():\n    \"\"\"FIRE: T=1200K, lifetime ~1s. Fire particles should disappear after ~1000 steps.\"\"\"\n    setup_all_modules()\n\n    n = 100\n    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=1200.0, lifetime=1.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 500 steps (~0.5s): should still have most particles alive\n    for step in range(500):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    alive_500 = np.sum(pi_h != 0)\n    # Should still have a fair number alive (lifetime=1.0s, only 0.5s elapsed)\n    assert alive_500 > n * 0.3, \\\n        f\"Only {alive_500}/{n} fire particles alive at t=0.5s (expected >30%)\"\n\n    # Run another 600 steps (~1.1s total): most should be dead\n    for step in range(500, 1100):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    alive_1100 = np.sum(pi_h != 0)\n    assert alive_1100 < n * 0.3, \\\n        f\"Still {alive_1100}/{n} fire particles alive at t=1.1s (expected <30%)\"\n\n    print(f\"PASS: test_fire_properties (alive@0.5s={alive_500}, alive@1.1s={alive_1100})\")\n\n\ndef test_smoke_properties():\n    \"\"\"SMOKE: T=500K, lifetime ~3s. No chemical interactions.\"\"\"\n    setup_all_modules()\n\n    n = 100\n    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=500.0, lifetime=3.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 1000 steps (~1.0s): all should still be alive\n    for step in range(1000):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    alive_1000 = np.sum(pi_h != 0)\n    assert alive_1000 > n * 0.9, \\\n        f\"Only {alive_1000}/{n} smoke particles alive at t=1.0s (expected >90%, lifetime=3s)\"\n\n    # Verify particles are rising due to buoyancy (T=500K > 293K)\n    y_final = w[\"position\"].get()[:, 1]\n    alive_mask = pi_h != 0\n    mean_y = np.mean(y_final[alive_mask])\n    assert mean_y > 0.0, \\\n        f\"Mean y position {mean_y:.4f} not positive -- smoke should rise\"\n\n    print(f\"PASS: test_smoke_properties (alive@1.0s={alive_1000}, mean_y={mean_y:.4f})\")\n\n\ndef test_steam_condensation():\n    \"\"\"STEAM: T=373K, condenses to WATER if T drops below 373K (via Reactions).\n\n    Spawn steam particles at T just above 373K. After cooling, some should\n    transition to WATER.\n    \"\"\"\n    setup_all_modules()\n\n    n = 100\n    # Start at 374K (just above boiling point) so cooling kicks in quickly\n    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=374.0, lifetime=10.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 500 steps (~0.5s): cooling should bring some below 373K\n    # cool_rate=0.1, T_ambient=293: dT/dt = -0.1*(T-293) ~ -8.1 K/s\n    # After 0.5s: T ~ 374 - 4.05 ~ 370K (below 373K threshold)\n    for step in range(500):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    water_count = 0\n    steam_count = 0\n    for pi in pi_h:\n        mat_id = GET_MATERIAL_ID(int(pi))\n        if mat_id == WATER:\n            water_count += 1\n        elif mat_id == STEAM:\n            steam_count += 1\n\n    # Some should have condensed to water\n    assert water_count > 0, \\\n        f\"No steam particles condensed to water after 500 steps (steam={steam_count})\"\n\n    print(f\"PASS: test_steam_condensation (water={water_count}, steam={steam_count})\")\n\n\ndef test_gas_no_clumping():\n    \"\"\"Gas particles don't collapse into clumps -- linear EOS provides gentle repulsion.\n\n    Spawn gas particles in a tight cluster. After many steps, they should\n    spread out (not collapse to a single point).\n    \"\"\"\n    setup_all_modules(gravity=(0.0, 0.0, 0.0))  # no gravity\n\n    n = 50\n    w = make_gas_particles(n, SMOKE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.01, temp=500.0, lifetime=10.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Measure initial spread (std dev of positions)\n    pos_init = w[\"position\"].get()[:, :3]\n    std_init = np.std(pos_init)\n\n    # Run 200 steps\n    for step in range(200):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pos_final = w[\"position\"].get()[:, :3]\n    alive_mask = w[\"packed_info\"].get() != 0\n    std_final = np.std(pos_final[alive_mask])\n\n    # Spread should NOT decrease significantly (particles shouldn't collapse)\n    assert std_final >= std_init * 0.5, \\\n        f\"Gas cloud collapsed: std went from {std_init:.6f} to {std_final:.6f}\"\n\n    print(f\"PASS: test_gas_no_clumping (std_init={std_init:.6f}, std_final={std_final:.6f})\")\n\n\ndef test_mixed_gas_fluid_granular_no_nan():\n    \"\"\"No NaN or explosions with mixed gas + fluid + granular over 5000 steps.\n\n    This is the main stability test. Spawn particles of all three behavior\n    classes and run for 5000 steps. Verify no NaN and no escaped particles.\n    \"\"\"\n    setup_all_modules()\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Create mixed particles\n    n_water = 100\n    n_sand = 100\n    n_fire = 50\n    n_smoke = 50\n    n_steam = 50\n    n_total = n_water + n_sand + n_fire + n_smoke + n_steam\n\n    np.random.seed(123)\n\n    pos = np.zeros((n_total, 4), dtype=np.float32)\n    vel = np.zeros((n_total, 4), dtype=np.float32)\n    mass = np.zeros(n_total, dtype=np.float32)\n    packed_info = np.zeros(n_total, dtype=np.uint32)\n    temperature = np.full(n_total, 293.0, dtype=np.float32)\n    health = np.full(n_total, 1.0, dtype=np.float32)\n    lifetime = np.zeros(n_total, dtype=np.float32)\n    sleep_counter = np.zeros(n_total, dtype=np.uint8)\n    shear_rate = np.zeros(n_total, dtype=np.float32)\n    color = np.zeros((n_total, 4), dtype=np.float32)\n    color[:, 3] = 1.0\n\n    idx = 0\n\n    # Water: spawn in a cube at y=0.3\n    for i in range(n_water):\n        pos[idx] = [\n            np.random.uniform(-0.2, 0.2),\n            np.random.uniform(0.2, 0.5),\n            np.random.uniform(-0.2, 0.2),\n            1.0,\n        ]\n        mass[idx] = 1000.0 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(WATER, FLUID)\n        idx += 1\n\n    # Sand: spawn in a bed at y=-0.3\n    for i in range(n_sand):\n        pos[idx] = [\n            np.random.uniform(-0.3, 0.3),\n            np.random.uniform(-0.5, -0.3),\n            np.random.uniform(-0.3, 0.3),\n            1.0,\n        ]\n        mass[idx] = 1600.0 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(SAND, GRANULAR)\n        idx += 1\n\n    # Fire: spawn at y=0\n    for i in range(n_fire):\n        pos[idx] = [\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(-0.1, 0.1),\n            1.0,\n        ]\n        mass[idx] = 0.2 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(FIRE, GAS)\n        temperature[idx] = 1200.0\n        lifetime[idx] = 1.0\n        idx += 1\n\n    # Smoke: spawn at y=0.1\n    for i in range(n_smoke):\n        pos[idx] = [\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(0.0, 0.2),\n            np.random.uniform(-0.1, 0.1),\n            1.0,\n        ]\n        mass[idx] = 0.3 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(SMOKE, GAS)\n        temperature[idx] = 500.0\n        lifetime[idx] = 3.0\n        idx += 1\n\n    # Steam: spawn at y=0.2\n    for i in range(n_steam):\n        pos[idx] = [\n            np.random.uniform(-0.1, 0.1),\n            np.random.uniform(0.1, 0.3),\n            np.random.uniform(-0.1, 0.1),\n            1.0,\n        ]\n        mass[idx] = 0.6 * SPACING**3\n        packed_info[idx] = MAKE_PACKED(STEAM, GAS)\n        temperature[idx] = 373.0\n        lifetime[idx] = 5.0\n        idx += 1\n\n    pos[:, 3] = 1.0\n\n    w = {\n        \"position\": cupy.asarray(pos),\n        \"velocity\": cupy.asarray(vel),\n        \"veleval\": cupy.asarray(vel.copy()),\n        \"mass\": cupy.asarray(mass),\n        \"packed_info\": cupy.asarray(packed_info),\n        \"temperature\": cupy.asarray(temperature),\n        \"health\": cupy.asarray(health),\n        \"lifetime\": cupy.asarray(lifetime),\n        \"sleep_counter\": cupy.asarray(sleep_counter),\n        \"shear_rate\": cupy.asarray(shear_rate),\n        \"color\": cupy.asarray(color),\n    }\n\n    # Run 5000 steps\n    for step in range(5000):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n        # Check for NaN every 500 steps\n        if (step + 1) % 500 == 0:\n            pos_h = w[\"position\"].get()\n            vel_h = w[\"velocity\"].get()\n            temp_h = w[\"temperature\"].get()\n\n            assert not np.any(np.isnan(pos_h)), \\\n                f\"NaN in positions at step {step+1}\"\n            assert not np.any(np.isnan(vel_h)), \\\n                f\"NaN in velocities at step {step+1}\"\n            assert not np.any(np.isnan(temp_h)), \\\n                f\"NaN in temperatures at step {step+1}\"\n\n            # Check no particles escaped boundaries (pos magnitude < 10)\n            alive_mask = w[\"packed_info\"].get() != 0\n            if np.any(alive_mask):\n                alive_pos = pos_h[alive_mask, :3]\n                max_mag = np.max(np.abs(alive_pos))\n                assert max_mag < 10.0, \\\n                    f\"Particle escaped boundaries at step {step+1}: max |pos|={max_mag:.2f}\"\n\n    print(f\"PASS: test_mixed_gas_fluid_granular_no_nan (5000 steps complete)\")\n\n\ndef test_fire_rise_slow_disappear():\n    \"\"\"Spawn 100 fire particles -- they rise, slow down, and disappear after ~1 second.\n\n    Full acceptance criterion test for fire behavior.\n    \"\"\"\n    setup_all_modules()\n\n    n = 100\n    w = make_gas_particles(n, FIRE, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=1200.0, lifetime=1.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    y_history = []\n    alive_history = []\n\n    # Run 1200 steps (1.2 seconds) in increments of 100\n    for epoch in range(12):\n        for step in range(100):\n            frame = epoch * 100 + step\n            w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=frame)\n\n        pos_h = w[\"position\"].get()\n        pi_h = w[\"packed_info\"].get()\n        alive_mask = pi_h != 0\n        alive_count = np.sum(alive_mask)\n        mean_y = np.mean(pos_h[alive_mask, 1]) if alive_count > 0 else 0.0\n        y_history.append(mean_y)\n        alive_history.append(int(alive_count))\n\n    # Check 1: particles rose (mean y at epoch 2 > epoch 0)\n    assert y_history[2] > y_history[0], \\\n        f\"Fire particles didn't rise: y@200steps={y_history[0]:.4f}, y@400steps={y_history[2]:.4f}\"\n\n    # Check 2: most disappeared by epoch 11 (~1.1s)\n    assert alive_history[11] < n * 0.3, \\\n        f\"Too many fire particles still alive at 1.1s: {alive_history[11]}/{n}\"\n\n    # Check 3: no NaN in final state\n    pos_h = w[\"position\"].get()\n    vel_h = w[\"velocity\"].get()\n    assert not np.any(np.isnan(pos_h)), \"NaN in final positions\"\n    assert not np.any(np.isnan(vel_h)), \"NaN in final velocities\"\n\n    print(f\"PASS: test_fire_rise_slow_disappear (alive history: {alive_history})\")\n\n\ndef test_steam_rise_and_condense():\n    \"\"\"Spawn 100 steam particles -- they rise and some condense back to water as they cool.\n\n    Full acceptance criterion test for steam behavior.\n    \"\"\"\n    setup_all_modules()\n\n    n = 100\n    # Start at 380K (slightly above boiling point) to allow realistic cooling\n    w = make_gas_particles(n, STEAM, pos_center=(0.0, 0.0, 0.0),\n                           spread=0.03, temp=380.0, lifetime=10.0)\n\n    grid_params = build_grid_params()\n    cell_start, cell_end = allocate_cell_tables()\n\n    # Run 2000 steps (2.0 seconds)\n    for step in range(2000):\n        w = run_full_pipeline_step(w, grid_params, cell_start, cell_end, frame=step)\n\n    pi_h = w[\"packed_info\"].get()\n    temp_h = w[\"temperature\"].get()\n    pos_h = w[\"position\"].get()\n\n    water_count = 0\n    steam_count = 0\n    dead_count = 0\n    for i, pi in enumerate(pi_h):\n        mat_id = GET_MATERIAL_ID(int(pi))\n        if mat_id == WATER:\n            water_count += 1\n        elif mat_id == STEAM:\n            steam_count += 1\n        elif mat_id == DEAD or pi == 0:\n            dead_count += 1\n\n    # Check 1: some condensed to water\n    assert water_count > 0, \\\n        f\"No steam particles condensed (steam={steam_count}, dead={dead_count})\"\n\n    # Check 2: verify rising (water condensed from steam may have fallen back down)\n    alive_mask = pi_h != 0\n    if np.any(alive_mask):\n        mean_y_alive = np.mean(pos_h[alive_mask, 1])\n        # Should be at least slightly elevated (started at y=0)\n        # Note: condensed water falls back, so check is lenient\n\n    # Check 3: no NaN\n    assert not np.any(np.isnan(pos_h)), \"NaN in positions\"\n    assert not np.any(np.isnan(temp_h)), \"NaN in temperatures\"\n\n    print(f\"PASS: test_steam_rise_and_condense (water={water_count}, steam={steam_count}, dead={dead_count})\")\n\n\n# ===========================================================================\n# Main\n# ===========================================================================\n\nif __name__ == \"__main__\":\n    tests = [\n        test_gas_linear_eos,\n        test_gas_buoyancy_rise,\n        test_gas_drag_slowdown,\n        test_fire_properties,\n        test_smoke_properties,\n        test_steam_condensation,\n        test_gas_no_clumping,\n        test_fire_rise_slow_disappear,\n        test_steam_rise_and_condense,\n        test_mixed_gas_fluid_granular_no_nan,\n    ]\n\n    passed = 0\n    failed = 0\n    for test_fn in tests:\n        try:\n            test_fn()\n            passed += 1\n        except Exception as e:\n            print(f\"FAIL: {test_fn.__name__}: {e}\")\n            import traceback\n            traceback.print_exc()\n            failed += 1\n\n    print(f\"\\n{'='*60}\")\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)}\")\n    if failed == 0:\n        print(\"All tests passed!\")\n    else:\n        sys.exit(1)\n","numLines":917,"startLine":1,"totalLines":917}}}

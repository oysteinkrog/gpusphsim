{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SvgtZKkrLG3vJePxFmdu4i","type":"tool_result","content":"     1→\"\"\"CUDA-GL interop via ctypes bindings for cudart64_12.dll (Windows/NVIDIA).\n     2→\n     3→Provides Python wrappers around CUDA runtime GL interop functions so that\n     4→an OpenGL VBO can be shared with CUDA (and written to by CuPy kernels)\n     5→without any CPU round-trip.\n     6→\n     7→Exported API\n     8→------------\n     9→- register_buffer(vbo_id, flags) -> cudaGraphicsResource*\n    10→- map_buffer(resource)\n    11→- get_mapped_pointer(resource) -> (dev_ptr, size)\n    12→- unmap_buffer(resource)\n    13→- CudaGLBuffer  -- convenience class wrapping the lifecycle\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import ctypes\n    19→import ctypes.util\n    20→import platform\n    21→from ctypes import (\n    22→    POINTER,\n    23→    byref,\n    24→    c_int,\n    25→    c_size_t,\n    26→    c_uint,\n    27→    c_void_p,\n    28→)\n    29→from typing import Optional\n    30→\n    31→# ---------------------------------------------------------------------------\n    32→# Load the CUDA runtime library\n    33→# ---------------------------------------------------------------------------\n    34→\n    35→# Opaque handle -- cudaGraphicsResource*\n    36→_cudaGraphicsResource_p = c_void_p\n    37→\n    38→# cudaError_t is an int enum in the CUDA headers\n    39→_cudaError_t = c_int\n    40→\n    41→# cudaGraphicsRegisterFlags / cudaGraphicsMapFlags\n    42→cudaGraphicsRegisterFlagsNone = 0\n    43→cudaGraphicsRegisterFlagsWriteDiscard = 2\n    44→cudaGraphicsMapFlagsNone = 0\n    45→cudaGraphicsMapFlagsReadOnly = 1\n    46→cudaGraphicsMapFlagsWriteDiscard = 2\n    47→\n    48→cudaSuccess = 0\n    49→\n    50→\n    51→def _load_cudart() -> ctypes.CDLL:\n    52→    \"\"\"Locate and load the CUDA runtime shared library.\"\"\"\n    53→    if platform.system() == \"Windows\":\n    54→        # Try CUDA 12.x first, then 11.x\n    55→        for ver in (\"12\", \"11\"):\n    56→            name = f\"cudart64_{ver}\"\n    57→            try:\n    58→                return ctypes.CDLL(name)\n    59→            except OSError:\n    60→                pass\n    61→        # Fallback: let ctypes.util find it\n    62→        path = ctypes.util.find_library(\"cudart64_12\") or ctypes.util.find_library(\n    63→            \"cudart\"\n    64→        )\n    65→        if path:\n    66→            return ctypes.CDLL(path)\n    67→        raise OSError(\n    68→            \"Cannot find cudart64_12.dll (or cudart64_11.dll). \"\n    69→            \"Make sure the NVIDIA CUDA Toolkit bin directory is on PATH.\"\n    70→        )\n    71→    else:\n    72→        # Linux / other\n    73→        for name in (\"libcudart.so.12\", \"libcudart.so.11\", \"libcudart.so\"):\n    74→            try:\n    75→                return ctypes.CDLL(name)\n    76→            except OSError:\n    77→                pass\n    78→        path = ctypes.util.find_library(\"cudart\")\n    79→        if path:\n    80→            return ctypes.CDLL(path)\n    81→        raise OSError(\"Cannot find libcudart.so. Is the CUDA Toolkit installed?\")\n    82→\n    83→\n    84→_cudart = _load_cudart()\n    85→\n    86→# ---------------------------------------------------------------------------\n    87→# Declare function signatures\n    88→# ---------------------------------------------------------------------------\n    89→\n    90→# cudaError_t cudaGraphicsGLRegisterBuffer(\n    91→#     cudaGraphicsResource **resource, GLuint buffer, unsigned int flags);\n    92→_cudart.cudaGraphicsGLRegisterBuffer.restype = _cudaError_t\n    93→_cudart.cudaGraphicsGLRegisterBuffer.argtypes = [\n    94→    POINTER(c_void_p),  # cudaGraphicsResource **resource\n    95→    c_uint,  # GLuint buffer\n    96→    c_uint,  # unsigned int flags\n    97→]\n    98→\n    99→# cudaError_t cudaGraphicsUnregisterResource(cudaGraphicsResource *resource);\n   100→_cudart.cudaGraphicsUnregisterResource.restype = _cudaError_t\n   101→_cudart.cudaGraphicsUnregisterResource.argtypes = [c_void_p]\n   102→\n   103→# cudaError_t cudaGraphicsMapResources(\n   104→#     int count, cudaGraphicsResource **resources, cudaStream_t stream);\n   105→_cudart.cudaGraphicsMapResources.restype = _cudaError_t\n   106→_cudart.cudaGraphicsMapResources.argtypes = [\n   107→    c_int,  # int count\n   108→    POINTER(c_void_p),  # cudaGraphicsResource **resources\n   109→    c_void_p,  # cudaStream_t stream (0 = default)\n   110→]\n   111→\n   112→# cudaError_t cudaGraphicsUnmapResources(\n   113→#     int count, cudaGraphicsResource **resources, cudaStream_t stream);\n   114→_cudart.cudaGraphicsUnmapResources.restype = _cudaError_t\n   115→_cudart.cudaGraphicsUnmapResources.argtypes = [\n   116→    c_int,\n   117→    POINTER(c_void_p),\n   118→    c_void_p,\n   119→]\n   120→\n   121→# cudaError_t cudaGraphicsResourceGetMappedPointer(\n   122→#     void **devPtr, size_t *size, cudaGraphicsResource *mappedResource);\n   123→_cudart.cudaGraphicsResourceGetMappedPointer.restype = _cudaError_t\n   124→_cudart.cudaGraphicsResourceGetMappedPointer.argtypes = [\n   125→    POINTER(c_void_p),  # void **devPtr\n   126→    POINTER(c_size_t),  # size_t *size\n   127→    c_void_p,  # cudaGraphicsResource *mappedResource\n   128→]\n   129→\n   130→# cudaError_t cudaGetLastError(void);\n   131→_cudart.cudaGetLastError.restype = _cudaError_t\n   132→_cudart.cudaGetLastError.argtypes = []\n   133→\n   134→# const char* cudaGetErrorString(cudaError_t error);\n   135→_cudart.cudaGetErrorString.restype = ctypes.c_char_p\n   136→_cudart.cudaGetErrorString.argtypes = [_cudaError_t]\n   137→\n   138→# cudaError_t cudaSetDevice(int device);\n   139→_cudart.cudaSetDevice.restype = _cudaError_t\n   140→_cudart.cudaSetDevice.argtypes = [c_int]\n   141→\n   142→# ---------------------------------------------------------------------------\n   143→# Error checking\n   144→# ---------------------------------------------------------------------------\n   145→\n   146→\n   147→class CudaError(RuntimeError):\n   148→    \"\"\"Raised when a CUDA runtime call returns a non-success error code.\"\"\"\n   149→\n   150→    def __init__(self, err_code: int, context: str = \"\"):\n   151→        err_name = _cudart.cudaGetErrorString(err_code)\n   152→        if isinstance(err_name, bytes):\n   153→            err_name = err_name.decode(\"utf-8\", errors=\"replace\")\n   154→        msg = f\"CUDA error {err_code}: {err_name}\"\n   155→        if context:\n   156→            msg = f\"{context} -- {msg}\"\n   157→        super().__init__(msg)\n   158→        self.err_code = err_code\n   159→\n   160→\n   161→def _check(err: int, context: str = \"\") -> None:\n   162→    \"\"\"Raise CudaError if *err* != cudaSuccess.\"\"\"\n   163→    if err != cudaSuccess:\n   164→        raise CudaError(err, context)\n   165→\n   166→\n   167→def check_last_error(context: str = \"\") -> None:\n   168→    \"\"\"Call cudaGetLastError and raise on failure.\"\"\"\n   169→    _check(_cudart.cudaGetLastError(), context)\n   170→\n   171→\n   172→# ---------------------------------------------------------------------------\n   173→# Public thin wrappers\n   174→# ---------------------------------------------------------------------------\n   175→\n   176→\n   177→def register_buffer(\n   178→    vbo_id: int,\n   179→    flags: int = cudaGraphicsRegisterFlagsWriteDiscard,\n   180→) -> int:\n   181→    \"\"\"Register an OpenGL buffer object for access by CUDA.\n   182→\n   183→    Parameters\n   184→    ----------\n   185→    vbo_id : int\n   186→        The OpenGL VBO name (GLuint).\n   187→    flags : int\n   188→        Registration flags.  Default is ``cudaGraphicsRegisterFlagsWriteDiscard``.\n   189→\n   190→    Returns\n   191→    -------\n   192→    int\n   193→        Opaque handle (cudaGraphicsResource pointer as integer)
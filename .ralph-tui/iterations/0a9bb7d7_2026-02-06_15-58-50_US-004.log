pped resource so OpenGL can access it again.\"\"\"\n   242→    res_ptr = c_void_p(resource)\n   243→    err = _cudart.cudaGraphicsUnmapResources(1, byref(res_ptr), c_void_p(0))\n   244→    _check(err, \"cudaGraphicsUnmapResources\")\n   245→    check_last_error(\"cudaGraphicsUnmapResources (post)\")\n   246→\n   247→\n   248→# ---------------------------------------------------------------------------\n   249→# CudaGLBuffer -- high-level RAII-style wrapper\n   250→# ---------------------------------------------------------------------------\n   251→\n   252→\n   253→class CudaGLBuffer:\n   254→    \"\"\"Manage the lifecycle of a CUDA-registered OpenGL buffer.\n   255→\n   256→    Usage::\n   257→\n   258→        buf = CudaGLBuffer(vbo_id, nbytes)\n   259→        with buf:\n   260→            ptr, size = buf.mapped_pointer()\n   261→            # ... write to ptr via CuPy ...\n   262→        # buffer is unmapped; GL can draw it\n   263→\n   264→    When the object is deleted (or :meth:`close` is called), the buffer\n   265→    is unregistered from CUDA.\n   266→    \"\"\"\n   267→\n   268→    def __init__(\n   269→        self,\n   270→        vbo_id: int,\n   271→        nbytes: int,\n   272→        flags: int = cudaGraphicsRegisterFlagsWriteDiscard,\n   273→    ) -> None:\n   274→        self.vbo_id = vbo_id\n   275→        self.nbytes = nbytes\n   276→        self._resource: Optional[int] = register_buffer(vbo_id, flags)\n   277→        self._mapped = False\n   278→\n   279→    # -- context manager for map / unmap ----------------------------------\n   280→\n   281→    def __enter__(self) -> \"CudaGLBuffer\":\n   282→        self.map()\n   283→        return self\n   284→\n   285→    def __exit__(self, *exc_info: object) -> None:\n   286→        self.unmap()\n   287→\n   288→    # -- core operations ---------------------------------------------------\n   289→\n   290→    def map(self) -> None:\n   291→        if self._mapped:\n   292→            return\n   293→        if self._resource is None:\n   294→            raise RuntimeError(\"CudaGLBuffer: resource already closed\")\n   295→        map_buffer(self._resource)\n   296→        self._mapped = True\n   297→\n   298→    def unmap(self) -> None:\n   299→        if not self._mapped:\n   300→            return\n   301→        if self._resource is None:\n   302→            raise RuntimeError(\"CudaGLBuffer: resource already closed\")\n   303→        unmap_buffer(self._resource)\n   304→        self._mapped = False\n   305→\n   306→    def mapped_pointer(self) -> tuple[int, int]:\n   307→        \"\"\"Return ``(device_ptr, byte_size)`` of the mapped buffer.\"\"\"\n   308→        if not self._mapped:\n   309→            raise RuntimeError(\"CudaGLBuffer: buffer is not mapped\")\n   310→        return get_mapped_pointer(self._resource)\n   311→\n   312→    def device_pointer_as_cupy_array(\n   313→        self,\n   314→        shape: tuple[int, ...],\n   315→        dtype: \"object\" = None,\n   316→    ) -> \"object\":\n   317→        \"\"\"Wrap the mapped device pointer as a CuPy ndarray (zero-copy).\n   318→\n   319→        Parameters\n   320→        ----------\n   321→        shape : tuple[int, ...]\n   322→            Desired array shape.\n   323→        dtype : numpy/cupy dtype\n   324→            Element type.  Defaults to ``float32``.\n   325→\n   326→        Returns\n   327→        -------\n   328→        cupy.ndarray\n   329→        \"\"\"\n   330→        import cupy\n   331→        import numpy as np\n   332→\n   333→        if dtype is None:\n   334→            dtype = np.float32\n   335→\n   336→        dev_ptr, size = self.mapped_pointer()\n   337→        mem = cupy.cuda.UnownedMemory(dev_ptr, size, owner=None)\n   338→        memptr = cupy.cuda.MemoryPointer(mem, 0)\n   339→        return cupy.ndarray(shape, dtype=dtype, memptr=memptr)\n   340→\n   341→    # -- cleanup -----------------------------------------------------------\n   342→\n   343→    def close(self) -> None:\n   344→        \"\"\"Unmap (if needed) and unregister the buffer.\"\"\"\n   345→        if self._mapped:\n   346→            self.unmap()\n   347→        if self._resource is not None:\n   348→            unregister_buffer(self._resource)\n   349→            self._resource = None\n   350→\n   351→    def __del__(self) -> None:\n   352→        try:\n   353→            self.close()\n   354→        except Exception:\n   355→            pass\n   356→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_011BUyk6g4Q2zpd7NZctmWCb","session_id":"5675b38f-9ee3-41e5-bc71-e9e61142b4ac","uuid":"f305019c-3e5e-42df-8533-d24545096a49"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MuSQU4du3sP4fLRWe1G9Gv","type":"tool_result","content":"     1→\"\"\"Orbit camera with spherical coordinates, view/projection matrices.\"\"\"\n     2→\n     3→import math\n     4→import numpy as np\n     5→\n     6→\n     7→class OrbitCamera:\n     8→    \"\"\"Orbit camera around a target point using spherical coordinates.\n     9→\n    10→    Controls: right-drag=orbit, scroll=zoom, middle-drag=pan.\n    11→    \"\"\"\n    12→\n    13→    def __init__(\n    14→        self,\n    15→        target: np.ndarray = None,\n    16→        distance: float = 3.0,\n    17→        azimuth: float = 0.0,\n    18→        elevation: float = 30.0,\n    19→        fov: float = 45.0,\n    20→        near: float = 0.01,\n    21→        far: float = 100.0,\n    22→    ):\n    23→        self.target = np.array(target if target is not None else [0.0, 0.0, 0.0], dtype=np.float32)\n    24→        self.distance = distance\n    25→        self.azimuth = azimuth      # degrees, horizontal rotation\n    26→        self.elevation = elevation  # degrees, vertical rotation\n    27→        self.fov = fov              # vertical field of view in degrees\n    28→        self.near = near\n    29→        self.far = far\n    30→        self.aspect = 16.0 / 9.0\n    31→\n    32→        # Zoom limits\n    33→        self.min_distance = 0.1\n    34→        self.max_distance = 50.0\n    35→\n    36→        # Elevation limits (avoid gimbal lock)\n    37→        self.min_elevation = -89.0\n    38→        self.max_elevation = 89.0\n    39→\n    40→        # Sensitivity\n    41→        self.orbit_sensitivity = 0.3\n    42→        self.zoom_sensitivity = 0.15\n    43→        self.pan_sensitivity = 0.003\n    44→\n    45→    @property\n    46→    def position(self) -> np.ndarray:\n    47→        \"\"\"Camera position in world space computed from spherical coords.\"\"\"\n    48→        az = math.radians(self.azimuth)\n    49→        el = math.radians(self.elevation)\n    50→        cos_el = math.cos(el)\n    51→        x = self.target[0] + self.distance * cos_el * math.sin(az)\n    52→        y = self.target[1] + self.distance * math.sin(el)\n    53→        z = self.target[2] + self.distance * cos_el * math.cos(az)\n    54→        return np.array([x, y, z], dtype=np.float32)\n    55→\n    56→    def orbit(self, dx: float, dy: float):\n    57→        \"\"\"Rotate camera around target. dx/dy in pixels.\"\"\"\n    58→        self.azimuth -= dx * self.orbit_sensitivity\n    59→        self.elevation += dy * self.orbit_sensitivity\n    60→        self.elevation = max(self.min_elevation, min(self.max_elevation, self.elevation))\n    61→\n    62→    def zoom(self, delta: float):\n    63→        \"\"\"Zoom in/out. Positive delta = zoom in.\"\"\"\n    64→        factor = 1.0 - delta * self.zoom_sensitivity\n    65→        self.distance *= factor\n    66→        self.distance = max(self.min_distance, min(self.max_distance, self.distance))\n    67→\n    68→    def pan(self, dx: float, dy: float):\n    69→        \"\"\"Pan the camera (move target). dx/dy in pixels.\"\"\"\n    70→        az = math.radians(self.azimuth)\n    71→        # Right vector (horizontal)\n    72→        right = np.array([math.cos(az), 0.0, -math.sin(az)], dtype=np.float32)\n    73→        # Up vector (world up projected)\n    74→        up = np.array([0.0, 1.0, 0.0], dtype=np.float32)\n    75→\n    76→        scale = self.distance * self.pan_sensitivity\n    77→        self.target -= right * dx * scale\n    78→        self.target += up * dy * scale\n    79→\n    80→    def view_matrix(self) -> np.ndarray:\n    81→        \"\"\"Compute 4x4 view matrix (look-at).\"\"\"\n    82→        eye = self.position\n    83→        center = self.target\n    84→        up = np.array([0.0, 1.0, 0.0], dtype=np.float32)\n    85→        return _look_at(eye, center, up)\n    86→\n    87→    def projection_matrix(self) -> np.ndarray:\n    88→        \"\"\"Compute 4x4 perspective projection matrix.\"\"\"\n    89→        return _perspective(self.fov, self.aspect, self.near, self.far)\n    90→\n    91→    def set_aspect(self, width: int, height: int):\n    92→        if height > 0:\n    93→            self.aspect = width / height\n    94→\n    95→\n    96→def _look_at(eye: np.ndarray, center: np.ndarray, up: np.ndarray) -> np.ndarray:\n    97→    \"\"\"Compute OpenGL-style look-at view matrix.\"\"\"\n    98→    f = center - eye\n    99→    f = f / np.linalg.norm(f)\n   100→    s = np.cross(f, up)\n   101→    s = s / np.linalg.norm(s)\n   102→    u = np.cross(s, f)\n   103→\n   104→    m = np.eye(4, dtype=np.float32)\n   105→    m[0, 0] = s[0]; m[0, 1] = s[1]; m[0, 2] = s[2]\n   106→    m[1, 0] = u[0]; m[1, 1] = u[1]; m[1, 2] = u[2]\n   107→    m[2, 0] = -f[0]; m[2, 1] = -f[1]; m[2, 2] = -f[2]\n   108→    m[0, 3] = -np.dot(s, eye)\n   109→    m[1, 3] = -np.dot(u, eye)\n   110→    m[2, 3] = np.dot(f, eye)\n   111→    return m\n   112→\n   113→\n   114→def _perspective(fov_deg: float, aspect: float, near: float, far: float) -> np.ndarray:\n   115→    \"\"\"Compute OpenGL-style perspective projection matrix.\"\"\"\n   116→    f = 1.0 / math.tan(math.radians(fov_deg) / 2.0)\n   117→    m = np.zeros((4, 4), dtype=np.float32)\n   118→    m[0, 0] = f / aspect\n   119→    m[1, 1] = f\n   120→    m[2, 2] = (far + near) / (near - far)\n   121→    m[2, 3] = (2.0 * far * near) / (near - far)\n   122→    m[3, 2] = -1.0\n   123→    return m\n   124→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_011BUyk6g4Q2zpd7NZctmWCb","session_id":"5675b38f-9ee3-41e5-bc71-e9e61142b4ac","uuid":"1b635618-f253-444a-a33f-4fb7ca6ad865"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RcWSPB2yANcLWCRQzC35tn","type":"tool_result","content":"     1→\"\"\"Falling Sand 3D - Main entry point with GLFW window and orbit camera.\"\"\"\n     2→\n     3→import time\n     4→import glfw\n     5→from OpenGL.GL import (\n     6→    glClearColor, glClear, glGetString, glGetError,\n     7→    GL_COLOR_BUFFER_BIT, GL_DEPTH_BUFFER_BIT,\n     8→    GL_VERSION, GL_RENDERER, GL_NO_ERROR,\n     9→)\n    10→from camera import OrbitCamera\n    11→\n    12→WINDOW_WIDTH = 1280\n    13→WINDOW_HEIGHT = 720\n    14→WINDOW_TITLE = \"Falling Sand 3D\"\n    15→\n    16→\n    17→def main():\n    18→    if not glfw.init():\n    19→        raise RuntimeError(\"Failed to initialize GLFW\")\n    20→\n    21→    # Request OpenGL 4.1+ core profile\n    22→    glfw.window_hint(glfw.CONTEXT_VERSION_MAJOR, 4)\n    23→    glfw.window_hint(glfw.CONTEXT_VERSION_MINOR, 1)\n    24→    glfw.window_hint(glfw.OPENGL_PROFILE, glfw.OPENGL_CORE_PROFILE)\n    25→    glfw.window_hint(glfw.OPENGL_FORWARD_COMPAT, glfw.TRUE)\n    26→\n    27→    window = glfw.create_window(WINDOW_WIDTH, WINDOW_HEIGHT, WINDOW_TITLE, None, None)\n    28→    if not window:\n    29→        glfw.terminate()\n    30→        raise RuntimeError(\"Failed to create GLFW window\")\n    31→\n    32→    glfw.make_context_current(window)\n    33→    glfw.swap_interval(1)  # vsync\n    34→\n    35→    # Verify OpenGL version\n    36→    gl_version = glGetString(GL_VERSION)\n    37→    gl_renderer = glGetString(GL_RENDERER)\n    38→    if gl_version:\n    39→        print(f\"OpenGL: {gl_version.decode()}\")\n    40→    if gl_renderer:\n    41→        print(f\"Renderer: {gl_renderer.decode()}\")\n    42→\n    43→    # Dark gray background\n    44→    glClearColor(0.15, 0.15, 0.15, 1.0)\n    45→\n    46→    camera = OrbitCamera()\n    47→    camera.set_aspect(WINDOW_WIDTH, WINDOW_HEIGHT)\n    48→\n    49→    # Input state\n    50→    right_pressed = False\n    51→    middle_pressed = False\n    52→    last_mx, last_my = 0.0, 0.0\n    53→\n    54→    def key_callback(_win, key, _scancode, action, _mods):\n    55→        if key == glfw.KEY_ESCAPE and action == glfw.PRESS:\n    56→            glfw.set_window_should_close(_win, True)\n    57→\n    58→    def mouse_button_callback(_win, button, action, _mods):\n    59→        nonlocal right_pressed, middle_pressed, last_mx, last_my\n    60→        if button == glfw.MOUSE_BUTTON_RIGHT:\n    61→            right_pressed = action == glfw.PRESS\n    62→            if right_pressed:\n    63→                last_mx, last_my = glfw.get_cursor_pos(_win)\n    64→        elif button == glfw.MOUSE_BUTTON_MIDDLE:\n    65→            middle_pressed = action == glfw.PRESS\n    66→            if middle_pressed:\n    67→                last_mx, last_my = glfw.get_cursor_pos(_win)\n    68→\n    69→    def cursor_pos_callback(_win, xpos, ypos):\n    70→        nonlocal last_mx, last_my\n    71→        dx = xpos - last_mx\n    72→        dy = ypos - last_my\n    73→        last_mx, last_my = xpos, ypos\n    74→\n    75→        if right_pressed:\n    76→            camera.orbit(dx, dy)\n    77→        elif middle_pressed:\n    78→            camera.pan(dx, dy)\n    79→\n    80→    def scroll_callback(_win, _xoffset, yoffset):\n    81→        camera.zoom(yoffset)\n    82→\n    83→    def framebuffer_size_callback(_win, width, height):\n    84→        camera.set_aspect(width, height)\n    85→\n    86→    glfw.set_key_callback(window, key_callback)\n    87→    glfw.set_mouse_button_callback(window, mouse_button_callback)\n    88→    glfw.set_cursor_pos_callback(window, cursor_pos_callback)\n    89→    glfw.set_scroll_callback(window, scroll_callback)\n    90→    glfw.set_framebuffer_size_callback(window, framebuffer_size_callback)\n    91→\n    92→    # FPS tracking\n    93→    frame_count = 0\n    94→    fps_time = time.perf_counter()\n    95→    fps = 0.0\n    96→\n    97→    while not glfw.window_should_close(window):\n    98→        glfw.poll_events()\n    99→\n   100→        glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)\n   101→\n   102→        # Camera matrices available for rendering\n   103→        _view = camera.view_matrix()\n   104→        _proj = camera.projection_matrix()\n   105→\n   106→        glfw.swap_buffers(window)\n   107→\n   108→        # FPS counter\n   109→        frame_count += 1\n   110→        now = time.perf_counter()\n   111→        elapsed = now - fps_time\n   112→        if elapsed >= 0.5:\n   113→            fps = frame_count / elapsed\n   114→            frame_count = 0\n   115→            fps_time = now\n   116→            glfw.set_window_title(window, f\"{WINDOW_TITLE} | FPS: {fps:.0f}\")\n   117→\n   118→        # Check GL errors\n   119→        err = glGetError()\n   120→        if err != GL_NO_ERROR:\n   121→            print(f\"GL error: {err}\")\n   122→\n   123→    glfw.destroy_window(window)\n   124→    glfw.terminate()\n   125→\n   126→\n   127→if __name__ == \"__main__\":\n   128→    main()\n   129→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_011BUyk6g4Q2zpd7NZctmWCb","session_id":"5675b38f-9ee3-41e5-bc71-e9e61142b4ac","uuid":"f6b7f1be-27cf-49f4-a34e-a9f46bec9783"}

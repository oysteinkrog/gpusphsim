{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015wEc4Qc7Zid2VDqZARebtD","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter\n     5→and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n     9→  2. Run sim_steps simulation substeps\n    10→  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import time\n    16→from typing import Optional\n    17→\n    18→import cupy as cp\n    19→import numpy as np\n    20→\n    21→from world import World\n    22→from materials import (\n    23→    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n    24→)\n    25→\n    26→import hash_sort\n    27→import fused_reorder\n    28→import build_grid\n    29→import step1\n    30→import step2\n    31→import integrate\n    32→import reactions\n    33→import spawn\n    34→import wake\n    35→\n    36→\n    37→class Simulation:\n    38→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    39→\n    40→    Parameters\n    41→    ----------\n    42→    world : World\n    43→        Particle state manager.\n    44→    dt : float\n    45→        Fixed simulation timestep (seconds).\n    46→    speed : float\n    47→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    48→    max_substeps : int\n    49→        Maximum substeps per render frame to prevent spiral-of-death.\n    50→    \"\"\"\n    51→\n    52→    def __init__(\n    53→        self,\n    54→        world: World,\n    55→        dt: float = 0.001,\n    56→        speed: float = 1.0,\n    57→        max_substeps: int = 20,\n    58→    ) -> None:\n    59→        self.world = world\n    60→        self.dt = dt\n    61→        self.speed = speed\n    62→        self.max_substeps = max_substeps\n    63→        self._paused = False\n    64→        self._prev_speed = speed\n    65→        self._last_frame_time: Optional[float] = None\n    66→        self._last_substeps = 0\n    67→        self.sim_time = 0.0\n    68→        self._frame_counter = 0\n    69→\n    70→        # Grid cell tables (pre-allocated, reused every frame)\n    71→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    72→\n    73→        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n    74→        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n    75→\n    76→        # Freelist for spawn/kill system (pre-allocated, reset each step)\n    77→        self._dead_indices, self._dead_count = spawn.allocate_freelist(\n    78→            world.max_particles\n    79→        )\n    80→\n    81→        # Compile all kernel modules and upload constant memory\n    82→        self._upload_constants()\n    83→\n    84→    def _upload_constants(self) -> None:\n    85→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n    86→        # Build shared param structs\n    87→        grid_params = hash_sort.build_grid_params()\n    88→        sim_params = step1.build_sim_params(\n    89→            smoothing_length=0.04,\n    90→            particle_mass=0.008,\n    91→            particle_spacing=0.02,\n    92→            gravity=(0.0, -9.8, 0.0),\n    93→            dt=self.dt,\n    94→            restitution=0.3,\n    95→            wall_friction=0.5,\n    96→            world_min=(-1.0, -1.0, -1.0),\n    97→            world_max=(1.0, 1.0, 1.0),\n    98→        )\n    99→        precalc_params = step1.build_precalc_params(\n   100→            smoothing_length=0.04,\n   101→            viscosity=1.0,\n   102→        )\n   103→        granular_params = step2.build_granular_params()\n   104→        materials_data = build_material_array()\n   105→        interactions_data = build_interaction_matrix()\n   106→\n   107→        # --- hash_sort module: c_grid ---\n   108→        hash_sort.upload_grid_params(grid_params)\n   109→\n   110→        # --- fused_reorder module: no constant memory needed ---\n   111→        fused_reorder.get_module()  # just compile\n   112→\n   113→        # --- build_grid module: c_grid ---\n   114→        build_grid.upload_grid_params(grid_params)\n   115→\n   116→        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n   117→        step1.upload_grid_params(grid_params)\n   118→        step1.upload_sim_params(sim_params)\n   119→        step1.upload_precalc_params(precalc_params)\n   120→        step1.upload_materials(materials_data)\n   121→        step1.upload_interactions(interactions_data)\n   122→\n   123→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   124→        step2.upload_grid_params(grid_params)\n   125→        step2.upload_sim_params(sim_params)\n   126→        step2.upload_precalc_params(precalc_params)\n   127→        step2.upload_materials(materials_data)\n   128→        step2.upload_granular_params(granular_params)\n   129→\n   130→        # --- integrate module: c_sim, c_materials ---\n   131→        integrate.upload_sim_params(sim_params)\n   132→        integrate.upload_materials(materials_data)\n   133→\n   134→        # --- reactions module: c_sim, c_materials ---\n   135→        reactions.upload_sim_params(sim_params)\n   136→        reactions.upload_materials(materials_data)\n   137→\n   138→        # --- spawn module: c_sim, c_materials ---\n   139→        spawn.upload_sim_params(sim_params)\n   140→        spawn.upload_materials(materials_data)\n   141→\n   142→        # --- wake module: c_grid ---\n   143→        wake.upload_grid_params(grid_params)\n   144→\n   145→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   146→        upload_to_gpu()\n   147→\n   148→    def _sim_step(self, n: int) -> None:\n   149→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   150→        w = self.world\n   151→\n   152→        # 1. Hash particle positions\n   153→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   154→\n   155→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   156→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   157→            hashes, indices,\n   158→            sorted_hashes_out=w.sorted_hashes,\n   159→            sorted_indices_out=w.sorted_indices,\n   160→        )\n   161→\n   162→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   163→        fused_reorder.fused_reorder(\n   164→            n, sorted_indices,\n   165→            w.position, w.velocity, w.veleval,\n   166→            w.mass, w.packed_info, w.temperature,\n   167→            w.health, w.lifetime, w.color,\n   168→            w.sleep_counter, w.shear_rate,\n   169→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   170→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   171→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   172→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   173→        )\n   174→\n   175→        # 4. Build grid data structure (cell_start / cell_end tables)\n   176→        build_grid.build_data_struct(\n   177→            sorted_hashes[:n], self._cell_start, self._cell_end\n   178→        )\n   179→\n   180→        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n   181→        step1.compute_step1(\n   182→            w.sorted_position[:n],\n   183→            w.sorted_velocity[:n],\n   184→            w.sorted_mass[:n],\n   185→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   186→            w.sorted_packed_info[:n],\n   187→            w.sorted_temperature[:n],\n   188→            self._cell_start,\n   189→            self._cell_end,\n   190→            density_out=w.sorted_density,\n   191→            shear_rate_out=w.sorted_shear_rate,\n   192→            dTdt_out=w.sorted_dTdt,\n   193→            exposure_heat_out=w.sorted_exposure_heat,\n   194→            exposure_corrode_out=w.sorted_exposure_corrode,\n   195→        )\n   196→        w._density_initialized = True\n   197→\n   198→        # 5b. Reset freelist counter for this step\n   199→        spawn.reset_freelist(self._dead_count)\n   200→\n   201→        # 5c. Reactions: phase transitions, combustion, corrosion, gas lifetime\n   202→        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n   203→        #     lifetime/velocity in-place before Step2 sees them.\n   204→        #     Also populates the freelist when particles die.\n   205→        reactions.compute_reactions(\n   206→            w.sorted_packed_info[:n],\n   207→            w.sorted_temperature[:n],\n   208→            w.sorted_health[:n],\n   209→            w.sorted_lifetime[:n],\n   210→            w.sorted_velocity[:n],\n   211→            w.sorted_exposure_heat[:n],\n   212→            w.sorted_exposure_corrode[:n],\n   213→            frame=self._frame_counter,\n   214→            dead_indices=self._dead_indices,\n   215→            dead_count=self._dead_count,\n   216→        )\n   217→\n   218→        # 5d. Spawn: consume from freelist to spawn steam from boiling water\n   219→        spawn.compute_spawn(\n   220→            w.sorted_packed_info[:n],\n   221→            w.sorted_position[:n],\n   222→            w.sorted_velocity[:n],\n   223→            w.sorted_veleval[:n],\n   224→            w.sorted_mass[:n],\n   225→            w.sorted_temperature[:n],\n   226→            w.sorted_health[:n],\n   227→            w.sorted_lifetime[:n],\n   228→            w.sorted_color[:n],\n   229→            w.sorted_sleep_counter[:n],\n   230→            w.sorted_density[:n],\n   231→            w.sorted_shear_rate[:n],\n   232→            self._dead_indices,\n   233→            self._dead_count,\n   234→        )\n   235→\n   236→        # 6. Step2: pressure + viscosity + XSPH forces\n   237→        step2.compute_step2(\n   238→            w.sorted_position[:n],\n   239→            w.sorted_velocity[:n],\n   240→            w.sorted_density[:n],\n   241→            w.sorted_mass[:n],\n   242→            w.sorted_packed_info[:n],\n   243→            self._cell_start,\n   244→            self._cell_end,\n   245→            sph_force_out=w.sorted_sph_force,\n   246→            veleval_out=w.sorted_veleval,\n   247→        )\n   248→\n   249→        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n   250→        #    Writes back to UNSORTED arrays via sort_indexes\n   251→        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n   252→        integrate.integrate(\n   253→            w.sorted_position[:n],\n   254→            w.sorted_velocity[:n],\n   255→            w.sorted_veleval[:n],\n   256→            w.sorted_sph_force[:n],\n   257→            w.sorted_mass[:n],\n   258→            w.sorted_packed_info[:n],\n   259→            w.sorted_temperature[:n],\n   260→            w.sorted_health[:n],\n   261→            sorted_density=w.sorted_density[:n],\n   262→            sorted_shear_rate=w.sorted_shear_rate[:n],\n   263→            sorted_dTdt=w.sorted_dTdt[:n],\n   264→            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n   265→            sort_indexes=sorted_indices[:n],\n   266→            position_out=w.position,\n   267→            velocity_out=w.velocity,\n   268→            color_out=w.color,\n   269→            packed_info_out=w.packed_info,\n   270→            sleep_counter_out=w.sleep_counter,\n   271→            temperature_out=w.temperature,\n   272→        )\n   273→\n   274→        # 8. Wake propagation: mark cells near just-woke particles,\n   275→        #    wake sleeping neighbors, clear JUST_WOKE flags\n   276→        wake.run_wake_propagation(\n   277→            w.position[:n],\n   278→            w.packed_info[:n],\n   279→            w.sleep_counter[:n],\n   280→            self._cell_wake_flags,\n   281→            num_particles=n,\n   282→        )\n   283→\n   284→        self.sim_time += self.dt\n   285→        self._frame_counter += 1\n   286→\n   287→    def step_frame(self) -> int:\n   288→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   289→        now = time.perf_counter()\n   290→        if self._last_frame_time is None:\n   291→            self._last_frame_time = now\n   292→            return 0\n   293→\n   294→        wall_dt = now - self._last_frame_time\n   295→        self._last_frame_time = now\n   296→\n   297→        if self._paused or self.speed <= 0.0:\n   298→            self._last_substeps = 0\n   299→            return 0\n   300→\n   301→        n = self.world._high_water\n   302→        if n == 0:\n   303→            self._last_substeps = 0\n   304→            return 0\n   305→\n   306→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   307→        sim_steps = max(0, min(\n   308→            self.max_substeps,\n   309→            round(self.speed * wall_dt / self.dt),\n   310→        ))\n   311→\n   312→        for _ in range(sim_steps):\n   313→            self._sim_step(n)\n   314→\n   315→        self._last_substeps = sim_steps\n   316→        return sim_steps\n   317→\n   318→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   319→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   320→\n   321→        Parameters\n   322→        ----------\n   323→        cuda_pos : CudaGLBuffer\n   324→            Position VBO wrapper (must be context-managed externally).\n   325→        cuda_col : CudaGLBuffer\n   326→            Color VBO wrapper (must be context-managed externally).\n   327→        \"\"\"\n   328→        n = self.world._high_water\n   329→        if n == 0:\n   330→            return\n   331→\n   332→        # Position: world pos (float4) -> VBO pos (float4)\n   333→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   334→            (cuda_pos.nbytes // 16, 4), np.float32,\n   335→        )\n   336→        pos_arr[:n] = self.world.position[:n]\n   337→\n   338→        # Color: world color (float4) -> VBO color (float4)\n   339→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   340→            (cuda_col.nbytes // 16, 4), np.float32,\n   341→        )\n   342→        col_arr[:n] = self.world.color[:n]\n   343→\n   344→    @property\n   345→    def paused(self) -> bool:\n   346→        return self._paused\n   347→\n   348→    def toggle_pause(self) -> None:\n   349→        self._paused = not self._paused\n   350→\n   351→    def adjust_speed(self, delta: float) -> None:\n   352→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   353→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   354→\n   355→    @property\n   356→    def last_substeps(self) -> int:\n   357→        return self._last_substeps\n   358→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"374499ef-5ec0-4577-85fa-be8b5d7ef994","uuid":"7047819c-52a6-4668-95e9-890e750b4a98","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/simulation.py","content":"\"\"\"SPH simulation orchestrator.\n\nWires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\nStep2 -> Integrate.  Decouples simulation from rendering via a speed parameter\nand substep budget.\n\nEach render frame:\n  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n  2. Run sim_steps simulation substeps\n  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Optional\n\nimport cupy as cp\nimport numpy as np\n\nfrom world import World\nfrom materials import (\n    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n)\n\nimport hash_sort\nimport fused_reorder\nimport build_grid\nimport step1\nimport step2\nimport integrate\nimport reactions\nimport spawn\nimport wake\n\n\nclass Simulation:\n    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n\n    Parameters\n    ----------\n    world : World\n        Particle state manager.\n    dt : float\n        Fixed simulation timestep (seconds).\n    speed : float\n        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    max_substeps : int\n        Maximum substeps per render frame to prevent spiral-of-death.\n    \"\"\"\n\n    def __init__(\n        self,\n        world: World,\n        dt: float = 0.001,\n        speed: float = 1.0,\n        max_substeps: int = 20,\n    ) -> None:\n        self.world = world\n        self.dt = dt\n        self.speed = speed\n        self.max_substeps = max_substeps\n        self._paused = False\n        self._prev_speed = speed\n        self._last_frame_time: Optional[float] = None\n        self._last_substeps = 0\n        self.sim_time = 0.0\n        self._frame_counter = 0\n\n        # Grid cell tables (pre-allocated, reused every frame)\n        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n\n        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n\n        # Freelist for spawn/kill system (pre-allocated, reset each step)\n        self._dead_indices, self._dead_count = spawn.allocate_freelist(\n            world.max_particles\n        )\n\n        # Compile all kernel modules and upload constant memory\n        self._upload_constants()\n\n    def _upload_constants(self) -> None:\n        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n        # Build shared param structs\n        grid_params = hash_sort.build_grid_params()\n        sim_params = step1.build_sim_params(\n            smoothing_length=0.04,\n            particle_mass=0.008,\n            particle_spacing=0.02,\n            gravity=(0.0, -9.8, 0.0),\n            dt=self.dt,\n            restitution=0.3,\n            wall_friction=0.5,\n            world_min=(-1.0, -1.0, -1.0),\n            world_max=(1.0, 1.0, 1.0),\n        )\n        precalc_params = step1.build_precalc_params(\n            smoothing_length=0.04,\n            viscosity=1.0,\n        )\n        granular_params = step2.build_granular_params()\n        materials_data = build_material_array()\n        interactions_data = build_interaction_matrix()\n\n        # --- hash_sort module: c_grid ---\n        hash_sort.upload_grid_params(grid_params)\n\n        # --- fused_reorder module: no constant memory needed ---\n        fused_reorder.get_module()  # just compile\n\n        # --- build_grid module: c_grid ---\n        build_grid.upload_grid_params(grid_params)\n\n        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n        step1.upload_grid_params(grid_params)\n        step1.upload_sim_params(sim_params)\n        step1.upload_precalc_params(precalc_params)\n        step1.upload_materials(materials_data)\n        step1.upload_interactions(interactions_data)\n\n        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n        step2.upload_grid_params(grid_params)\n        step2.upload_sim_params(sim_params)\n        step2.upload_precalc_params(precalc_params)\n        step2.upload_materials(materials_data)\n        step2.upload_granular_params(granular_params)\n\n        # --- integrate module: c_sim, c_materials ---\n        integrate.upload_sim_params(sim_params)\n        integrate.upload_materials(materials_data)\n\n        # --- reactions module: c_sim, c_materials ---\n        reactions.upload_sim_params(sim_params)\n        reactions.upload_materials(materials_data)\n\n        # --- spawn module: c_sim, c_materials ---\n        spawn.upload_sim_params(sim_params)\n        spawn.upload_materials(materials_data)\n\n        # --- wake module: c_grid ---\n        wake.upload_grid_params(grid_params)\n\n        # --- materials module (its own internal module): c_materials, c_interactions ---\n        upload_to_gpu()\n\n    def _sim_step(self, n: int) -> None:\n        \"\"\"Run one simulation substep on n particles.\"\"\"\n        w = self.world\n\n        # 1. Hash particle positions\n        hashes, indices = hash_sort.calc_hash(w.position[:n])\n\n        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n            hashes, indices,\n            sorted_hashes_out=w.sorted_hashes,\n            sorted_indices_out=w.sorted_indices,\n        )\n\n        # 3. Fused reorder: gather all unsorted arrays into sorted order\n        fused_reorder.fused_reorder(\n            n, sorted_indices,\n            w.position, w.velocity, w.veleval,\n            w.mass, w.packed_info, w.temperature,\n            w.health, w.lifetime, w.color,\n            w.sleep_counter, w.shear_rate,\n            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n            w.sorted_sleep_counter, w.sorted_shear_rate,\n        )\n\n        # 4. Build grid data structure (cell_start / cell_end tables)\n        build_grid.build_data_struct(\n            sorted_hashes[:n], self._cell_start, self._cell_end\n        )\n\n        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n        step1.compute_step1(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_mass[:n],\n            w.sorted_density if hasattr(w, '_density_initialized') else None,\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            self._cell_start,\n            self._cell_end,\n            density_out=w.sorted_density,\n            shear_rate_out=w.sorted_shear_rate,\n            dTdt_out=w.sorted_dTdt,\n            exposure_heat_out=w.sorted_exposure_heat,\n            exposure_corrode_out=w.sorted_exposure_corrode,\n        )\n        w._density_initialized = True\n\n        # 5b. Reset freelist counter for this step\n        spawn.reset_freelist(self._dead_count)\n\n        # 5c. Reactions: phase transitions, combustion, corrosion, gas lifetime\n        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n        #     lifetime/velocity in-place before Step2 sees them.\n        #     Also populates the freelist when particles die.\n        reactions.compute_reactions(\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            w.sorted_lifetime[:n],\n            w.sorted_velocity[:n],\n            w.sorted_exposure_heat[:n],\n            w.sorted_exposure_corrode[:n],\n            frame=self._frame_counter,\n            dead_indices=self._dead_indices,\n            dead_count=self._dead_count,\n        )\n\n        # 5d. Spawn: consume from freelist to spawn steam from boiling water\n        spawn.compute_spawn(\n            w.sorted_packed_info[:n],\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_mass[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            w.sorted_lifetime[:n],\n            w.sorted_color[:n],\n            w.sorted_sleep_counter[:n],\n            w.sorted_density[:n],\n            w.sorted_shear_rate[:n],\n            self._dead_indices,\n            self._dead_count,\n        )\n\n        # 6. Step2: pressure + viscosity + XSPH forces\n        step2.compute_step2(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_density[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            sph_force_out=w.sorted_sph_force,\n            veleval_out=w.sorted_veleval,\n        )\n\n        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n        #    Writes back to UNSORTED arrays via sort_indexes\n        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n        integrate.integrate(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_sph_force[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            sorted_density=w.sorted_density[:n],\n            sorted_shear_rate=w.sorted_shear_rate[:n],\n            sorted_dTdt=w.sorted_dTdt[:n],\n            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n            sort_indexes=sorted_indices[:n],\n            position_out=w.position,\n            velocity_out=w.velocity,\n            color_out=w.color,\n            packed_info_out=w.packed_info,\n            sleep_counter_out=w.sleep_counter,\n            temperature_out=w.temperature,\n        )\n\n        # 8. Wake propagation: mark cells near just-woke particles,\n        #    wake sleeping neighbors, clear JUST_WOKE flags\n        wake.run_wake_propagation(\n            w.position[:n],\n            w.packed_info[:n],\n            w.sleep_counter[:n],\n            self._cell_wake_flags,\n            num_particles=n,\n        )\n\n        self.sim_time += self.dt\n        self._frame_counter += 1\n\n    def step_frame(self) -> int:\n        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n        now = time.perf_counter()\n        if self._last_frame_time is None:\n            self._last_frame_time = now\n            return 0\n\n        wall_dt = now - self._last_frame_time\n        self._last_frame_time = now\n\n        if self._paused or self.speed <= 0.0:\n            self._last_substeps = 0\n            return 0\n\n        n = self.world._high_water\n        if n == 0:\n            self._last_substeps = 0\n            return 0\n\n        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n        sim_steps = max(0, min(\n            self.max_substeps,\n            round(self.speed * wall_dt / self.dt),\n        ))\n\n        for _ in range(sim_steps):\n            self._sim_step(n)\n\n        self._last_substeps = sim_steps\n        return sim_steps\n\n    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n\n        Parameters\n        ----------\n        cuda_pos : CudaGLBuffer\n            Position VBO wrapper (must be context-managed externally).\n        cuda_col : CudaGLBuffer\n            Color VBO wrapper (must be context-managed externally).\n        \"\"\"\n        n = self.world._high_water\n        if n == 0:\n            return\n\n        # Position: world pos (float4) -> VBO pos (float4)\n        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n            (cuda_pos.nbytes // 16, 4), np.float32,\n        )\n        pos_arr[:n] = self.world.position[:n]\n\n        # Color: world color (float4) -> VBO color (float4)\n        col_arr = cuda_col.device_pointer_as_cupy_array(\n            (cuda_col.nbytes // 16, 4), np.float32,\n        )\n        col_arr[:n] = self.world.color[:n]\n\n    @property\n    def paused(self) -> bool:\n        return self._paused\n\n    def toggle_pause(self) -> None:\n        self._paused = not self._paused\n\n    def adjust_speed(self, delta: float) -> None:\n        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n        self.speed = max(0.1, min(10.0, self.speed + delta))\n\n    @property\n    def last_substeps(self) -> int:\n        return self._last_substeps\n","numLines":358,"startLine":1,"totalLines":358}}}

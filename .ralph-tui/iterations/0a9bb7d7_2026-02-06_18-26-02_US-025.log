{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KqHAzX2qGgJ9HX7pNrXUyU","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter,\n     5→accuracy parameter (CFL number), and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. If adaptive mode: compute dt from CFL constraints (advection, acoustic, viscous)\n     9→  2. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n    10→  3. Run sim_steps simulation substeps\n    11→  4. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    12→\"\"\"\n    13→\n    14→from __future__ import annotations\n    15→\n    16→import math\n    17→import time\n    18→from typing import Optional\n    19→\n    20→import cupy as cp\n    21→import numpy as np\n    22→\n    23→from world import World\n    24→from materials import (\n    25→    WATER, SAND, MATERIALS, GRANULAR, GAS, STATIC,\n    26→    build_material_array, build_interaction_matrix, upload_to_gpu,\n    27→)\n    28→\n    29→import hash_sort\n    30→import fused_reorder\n    31→import build_grid\n    32→import step1\n    33→import step2\n    34→import integrate\n    35→import reactions\n    36→import spawn\n    37→import wake\n    38→\n    39→# Adaptive timestep limits\n    40→DT_MIN = 1e-5\n    41→DT_MAX = 0.005\n    42→\n    43→\n    44→class Simulation:\n    45→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    46→\n    47→    Parameters\n    48→    ----------\n    49→    world : World\n    50→        Particle state manager.\n    51→    dt : float\n    52→        Initial simulation timestep (seconds). Used as fixed_dt_value when\n    53→        fixed_dt is ON.\n    54→    speed : float\n    55→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    56→    accuracy : float\n    57→        CFL number for adaptive timestep (0.1-1.0, default 0.4).\n    58→        Lower = smaller dt = more stable. Higher = larger dt = faster but riskier.\n    59→    fixed_dt : bool\n    60→        If True, use fixed timestep (no CFL computation). Default False.\n    61→    max_substeps : int\n    62→        Maximum substeps per render frame to prevent spiral-of-death.\n    63→    \"\"\"\n    64→\n    65→    def __init__(\n    66→        self,\n    67→        world: World,\n    68→        dt: float = 0.001,\n    69→        speed: float = 1.0,\n    70→        accuracy: float = 0.4,\n    71→        fixed_dt: bool = False,\n    72→        max_substeps: int = 20,\n    73→    ) -> None:\n    74→        self.world = world\n    75→        self.dt = dt\n    76→        self.speed = speed\n    77→        self.accuracy = accuracy\n    78→        self.fixed_dt = fixed_dt\n    79→        self.fixed_dt_value = dt\n    80→        self.max_substeps = max_substeps\n    81→        self._paused = False\n    82→        self._prev_speed = speed\n    83→        self._last_frame_time: Optional[float] = None\n    84→        self._last_substeps = 0\n    85→        self.sim_time = 0.0\n    86→        self._frame_counter = 0\n    87→\n    88→        # Precompute acoustic speed from materials table\n    89→        self._c_sound = self._compute_c_sound()\n    90→        # Precompute max viscosity and min density for viscous CFL\n    91→        self._max_eta, self._rho_min = self._compute_viscosity_bounds()\n    92→\n    93→        # Smoothing length (must match _upload_constants)\n    94→        self._h = 0.04\n    95→\n    96→        # Grid cell tables (pre-allocated, reused every frame)\n    97→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    98→\n    99→        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n   100→        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n   101→\n   102→        # Freelist for spawn/kill system (pre-allocated, reset each step)\n   103→        self._dead_indices, self._dead_count = spawn.allocate_freelist(\n   104→            world.max_particles\n   105→        )\n   106→\n   107→        # Cached sim_params for dt updates (set during _upload_constants)\n   108→        self._sim_params: Optional[np.ndarray] = None\n   109→\n   110→        # Compile all kernel modules and upload constant memory\n   111→        self._upload_constants()\n   112→\n   113→    def _compute_c_sound(self) -> float:\n   114→        \"\"\"Compute acoustic speed: max over active materials of sqrt(k * gamma / rho0).\"\"\"\n   115→        c_sound = 0.0\n   116→        for mat in MATERIALS.values():\n   117→            if mat.behavior_class == STATIC or mat.rest_density <= 0.0:\n   118→                continue\n   119→            k = mat.eos_stiffness\n   120→            gamma = mat.eos_gamma\n   121→            rho0 = mat.rest_density\n   122→            if k > 0.0 and gamma > 0.0 and rho0 > 0.0:\n   123→                c = math.sqrt(k * gamma / rho0)\n   124→                c_sound = max(c_sound, c)\n   125→        return max(c_sound, 0.01)  # floor to avoid zero\n   126→\n   127→    def _compute_viscosity_bounds(self) -> tuple:\n   128→        \"\"\"Compute max viscosity and min density across active materials.\n   129→\n   130→        For GRANULAR materials, uses mu_max (10000) as worst-case eta.\n   131→        For FLUID/GAS, uses base_viscosity from the material table.\n   132→        \"\"\"\n   133→        max_eta = 0.0\n   134→        rho_min = 1e30\n   135→        has_granular = False\n   136→        for mat in MATERIALS.values():\n   137→            if mat.behavior_class == STATIC or mat.rest_density <= 0.0:\n   138→                continue\n   139→            if mat.rest_density < rho_min:\n   140→                rho_min = mat.rest_density\n   141→            if mat.behavior_class == GRANULAR:\n   142→                has_granular = True\n   143→            if mat.base_viscosity > max_eta:\n   144→                max_eta = mat.base_viscosity\n   145→        if has_granular:\n   146→            max_eta = max(max_eta, float(step2.DEFAULT_MU_MAX))\n   147→        rho_min = max(rho_min, 0.1)  # floor\n   148→        return max_eta, rho_min\n   149→\n   150→    def _compute_adaptive_dt(self, n: int) -> float:\n   151→        \"\"\"Compute adaptive dt from CFL constraints.\n   152→\n   153→        Three constraints:\n   154→          dt_advection = accuracy * h / max(max_v, 1e-6)\n   155→          dt_acoustic  = 0.25 * h / c_sound\n   156→          dt_viscous   = accuracy * rho_min * h^2 / max(max_eta, 1e-6)\n   157→          dt = min(dt_adv, dt_acou, dt_visc) clamped to [DT_MIN, DT_MAX]\n   158→        \"\"\"\n   159→        h = self._h\n   160→\n   161→        # Max velocity magnitude via CuPy reduction\n   162→        vel = self.world.velocity[:n]  # (n, 4) float32\n   163→        vel_sq = vel[:, 0]**2 + vel[:, 1]**2 + vel[:, 2]**2\n   164→        max_v = float(cp.sqrt(cp.max(vel_sq)))\n   165→\n   166→        # Advection CFL\n   167→        dt_advection = self.accuracy * h / max(max_v, 1e-6)\n   168→\n   169→        # Acoustic CFL (fixed 0.25 coefficient, not scaled by accuracy)\n   170→        dt_acoustic = 0.25 * h / self._c_sound\n   171→\n   172→        # Viscous CFL\n   173→        dt_viscous = self.accuracy * self._rho_min * h * h / max(self._max_eta, 1e-6)\n   174→\n   175→        dt = min(dt_advection, dt_acoustic, dt_viscous)\n   176→        return max(DT_MIN, min(DT_MAX, dt))\n   177→\n   178→    def _upload_dt(self, new_dt: float) -> None:\n   179→        \"\"\"Update dt in c_sim constant memory across all modules that read it.\"\"\"\n   180→        if self._sim_params is None:\n   181→            return\n   182→        self._sim_params[0][\"dt\"] = np.float32(new_dt)\n   183→        self.dt = new_dt\n   184→        # Upload to all modules that read c_sim.dt\n   185→        step1.upload_sim_params(self._sim_params)\n   186→        step2.upload_sim_params(self._sim_params)\n   187→        integrate.upload_sim_params(self._sim_params)\n   188→        reactions.upload_sim_params(self._sim_params)\n   189→        spawn.upload_sim_params(self._sim_params)\n   190→\n   191→    def _upload_constants(self) -> None:\n   192→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n   193→        # Build shared param structs\n   194→        grid_params = hash_sort.build_grid_params()\n   195→        sim_params = step1.build_sim_params(\n   196→            smoothing_length=self._h,\n   197→            particle_mass=0.008,\n   198→            particle_spacing=0.02,\n   199→            gravity=(0.0, -9.8, 0.0),\n   200→            dt=self.dt,\n   201→            restitution=0.3,\n   202→            wall_friction=0.5,\n   203→            world_min=(-1.0, -1.0, -1.0),\n   204→            world_max=(1.0, 1.0, 1.0),\n   205→        )\n   206→        self._sim_params = sim_params\n   207→        precalc_params = step1.build_precalc_params(\n   208→            smoothing_length=0.04,\n   209→            viscosity=1.0,\n   210→        )\n   211→        granular_params = step2.build_granular_params()\n   212→        materials_data = build_material_array()\n   213→        interactions_data = build_interaction_matrix()\n   214→\n   215→        # --- hash_sort module: c_grid ---\n   216→        hash_sort.upload_grid_params(grid_params)\n   217→\n   218→        # --- fused_reorder module: no constant memory needed ---\n   219→        fused_reorder.get_module()  # just compile\n   220→\n   221→        # --- build_grid module: c_grid ---\n   222→        build_grid.upload_grid_params(grid_params)\n   223→\n   224→        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n   225→        step1.upload_grid_params(grid_params)\n   226→        step1.upload_sim_params(sim_params)\n   227→        step1.upload_precalc_params(precalc_params)\n   228→        step1.upload_materials(materials_data)\n   229→        step1.upload_interactions(interactions_data)\n   230→\n   231→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   232→        step2.upload_grid_params(grid_params)\n   233→        step2.upload_sim_params(sim_params)\n   234→        step2.upload_precalc_params(precalc_params)\n   235→        step2.upload_materials(materials_data)\n   236→        step2.upload_granular_params(granular_params)\n   237→\n   238→        # --- integrate module: c_sim, c_materials ---\n   239→        integrate.upload_sim_params(sim_params)\n   240→        integrate.upload_materials(materials_data)\n   241→\n   242→        # --- reactions module: c_sim, c_materials ---\n   243→        reactions.upload_sim_params(sim_params)\n   244→        reactions.upload_materials(materials_data)\n   245→\n   246→        # --- spawn module: c_sim, c_materials ---\n   247→        spawn.upload_sim_params(sim_params)\n   248→        spawn.upload_materials(materials_data)\n   249→\n   250→        # --- wake module: c_grid ---\n   251→        wake.upload_grid_params(grid_params)\n   252→\n   253→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   254→        upload_to_gpu()\n   255→\n   256→    def _sim_step(self, n: int) -> None:\n   257→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   258→        w = self.world\n   259→\n   260→        # 1. Hash particle positions\n   261→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   262→\n   263→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   264→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   265→            hashes, indices,\n   266→            sorted_hashes_out=w.sorted_hashes,\n   267→            sorted_indices_out=w.sorted_indices,\n   268→        )\n   269→\n   270→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   271→        fused_reorder.fused_reorder(\n   272→            n, sorted_indices,\n   273→            w.position, w.velocity, w.veleval,\n   274→            w.mass, w.packed_info, w.temperature,\n   275→            w.health, w.lifetime, w.color,\n   276→            w.sleep_counter, w.shear_rate,\n   277→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   278→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   279→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   280→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   281→        )\n   282→\n   283→        # 4. Build grid data structure (cell_start / cell_end tables)\n   284→        build_grid.build_data_struct(\n   285→            sorted_hashes[:n], self._cell_start, self._cell_end\n   286→        )\n   287→\n   288→        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n   289→        step1.compute_step1(\n   290→            w.sorted_position[:n],\n   291→            w.sorted_velocity[:n],\n   292→            w.sorted_mass[:n],\n   293→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   294→            w.sorted_packed_info[:n],\n   295→            w.sorted_temperature[:n],\n   296→            self._cell_start,\n   297→            self._cell_end,\n   298→            density_out=w.sorted_density,\n   299→            shear_rate_out=w.sorted_shear_rate,\n   300→            dTdt_out=w.sorted_dTdt,\n   301→            exposure_heat_out=w.sorted_exposure_heat,\n   302→            exposure_corrode_out=w.sorted_exposure_corrode,\n   303→        )\n   304→        w._density_initialized = True\n   305→\n   306→        # 5b. Reset freelist counter for this step\n   307→        spawn.reset_freelist(self._dead_count)\n   308→\n   309→        # 5c. Reactions: phase transitions, combustion, corrosion, gas lifetime\n   310→        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n   311→        #     lifetime/velocity in-place before Step2 sees them.\n   312→        #     Also populates the freelist when particles die.\n   313→        reactions.compute_reactions(\n   314→            w.sorted_packed_info[:n],\n   315→            w.sorted_temperature[:n],\n   316→            w.sorted_health[:n],\n   317→            w.sorted_lifetime[:n],\n   318→            w.sorted_velocity[:n],\n   319→            w.sorted_exposure_heat[:n],\n   320→            w.sorted_exposure_corrode[:n],\n   321→            frame=self._frame_counter,\n   322→            dead_indices=self._dead_indices,\n   323→            dead_count=self._dead_count,\n   324→        )\n   325→\n   326→        # 5d. Spawn: consume from freelist to spawn steam from boiling water\n   327→        spawn.compute_spawn(\n   328→            w.sorted_packed_info[:n],\n   329→            w.sorted_position[:n],\n   330→            w.sorted_velocity[:n],\n   331→            w.sorted_veleval[:n],\n   332→            w.sorted_mass[:n],\n   333→            w.sorted_temperature[:n],\n   334→            w.sorted_health[:n],\n   335→            w.sorted_lifetime[:n],\n   336→            w.sorted_color[:n],\n   337→            w.sorted_sleep_counter[:n],\n   338→            w.sorted_density[:n],\n   339→            w.sorted_shear_rate[:n],\n   340→            self._dead_indices,\n   341→            self._dead_count,\n   342→        )\n   343→\n   344→        # 6. Step2: pressure + viscosity + XSPH forces\n   345→        step2.compute_step2(\n   346→            w.sorted_position[:n],\n   347→            w.sorted_velocity[:n],\n   348→            w.sorted_density[:n],\n   349→            w.sorted_mass[:n],\n   350→            w.sorted_packed_info[:n],\n   351→            self._cell_start,\n   352→            self._cell_end,\n   353→            sph_force_out=w.sorted_sph_force,\n   354→            veleval_out=w.sorted_veleval,\n   355→        )\n   356→\n   357→        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n   358→        #    Writes back to UNSORTED arrays via sort_indexes\n   359→        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n   360→        integrate.integrate(\n   361→            w.sorted_position[:n],\n   362→            w.sorted_velocity[:n],\n   363→            w.sorted_veleval[:n],\n   364→            w.sorted_sph_force[:n],\n   365→            w.sorted_mass[:n],\n   366→            w.sorted_packed_info[:n],\n   367→            w.sorted_temperature[:n],\n   368→            w.sorted_health[:n],\n   369→            sorted_density=w.sorted_density[:n],\n   370→            sorted_shear_rate=w.sorted_shear_rate[:n],\n   371→            sorted_dTdt=w.sorted_dTdt[:n],\n   372→            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n   373→            sort_indexes=sorted_indices[:n],\n   374→            position_out=w.position,\n   375→            velocity_out=w.velocity,\n   376→            color_out=w.color,\n   377→            packed_info_out=w.packed_info,\n   378→            sleep_counter_out=w.sleep_counter,\n   379→            temperature_out=w.temperature,\n   380→        )\n   381→\n   382→        # 8. Wake propagation: mark cells near just-woke particles,\n   383→        #    wake sleeping neighbors, clear JUST_WOKE flags\n   384→        wake.run_wake_propagation(\n   385→            w.position[:n],\n   386→            w.packed_info[:n],\n   387→            w.sleep_counter[:n],\n   388→            self._cell_wake_flags,\n   389→            num_particles=n,\n   390→        )\n   391→\n   392→        self.sim_time += self.dt\n   393→        self._frame_counter += 1\n   394→\n   395→    def step_frame(self) -> int:\n   396→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   397→        now = time.perf_counter()\n   398→        if self._last_frame_time is None:\n   399→            self._last_frame_time = now\n   400→            return 0\n   401→\n   402→        wall_dt = now - self._last_frame_time\n   403→        self._last_frame_time = now\n   404→\n   405→        if self._paused or self.speed <= 0.0:\n   406→            self._last_substeps = 0\n   407→            return 0\n   408→\n   409→        n = self.world._high_water\n   410→        if n == 0:\n   411→            self._last_substeps = 0\n   412→            return 0\n   413→\n   414→        # Compute adaptive dt if not using fixed timestep\n   415→        if not self.fixed_dt:\n   416→            new_dt = self._compute_adaptive_dt(n)\n   417→            if abs(new_dt - self.dt) > 1e-8:\n   418→                self._upload_dt(new_dt)\n   419→\n   420→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   421→        sim_steps = max(0, min(\n   422→            self.max_substeps,\n   423→            round(self.speed * wall_dt / self.dt),\n   424→        ))\n   425→\n   426→        for _ in range(sim_steps):\n   427→            self._sim_step(n)\n   428→\n   429→        self._last_substeps = sim_steps\n   430→        return sim_steps\n   431→\n   432→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   433→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   434→\n   435→        Parameters\n   436→        ----------\n   437→        cuda_pos : CudaGLBuffer\n   438→            Position VBO wrapper (must be context-managed externally).\n   439→        cuda_col : CudaGLBuffer\n   440→            Color VBO wrapper (must be context-managed externally).\n   441→        \"\"\"\n   442→        n = self.world._high_water\n   443→        if n == 0:\n   444→            return\n   445→\n   446→        # Position: world pos (float4) -> VBO pos (float4)\n   447→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   448→            (cuda_pos.nbytes // 16, 4), np.float32,\n   449→        )\n   450→        pos_arr[:n] = self.world.position[:n]\n   451→\n   452→        # Color: world
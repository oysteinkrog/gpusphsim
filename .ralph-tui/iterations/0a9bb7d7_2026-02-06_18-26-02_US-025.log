{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KA1FhVA5vvkPRUfMXBBtzj","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter\n     5→and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n     9→  2. Run sim_steps simulation substeps\n    10→  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import time\n    16→from typing import Optional\n    17→\n    18→import cupy as cp\n    19→import numpy as np\n    20→\n    21→from world import World\n    22→from materials import (\n    23→    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n    24→)\n    25→\n    26→import hash_sort\n    27→import fused_reorder\n    28→import build_grid\n    29→import step1\n    30→import step2\n    31→import integrate\n    32→import reactions\n    33→import spawn\n    34→import wake\n    35→\n    36→\n    37→class Simulation:\n    38→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    39→\n    40→    Parameters\n    41→    ----------\n    42→    world : World\n    43→        Particle state manager.\n    44→    dt : float\n    45→        Fixed simulation timestep (seconds).\n    46→    speed : float\n    47→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    48→    max_substeps : int\n    49→        Maximum substeps per render frame to prevent spiral-of-death.\n    50→    \"\"\"\n    51→\n    52→    def __init__(\n    53→        self,\n    54→        world: World,\n    55→        dt: float = 0.001,\n    56→        speed: float = 1.0,\n    57→        max_substeps: int = 20,\n    58→    ) -> None:\n    59→        self.world = world\n    60→        self.dt = dt\n    61→        self.speed = speed\n    62→        self.max_substeps = max_substeps\n    63→        self._paused = False\n    64→        self._prev_speed = speed\n    65→        self._last_frame_time: Optional[float] = None\n    66→        self._last_substeps = 0\n    67→        self.sim_time = 0.0\n    68→        self._frame_counter = 0\n    69→\n    70→        # Grid cell tables (pre-allocated, reused every frame)\n    71→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    72→\n    73→        # Cell wake flags for wake propagation (pre-allocated, cleared each step)\n    74→        self._cell_wake_flags = wake.allocate_cell_wake_flags()\n    75→\n    76→        # Freelist for spawn/kill system (pre-allocated, reset each step)\n    77→        self._dead_indices, self._dead_count = spawn.allocate_freelist(\n    78→            world.max_particles\n    79→        )\n    80→\n    81→        # Compile all kernel modules and upload constant memory\n    82→        self._upload_constants()\n    83→\n    84→    def _upload_constants(self) -> None:\n    85→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n    86→        # Build shared param structs\n    87→        grid_params = hash_sort.build_grid_params()\n    88→        sim_params = step1.build_sim_params(\n    89→            smoothing_length=0.04,\n    90→            particle_mass=0.008,\n    91→            particle_spacing=0.02,\n    92→            gravity=(0.0, -9.8, 0.0),\n    93→            dt=self.dt,\n    94→            restitution=0.3,\n    95→            wall_friction=0.5,\n    96→            world_min=(-1.0, -1.0, -1.0),\n    97→            world_max=(1.0, 1.0, 1.0),\n    98→        )\n    99→        precalc_params = step1.build_precalc_params(\n   100→            smoothing_length=0.04,\n   101→            viscosity=1.0,\n   102→        )\n   103→        granular_params = step2.build_granular_params()\n   104→        materials_data = build_material_array()\n   105→        interactions_data = build_interaction_matrix()\n   106→\n   107→        # --- hash_sort module: c_grid ---\n   108→        hash_sort.upload_grid_params(grid_params)\n   109→\n   110→        # --- fused_reorder module: no constant memory needed ---\n   111→        fused_reorder.get_module()  # just compile\n   112→\n   113→        # --- build_grid module: c_grid ---\n   114→        build_grid.upload_grid_params(grid_params)\n   115→\n   116→        # --- step1 module: c_grid, c_sim, c_precalc, c_materials, c_interactions ---\n   117→        step1.upload_grid_params(grid_params)\n   118→        step1.upload_sim_params(sim_params)\n   119→        step1.upload_precalc_params(precalc_params)\n   120→        step1.upload_materials(materials_data)\n   121→        step1.upload_interactions(interactions_data)\n   122→\n   123→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   124→        step2.upload_grid_params(grid_params)\n   125→        step2.upload_sim_params(sim_params)\n   126→        step2.upload_precalc_params(precalc_params)\n   127→        step2.upload_materials(materials_data)\n   128→        step2.upload_granular_params(granular_params)\n   129→\n   130→        # --- integrate module: c_sim, c_materials ---\n   131→        integrate.upload_sim_params(sim_params)\n   132→        integrate.upload_materials(materials_data)\n   133→\n   134→        # --- reactions module: c_sim, c_materials ---\n   135→        reactions.upload_sim_params(sim_params)\n   136→        reactions.upload_materials(materials_data)\n   137→\n   138→        # --- spawn module: c_sim, c_materials ---\n   139→        spawn.upload_sim_params(sim_params)\n   140→        spawn.upload_materials(materials_data)\n   141→\n   142→        # --- wake module: c_grid ---\n   143→        wake.upload_grid_params(grid_params)\n   144→\n   145→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   146→        upload_to_gpu()\n   147→\n   148→    def _sim_step(self, n: int) -> None:\n   149→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   150→        w = self.world\n   151→\n   152→        # 1. Hash particle positions\n   153→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   154→\n   155→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   156→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   157→            hashes, indices,\n   158→            sorted_hashes_out=w.sorted_hashes,\n   159→            sorted_indices_out=w.sorted_indices,\n   160→        )\n   161→\n   162→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   163→        fused_reorder.fused_reorder(\n   164→            n, sorted_indices,\n   165→            w.position, w.velocity, w.veleval,\n   166→            w.mass, w.packed_info, w.temperature,\n   167→            w.health, w.lifetime, w.color,\n   168→            w.sleep_counter, w.shear_rate,\n   169→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   170→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   171→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   172→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   173→        )\n   174→\n   175→        # 4. Build grid data structure (cell_start / cell_end tables)\n   176→        build_grid.build_data_struct(\n   177→            sorted_hashes[:n], self._cell_start, self._cell_end\n   178→        )\n   179→\n   180→        # 5. Step1: density summation + strain-rate tensor + heat diffusion + exposure\n   181→        step1.compute_step1(\n   182→            w.sorted_position[:n],\n   183→            w.sorted_velocity[:n],\n   184→            w.sorted_mass[:n],\n   185→            w.sorted_density if hasattr(w, '_density_initialized') else None,\n   186→            w.sorted_packed_info[:n],\n   187→            w.sorted_temperature[:n],\n   188→            self._cell_start,\n   189→            self._cell_end,\n   190→            density_out=w.sorted_density,\n   191→            shear_rate_out=w.sorted_shear_rate,\n   192→            dTdt_out=w.sorted_dTdt,\n   193→            exposure_heat_out=w.sorted_exposure_heat,\n   194→            exposure_corrode_out=w.sorted_exposure_corrode,\n   195→        )\n   196→        w._density_initialized = True\n   197→\n   198→        # 5b. Reset freelist counter for this step\n   199→        spawn.reset_freelist(self._dead_count)\n   200→\n   201→        # 5c. Reactions: phase transitions, combustion, corrosion, gas lifetime\n   202→        #     Runs on sorted arrays, modifies packed_info/temperature/health/\n   203→        #     lifetime/velocity in-place before Step2 sees them.\n   204→        #     Also populates the freelist when particles die.\n   205→        reactions.compute_reactions(\n   206→            w.sorted_packed_info[:n],\n   207→            w.sorted_temperature[:n],\n   208→            w.sorted_health[:n],\n   209→            w.sorted_lifetime[:n],\n   210→            w.sorted_velocity[:n],\n   211→            w.sorted_exposure_heat[:n],\n   212→            w.sorted_exposure_corrode[:n],\n   213→            frame=self._frame_counter,\n   214→            dead_indices=self._dead_indices,\n   215→            dead_count=self._dead_count,\n   216→        )\n   217→\n   218→        # 5d. Spawn: consume from freelist to spawn steam from boiling water\n   219→        spawn.compute_spawn(\n   220→            w.sorted_packed_info[:n],\n   221→            w.sorted_position[:n],\n   222→            w.sorted_velocity[:n],\n   223→            w.sorted_veleval[:n],\n   224→            w.sorted_mass[:n],\n   225→            w.sorted_temperature[:n],\n   226→            w.sorted_health[:n],\n   227→            w.sorted_lifetime[:n],\n   228→            w.sorted_color[:n],\n   229→            w.sorted_sleep_counter[:n],\n   230→            w.sorted_density[:n],\n   231→            w.sorted_shear_rate[:n],\n   232→            self._dead_indices,\n   233→            self._dead_count,\n   234→        )\n   235→\n   236→        # 6. Step2: pressure + viscosity + XSPH forces\n   237→        step2.compute_step2(\n   238→            w.sorted_position[:n],\n   239→            w.sorted_velocity[:n],\n   240→            w.sorted_density[:n],\n   241→            w.sorted_mass[:n],\n   242→            w.sorted_packed_info[:n],\n   243→            self._cell_start,\n   244→            self._cell_end,\n   245→            sph_force_out=w.sorted_sph_force,\n   246→            veleval_out=w.sorted_veleval,\n   247→        )\n   248→\n   249→        # 7. Integrate: symplectic Euler + SDF boundaries + color + temperature update\n   250→        #    Writes back to UNSORTED arrays via sort_indexes\n   251→        #    Also updates packed_info (sleep flag), sleep_counter, and temperature\n   252→        integrate.integrate(\n   253→            w.sorted_position[:n],\n   254→            w.sorted_velocity[:n],\n   255→            w.sorted_veleval[:n],\n   256→            w.sorted_sph_force[:n],\n   257→            w.sorted_mass[:n],\n   258→            w.sorted_packed_info[:n],\n   259→            w.sorted_temperature[:n],\n   260→            w.sorted_health[:n],\n   261→            sorted_density=w.sorted_density[:n],\n   262→            sorted_shear_rate=w.sorted_shear_rate[:n],\n   263→            sorted_dTdt=w.sorted_dTdt[:n],\n   264→            sorted_sleep_counter=w.sorted_sleep_counter[:n],\n   265→            sort_indexes=sorted_indices[:n],\n   266→            position_out=w.position,\n   267→            velocity_out=w.velocity,\n   268→            color_out=w.color,\n   269→            packed_info_out=w.packed_info,\n   270→            sleep_counter_out=w.sleep_counter,\n   271→            temperature_out=w.temperature,\n   272→        )\n   273→\n   274→        # 8. Wake propagation: mark cells near just-woke particles,\n   275→        #    wake sleeping neighbors, clear JUST_WOKE flags\n   276→        wake.run_wake_propagation(\n   277→            w.position[:n],\n   278→            w.packed_info[:n],\n   279→            w.sleep_counter[:n],\n   280→            self._cell_wake_flags,\n   281→            num_particles=n,\n   282→        )\n   283→\n   284→        self.sim_time += self.dt\n   285→        self._frame_counter += 1\n   286→\n   287→    def step_frame(self) -> int:\n   288→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   289→        now = time.perf_counter()\n   290→        if self._last_frame_time is None:\n   291→            self._last_frame_time = now\n   292→            return 0\n   293→\n   294→        wall_dt = now - self._last_frame_time\n   295→        self._last_frame_time = now\n   296→\n   297→        if self._paused or self.speed <= 0.0:\n   298→            self._last_substeps = 0\n   299→            return 0\n   300→\n   301→        n = self.world._high_water\n   302→        if n == 0:\n   303→            self._last_substeps = 0\n   304→            return 0\n   305→\n   306→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   307→        sim_steps = max(0, min(\n   308→            self.max_substeps,\n   309→            round(self.speed * wall_dt / self.dt),\n   310→        ))\n   311→\n   312→        for _ in range(sim_steps):\n   313→            self._sim_step(n)\n   314→\n   315→        self._last_substeps = sim_steps\n   316→        return sim_steps\n   317→\n   318→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   319→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   320→\n   321→        Parameters\n   322→        ----------\n   323→        cuda_pos : CudaGLBuffer\n   324→            Position VBO wrapper (must be context-managed externally).\n   325→        cuda_col : CudaGLBuffer\n   326→            Color VBO wrapper (must be context-managed externally).\n   327→        \"\"\"\n   328→        n = self.world._high_water\n   329→        if n == 0:\n   330→            return\n   331→\n   332→        # Position: world pos (float4) -> VBO pos (float4)\n   333→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   334→            (cuda_pos.nbytes // 16, 4), np.float32,\n   335→        )\n   336→        pos_arr[:n] = self.world.position[:n]\n   337→\n   338→        # Color: world color (float4) -> VBO color (float4)\n   339→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   340→            (cuda_col.nbytes // 16, 4), np.float32,\n   341→        )\n   342→        col_arr[:n] = self.world.color[:n]\n   343→\n   344→    @property\n   345→    def paused(self) -> bool:\n   346→        return self._paused\n   347→\n   348→    def toggle_pause(self) -> None:\n   349→        self._paused = not self._paused\n   350→\n   351→    def adjust_speed(self, delta: float) -> None:\n   352→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   353→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   354→\n   355→    @property\n   356→    def last_substeps(self) -> int:\n   357→        return self._last_substeps\n   358→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01BZsEZgYZF83kNNS6cm6S7X","session_id":"374499ef-5ec0-4577-85fa-be8b5d7ef994","uuid":"be77d28c-8fb8-4e62-8899-151ee395365e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018R3JASFKPefivZCJrZfrdC","type":"tool_result","content":"     1→\"\"\"Step1 kernel: SPH density summation + strain-rate tensor + heat diffusion\n     2→+ exposure accumulation.\n     3→\n     4→Compiles physics/kernels/step1.cu via CuPy RawModule and provides\n     5→a function to launch K_Step1 which computes per-particle density\n     6→from the sorted particle positions and masses using neighbor iteration.\n     7→\n     8→Additionally computes heat diffusion dTdt via SPH Laplacian of temperature:\n     9→  dTdt = kappa_i * viscosity_lap_coeff * sum_j (m_j/rho_j) * (T_j - T_i) * (h - |r|)\n    10→\n    11→Exposure accumulation via c_interactions table lookup (no branching):\n    12→  exposure_corrode_i += c_interactions[mat_i][mat_j].reaction_rate * W_poly6(r_sq, h_sq)\n    13→  exposure_heat_i += c_interactions[mat_i][mat_j].heat_exchange * max(T_j - T_i, 0) * W_poly6\n    14→\n    15→For GRANULAR particles, computes the symmetric strain-rate tensor D from\n    16→SPH velocity gradient (spiky kernel) and writes the second invariant\n    17→gamma_dot = sqrt(2 * D:D) to the shear_rate output array.\n    18→Non-GRANULAR particles get shear_rate = 0.\n    19→\n    20→Density formula\n    21→---------------\n    22→density_sum += m_j * (h^2 - |r_ij|^2)^3   for all neighbors j within h\n    23→density_i = max(1.0, poly6_coeff * density_sum)\n    24→\n    25→Self-interaction is included (particle i contributes to its own density).\n    26→Per-particle mass m_j supports multi-material and mass splitting.\n    27→\"\"\"\n    28→\n    29→from __future__ import annotations\n    30→\n    31→import math\n    32→import os\n    33→from typing import Optional\n    34→\n    35→import cupy\n    36→import numpy as np\n    37→\n    38→# ---------------------------------------------------------------------------\n    39→# Numpy dtypes matching constant memory structs in common.cuh\n    40→# ---------------------------------------------------------------------------\n    41→\n    42→# SimParams -- matches struct SimParams in common.cuh\n    43→# struct SimParams {\n    44→#     float  smoothing_length;     //  4 bytes\n    45→#     float  smoothing_length_sq;  //  4 bytes\n    46→#     float  particle_mass;        //  4 bytes\n    47→#     float  particle_spacing;     //  4 bytes\n    48→#     float3 gravity;              // 12 bytes\n    49→#     float  dt;                   //  4 bytes\n    50→#     float  restitution;          //  4 bytes\n    51→#     float  wall_friction;        //  4 bytes\n    52→#     float3 world_min;            // 12 bytes\n    53→#     float3 world_max;            // 12 bytes\n    54→# };                               // Total: 64 bytes\n    55→SIM_PARAMS_DTYPE = np.dtype(\n    56→    [\n    57→        (\"smoothing_length\", np.float32),\n    58→        (\"smoothing_length_sq\", np.float32),\n    59→        (\"particle_mass\", np.float32),\n    60→        (\"particle_spacing\", np.float32),\n    61→        (\"gravity\", np.float32, (3,)),\n    62→        (\"dt\", np.float32),\n    63→        (\"restitution\", np.float32),\n    64→        (\"wall_friction\", np.float32),\n    65→        (\"world_min\", np.float32, (3,)),\n    66→        (\"world_max\", np.float32, (3,)),\n    67→    ],\n    68→    align=False,\n    69→)\n    70→\n    71→# PrecalcParams -- matches struct PrecalcParams in common.cuh\n    72→# struct PrecalcParams {\n    73→#     float poly6_coeff;           //  4 bytes\n    74→#     float spiky_grad_coeff;      //  4 bytes\n    75→#     float viscosity_lap_coeff;   //  4 bytes\n    76→#     float pressure_precalc;      //  4 bytes\n    77→#     float viscosity_precalc;     //  4 bytes\n    78→# };                               // Total: 20 bytes\n    79→PRECALC_PARAMS_DTYPE = np.dtype(\n    80→    [\n    81→        (\"poly6_coeff\", np.float32),\n    82→        (\"spiky_grad_coeff\", np.float32),\n    83→        (\"viscosity_lap_coeff\", np.float32),\n    84→        (\"pressure_precalc\", np.float32),\n    85→        (\"viscosity_precalc\", np.float32),\n    86→    ],\n    87→    align=False,\n    88→)\n    89→\n    90→\n    91→def build_sim_params(\n    92→    smoothing_length: float = 0.04,\n    93→    particle_mass: float = 0.008,\n    94→    particle_spacing: float = 0.02,\n    95→    gravity: tuple = (0.0, -9.8, 0.0),\n    96→    dt: float = 0.001,\n    97→    restitution: float = 0.3,\n    98→    wall_friction: float = 0.5,\n    99→    world_min: tuple = (-1.0, -1.0, -1.0),\n   100→    world_max: tuple = (1.0, 1.0, 1.0),\n   101→) -> np.ndarray:\n   102→    \"\"\"Build a single SimParams struct as a numpy structured array.\"\"\"\n   103→    params = np.zeros(1, dtype=SIM_PARAMS_DTYPE)\n   104→    params[0][\"smoothing_length\"] = smoothing_length\n   105→    params[0][\"smoothing_length_sq\"] = smoothing_length * smoothing_length\n   106→    params[0][\"particle_mass\"] = particle_mass\n   107→    params[0][\"particle_spacing\"] = particle_spacing\n   108→    params[0][\"gravity\"] = gravity\n   109→    params[0][\"dt\"] = dt\n   110→    params[0][\"restitution\"] = restitution\n   111→    params[0][\"wall_friction\"] = wall_friction\n   112→    params[0][\"world_min\"] = world_min\n   113→    params[0][\"world_max\"] = world_max\n   114→    return params\n   115→\n   116→\n   117→def build_precalc_params(\n   118→    smoothing_length: float = 0.04,\n   119→    viscosity: float = 0.001,\n   120→) -> np.ndarray:\n   121→    \"\"\"Build PrecalcParams from smoothing length.\n   122→\n   123→    Parameters\n   124→    ----------\n   125→    smoothing_length : float\n   126→        SPH smoothing length h.\n   127→    viscosity : float\n   128→        Base viscosity mu (Pa*s).\n   129→    \"\"\"\n   130→    h = smoothing_length\n   131→    params = np.zeros(1, dtype=PRECALC_PARAMS_DTYPE)\n   132→    params[0][\"poly6_coeff\"] = np.float32(315.0 / (64.0 * math.pi * h**9))\n   133→    params[0][\"spiky_grad_coeff\"] = np.float32(-45.0 / (math.pi * h**6))\n   134→    params[0][\"viscosity_lap_coeff\"] = np.float32(45.0 / (math.pi * h**6))\n   135→    params[0][\"pressure_precalc\"] = np.float32(45.0 / (math.pi * h**6))\n   136→    params[0][\"viscosity_precalc\"] = np.float32(viscosity * 45.0 / (math.pi * h**6))\n   137→    return params\n   138→\n   139→\n   140→# ---------------------------------------------------------------------------\n   141→# CuPy RawModule compilation\n   142→# ---------------------------------------------------------------------------\n   143→\n   144→_module: Optional[object] = None\n   145→\n   146→\n   147→def _ensure_ptx_if_needed() -> None:\n   148→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n   149→    from cupy.cuda import compiler as _compiler\n   150→    from cupy.cuda import device as _device\n   151→\n   152→    gpu_cc = _device.Device().compute_capability\n   153→    nvrtc_max = _compiler._get_max_compute_capability()\n   154→    if int(gpu_cc) > int(nvrtc_max):\n   155→        _compiler._use_ptx = True\n   156→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n   157→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n   158→        if hasattr(_compiler._get_arch, \"_cache\"):\n   159→            _compiler._get_arch._cache = {}\n   160→\n   161→\n   162→def _get_module() -> \"object\":\n   163→    \"\"\"Compile (or return cached) CuPy RawModule from step1.cu.\"\"\"\n   164→    global _module\n   165→    if _module is not None:\n   166→        return _module\n   167→\n   168→    _ensure_ptx_if_needed()\n   169→\n   170→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   171→    cu_path = os.path.join(kernel_dir, \"step1.cu\")\n   172→    with open(cu_path) as f:\n   173→        source = f.read()\n   174→\n   175→    _module = cupy.RawModule(\n   176→        code=source,\n   177→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n   178→    )\n   179→    return _module\n   180→\n   181→\n   182→def get_module() -> \"object\":\n   183→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n   184→    return _get_module()\n   185→\n   186→\n   187→# ---------------------------------------------------------------------------\n   188→# Constant memory upload\n   189→# ---------------------------------------------------------------------------\n   190→\n   191→\n   192→def upload_grid_params(params: np.ndarray) -> None:\n   193→    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\"\"\"\n   194→    module = _get_module()\n   195→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n   196→    cupy.cuda.runtime.memcpy(\n   197→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   198→    )\n   199→\n   200→\n   201→def upload_sim_params(params: Optional[np.ndarray] = None) -> None:\n   202→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n   203→    if params is None:\n   204→        params = build_sim_params()\n   205→    module = _get_module()\n   206→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n   207→    cupy.cuda.runtime.memcpy(\n   208→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   209→    )\n   210→\n   211→\n   212→def upload_precalc_params(params: Optional[np.ndarray] = None) -> None:\n   213→    \"\"\"Upload PrecalcParams to ``__constant__ PrecalcParams c_precalc``.\"\"\"\n   214→    if params is None:\n   215→        params = build_precalc_params()\n   216→    module = _get_module()\n   217→    d_ptr = module.get_global(\"c_precalc\")  # type: ignore[union-attr]\n   218→    cupy.cuda.runtime.memcpy(\n   219→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   220→    )\n   221→\n   222→\n   223→def upload_materials(materials_data: np.ndarray) -> None:\n   224→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n   225→    module = _get_module()\n   226→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n   227→    cupy.cuda.runtime.memcpy(\n   228→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n   229→    )\n   230→\n   231→\n   232→def upload_interactions(interactions_data: np.ndarray) -> None:\n   233→    \"\"\"Upload Interaction[32][32] to ``__constant__ Interaction c_interactions[32][32]``.\"\"\"\n   234→    module = _get_module()\n   235→    d_ptr = module.get_global(\"c_interactions\")  # type: ignore[union-attr]\n   236→    cupy.cuda.runtime.memcpy(\n   237→        int(d_ptr), interactions_data.ctypes.data, interactions_data.nbytes, 1\n   238→    )\n   239→\n   240→\n   241→# ---------------------------------------------------------------------------\n   242→# Kernel launch\n   243→# ---------------------------------------------------------------------------\n   244→\n   245→BLOCK_SIZE = 128\n   246→\n   247→\n   248→def compute_step1(\n   249→    position: cupy.ndarray,\n   250→    velocity: cupy.ndarray,\n   251→    mass: cupy.ndarray,\n   252→    density_in: Optional[cupy.ndarray],\n   253→    packed_info: cupy.ndarray,\n   254→    temperature_in: cupy.ndarray,\n   255→    cell_start: cupy.ndarray,\n   256→    cell_end: cupy.ndarray,\n   257→    density_out: Optional[cupy.ndarray] = None,\n   258→    shear_rate_out: Optional[cupy.ndarray] = None,\n   259→    dTdt_out: Optional[cupy.ndarray] = None,\n   260→    exposure_heat_out: Optional[cupy.ndarray] = None,\n   261→    exposure_corrode_out: Optional[cupy.ndarray] = None,\n   262→) -> tuple:\n   263→    \"\"\"Launch K_Step1 and return (density, shear_rate, dTdt, exposure_heat, exposure_corrode).\n   264→\n   265→    Parameters\n   266→    ----------\n   267→    position : cupy.ndarray, (N, 4) float32\n   268→        Sorted particle positions.\n   269→    velocity : cupy.ndarray, (N, 4) float32\n   270→        Sorted particle velocities (used for strain-rate computation).\n   271→    mass : cupy.ndarray, (N,) float32\n   272→        Sorted per-particle masses.\n   273→    density_in : cupy.ndarray or None, (N,) float32\n   274→        Density from previous step for m_j/rho_j weighting in strain-rate\n   275→        and heat diffusion. Pass None on first frame (kernel uses rho0=1000 fallback).\n   276→    packed_info : cupy.ndarray, (N,) uint32\n   277→        Sorted packed_info for behavior class and material ID.\n   278→    temperature_in : cupy.ndarray, (N,) float32\n   279→        Sorted temperature per particle (for heat diffusion).\n   280→    cell_start : cupy.ndarray, (num_cells,) uint32\n   281→        Grid cell start indices (0xFFFFFFFF for empty).\n   282→    cell_end : cupy.ndarray, (num_cells,) uint32\n   283→        Grid cell end indices.\n   284→    density_out : cupy.ndarray, optional\n   285→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   286→    shear_rate_out : cupy.ndarray, optional\n   287→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   288→    dTdt_out : cupy.ndarray, optional\n   289→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   290→    exposure_heat_out : cupy.ndarray, optional\n   291→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   292→    exposure_corrode_out : cupy.ndarray, optional\n   293→        Pre-allocated (N,) float32 output buffer. If None, allocates new.\n   294→\n   295→    Returns\n   296→    -------\n   297→    (density, shear_rate, dTdt, exposure_heat, exposure_corrode) : tuple of cupy.ndarray\n   298→        density: Per-particle density (clamped >= 1.0).\n   299→        shear_rate: Per-particle gamma_dot (0 for non-GRANULAR).\n   300→        dTdt: Per-particle temperature rate of change from heat diffusion.\n   301→        exposure_heat: Per-particle heat exposure from interaction table.\n   302→        exposure_corrode: Per-particle corrosion exposure from interaction table.\n   303→    \"\"\"\n   304→    n = position.shape[0]\n   305→    if density_out is None:\n   306→        density_out = cupy.empty(n, dtype=cupy.float32)\n   307→    if shear_rate_out is None:\n   308→        shear_rate_out = cupy.empty(n, dtype=cupy.float32)\n   309→    if dTdt_out is None:\n   310→        dTdt_out = cupy.empty(n, dtype=cupy.float32)\n   311→    if exposure_heat_out is None:\n   312→        exposure_heat_out = cupy.empty(n, dtype=cupy.float32)\n   313→    if exposure_corrode_out is None:\n   314→        exposure_corrode_out = cupy.empty(n, dtype=cupy.float32)\n   315→\n   316→    # density_in can be None (first frame) -- pass null pointer\n   317→    density_in_ptr = density_in if density_in is not None else cupy.ndarray(0, dtype=cupy.float32)\n   318→\n   319→    module = _get_module()\n   320→    kernel = module.get_function(\"K_Step1\")  # type: ignore[union-attr]\n   321→\n   322→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   323→    block = (BLOCK_SIZE,)\n   324→\n   325→    kernel(\n   326→        grid,\n   327→        block,\n   328→        (\n   329→            np.uint32(n),\n   330→            position,\n   331→            velocity,\n   332→            mass,\n   333→            density_in_ptr,\n   334→            packed_info,\n   335→            temperature_in,\n   336→            cell_start,\n   337→            cell_end,\n   338→            density_out,\n   339→            shear_rate_out,\n   340→            dTdt_out,\n   341→            exposure_heat_out,\n   342→            exposure_corrode_out,\n   343→        ),\n   344→    )\n   345→\n   346→    return density_out, shear_rate_out, dTdt_out, exposure_heat_out, exposure_corrode_out\n   347→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01BZsEZgYZF83kNNS6cm6S7X","session_id":"374499ef-5ec0-4577-85fa-be8b5d7ef994","uuid":"10e9995e-256b-4327-ab19-e8fd46a90f00"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019DCe4xSwfqtii25XT4CjTX","type":"tool_result","content":"     1→\"\"\"Step2 kernel: pressure, viscosity, and XSPH force computation.\n     2→\n     3→Compiles physics/kernels/step2.cu via CuPy RawModule and provides\n     4→functions to upload GranularParams to constant memory and launch\n     5→the K_Step2 kernel.\n     6→\n     7→Uses shared constant memory from common.cuh:\n     8→  c_grid     -- GridParams (uploaded by hash_sort.py)\n     9→  c_sim      -- SimParams (uploaded by step1.py)\n    10→  c_precalc  -- PrecalcParams (uploaded by step1.py)\n    11→  c_materials -- MaterialProps[32] (uploaded by materials.py)\n    12→\n    13→Additional constant memory local to this module:\n    14→  c_granular -- GranularParams (mu(I) rheology + xsph_epsilon)\n    15→\n    16→Tait EOS pressure\n    17→-----------------\n    18→- FLUID/GRANULAR: p_raw = k * (pow(rho/rho0, 7) - 1)\n    19→  - FLUID:    p = max(p_raw, -0.5*k)\n    20→  - GRANULAR: p = max(p_raw, 0)\n    21→- GAS: p = k_gas * max(rho - rho0, 0) with gamma=1\n    22→\n    23→Force accumulation\n    24→------------------\n    25→- Pressure force: pressure_precalc * m_j * (p_i/rho_i^2 + p_j/rho_j^2) * grad_spiky_variable\n    26→- Viscosity force: viscosity_precalc * m_j * (v_j - v_i) / rho_j * lap_visc_variable\n    27→- XSPH (FLUID only): epsilon * sum(m_j / rho_avg * (v_j - v_i) * W_poly6)\n    28→\"\"\"\n    29→\n    30→from __future__ import annotations\n    31→\n    32→import os\n    33→from typing import Optional\n    34→\n    35→import cupy\n    36→import numpy as np\n    37→\n    38→# ---------------------------------------------------------------------------\n    39→# Default physical parameters\n    40→# ---------------------------------------------------------------------------\n    41→\n    42→DEFAULT_MU_S = np.float32(0.36)\n    43→DEFAULT_MU_2 = np.float32(0.70)\n    44→DEFAULT_I0 = np.float32(0.3)\n    45→DEFAULT_MU_MAX = np.float32(10000.0)\n    46→DEFAULT_PARTICLE_SPACING = np.float32(0.02)\n    47→DEFAULT_MU0 = np.float32(3.5)\n    48→DEFAULT_XSPH_EPSILON = np.float32(0.5)\n    49→\n    50→# ---------------------------------------------------------------------------\n    51→# Numpy dtype matching GranularParams struct in step2.cu\n    52→#\n    53→# struct GranularParams {\n    54→#     float mu_s;               //  4 bytes\n    55→#     float mu_2;               //  4 bytes\n    56→#     float I0;                 //  4 bytes\n    57→#     float mu_max;             //  4 bytes\n    58→#     float particle_spacing;   //  4 bytes\n    59→#     float mu0;                //  4 bytes\n    60→#     float xsph_epsilon;       //  4 bytes\n    61→#     float _pad0;              //  4 bytes\n    62→# };                            // Total: 32 bytes\n    63→# ---------------------------------------------------------------------------\n    64→\n    65→GRANULAR_PARAMS_DTYPE = np.dtype(\n    66→    [\n    67→        (\"mu_s\", np.float32),\n    68→        (\"mu_2\", np.float32),\n    69→        (\"I0\", np.float32),\n    70→        (\"mu_max\", np.float32),\n    71→        (\"particle_spacing\", np.float32),\n    72→        (\"mu0\", np.float32),\n    73→        (\"xsph_epsilon\", np.float32),\n    74→        (\"_pad0\", np.float32),\n    75→    ],\n    76→    align=False,\n    77→)\n    78→\n    79→assert GRANULAR_PARAMS_DTYPE.itemsize == 32, (\n    80→    f\"GranularParams size mismatch: {GRANULAR_PARAMS_DTYPE.itemsize} != 32\"\n    81→)\n    82→\n    83→\n    84→def build_granular_params(\n    85→    mu_s: float = DEFAULT_MU_S,\n    86→    mu_2: float = DEFAULT_MU_2,\n    87→    I0: float = DEFAULT_I0,\n    88→    mu_max: float = DEFAULT_MU_MAX,\n    89→    particle_spacing: float = DEFAULT_PARTICLE_SPACING,\n    90→    mu0: float = DEFAULT_MU0,\n    91→    xsph_epsilon: float = DEFAULT_XSPH_EPSILON,\n    92→) -> np.ndarray:\n    93→    \"\"\"Build a GranularParams struct as a numpy structured array.\"\"\"\n    94→    params = np.zeros(1, dtype=GRANULAR_PARAMS_DTYPE)\n    95→    params[0][\"mu_s\"] = mu_s\n    96→    params[0][\"mu_2\"] = mu_2\n    97→    params[0][\"I0\"] = I0\n    98→    params[0][\"mu_max\"] = mu_max\n    99→    params[0][\"particle_spacing\"] = particle_spacing\n   100→    params[0][\"mu0\"] = mu0\n   101→    params[0][\"xsph_epsilon\"] = xsph_epsilon\n   102→    return params\n   103→\n   104→\n   105→# ---------------------------------------------------------------------------\n   106→# CuPy RawModule compilation\n   107→# ---------------------------------------------------------------------------\n   108→\n   109→_module: Optional[object] = None\n   110→\n   111→\n   112→def _ensure_ptx_if_needed() -> None:\n   113→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n   114→    from cupy.cuda import compiler as _compiler\n   115→    from cupy.cuda import device as _device\n   116→\n   117→    gpu_cc = _device.Device().compute_capability\n   118→    nvrtc_max = _compiler._get_max_compute_capability()\n   119→    if int(gpu_cc) > int(nvrtc_max):\n   120→        _compiler._use_ptx = True\n   121→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n   122→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n   123→        if hasattr(_compiler._get_arch, \"_cache\"):\n   124→            _compiler._get_arch._cache = {}\n   125→\n   126→\n   127→def _get_module() -> \"object\":\n   128→    \"\"\"Compile (or return cached) CuPy RawModule from step2.cu.\"\"\"\n   129→    global _module\n   130→    if _module is not None:\n   131→        return _module\n   132→\n   133→    _ensure_ptx_if_needed()\n   134→\n   135→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n   136→    cu_path = os.path.join(kernel_dir, \"step2.cu\")\n   137→    with open(cu_path) as f:\n   138→        source = f.read()\n   139→\n   140→    _module = cupy.RawModule(\n   141→        code=source,\n   142→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n   143→    )\n   144→    return _module\n   145→\n   146→\n   147→def get_module() -> \"object\":\n   148→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n   149→    return _get_module()\n   150→\n   151→\n   152→# ---------------------------------------------------------------------------\n   153→# Constant memory upload\n   154→# ---------------------------------------------------------------------------\n   155→\n   156→\n   157→def upload_grid_params(grid_params: np.ndarray) -> None:\n   158→    \"\"\"Upload GridParams to ``__constant__ GridParams c_grid``.\"\"\"\n   159→    module = _get_module()\n   160→    d_ptr = module.get_global(\"c_grid\")  # type: ignore[union-attr]\n   161→    cupy.cuda.runtime.memcpy(\n   162→        int(d_ptr), grid_params.ctypes.data, grid_params.nbytes, 1\n   163→    )\n   164→\n   165→\n   166→def upload_sim_params(params: np.ndarray) -> None:\n   167→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n   168→    module = _get_module()\n   169→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n   170→    cupy.cuda.runtime.memcpy(\n   171→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   172→    )\n   173→\n   174→\n   175→def upload_precalc_params(params: np.ndarray) -> None:\n   176→    \"\"\"Upload PrecalcParams to ``__constant__ PrecalcParams c_precalc``.\"\"\"\n   177→    module = _get_module()\n   178→    d_ptr = module.get_global(\"c_precalc\")  # type: ignore[union-attr]\n   179→    cupy.cuda.runtime.memcpy(\n   180→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n   181→    )\n   182→\n   183→\n   184→def upload_granular_params(params: Optional[np.ndarray] = None) -> None:\n   185→    \"\"\"Upload GranularParams to ``__constant__ GranularParams c_granular``.\"\"\"\n   186→    if params is None:\n   187→        params = build_granular_params()\n   188→    module = _get_module()\n   189→    d_ptr = module.get_global(\"c_granular\")  # type: ignore[union-attr]\n   190→    cupy.cuda.runtime.memcpy(int(d_ptr), params.ctypes.data, params.nbytes, 1)\n   191→\n   192→\n   193→def upload_materials(materials_data: np.ndarray) -> None:\n   194→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n   195→    module = _get_module()\n   196→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n   197→    cupy.cuda.runtime.memcpy(\n   198→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n   199→    )\n   200→\n   201→\n   202→# ---------------------------------------------------------------------------\n   203→# Kernel launch\n   204→# ---------------------------------------------------------------------------\n   205→\n   206→BLOCK_SIZE = 128\n   207→\n   208→\n   209→def compute_step2(\n   210→    position: cupy.ndarray,\n   211→    velocity: cupy.ndarray,\n   212→    density: cupy.ndarray,\n   213→    mass: cupy.ndarray,\n   214→    packed_info: cupy.ndarray,\n   215→    cell_start: cupy.ndarray,\n   216→    cell_end: cupy.ndarray,\n   217→    sph_force_out: \"Optional[cupy.ndarray]\" = None,\n   218→    veleval_out: \"Optional[cupy.ndarray]\" = None,\n   219→) -> tuple:\n   220→    \"\"\"Launch K_Step2 and return (sph_force, veleval_out).\n   221→\n   222→    Parameters\n   223→    ----------\n   224→    position : cupy.ndarray, (N, 4) float32\n   225→        Sorted particle positions.\n   226→    velocity : cupy.ndarray, (N, 4) float32\n   227→        Sorted evaluation velocities.\n   228→    density : cupy.ndarray, (N,) float32\n   229→        Sorted particle densities (from Step1).\n   230→    mass : cupy.ndarray, (N,) float32\n   231→        Sorted per-particle mass.\n   232→    packed_info : cupy.ndarray, (N,) uint32\n   233→        Sorted packed_info (material_id + behavior_class + flags).\n   234→    cell_start : cupy.ndarray, (num_cells,) uint32\n   235→        Grid cell start indices (0xFFFFFFFF for empty).\n   236→    cell_end : cupy.ndarray, (num_cells,) uint32\n   237→        Grid cell end indices.\n   238→    sph_force_out : cupy.ndarray, optional\n   239→        Pre-allocated (N, 4) float32 output. If None, allocates new.\n   240→    veleval_out : cupy.ndarray, optional\n   241→        Pre-allocated (N, 4) float32 output. If None, allocates new.\n   242→\n   243→    Returns\n   244→    -------\n   245→    sph_force : cupy.ndarray, (N, 4) float32\n   246→        Accumulated SPH force per particle.\n   247→    veleval_out : cupy.ndarray, (N, 4) float32\n   248→        XSPH-corrected evaluation velocity (FLUID only; others unchanged).\n   249→    \"\"\"\n   250→    n = position.shape[0]\n   251→    if sph_force_out is None:\n   252→        sph_force_out = cupy.zeros((n, 4), dtype=cupy.float32)\n   253→    if veleval_out is None:\n   254→        veleval_out = cupy.zeros((n, 4), dtype=cupy.float32)\n   255→\n   256→    module = _get_module()\n   257→    kernel = module.get_function(\"K_Step2\")  # type: ignore[union-attr]\n   258→\n   259→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   260→    block = (BLOCK_SIZE,)\n   261→\n   262→    kernel(\n   263→        grid,\n   264→        block,\n   265→        (\n   266→            np.uint32(n),\n   267→            position,\n   268→            velocity,\n   269→            density,\n   270→            mass,\n   271→            packed_info,\n   272→            cell_start,\n   273→            cell_end,\n   274→            sph_force_out,\n   275→            veleval_out,\n   276→        ),\n   277→    )\n   278→\n   279→    return sph_force_out, veleval_out\n   280→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01BZsEZgYZF83kNNS6cm6S7X","session_id":"374499ef-5ec0-4577-85fa-be8b5d7ef994","uuid":"15aaa77c-a9b0-41a1-85ac-2f22c2abe93f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019SyFtxYFJPA3GJb4qKvziG","type":"tool_result","content":"     1→\"\"\"Integrate kernel: symplectic Euler with SDF boundaries and color update.\n     2→\n     3→Compiles physics/kernels/integrate.cu via CuPy RawModule and provides\n     4→a function to launch K_Integrate which performs:\n     5→  - Symplectic Euler velocity/position integration\n     6→  - Impulse-style SDF box boundary collisions (restitution + Coulomb friction)\n     7→  - GAS buoyancy and drag\n     8→  - Velocity magnitude clamping\n     9→  - Particle color computation from material, temperature, and health\n    10→  - Writeback to UNSORTED arrays via sort_indexes permutation\n    11→\n    12→Uses shared constant memory from common.cuh:\n    13→  c_sim       -- SimParams (gravity, dt, restitution, wall_friction, world bounds)\n    14→  c_materials -- MaterialProps[32] (for color lookup)\n    15→\"\"\"\n    16→\n    17→from __future__ import annotations\n    18→\n    19→import os\n    20→from typing import Optional\n    21→\n    22→import cupy\n    23→import numpy as np\n    24→\n    25→# ---------------------------------------------------------------------------\n    26→# CuPy RawModule compilation\n    27→# ---------------------------------------------------------------------------\n    28→\n    29→_module: Optional[object] = None\n    30→\n    31→\n    32→def _ensure_ptx_if_needed() -> None:\n    33→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    34→    from cupy.cuda import compiler as _compiler\n    35→    from cupy.cuda import device as _device\n    36→\n    37→    gpu_cc = _device.Device().compute_capability\n    38→    nvrtc_max = _compiler._get_max_compute_capability()\n    39→    if int(gpu_cc) > int(nvrtc_max):\n    40→        _compiler._use_ptx = True\n    41→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    42→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    43→        if hasattr(_compiler._get_arch, \"_cache\"):\n    44→            _compiler._get_arch._cache = {}\n    45→\n    46→\n    47→def _get_module() -> \"object\":\n    48→    \"\"\"Compile (or return cached) CuPy RawModule from integrate.cu.\"\"\"\n    49→    global _module\n    50→    if _module is not None:\n    51→        return _module\n    52→\n    53→    _ensure_ptx_if_needed()\n    54→\n    55→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    56→    cu_path = os.path.join(kernel_dir, \"integrate.cu\")\n    57→    with open(cu_path) as f:\n    58→        source = f.read()\n    59→\n    60→    _module = cupy.RawModule(\n    61→        code=source,\n    62→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    63→    )\n    64→    return _module\n    65→\n    66→\n    67→def get_module() -> \"object\":\n    68→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    69→    return _get_module()\n    70→\n    71→\n    72→# ---------------------------------------------------------------------------\n    73→# Constant memory upload\n    74→# ---------------------------------------------------------------------------\n    75→\n    76→\n    77→def upload_sim_params(params: np.ndarray) -> None:\n    78→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    79→    module = _get_module()\n    80→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    81→    cupy.cuda.runtime.memcpy(\n    82→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    83→    )\n    84→\n    85→\n    86→def upload_materials(materials_data: np.ndarray) -> None:\n    87→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    88→    module = _get_module()\n    89→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    90→    cupy.cuda.runtime.memcpy(\n    91→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    92→    )\n    93→\n    94→\n    95→# ---------------------------------------------------------------------------\n    96→# Kernel launch\n    97→# ---------------------------------------------------------------------------\n    98→\n    99→BLOCK_SIZE = 256\n   100→\n   101→\n   102→def integrate(\n   103→    sorted_position: cupy.ndarray,\n   104→    sorted_velocity: cupy.ndarray,\n   105→    sorted_veleval: cupy.ndarray,\n   106→    sorted_sph_force: cupy.ndarray,\n   107→    sorted_mass: cupy.ndarray,\n   108→    sorted_packed_info: cupy.ndarray,\n   109→    sorted_temperature: cupy.ndarray,\n   110→    sorted_health: cupy.ndarray,\n   111→    sorted_density: \"Optional[cupy.ndarray]\" = None,\n   112→    sorted_shear_rate: \"Optional[cupy.ndarray]\" = None,\n   113→    sorted_dTdt: \"Optional[cupy.ndarray]\" = None,\n   114→    sorted_sleep_counter: \"Optional[cupy.ndarray]\" = None,\n   115→    sort_indexes: \"Optional[cupy.ndarray]\" = None,\n   116→    position_out: \"Optional[cupy.ndarray]\" = None,\n   117→    velocity_out: \"Optional[cupy.ndarray]\" = None,\n   118→    color_out: \"Optional[cupy.ndarray]\" = None,\n   119→    packed_info_out: \"Optional[cupy.ndarray]\" = None,\n   120→    sleep_counter_out: \"Optional[cupy.ndarray]\" = None,\n   121→    temperature_out: \"Optional[cupy.ndarray]\" = None,\n   122→) -> tuple:\n   123→    \"\"\"Launch K_Integrate and return outputs tuple.\n   124→\n   125→    All sorted_* inputs are in sorted (grid) order.\n   126→    Outputs are written to UNSORTED arrays via sort_indexes[i] mapping.\n   127→\n   128→    Parameters\n   129→    ----------\n   130→    sorted_position : cupy.ndarray, (N, 4) float32\n   131→    sorted_velocity : cupy.ndarray, (N, 4) float32\n   132→    sorted_veleval : cupy.ndarray, (N, 4) float32\n   133→        XSPH-corrected veleval for FLUID; original velocity for others.\n   134→    sorted_sph_force : cupy.ndarray, (N, 4) float32\n   135→    sorted_mass : cupy.ndarray, (N,) float32\n   136→    sorted_packed_info : cupy.ndarray, (N,) uint32\n   137→    sorted_temperature : cupy.ndarray, (N,) float32\n   138→    sorted_health : cupy.ndarray, (N,) float32\n   139→    sorted_density : cupy.ndarray, optional, (N,) float32\n   140→        Density from Step1. Used for GRANULAR anti-creep check.\n   141→        If None, a zeros array is used (anti-creep won't trigger).\n   142→    sorted_shear_rate : cupy.ndarray, optional, (N,) float32\n   143→        Shear rate from Step1. Used for GRANULAR anti-creep and sleep check.\n   144→        If None, a zeros array is used.\n   145→    sorted_dTdt : cupy.ndarray, optional, (N,) float32\n   146→        Temperature rate of change from Step1 heat diffusion.\n   147→        If None, a zeros array is used (no heat diffusion).\n   148→    sorted_sleep_counter : cupy.ndarray, optional, (N,) uint8\n   149→        Sleep counter from previous frame. If None, zeros are used.\n   150→    sort_indexes : cupy.ndarray, (N,) uint32\n   151→        sort_indexes[sorted_i] = original unsorted index.\n   152→    position_out : cupy.ndarray, optional\n   153→        Pre-allocated (M, 4) float32 unsorted output.\n   154→    velocity_out : cupy.ndarray, optional\n   155→        Pre-allocated (M, 4) float32 unsorted output.\n   156→    color_out : cupy.ndarray, optional\n   157→        Pre-allocated (M, 4) float32 unsorted output.\n   158→    packed_info_out : cupy.ndarray, optional\n   159→        Pre-allocated (M,) uint32 unsorted output for updated packed_info.\n   160→    sleep_counter_out : cupy.ndarray, optional\n   161→        Pre-allocated (M,) uint8 unsorted output for updated sleep counter.\n   162→    temperature_out : cupy.ndarray, optional\n   163→        Pre-allocated (M,) float32 unsorted output for updated temperature.\n   164→\n   165→    Returns\n   166→    -------\n   167→    (position_out, velocity_out, color_out, packed_info_out,\n   168→     sleep_counter_out, temperature_out)\n   169→    \"\"\"\n   170→    n = sorted_position.shape[0]\n   171→    if n == 0:\n   172→        return (position_out, velocity_out, color_out, packed_info_out,\n   173→                sleep_counter_out, temperature_out)\n   174→\n   175→    # Default density/shear_rate/dTdt/sleep_counter to zeros if not provided\n   176→    if sorted_density is None:\n   177→        sorted_density = cupy.zeros(n, dtype=cupy.float32)\n   178→    if sorted_shear_rate is None:\n   179→        sorted_shear_rate = cupy.zeros(n, dtype=cupy.float32)\n   180→    if sorted_dTdt is None:\n   181→        sorted_dTdt = cupy.zeros(n, dtype=cupy.float32)\n   182→    if sorted_sleep_counter is None:\n   183→        sorted_sleep_counter = cupy.zeros(n, dtype=cupy.uint8)\n   184→\n   185→    # Allocate outputs if not provided\n   186→    if position_out is None:\n   187→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   188→        position_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n   189→    if velocity_out is None:\n   190→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   191→        velocity_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n   192→    if color_out is None:\n   193→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   194→        color_out = cupy.zeros((max_idx, 4), dtype=cupy.float32)\n   195→    if packed_info_out is None:\n   196→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   197→        packed_info_out = cupy.zeros(max_idx, dtype=cupy.uint32)\n   198→    if sleep_counter_out is None:\n   199→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   200→        sleep_counter_out = cupy.zeros(max_idx, dtype=cupy.uint8)\n   201→    if temperature_out is None:\n   202→        max_idx = int(sort_indexes.max()) + 1 if n > 0 else n\n   203→        temperature_out = cupy.zeros(max_idx, dtype=cupy.float32)\n   204→\n   205→    module = _get_module()\n   206→    kernel = module.get_function(\"K_Integrate\")  # type: ignore[union-attr]\n   207→\n   208→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   209→    block = (BLOCK_SIZE,)\n   210→\n   211→    kernel(\n   212→        grid,\n   213→        block,\n   214→        (\n   215→            np.uint32(n),\n   216→            sorted_position,\n   217→            sorted_velocity,\n   218→            sorted_veleval,\n   219→            sorted_sph_force,\n   220→            sorted_mass,\n   221→            sorted_packed_info,\n   222→            sorted_temperature,\n   223→            sorted_health,\n   224→            sorted_density,\n   225→            sorted_shear_rate,\n   226→            sorted_dTdt,\n   227→            sorted_sleep_counter,\n   228→            sort_indexes,\n   229→            position_out,\n   230→            velocity_out,\n   231→            color_out,\n   232→            packed_info_out,\n   233→            sleep_counter_out,\n   234→            temperature_out,\n   235→        ),\n   236→    )\n   237→\n   238→    return (position_out, velocity_out, color_out, packed_info_out,\n   239→            sleep_counter_out, temperature_out)\n   240→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01BZsEZgYZF83kNNS6cm6S7X","session_id":"374499ef-5ec0-4577-85fa-be8b5d7ef994","uuid":"ae4757d1-611d-4320-a8c3-a22ea9acf384"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0149ZpGjqdebyehTdMMinkpU","type":"tool_result","content":"     1→\"\"\"Reactions kernel: per-particle phase transitions, combustion, and corrosion.\n     2→\n     3→Compiles physics/kernels/reactions.cu via CuPy RawModule and provides\n     4→a function to launch K_Reactions which performs:\n     5→  - ICE -> WATER (temp > 273K)\n     6→  - LAVA -> STONE (temp < 900K)\n     7→  - WATER -> SPAWN_GAS flag (temp > 373K)\n     8→  - STEAM -> WATER (temp < 373K)\n     9→  - WOOD/OIL/GUNPOWDER -> FIRE (exposure_heat threshold)\n    10→  - Corrosion: health -= exposure_corrode * dt\n    11→  - GAS lifetime decay -> DEAD when expired\n    12→\n    13→Operates on SORTED arrays, runs after Step1 (which computes exposure)\n    14→and before Step2 (which computes forces).\n    15→\n    16→Uses shared constant memory from common.cuh:\n    17→  c_sim       -- SimParams (dt)\n    18→  c_materials -- MaterialProps[32]\n    19→\"\"\"\n    20→\n    21→from __future__ import annotations\n    22→\n    23→import os\n    24→from typing import Optional\n    25→\n    26→import cupy\n    27→import numpy as np\n    28→\n    29→# ---------------------------------------------------------------------------\n    30→# CuPy RawModule compilation\n    31→# ---------------------------------------------------------------------------\n    32→\n    33→_module: Optional[object] = None\n    34→\n    35→\n    36→def _ensure_ptx_if_needed() -> None:\n    37→    \"\"\"Force PTX compilation when GPU arch exceeds NVRTC's max sm target.\"\"\"\n    38→    from cupy.cuda import compiler as _compiler\n    39→    from cupy.cuda import device as _device\n    40→\n    41→    gpu_cc = _device.Device().compute_capability\n    42→    nvrtc_max = _compiler._get_max_compute_capability()\n    43→    if int(gpu_cc) > int(nvrtc_max):\n    44→        _compiler._use_ptx = True\n    45→        if hasattr(_compiler._get_arch_for_options_for_nvrtc, \"_cache\"):\n    46→            _compiler._get_arch_for_options_for_nvrtc._cache = {}\n    47→        if hasattr(_compiler._get_arch, \"_cache\"):\n    48→            _compiler._get_arch._cache = {}\n    49→\n    50→\n    51→def _get_module() -> \"object\":\n    52→    \"\"\"Compile (or return cached) CuPy RawModule from reactions.cu.\"\"\"\n    53→    global _module\n    54→    if _module is not None:\n    55→        return _module\n    56→\n    57→    _ensure_ptx_if_needed()\n    58→\n    59→    kernel_dir = os.path.join(os.path.dirname(__file__), \"physics\", \"kernels\")\n    60→    cu_path = os.path.join(kernel_dir, \"reactions.cu\")\n    61→    with open(cu_path) as f:\n    62→        source = f.read()\n    63→\n    64→    _module = cupy.RawModule(\n    65→        code=source,\n    66→        options=(\"--std=c++11\", \"--use_fast_math\", f\"-I{kernel_dir}\"),\n    67→    )\n    68→    return _module\n    69→\n    70→\n    71→def get_module() -> \"object\":\n    72→    \"\"\"Return the compiled CuPy RawModule (public accessor).\"\"\"\n    73→    return _get_module()\n    74→\n    75→\n    76→# ---------------------------------------------------------------------------\n    77→# Constant memory upload\n    78→# ---------------------------------------------------------------------------\n    79→\n    80→\n    81→def upload_sim_params(params: np.ndarray) -> None:\n    82→    \"\"\"Upload SimParams to ``__constant__ SimParams c_sim``.\"\"\"\n    83→    module = _get_module()\n    84→    d_ptr = module.get_global(\"c_sim\")  # type: ignore[union-attr]\n    85→    cupy.cuda.runtime.memcpy(\n    86→        int(d_ptr), params.ctypes.data, params.nbytes, 1\n    87→    )\n    88→\n    89→\n    90→def upload_materials(materials_data: np.ndarray) -> None:\n    91→    \"\"\"Upload MaterialProps[32] to ``__constant__ MaterialProps c_materials[32]``.\"\"\"\n    92→    module = _get_module()\n    93→    d_ptr = module.get_global(\"c_materials\")  # type: ignore[union-attr]\n    94→    cupy.cuda.runtime.memcpy(\n    95→        int(d_ptr), materials_data.ctypes.data, materials_data.nbytes, 1\n    96→    )\n    97→\n    98→\n    99→# ---------------------------------------------------------------------------\n   100→# Kernel launch\n   101→# ---------------------------------------------------------------------------\n   102→\n   103→BLOCK_SIZE = 256\n   104→\n   105→\n   106→def compute_reactions(\n   107→    sorted_packed_info: cupy.ndarray,\n   108→    sorted_temperature: cupy.ndarray,\n   109→    sorted_health: cupy.ndarray,\n   110→    sorted_lifetime: cupy.ndarray,\n   111→    sorted_velocity: cupy.ndarray,\n   112→    sorted_exposure_heat: cupy.ndarray,\n   113→    sorted_exposure_corrode: cupy.ndarray,\n   114→    frame: int = 0,\n   115→    dead_indices: Optional[cupy.ndarray] = None,\n   116→    dead_count: Optional[cupy.ndarray] = None,\n   117→) -> None:\n   118→    \"\"\"Launch K_Reactions kernel.\n   119→\n   120→    Modifies sorted arrays in-place: packed_info, temperature, health,\n   121→    lifetime, velocity.\n   122→\n   123→    Parameters\n   124→    ----------\n   125→    sorted_packed_info : cupy.ndarray, (N,) uint32\n   126→        Packed info (material_id + behavior + flags). Modified in-place.\n   127→    sorted_temperature : cupy.ndarray, (N,) float32\n   128→        Particle temperature. Modified in-place.\n   129→    sorted_health : cupy.ndarray, (N,) float32\n   130→        Particle health [0,1]. Modified in-place.\n   131→    sorted_lifetime : cupy.ndarray, (N,) float32\n   132→        Remaining lifetime in seconds. Modified in-place.\n   133→    sorted_velocity : cupy.ndarray, (N, 4) float32\n   134→        Particle velocity. Modified in-place (gunpowder explosion).\n   135→    sorted_exposure_heat : cupy.ndarray, (N,) float32\n   136→        Heat exposure from Step1 (read-only).\n   137→    sorted_exposure_corrode : cupy.ndarray, (N,) float32\n   138→        Corrosion exposure from Step1 (read-only).\n   139→    frame : int\n   140→        Frame counter for RNG seed (gunpowder explosion direction).\n   141→    dead_indices : cupy.ndarray, optional\n   142→        (max_particles,) uint32 freelist array. Dead particle sorted indices\n   143→        are appended here via atomicAdd on dead_count.\n   144→    dead_count : cupy.ndarray, optional\n   145→        (1,) uint32 atomic counter for freelist size.\n   146→    \"\"\"\n   147→    n = sorted_packed_info.shape[0]\n   148→    if n == 0:\n   149→        return\n   150→\n   151→    module = _get_module()\n   152→    kernel = module.get_function(\"K_Reactions\")  # type: ignore[union-attr]\n   153→\n   154→    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)\n   155→    block = (BLOCK_SIZE,)\n   156→\n   157→    # Pass null (0) pointers when freelist not provided\n   158→    d_dead_indices = dead_indices if dead_indices is not None else np.intp(0)\n   159→    d_dead_count = dead_count if dead_count is not None else np.intp(0)\n   160→\n   161→    kernel(\n   162→        grid,\n   163→        block,\n   164→        (\n   165→            np.uint32(n),\n   166→            np.uint32(frame),\n   167→            sorted_packed_info,\n   168→            sorted_temperature,\n   169→            sorted_health,\n   170→            sorted_lifetime,\n   171→            sorted_velocity,\n   172→            sorted_exposure_heat,\n   173→            sorted_exposure_corrode,\n   174→            d_dead_indices,\n   175→            d_dead_count,\n   176→        ),\n   177→    )\n   178→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01BZsEZgYZF83kNNS6cm6S7X","session_id":"374499ef-5ec0-4577-85fa-be8b5d7ef994","uuid":"6a42c317-22fe-4acc-ab88-f0b8aff825c6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HdtyCPgUhu7pf8nFhz7mGR","type":"tool_result","content":"     1→/*\n     2→ * common.cuh -- Single source of truth for all GPU data layouts.\n     3→ *\n     4→ * All .cu kernel files include this header. It defines:\n     5→ *   - BehaviorClass enum\n     6→ *   - MaterialProps / Interaction structs + constant memory arrays\n     7→ *   - GridParams struct + constant memory\n     8→ *   - SimParams / PrecalcParams structs + constant memory\n     9→ *   - packed_info bitfield macros\n    10→ *   - Array type conventions (documented in comments)\n    11→ */\n    12→\n    13→#ifndef FALLINGSAND3D_COMMON_CUH\n    14→#define FALLINGSAND3D_COMMON_CUH\n    15→\n    16→typedef unsigned int uint;\n    17→\n    18→/* ======================================================================\n    19→ * Behavior classes\n    20→ * ====================================================================== */\n    21→\n    22→enum BehaviorClass {\n    23→    FLUID   = 0,\n    24→    GRANULAR = 1,\n    25→    GAS     = 2,\n    26→    STATIC  = 3\n    27→};\n    28→\n    29→/* ======================================================================\n    30→ * MaterialProps -- per-material constants uploaded to constant memory.\n    31→ * 16 fields x 4 bytes = 64 bytes (no extra padding needed).\n    32→ * ====================================================================== */\n    33→\n    34→struct MaterialProps {\n    35→    float rest_density;          // kg/m^3\n    36→    float eos_stiffness;         // Tait EOS k\n    37→    float eos_gamma;             // Tait EOS exponent (7 for liquid, 1 for gas)\n    38→    float base_viscosity;        // Pa*s\n    39→    float friction_coeff;        // mu_s for granular friction\n    40→    float cohesion;              // cohesion coefficient\n    41→    float buoyancy_extra;        // extra buoyancy factor for gas\n    42→    float thermal_conductivity;  // W/(m*K)\n    43→    float heat_capacity;         // J/(kg*K)\n    44→    float temp_melt;             // Kelvin\n    45→    float temp_boil;             // Kelvin\n    46→    float temp_ignite;           // Kelvin (0 = non-flammable)\n    47→    int   behavior_class;        // BehaviorClass enum value\n    48→    float color_r;               // default material color R\n    49→    float color_g;               // default material color G\n    50→    float color_b;               // default material color B\n    51→};\n    52→// Static assert: sizeof(MaterialProps) must be 64 bytes\n    53→\n    54→/* ======================================================================\n    55→ * Interaction -- per-pair (i,j) reaction parameters.\n    56→ * 2 fields x 4 bytes = 8 bytes.\n    57→ * ====================================================================== */\n    58→\n    59→struct Interaction {\n    60→    float reaction_rate;   // reaction speed (0 = no reaction)\n    61→    float heat_exchange;   // heat transfer coefficient between pair\n    62→};\n    63→\n    64→/* ======================================================================\n    65→ * Constant memory: materials and interactions\n    66→ * Total: 32*64 + 32*32*8 = 2048 + 8192 = 10240 bytes (well under 64 KB)\n    67→ * ====================================================================== */\n    68→\n    69→__constant__ MaterialProps c_materials[32];\n    70→__constant__ Interaction   c_interactions[32][32];\n    71→\n    72→/* ======================================================================\n    73→ * GridParams -- uniform grid parameters for spatial hashing.\n    74→ *\n    75→ * grid_res uses int3 (not float3 as in the root-level prototype) for\n    76→ * correct integer arithmetic in hash computation.\n    77→ * ====================================================================== */\n    78→\n    79→struct GridParams {\n    80→    float3 grid_min;    // world-space minimum corner\n    81→    float3 grid_max;    // world-space maximum corner\n    82→    int3   grid_res;    // number of cells per axis\n    83→    float3 grid_delta;  // 1 / cell_size = grid_res / grid_size\n    84→    int    num_cells;   // grid_res.x * grid_res.y * grid_res.z\n    85→};\n    86→\n    87→__constant__ GridParams c_grid;\n    88→\n    89→/* ======================================================================\n    90→ * SimParams -- simulation-wide parameters.\n    91→ *\n    92→ * Uploaded once per frame (or when sim config changes).\n    93→ * ====================================================================== */\n    94→\n    95→struct SimParams {\n    96→    float  smoothing_length;     // h\n    97→    float  smoothing_length_sq;  // h^2\n    98→    float  particle_mass;        // uniform mass per particle\n    99→    float  particle_spacing;     // rest spacing between particles\n   100→    float3 gravity;              // (0, -9.8, 0) typically\n   101→    float  dt;                   // simulation timestep\n   102→    float  restitution;          // wall bounce coefficient\n   103→    float  wall_friction;        // wall friction coefficient\n   104→    float3 world_min;            // simulation domain min\n   105→    float3 world_max;            // simulation domain max\n   106→};\n   107→\n   108→__constant__ SimParams c_sim;\n   109→\n   110→/* ======================================================================\n   111→ * PrecalcParams -- kernel coefficients precomputed from smoothing_length.\n   112→ *\n   113→ * These depend on h and are recomputed when h changes. Stored separately\n   114→ * from SimParams to keep the intent clear.\n   115→ *\n   116→ * Sign convention: pressure_precalc is POSITIVE (+45/(pi*h^6)) because\n   117→ * it absorbs the double negative from the SPH momentum equation.\n   118→ * ====================================================================== */\n   119→\n   120→struct PrecalcParams {\n   121→    float poly6_coeff;           // 315 / (64 * pi * h^9)\n   122→    float spiky_grad_coeff;      // -45 / (pi * h^6)  (negative)\n   123→    float viscosity_lap_coeff;   // 45 / (pi * h^6)\n   124→    float pressure_precalc;      // +45 / (pi * h^6)   (positive, see note)\n   125→    float viscosity_precalc;     // mu * 45 / (pi * h^6)\n   126→};\n   127→\n   128→__constant__ PrecalcParams c_precalc;\n   129→\n   130→/* ======================================================================\n   131→ * packed_info bitfield layout (uint32)\n   132→ *\n   133→ *   Bits [7:0]   material_id    (256 materials max, 32 used)\n   134→ *   Bits [9:8]   behavior_class (FLUID=0, GRANULAR=1, GAS=2, STATIC=3)\n   135→ *   Bit  [10]    is_sleeping    (1 = asleep, skip force computation)\n   136→ *   Bit  [11]    spawn_flag     (1 = just spawned, needs initialization)\n   137→ *   Bit  [12]    just_woke      (1 = woke this frame, needs velocity reset)\n   138→ *   Bits [31:13] reserved\n   139→ * ====================================================================== */\n   140→\n   141→#define GET_MATERIAL_ID(p)  ((p) & 0xFF)\n   142→#define GET_BEHAVIOR(p)     (((p) >> 8) & 0x3)\n   143→#define IS_SLEEPING(p)      (((p) >> 10) & 1)\n   144→#define SET_SLEEPING(p)     ((p) | 0x400)\n   145→#define CLEAR_SLEEPING(p)   ((p) & ~0x400)\n   146→#define HAS_SPAWN_FLAG(p)   (((p) >> 11) & 1)\n   147→#define SET_SPAWN_FLAG(p)   ((p) | 0x800)\n   148→#define CLEAR_SPAWN_FLAG(p) ((p) & ~0x800)\n   149→#define HAS_JUST_WOKE(p)    (((p) >> 12) & 1)\n   150→#define SET_JUST_WOKE(p)    ((p) | 0x1000)\n   151→#define CLEAR_JUST_WOKE(p)  ((p) & ~0x1000)\n   152→#define MAKE_PACKED(mat, beh) (((mat) & 0xFF) | (((beh) & 0x3) << 8))\n   153→\n   154→/* ======================================================================\n   155→ * Array type conventions (documented per acceptance criteria)\n   156→ *\n   157→ * float4 arrays (w component unused, set to 0):\n   158→ *   position, velocity, veleval, sph_force, color\n   159→ *\n   160→ * float arrays:\n   161→ *   density, mass, temperature, health, lifetime,\n   162→ *   shear_rate, exposure_heat, exposure_corrode\n   163→ *\n   164→ * uint32 arrays:\n   165→ *   packed_info\n   166→ *\n   167→ * uint8 arrays:\n   168→ *   sleep_counter\n   169→ * ====================================================================== */\n   170→\n   171→#endif /* FALLINGSAND3D_COMMON_CUH */\n   172→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01BZsEZgYZF83kNNS6cm6S7X","session_id":"374499ef-5ec0-4577-85fa-be8b5d7ef994","uuid":"56d8259a-89f3-4d0f-becc-9e8a396cf6f2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N5YL6q12cHZSkoMasCUR6o","type":"tool_result","content":"     1→\"\"\"Falling Sand 3D - Main entry point with GLFW window and orbit camera.\"\"\"\n     2→\n     3→import time\n     4→import glfw\n     5→import numpy as np\n     6→from OpenGL.GL import (\n     7→    glClearColor, glClear, glGetString, glGetError, glViewport,\n     8→    GL_COLOR_BUFFER_BIT, GL_DEPTH_BUFFER_BIT,\n     9→    GL_VERSION, GL_RENDERER, GL_NO_ERROR,\n    10→)\n    11→from camera import OrbitCamera\n    12→from renderer import Renderer\n    13→\n    14→WINDOW_WIDTH = 1280\n    15→WINDOW_HEIGHT = 720\n    16→WINDOW_TITLE = \"Falling Sand 3D\"\n    17→MAX_PARTICLES = 30_000  # budget for initial scene (~20K used)\n    18→\n    19→\n    20→def _apply_ptx_workaround():\n    21→    \"\"\"Force CuPy to emit PTX instead of cubin for forward-compat with newer GPUs.\"\"\"\n    22→    try:\n    23→        import cupy.cuda.compiler as _compiler\n    24→        _compiler._use_ptx = True\n    25→        if hasattr(_compiler._get_arch, '_cache'):\n    26→            _compiler._get_arch._cache = {}\n    27→        if hasattr(_compiler, '_get_arch_for_options_for_nvrtc'):\n    28→            fn = _compiler._get_arch_for_options_for_nvrtc\n    29→            if hasattr(fn, '_cache'):\n    30→                fn._cache = {}\n    31→    except Exception:\n    32→        pass\n    33→\n    34→\n    35→def _spawn_initial_scene(world):\n    36→    \"\"\"Spawn the initial scene: water cube + sand bed.\"\"\"\n    37→    from materials import WATER, SAND\n    38→\n    39→    # 10K water particles in cube at (0, 0.5, 0) size 0.4\n    40→    n_water = world.spawn_cube(\n    41→        min_corner=(-0.2, 0.3, -0.2),\n    42→        max_corner=(0.2, 0.7, 0.2),\n    43→        material_id=WATER,\n    44→        spacing=0.02,\n    45→    )\n    46→    print(f\"  Water: {n_water:,} particles\")\n    47→\n    48→    # 10K sand particles in flat bed y=-0.5 to y=-0.3, x/z spanning -0.8 to 0.8\n    49→    n_sand = world.spawn_cube(\n    50→        min_corner=(-0.8, -0.5, -0.8),\n    51→        max_corner=(0.8, -0.3, 0.8),\n    52→        material_id=SAND,\n    53→        spacing=0.04,\n    54→    )\n    55→    print(f\"  Sand:  {n_sand:,} particles\")\n    56→\n    57→    total = n_water + n_sand\n    58→    print(f\"  Total: {total:,} particles\")\n    59→    return total\n    60→\n    61→\n    62→def main():\n    63→    if not glfw.init():\n    64→        raise RuntimeError(\"Failed to initialize GLFW\")\n    65→\n    66→    # Request OpenGL 4.1+ core profile\n    67→    glfw.window_hint(glfw.CONTEXT_VERSION_MAJOR, 4)\n    68→    glfw.window_hint(glfw.CONTEXT_VERSION_MINOR, 1)\n    69→    glfw.window_hint(glfw.OPENGL_PROFILE, glfw.OPENGL_CORE_PROFILE)\n    70→    glfw.window_hint(glfw.OPENGL_FORWARD_COMPAT, glfw.TRUE)\n    71→\n    72→    window = glfw.create_window(WINDOW_WIDTH, WINDOW_HEIGHT, WINDOW_TITLE, None, None)\n    73→    if not window:\n    74→        glfw.terminate()\n    75→        raise RuntimeError(\"Failed to create GLFW window\")\n    76→\n    77→    glfw.make_context_current(window)\n    78→    glfw.swap_interval(0)  # no vsync for FPS measurement\n    79→\n    80→    # Verify OpenGL version\n    81→    gl_version = glGetString(GL_VERSION)\n    82→    gl_renderer = glGetString(GL_RENDERER)\n    83→    if gl_version:\n    84→        print(f\"OpenGL: {gl_version.decode()}\")\n    85→    if gl_renderer:\n    86→        print(f\"Renderer: {gl_renderer.decode()}\")\n    87→\n    88→    # Dark gray background\n    89→    glClearColor(0.15, 0.15, 0.15, 1.0)\n    90→\n    91→    camera = OrbitCamera(distance=2.0, elevation=20.0)\n    92→    camera.set_aspect(WINDOW_WIDTH, WINDOW_HEIGHT)\n    93→\n    94→    # Apply PTX workaround before any CuPy compilation\n    95→    _apply_ptx_workaround()\n    96→\n    97→    # Create world and spawn initial scene\n    98→    from world import World\n    99→    from simulation import Simulation\n   100→\n   101→    world = World(max_particles=MAX_PARTICLES)\n   102→    print(\"Spawning initial scene...\")\n   103→    num_active = _spawn_initial_scene(world)\n   104→\n   105→    # Create renderer sized to max_particles\n   106→    renderer = Renderer(MAX_PARTICLES, point_scale=20.0)\n   107→    renderer.num_active = num_active\n   108→\n   109→    # Create simulation orchestrator\n   110→    sim = Simulation(world, dt=0.001, speed=1.0, max_substeps=20)\n   111→    print(\"Simulation initialized -- kernels compiled and constants uploaded\")\n   112→\n   113→    # Copy initial state to VBOs\n   114→    with renderer.cuda_pos as pos_buf, renderer.cuda_col as col_buf:\n   115→        sim.copy_to_vbos(pos_buf, col_buf)\n   116→    import cupy\n   117→    cupy.cuda.Device().synchronize()\n   118→\n   119→    # Input state\n   120→    right_pressed = False\n   121→    middle_pressed = False\n   122→    last_mx, last_my = 0.0, 0.0\n   123→\n   124→    def key_callback(_win, key, _scancode, action, _mods):\n   125→        nonlocal num_active\n   126→        if action != glfw.PRESS:\n   127→            return\n   128→        if key == glfw.KEY_ESCAPE:\n   129→            glfw.set_window_should_close(_win, True)\n   130→        elif key == glfw.KEY_SPACE:\n   131→            sim.toggle_pause()\n   132→        elif key == glfw.KEY_R:\n   133→            # Reset to initial configuration\n   134→            world.packed_info[:] = 0\n   135→            world._high_water = 0\n   136→            num_active = _spawn_initial_scene(world)\n   137→            renderer.num_active = num_active\n   138→            sim.sim_time = 0.0\n   139→            sim._last_frame_time = None\n   140→        elif key == glfw.KEY_EQUAL or key == glfw.KEY_KP_ADD:\n   141→            sim.adjust_speed(0.2)\n   142→        elif key == glfw.KEY_MINUS or key == glfw.KEY_KP_SUBTRACT:\n   143→            sim.adjust_speed(-0.2)\n   144→\n   145→    def mouse_button_callback(_win, button, action, _mods):\n   146→        nonlocal right_pressed, middle_pressed, last_mx, last_my\n   147→        if button == glfw.MOUSE_BUTTON_RIGHT:\n   148→            right_pressed = action == glfw.PRESS\n   149→            if right_pressed:\n   150→                last_mx, last_my = glfw.get_cursor_pos(_win)\n   151→        elif button == glfw.MOUSE_BUTTON_MIDDLE:\n   152→            middle_pressed = action == glfw.PRESS\n   153→            if middle_pressed:\n   154→                last_mx, last_my = glfw.get_cursor_pos(_win)\n   155→\n   156→    def cursor_pos_callback(_win, xpos, ypos):\n   157→        nonlocal last_mx, last_my\n   158→        dx = xpos - last_mx\n   159→        dy = ypos - last_my\n   160→        last_mx, last_my = xpos, ypos\n   161→\n   162→        if right_pressed:\n   163→            camera.orbit(dx, dy)\n   164→        elif middle_pressed:\n   165→            camera.pan(dx, dy)\n   166→\n   167→    def scroll_callback(_win, _xoffset, yoffset):\n   168→        camera.zoom(yoffset)\n   169→\n   170→    def framebuffer_size_callback(_win, width, height):\n   171→        if width > 0 and height > 0:\n   172→            glViewport(0, 0, width, height)\n   173→            camera.set_aspect(width, height)\n   174→\n   175→    glfw.set_key_callback(window, key_callback)\n   176→    glfw.set_mouse_button_callback(window, mouse_button_callback)\n   177→    glfw.set_cursor_pos_callback(window, cursor_pos_callback)\n   178→    glfw.set_scroll_callback(window, scroll_callback)\n   179→    glfw.set_framebuffer_size_callback(window, framebuffer_size_callback)\n   180→\n   181→    # FPS tracking\n   182→    frame_count = 0\n   183→    fps_time = time.perf_counter()\n   184→    fps = 0.0\n   185→\n   186→    while not glfw.window_should_close(window):\n   187→        glfw.poll_events()\n   188→\n   189→        # --- Simulation substeps ---\n   190→        substeps = sim.step_frame()\n   191→\n   192→        # --- Copy to VBOs (once per frame) ---\n   193→        with renderer.cuda_pos as pos_buf, renderer.cuda_col as col_buf:\n   194→            sim.copy_to_vbos(pos_buf, col_buf)\n   195→\n   196→        # Update active count for renderer\n   197→        renderer.num_active = world._high_water\n   198→\n   199→        # --- Render ---\n   200→        glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)\n   201→\n   202→        view = camera.view_matrix()\n   203→        proj = camera.projection_matrix()\n   204→        renderer.draw(view, proj)\n   205→\n   206→        glfw.swap_buffers(window)\n   207→\n   208→        # FPS counter\n   209→        frame_count += 1\n   210→        now = time.perf_counter()\n   211→        elapsed = now - fps_time\n   212→        if elapsed >= 0.5:\n   213→            fps = frame_count / elapsed\n   214→            frame_count = 0\n   215→            fps_time = now\n   216→            pause_str = \" [PAUSED]\" if sim.paused else \"\"\n   217→            glfw.set_window_title(\n   218→                window,\n   219→                f\"{WINDOW_TITLE} | {world._high_water // 1000}K | \"\n   220→                f\"FPS: {fps:.0f} | steps: {substeps} | \"\n   221→                f\"speed: {sim.speed:.1f}x{pause_str}\",\n   222→            )\n   223→\n   224→        # Check GL errors\n   225→        err = glGetError()\n   226→        if err != GL_NO_ERROR:\n   227→            print(f\"GL error: {err}\")\n   228→\n   229→    renderer.close()\n   230→    glfw.destroy_window(window)\n   231→    glfw.terminate()\n   232→\n   233→\n   234→if __name__ == \"__main__\":\n   235→    main()\n   236→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01BZsEZgYZF83kNNS6cm6S7X
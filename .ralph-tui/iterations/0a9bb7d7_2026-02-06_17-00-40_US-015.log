{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014qjyRZe2Vxz71gttpgcKNh","type":"tool_result","content":"     1→/*\n     2→ * common.cuh -- Single source of truth for all GPU data layouts.\n     3→ *\n     4→ * All .cu kernel files include this header. It defines:\n     5→ *   - BehaviorClass enum\n     6→ *   - MaterialProps / Interaction structs + constant memory arrays\n     7→ *   - GridParams struct + constant memory\n     8→ *   - SimParams / PrecalcParams structs + constant memory\n     9→ *   - packed_info bitfield macros\n    10→ *   - Array type conventions (documented in comments)\n    11→ */\n    12→\n    13→#ifndef FALLINGSAND3D_COMMON_CUH\n    14→#define FALLINGSAND3D_COMMON_CUH\n    15→\n    16→typedef unsigned int uint;\n    17→\n    18→/* ======================================================================\n    19→ * Behavior classes\n    20→ * ====================================================================== */\n    21→\n    22→enum BehaviorClass {\n    23→    FLUID   = 0,\n    24→    GRANULAR = 1,\n    25→    GAS     = 2,\n    26→    STATIC  = 3\n    27→};\n    28→\n    29→/* ======================================================================\n    30→ * MaterialProps -- per-material constants uploaded to constant memory.\n    31→ * 16 fields x 4 bytes = 64 bytes (no extra padding needed).\n    32→ * ====================================================================== */\n    33→\n    34→struct MaterialProps {\n    35→    float rest_density;          // kg/m^3\n    36→    float eos_stiffness;         // Tait EOS k\n    37→    float eos_gamma;             // Tait EOS exponent (7 for liquid, 1 for gas)\n    38→    float base_viscosity;        // Pa*s\n    39→    float friction_coeff;        // mu_s for granular friction\n    40→    float cohesion;              // cohesion coefficient\n    41→    float buoyancy_extra;        // extra buoyancy factor for gas\n    42→    float thermal_conductivity;  // W/(m*K)\n    43→    float heat_capacity;         // J/(kg*K)\n    44→    float temp_melt;             // Kelvin\n    45→    float temp_boil;             // Kelvin\n    46→    float temp_ignite;           // Kelvin (0 = non-flammable)\n    47→    int   behavior_class;        // BehaviorClass enum value\n    48→    float color_r;               // default material color R\n    49→    float color_g;               // default material color G\n    50→    float color_b;               // default material color B\n    51→};\n    52→// Static assert: sizeof(MaterialProps) must be 64 bytes\n    53→\n    54→/* ======================================================================\n    55→ * Interaction -- per-pair (i,j) reaction parameters.\n    56→ * 2 fields x 4 bytes = 8 bytes.\n    57→ * ====================================================================== */\n    58→\n    59→struct Interaction {\n    60→    float reaction_rate;   // reaction speed (0 = no reaction)\n    61→    float heat_exchange;   // heat transfer coefficient between pair\n    62→};\n    63→\n    64→/* ======================================================================\n    65→ * Constant memory: materials and interactions\n    66→ * Total: 32*64 + 32*32*8 = 2048 + 8192 = 10240 bytes (well under 64 KB)\n    67→ * ====================================================================== */\n    68→\n    69→__constant__ MaterialProps c_materials[32];\n    70→__constant__ Interaction   c_interactions[32][32];\n    71→\n    72→/* ======================================================================\n    73→ * GridParams -- uniform grid parameters for spatial hashing.\n    74→ *\n    75→ * grid_res uses int3 (not float3 as in the root-level prototype) for\n    76→ * correct integer arithmetic in hash computation.\n    77→ * ====================================================================== */\n    78→\n    79→struct GridParams {\n    80→    float3 grid_min;    // world-space minimum corner\n    81→    float3 grid_max;    // world-space maximum corner\n    82→    int3   grid_res;    // number of cells per axis\n    83→    float3 grid_delta;  // 1 / cell_size = grid_res / grid_size\n    84→    int    num_cells;   // grid_res.x * grid_res.y * grid_res.z\n    85→};\n    86→\n    87→__constant__ GridParams c_grid;\n    88→\n    89→/* ======================================================================\n    90→ * SimParams -- simulation-wide parameters.\n    91→ *\n    92→ * Uploaded once per frame (or when sim config changes).\n    93→ * ====================================================================== */\n    94→\n    95→struct SimParams {\n    96→    float  smoothing_length;     // h\n    97→    float  smoothing_length_sq;  // h^2\n    98→    float  particle_mass;        // uniform mass per particle\n    99→    float  particle_spacing;     // rest spacing between particles\n   100→    float3 gravity;              // (0, -9.8, 0) typically\n   101→    float  dt;                   // simulation timestep\n   102→    float  restitution;          // wall bounce coefficient\n   103→    float  wall_friction;        // wall friction coefficient\n   104→    float3 world_min;            // simulation domain min\n   105→    float3 world_max;            // simulation domain max\n   106→};\n   107→\n   108→__constant__ SimParams c_sim;\n   109→\n   110→/* ======================================================================\n   111→ * PrecalcParams -- kernel coefficients precomputed from smoothing_length.\n   112→ *\n   113→ * These depend on h and are recomputed when h changes. Stored separately\n   114→ * from SimParams to keep the intent clear.\n   115→ *\n   116→ * Sign convention: pressure_precalc is POSITIVE (+45/(pi*h^6)) because\n   117→ * it absorbs the double negative from the SPH momentum equation.\n   118→ * ====================================================================== */\n   119→\n   120→struct PrecalcParams {\n   121→    float poly6_coeff;           // 315 / (64 * pi * h^9)\n   122→    float spiky_grad_coeff;      // -45 / (pi * h^6)  (negative)\n   123→    float viscosity_lap_coeff;   // 45 / (pi * h^6)\n   124→    float pressure_precalc;      // +45 / (pi * h^6)   (positive, see note)\n   125→    float viscosity_precalc;     // mu * 45 / (pi * h^6)\n   126→};\n   127→\n   128→__constant__ PrecalcParams c_precalc;\n   129→\n   130→/* ======================================================================\n   131→ * packed_info bitfield layout (uint32)\n   132→ *\n   133→ *   Bits [7:0]   material_id    (256 materials max, 32 used)\n   134→ *   Bits [9:8]   behavior_class (FLUID=0, GRANULAR=1, GAS=2, STATIC=3)\n   135→ *   Bit  [10]    is_sleeping    (1 = asleep, skip force computation)\n   136→ *   Bit  [11]    spawn_flag     (1 = just spawned, needs initialization)\n   137→ *   Bit  [12]    just_woke      (1 = woke this frame, needs velocity reset)\n   138→ *   Bits [31:13] reserved\n   139→ * ====================================================================== */\n   140→\n   141→#define GET_MATERIAL_ID(p)  ((p) & 0xFF)\n   142→#define GET_BEHAVIOR(p)     (((p) >> 8) & 0x3)\n   143→#define IS_SLEEPING(p)      (((p) >> 10) & 1)\n   144→#define SET_SLEEPING(p)     ((p) | 0x400)\n   145→#define CLEAR_SLEEPING(p)   ((p) & ~0x400)\n   146→#define HAS_SPAWN_FLAG(p)   (((p) >> 11) & 1)\n   147→#define SET_SPAWN_FLAG(p)   ((p) | 0x800)\n   148→#define HAS_JUST_WOKE(p)    (((p) >> 12) & 1)\n   149→#define MAKE_PACKED(mat, beh) (((mat) & 0xFF) | (((beh) & 0x3) << 8))\n   150→\n   151→/* ======================================================================\n   152→ * Array type conventions (documented per acceptance criteria)\n   153→ *\n   154→ * float4 arrays (w component unused, set to 0):\n   155→ *   position, velocity, veleval, sph_force, color\n   156→ *\n   157→ * float arrays:\n   158→ *   density, mass, temperature, health, lifetime,\n   159→ *   shear_rate, exposure_heat, exposure_corrode\n   160→ *\n   161→ * uint32 arrays:\n   162→ *   packed_info\n   163→ *\n   164→ * uint8 arrays:\n   165→ *   sleep_counter\n   166→ * ====================================================================== */\n   167→\n   168→#endif /* FALLINGSAND3D_COMMON_CUH */\n   169→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"eb47956f-dbff-4960-8452-8e302b089f1c","uuid":"caff83dd-0e67-4033-ab52-2bccde6803e1","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/physics/kernels/common.cuh","content":"/*\n * common.cuh -- Single source of truth for all GPU data layouts.\n *\n * All .cu kernel files include this header. It defines:\n *   - BehaviorClass enum\n *   - MaterialProps / Interaction structs + constant memory arrays\n *   - GridParams struct + constant memory\n *   - SimParams / PrecalcParams structs + constant memory\n *   - packed_info bitfield macros\n *   - Array type conventions (documented in comments)\n */\n\n#ifndef FALLINGSAND3D_COMMON_CUH\n#define FALLINGSAND3D_COMMON_CUH\n\ntypedef unsigned int uint;\n\n/* ======================================================================\n * Behavior classes\n * ====================================================================== */\n\nenum BehaviorClass {\n    FLUID   = 0,\n    GRANULAR = 1,\n    GAS     = 2,\n    STATIC  = 3\n};\n\n/* ======================================================================\n * MaterialProps -- per-material constants uploaded to constant memory.\n * 16 fields x 4 bytes = 64 bytes (no extra padding needed).\n * ====================================================================== */\n\nstruct MaterialProps {\n    float rest_density;          // kg/m^3\n    float eos_stiffness;         // Tait EOS k\n    float eos_gamma;             // Tait EOS exponent (7 for liquid, 1 for gas)\n    float base_viscosity;        // Pa*s\n    float friction_coeff;        // mu_s for granular friction\n    float cohesion;              // cohesion coefficient\n    float buoyancy_extra;        // extra buoyancy factor for gas\n    float thermal_conductivity;  // W/(m*K)\n    float heat_capacity;         // J/(kg*K)\n    float temp_melt;             // Kelvin\n    float temp_boil;             // Kelvin\n    float temp_ignite;           // Kelvin (0 = non-flammable)\n    int   behavior_class;        // BehaviorClass enum value\n    float color_r;               // default material color R\n    float color_g;               // default material color G\n    float color_b;               // default material color B\n};\n// Static assert: sizeof(MaterialProps) must be 64 bytes\n\n/* ======================================================================\n * Interaction -- per-pair (i,j) reaction parameters.\n * 2 fields x 4 bytes = 8 bytes.\n * ====================================================================== */\n\nstruct Interaction {\n    float reaction_rate;   // reaction speed (0 = no reaction)\n    float heat_exchange;   // heat transfer coefficient between pair\n};\n\n/* ======================================================================\n * Constant memory: materials and interactions\n * Total: 32*64 + 32*32*8 = 2048 + 8192 = 10240 bytes (well under 64 KB)\n * ====================================================================== */\n\n__constant__ MaterialProps c_materials[32];\n__constant__ Interaction   c_interactions[32][32];\n\n/* ======================================================================\n * GridParams -- uniform grid parameters for spatial hashing.\n *\n * grid_res uses int3 (not float3 as in the root-level prototype) for\n * correct integer arithmetic in hash computation.\n * ====================================================================== */\n\nstruct GridParams {\n    float3 grid_min;    // world-space minimum corner\n    float3 grid_max;    // world-space maximum corner\n    int3   grid_res;    // number of cells per axis\n    float3 grid_delta;  // 1 / cell_size = grid_res / grid_size\n    int    num_cells;   // grid_res.x * grid_res.y * grid_res.z\n};\n\n__constant__ GridParams c_grid;\n\n/* ======================================================================\n * SimParams -- simulation-wide parameters.\n *\n * Uploaded once per frame (or when sim config changes).\n * ====================================================================== */\n\nstruct SimParams {\n    float  smoothing_length;     // h\n    float  smoothing_length_sq;  // h^2\n    float  particle_mass;        // uniform mass per particle\n    float  particle_spacing;     // rest spacing between particles\n    float3 gravity;              // (0, -9.8, 0) typically\n    float  dt;                   // simulation timestep\n    float  restitution;          // wall bounce coefficient\n    float  wall_friction;        // wall friction coefficient\n    float3 world_min;            // simulation domain min\n    float3 world_max;            // simulation domain max\n};\n\n__constant__ SimParams c_sim;\n\n/* ======================================================================\n * PrecalcParams -- kernel coefficients precomputed from smoothing_length.\n *\n * These depend on h and are recomputed when h changes. Stored separately\n * from SimParams to keep the intent clear.\n *\n * Sign convention: pressure_precalc is POSITIVE (+45/(pi*h^6)) because\n * it absorbs the double negative from the SPH momentum equation.\n * ====================================================================== */\n\nstruct PrecalcParams {\n    float poly6_coeff;           // 315 / (64 * pi * h^9)\n    float spiky_grad_coeff;      // -45 / (pi * h^6)  (negative)\n    float viscosity_lap_coeff;   // 45 / (pi * h^6)\n    float pressure_precalc;      // +45 / (pi * h^6)   (positive, see note)\n    float viscosity_precalc;     // mu * 45 / (pi * h^6)\n};\n\n__constant__ PrecalcParams c_precalc;\n\n/* ======================================================================\n * packed_info bitfield layout (uint32)\n *\n *   Bits [7:0]   material_id    (256 materials max, 32 used)\n *   Bits [9:8]   behavior_class (FLUID=0, GRANULAR=1, GAS=2, STATIC=3)\n *   Bit  [10]    is_sleeping    (1 = asleep, skip force computation)\n *   Bit  [11]    spawn_flag     (1 = just spawned, needs initialization)\n *   Bit  [12]    just_woke      (1 = woke this frame, needs velocity reset)\n *   Bits [31:13] reserved\n * ====================================================================== */\n\n#define GET_MATERIAL_ID(p)  ((p) & 0xFF)\n#define GET_BEHAVIOR(p)     (((p) >> 8) & 0x3)\n#define IS_SLEEPING(p)      (((p) >> 10) & 1)\n#define SET_SLEEPING(p)     ((p) | 0x400)\n#define CLEAR_SLEEPING(p)   ((p) & ~0x400)\n#define HAS_SPAWN_FLAG(p)   (((p) >> 11) & 1)\n#define SET_SPAWN_FLAG(p)   ((p) | 0x800)\n#define HAS_JUST_WOKE(p)    (((p) >> 12) & 1)\n#define MAKE_PACKED(mat, beh) (((mat) & 0xFF) | (((beh) & 0x3) << 8))\n\n/* ======================================================================\n * Array type conventions (documented per acceptance criteria)\n *\n * float4 arrays (w component unused, set to 0):\n *   position, velocity, veleval, sph_force, color\n *\n * float arrays:\n *   density, mass, temperature, health, lifetime,\n *   shear_rate, exposure_heat, exposure_corrode\n *\n * uint32 arrays:\n *   packed_info\n *\n * uint8 arrays:\n *   sleep_counter\n * ====================================================================== */\n\n#endif /* FALLINGSAND3D_COMMON_CUH */\n","numLines":169,"startLine":1,"totalLines":169}}}

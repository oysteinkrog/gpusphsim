{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TmMD1NnqMAfhdfujCV6JHK","type":"tool_result","content":"     1→\"\"\"SPH simulation orchestrator.\n     2→\n     3→Wires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\n     4→Step2 -> Integrate.  Decouples simulation from rendering via a speed parameter\n     5→and substep budget.\n     6→\n     7→Each render frame:\n     8→  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n     9→  2. Run sim_steps simulation substeps\n    10→  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import time\n    16→from typing import Optional\n    17→\n    18→import cupy as cp\n    19→import numpy as np\n    20→\n    21→from world import World\n    22→from materials import (\n    23→    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n    24→)\n    25→\n    26→import hash_sort\n    27→import fused_reorder\n    28→import build_grid\n    29→import step1\n    30→import step2\n    31→import integrate\n    32→\n    33→\n    34→class Simulation:\n    35→    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n    36→\n    37→    Parameters\n    38→    ----------\n    39→    world : World\n    40→        Particle state manager.\n    41→    dt : float\n    42→        Fixed simulation timestep (seconds).\n    43→    speed : float\n    44→        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    45→    max_substeps : int\n    46→        Maximum substeps per render frame to prevent spiral-of-death.\n    47→    \"\"\"\n    48→\n    49→    def __init__(\n    50→        self,\n    51→        world: World,\n    52→        dt: float = 0.001,\n    53→        speed: float = 1.0,\n    54→        max_substeps: int = 20,\n    55→    ) -> None:\n    56→        self.world = world\n    57→        self.dt = dt\n    58→        self.speed = speed\n    59→        self.max_substeps = max_substeps\n    60→        self._paused = False\n    61→        self._prev_speed = speed\n    62→        self._last_frame_time: Optional[float] = None\n    63→        self._last_substeps = 0\n    64→        self.sim_time = 0.0\n    65→\n    66→        # Grid cell tables (pre-allocated, reused every frame)\n    67→        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n    68→\n    69→        # Compile all kernel modules and upload constant memory\n    70→        self._upload_constants()\n    71→\n    72→    def _upload_constants(self) -> None:\n    73→        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n    74→        # Build shared param structs\n    75→        grid_params = hash_sort.build_grid_params()\n    76→        sim_params = step1.build_sim_params(\n    77→            smoothing_length=0.04,\n    78→            particle_mass=0.008,\n    79→            particle_spacing=0.02,\n    80→            gravity=(0.0, -9.8, 0.0),\n    81→            dt=self.dt,\n    82→            restitution=0.3,\n    83→            wall_friction=0.5,\n    84→            world_min=(-1.0, -1.0, -1.0),\n    85→            world_max=(1.0, 1.0, 1.0),\n    86→        )\n    87→        precalc_params = step1.build_precalc_params(\n    88→            smoothing_length=0.04,\n    89→            viscosity=1.0,\n    90→        )\n    91→        granular_params = step2.build_granular_params()\n    92→        materials_data = build_material_array()\n    93→        interactions_data = build_interaction_matrix()\n    94→\n    95→        # --- hash_sort module: c_grid ---\n    96→        hash_sort.upload_grid_params(grid_params)\n    97→\n    98→        # --- fused_reorder module: no constant memory needed ---\n    99→        fused_reorder.get_module()  # just compile\n   100→\n   101→        # --- build_grid module: c_grid ---\n   102→        build_grid.upload_grid_params(grid_params)\n   103→\n   104→        # --- step1 module: c_grid, c_sim, c_precalc ---\n   105→        step1.upload_grid_params(grid_params)\n   106→        step1.upload_sim_params(sim_params)\n   107→        step1.upload_precalc_params(precalc_params)\n   108→\n   109→        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n   110→        step2.upload_grid_params(grid_params)\n   111→        step2.upload_sim_params(sim_params)\n   112→        step2.upload_precalc_params(precalc_params)\n   113→        step2.upload_materials(materials_data)\n   114→        step2.upload_granular_params(granular_params)\n   115→\n   116→        # --- integrate module: c_sim, c_materials ---\n   117→        integrate.upload_sim_params(sim_params)\n   118→        integrate.upload_materials(materials_data)\n   119→\n   120→        # --- materials module (its own internal module): c_materials, c_interactions ---\n   121→        upload_to_gpu()\n   122→\n   123→    def _sim_step(self, n: int) -> None:\n   124→        \"\"\"Run one simulation substep on n particles.\"\"\"\n   125→        w = self.world\n   126→\n   127→        # 1. Hash particle positions\n   128→        hashes, indices = hash_sort.calc_hash(w.position[:n])\n   129→\n   130→        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n   131→        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n   132→            hashes, indices,\n   133→            sorted_hashes_out=w.sorted_hashes,\n   134→            sorted_indices_out=w.sorted_indices,\n   135→        )\n   136→\n   137→        # 3. Fused reorder: gather all unsorted arrays into sorted order\n   138→        fused_reorder.fused_reorder(\n   139→            n, sorted_indices,\n   140→            w.position, w.velocity, w.veleval,\n   141→            w.mass, w.packed_info, w.temperature,\n   142→            w.health, w.lifetime, w.color,\n   143→            w.sleep_counter, w.shear_rate,\n   144→            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n   145→            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n   146→            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n   147→            w.sorted_sleep_counter, w.sorted_shear_rate,\n   148→        )\n   149→\n   150→        # 4. Build grid data structure (cell_start / cell_end tables)\n   151→        build_grid.build_data_struct(\n   152→            sorted_hashes[:n], self._cell_start, self._cell_end\n   153→        )\n   154→\n   155→        # 5. Step1: density summation\n   156→        step1.compute_step1(\n   157→            w.sorted_position[:n],\n   158→            w.sorted_mass[:n],\n   159→            self._cell_start,\n   160→            self._cell_end,\n   161→            density_out=w.sorted_density,\n   162→        )\n   163→\n   164→        # 6. Step2: pressure + viscosity + XSPH forces\n   165→        step2.compute_step2(\n   166→            w.sorted_position[:n],\n   167→            w.sorted_velocity[:n],\n   168→            w.sorted_density[:n],\n   169→            w.sorted_mass[:n],\n   170→            w.sorted_packed_info[:n],\n   171→            self._cell_start,\n   172→            self._cell_end,\n   173→            sph_force_out=w.sorted_sph_force,\n   174→            veleval_out=w.sorted_veleval,\n   175→        )\n   176→\n   177→        # 7. Integrate: symplectic Euler + SDF boundaries + color update\n   178→        #    Writes back to UNSORTED arrays via sort_indexes\n   179→        integrate.integrate(\n   180→            w.sorted_position[:n],\n   181→            w.sorted_velocity[:n],\n   182→            w.sorted_veleval[:n],\n   183→            w.sorted_sph_force[:n],\n   184→            w.sorted_mass[:n],\n   185→            w.sorted_packed_info[:n],\n   186→            w.sorted_temperature[:n],\n   187→            w.sorted_health[:n],\n   188→            sorted_indices[:n],\n   189→            position_out=w.position,\n   190→            velocity_out=w.velocity,\n   191→            color_out=w.color,\n   192→        )\n   193→\n   194→        self.sim_time += self.dt\n   195→\n   196→    def step_frame(self) -> int:\n   197→        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n   198→        now = time.perf_counter()\n   199→        if self._last_frame_time is None:\n   200→            self._last_frame_time = now\n   201→            return 0\n   202→\n   203→        wall_dt = now - self._last_frame_time\n   204→        self._last_frame_time = now\n   205→\n   206→        if self._paused or self.speed <= 0.0:\n   207→            self._last_substeps = 0\n   208→            return 0\n   209→\n   210→        n = self.world._high_water\n   211→        if n == 0:\n   212→            self._last_substeps = 0\n   213→            return 0\n   214→\n   215→        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n   216→        sim_steps = max(0, min(\n   217→            self.max_substeps,\n   218→            round(self.speed * wall_dt / self.dt),\n   219→        ))\n   220→\n   221→        for _ in range(sim_steps):\n   222→            self._sim_step(n)\n   223→\n   224→        self._last_substeps = sim_steps\n   225→        return sim_steps\n   226→\n   227→    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n   228→        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n   229→\n   230→        Parameters\n   231→        ----------\n   232→        cuda_pos : CudaGLBuffer\n   233→            Position VBO wrapper (must be context-managed externally).\n   234→        cuda_col : CudaGLBuffer\n   235→            Color VBO wrapper (must be context-managed externally).\n   236→        \"\"\"\n   237→        n = self.world._high_water\n   238→        if n == 0:\n   239→            return\n   240→\n   241→        # Position: world pos (float4) -> VBO pos (float4)\n   242→        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n   243→            (cuda_pos.nbytes // 16, 4), np.float32,\n   244→        )\n   245→        pos_arr[:n] = self.world.position[:n]\n   246→\n   247→        # Color: world color (float4) -> VBO color (float4)\n   248→        col_arr = cuda_col.device_pointer_as_cupy_array(\n   249→            (cuda_col.nbytes // 16, 4), np.float32,\n   250→        )\n   251→        col_arr[:n] = self.world.color[:n]\n   252→\n   253→    @property\n   254→    def paused(self) -> bool:\n   255→        return self._paused\n   256→\n   257→    def toggle_pause(self) -> None:\n   258→        self._paused = not self._paused\n   259→\n   260→    def adjust_speed(self, delta: float) -> None:\n   261→        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n   262→        self.speed = max(0.1, min(10.0, self.speed + delta))\n   263→\n   264→    @property\n   265→    def last_substeps(self) -> int:\n   266→        return self._last_substeps\n   267→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"eb47956f-dbff-4960-8452-8e302b089f1c","uuid":"0e20c49c-7e2d-4f5e-9800-917255c2823c","tool_use_result":{"type":"text","file":{"filePath":"/c/WORK/gpusphsim/fallingsand3d/simulation.py","content":"\"\"\"SPH simulation orchestrator.\n\nWires up the full SPH pipeline: Hash -> Sort -> Reorder -> Build -> Step1 ->\nStep2 -> Integrate.  Decouples simulation from rendering via a speed parameter\nand substep budget.\n\nEach render frame:\n  1. Compute sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max_substeps)\n  2. Run sim_steps simulation substeps\n  3. Copy UNSORTED pos/color to mapped VBOs (rendering happens once per frame)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Optional\n\nimport cupy as cp\nimport numpy as np\n\nfrom world import World\nfrom materials import (\n    WATER, SAND, build_material_array, build_interaction_matrix, upload_to_gpu,\n)\n\nimport hash_sort\nimport fused_reorder\nimport build_grid\nimport step1\nimport step2\nimport integrate\n\n\nclass Simulation:\n    \"\"\"Orchestrates the full SPH pipeline with sim/render decoupling.\n\n    Parameters\n    ----------\n    world : World\n        Particle state manager.\n    dt : float\n        Fixed simulation timestep (seconds).\n    speed : float\n        Time scale: 1.0 = realtime, <1 = slow-mo, >1 = fast-forward.\n    max_substeps : int\n        Maximum substeps per render frame to prevent spiral-of-death.\n    \"\"\"\n\n    def __init__(\n        self,\n        world: World,\n        dt: float = 0.001,\n        speed: float = 1.0,\n        max_substeps: int = 20,\n    ) -> None:\n        self.world = world\n        self.dt = dt\n        self.speed = speed\n        self.max_substeps = max_substeps\n        self._paused = False\n        self._prev_speed = speed\n        self._last_frame_time: Optional[float] = None\n        self._last_substeps = 0\n        self.sim_time = 0.0\n\n        # Grid cell tables (pre-allocated, reused every frame)\n        self._cell_start, self._cell_end = build_grid.allocate_cell_tables()\n\n        # Compile all kernel modules and upload constant memory\n        self._upload_constants()\n\n    def _upload_constants(self) -> None:\n        \"\"\"Compile all .cu kernels and upload constant memory to each module.\"\"\"\n        # Build shared param structs\n        grid_params = hash_sort.build_grid_params()\n        sim_params = step1.build_sim_params(\n            smoothing_length=0.04,\n            particle_mass=0.008,\n            particle_spacing=0.02,\n            gravity=(0.0, -9.8, 0.0),\n            dt=self.dt,\n            restitution=0.3,\n            wall_friction=0.5,\n            world_min=(-1.0, -1.0, -1.0),\n            world_max=(1.0, 1.0, 1.0),\n        )\n        precalc_params = step1.build_precalc_params(\n            smoothing_length=0.04,\n            viscosity=1.0,\n        )\n        granular_params = step2.build_granular_params()\n        materials_data = build_material_array()\n        interactions_data = build_interaction_matrix()\n\n        # --- hash_sort module: c_grid ---\n        hash_sort.upload_grid_params(grid_params)\n\n        # --- fused_reorder module: no constant memory needed ---\n        fused_reorder.get_module()  # just compile\n\n        # --- build_grid module: c_grid ---\n        build_grid.upload_grid_params(grid_params)\n\n        # --- step1 module: c_grid, c_sim, c_precalc ---\n        step1.upload_grid_params(grid_params)\n        step1.upload_sim_params(sim_params)\n        step1.upload_precalc_params(precalc_params)\n\n        # --- step2 module: c_grid, c_sim, c_precalc, c_materials, c_granular ---\n        step2.upload_grid_params(grid_params)\n        step2.upload_sim_params(sim_params)\n        step2.upload_precalc_params(precalc_params)\n        step2.upload_materials(materials_data)\n        step2.upload_granular_params(granular_params)\n\n        # --- integrate module: c_sim, c_materials ---\n        integrate.upload_sim_params(sim_params)\n        integrate.upload_materials(materials_data)\n\n        # --- materials module (its own internal module): c_materials, c_interactions ---\n        upload_to_gpu()\n\n    def _sim_step(self, n: int) -> None:\n        \"\"\"Run one simulation substep on n particles.\"\"\"\n        w = self.world\n\n        # 1. Hash particle positions\n        hashes, indices = hash_sort.calc_hash(w.position[:n])\n\n        # 2. Sort by hash (argsort -> gather sorted hashes and indices)\n        sorted_hashes, sorted_indices = hash_sort.sort_by_hash(\n            hashes, indices,\n            sorted_hashes_out=w.sorted_hashes,\n            sorted_indices_out=w.sorted_indices,\n        )\n\n        # 3. Fused reorder: gather all unsorted arrays into sorted order\n        fused_reorder.fused_reorder(\n            n, sorted_indices,\n            w.position, w.velocity, w.veleval,\n            w.mass, w.packed_info, w.temperature,\n            w.health, w.lifetime, w.color,\n            w.sleep_counter, w.shear_rate,\n            w.sorted_position, w.sorted_velocity, w.sorted_veleval,\n            w.sorted_mass, w.sorted_packed_info, w.sorted_temperature,\n            w.sorted_health, w.sorted_lifetime, w.sorted_color,\n            w.sorted_sleep_counter, w.sorted_shear_rate,\n        )\n\n        # 4. Build grid data structure (cell_start / cell_end tables)\n        build_grid.build_data_struct(\n            sorted_hashes[:n], self._cell_start, self._cell_end\n        )\n\n        # 5. Step1: density summation\n        step1.compute_step1(\n            w.sorted_position[:n],\n            w.sorted_mass[:n],\n            self._cell_start,\n            self._cell_end,\n            density_out=w.sorted_density,\n        )\n\n        # 6. Step2: pressure + viscosity + XSPH forces\n        step2.compute_step2(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_density[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            self._cell_start,\n            self._cell_end,\n            sph_force_out=w.sorted_sph_force,\n            veleval_out=w.sorted_veleval,\n        )\n\n        # 7. Integrate: symplectic Euler + SDF boundaries + color update\n        #    Writes back to UNSORTED arrays via sort_indexes\n        integrate.integrate(\n            w.sorted_position[:n],\n            w.sorted_velocity[:n],\n            w.sorted_veleval[:n],\n            w.sorted_sph_force[:n],\n            w.sorted_mass[:n],\n            w.sorted_packed_info[:n],\n            w.sorted_temperature[:n],\n            w.sorted_health[:n],\n            sorted_indices[:n],\n            position_out=w.position,\n            velocity_out=w.velocity,\n            color_out=w.color,\n        )\n\n        self.sim_time += self.dt\n\n    def step_frame(self) -> int:\n        \"\"\"Advance simulation for one render frame. Returns number of substeps run.\"\"\"\n        now = time.perf_counter()\n        if self._last_frame_time is None:\n            self._last_frame_time = now\n            return 0\n\n        wall_dt = now - self._last_frame_time\n        self._last_frame_time = now\n\n        if self._paused or self.speed <= 0.0:\n            self._last_substeps = 0\n            return 0\n\n        n = self.world._high_water\n        if n == 0:\n            self._last_substeps = 0\n            return 0\n\n        # Compute number of substeps: sim_steps = clamp(round(speed * wall_dt / sim_dt), 0, max)\n        sim_steps = max(0, min(\n            self.max_substeps,\n            round(self.speed * wall_dt / self.dt),\n        ))\n\n        for _ in range(sim_steps):\n            self._sim_step(n)\n\n        self._last_substeps = sim_steps\n        return sim_steps\n\n    def copy_to_vbos(self, cuda_pos, cuda_col) -> None:\n        \"\"\"Copy UNSORTED pos/color arrays into mapped GL VBOs.\n\n        Parameters\n        ----------\n        cuda_pos : CudaGLBuffer\n            Position VBO wrapper (must be context-managed externally).\n        cuda_col : CudaGLBuffer\n            Color VBO wrapper (must be context-managed externally).\n        \"\"\"\n        n = self.world._high_water\n        if n == 0:\n            return\n\n        # Position: world pos (float4) -> VBO pos (float4)\n        pos_arr = cuda_pos.device_pointer_as_cupy_array(\n            (cuda_pos.nbytes // 16, 4), np.float32,\n        )\n        pos_arr[:n] = self.world.position[:n]\n\n        # Color: world color (float4) -> VBO color (float4)\n        col_arr = cuda_col.device_pointer_as_cupy_array(\n            (cuda_col.nbytes // 16, 4), np.float32,\n        )\n        col_arr[:n] = self.world.color[:n]\n\n    @property\n    def paused(self) -> bool:\n        return self._paused\n\n    def toggle_pause(self) -> None:\n        self._paused = not self._paused\n\n    def adjust_speed(self, delta: float) -> None:\n        \"\"\"Adjust speed by delta, clamping to [0.1, 10.0].\"\"\"\n        self.speed = max(0.1, min(10.0, self.speed + delta))\n\n    @property\n    def last_substeps(self) -> int:\n        return self._last_substeps\n","numLines":267,"startLine":1,"totalLines":267}}}

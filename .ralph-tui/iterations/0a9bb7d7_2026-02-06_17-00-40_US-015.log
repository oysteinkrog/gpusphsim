 0.5f * weight * (dvy * gWz + dvz * gWy);","+                        }","                     }","                 }","             }","         }","     }"," ","-    // density = poly6_coeff * density_sum, clamped to >= 1.0","+    // --- PostCalc: density ---","     float density = c_precalc.poly6_coeff * sum_density;","     density_out[index_i] = fmaxf(density, 1.0f);","+","+    // --- PostCalc: strain-rate magnitude (gamma_dot) ---","+    if (is_granular) {","+        // gamma_dot = sqrt(2 * D:D)","+        //           = sqrt(2 * (Dxx^2 + Dyy^2 + Dzz^2 + 2*(Dxy^2 + Dxz^2 + Dyz^2)))","+        float D_sq = Dxx * Dxx + Dyy * Dyy + Dzz * Dzz","+                   + 2.0f * (Dxy * Dxy + Dxz * Dxz + Dyz * Dyz);","+        float gamma_dot = sqrtf(fmaxf(2.0f * D_sq, 0.0f));","+        shear_rate_out[index_i] = gamma_dot;","+    } else {","+        shear_rate_out[index_i] = 0.0f;","+    }"," }"]}],"userModified":false,"replaceAll":false}}
